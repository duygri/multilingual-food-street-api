@implements IDisposable
@inject NavigationManager NavigationManager

<div class="portal-shell">
    <aside class="portal-shell__sidebar">
        <div class="portal-shell__brand">
            <h1>@Brand</h1>
            @if (!string.IsNullOrWhiteSpace(Eyebrow))
            {
                <p class="portal-shell__brand-meta">@Eyebrow</p>
            }
            @if (!string.IsNullOrWhiteSpace(Tagline))
            {
                <p class="portal-shell__brand-copy">@Tagline</p>
            }
        </div>

        @if (SidebarProfileContent is not null)
        {
            <div class="portal-shell__profile">
                @SidebarProfileContent
            </div>
        }

        @if (NavigationItems.Count > 0)
        {
            <nav class="portal-shell__nav" aria-label="Primary">
                @foreach (var group in NavigationGroups)
                {
                    <section class="portal-shell__nav-group">
                        @if (!string.IsNullOrWhiteSpace(group.Key))
                        {
                            <p class="portal-shell__nav-group-title">@group.Key</p>
                        }

                        <div class="portal-shell__nav-items">
                            @foreach (var item in group.Items)
                            {
                                <a href="@item.Href"
                                   class="@GetNavLinkClass(item)"
                                   aria-current="@GetAriaCurrent(item)">
                                    <span class="portal-shell__nav-label">@item.Label</span>
                                    @if (!string.IsNullOrWhiteSpace(item.BadgeText))
                                    {
                                        <span class="portal-shell__nav-badge">@item.BadgeText</span>
                                    }
                                </a>
                            }
                        </div>
                    </section>
                }
            </nav>
        }

    </aside>

    <div class="portal-shell__main">
        <header class="portal-shell__header">
            @HeaderContent
        </header>

        <main class="portal-shell__content">
            @ChildContent
        </main>
    </div>
</div>

@code {
    [Parameter]
    public string Brand { get; set; } = "Narration Portal";

    [Parameter]
    public string Eyebrow { get; set; } = "Vinh Khanh Food Street";

    [Parameter]
    public string Tagline { get; set; } = "Multilingual audio narration control room.";

    [Parameter]
    public IReadOnlyList<ShellNavItem> NavigationItems { get; set; } = Array.Empty<ShellNavItem>();

    [Parameter]
    public RenderFragment? SidebarProfileContent { get; set; }

    [Parameter]
    public RenderFragment? HeaderContent { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private IReadOnlyList<NavGroup> NavigationGroups => NavigationItems
        .GroupBy(item => item.Group ?? string.Empty)
        .Select(group => new NavGroup(group.Key, group.ToArray()))
        .ToArray();

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    private string GetNavLinkClass(ShellNavItem item)
    {
        const string baseClass = "portal-shell__nav-link--plain portal-shell__nav-link";
        return IsActive(item)
            ? $"{baseClass} active portal-shell__nav-link--active"
            : baseClass;
    }

    private string? GetAriaCurrent(ShellNavItem item)
    {
        return IsActive(item) ? "page" : null;
    }

    private bool IsActive(ShellNavItem item)
    {
        var itemPath = NormalizePath(item.Href);
        var currentPath = GetCurrentPath();
        var match = item.MatchAll ? ShellNavItemMatch.Exact : item.Match;

        if (match == ShellNavItemMatch.Exact)
        {
            return string.Equals(currentPath, itemPath, StringComparison.OrdinalIgnoreCase);
        }

        if (!MatchesPrefix(currentPath, itemPath))
        {
            return false;
        }

        return !HasMoreSpecificExactMatch(itemPath, currentPath);
    }

    private bool HasMoreSpecificExactMatch(string itemPath, string currentPath)
    {
        return NavigationItems
            .Where(item => item.MatchAll || item.Match == ShellNavItemMatch.Exact)
            .Select(item => NormalizePath(item.Href))
            .Any(exactPath =>
                exactPath.Length > itemPath.Length &&
                string.Equals(exactPath, currentPath, StringComparison.OrdinalIgnoreCase) &&
                MatchesPrefix(exactPath, itemPath));
    }

    private string GetCurrentPath()
    {
        return NormalizePath(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));
    }

    private static bool MatchesPrefix(string currentPath, string itemPath)
    {
        return string.Equals(currentPath, itemPath, StringComparison.OrdinalIgnoreCase) ||
            currentPath.StartsWith($"{itemPath.TrimEnd('/')}/", StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizePath(string path)
    {
        var normalized = path;
        var queryIndex = normalized.IndexOfAny(['?', '#']);
        if (queryIndex >= 0)
        {
            normalized = normalized[..queryIndex];
        }

        normalized = normalized.Trim();
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return "/";
        }

        return $"/{normalized.Trim('/')}";
    }

    private sealed record NavGroup(string Key, IReadOnlyList<ShellNavItem> Items);
}
