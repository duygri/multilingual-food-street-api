@if (IsOpen)
{
    <div class="confirm-dialog__backdrop">
        <section class="confirm-dialog confirm-dialog--@NormalizeTone(Tone)"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="@_titleId"
                 tabindex="-1"
                 data-focus-target="confirm-dialog"
                 @onkeydown="HandleKeyDownAsync">
            <span class="confirm-dialog__focus-sentinel"
                  tabindex="0"
                  data-focus-sentinel="start"
                  aria-label="Chuyển focus đến nút cuối trong hộp thoại"
                  @onfocus="async _ => await FocusLastActionAsync()"></span>

            <div class="confirm-dialog__body">
                <p class="confirm-dialog__eyebrow">@Eyebrow</p>
                <h2 id="@_titleId">@Title</h2>
                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <p class="confirm-dialog__message">@Message</p>
                }
                @ChildContent
            </div>

            <div class="confirm-dialog__actions">
                <button class="app-button app-button--ghost" type="button" data-action="cancel" autofocus="autofocus" @ref="_cancelButton" @onclick="OnCancel">
                    @CancelText
                </button>
                <button class="app-button app-button--primary" type="button" data-action="confirm" @ref="_confirmButton" @onclick="OnConfirm">
                    @ConfirmText
                </button>
            </div>

            <span class="confirm-dialog__focus-sentinel"
                  tabindex="0"
                  data-focus-sentinel="end"
                  aria-label="Chuyển focus đến nút đầu trong hộp thoại"
                  @onfocus="async _ => await FocusFirstActionAsync()"></span>
        </section>
    </div>
}

@code {
    private readonly string _titleId = $"confirm-dialog-title-{Guid.NewGuid():N}";
    private ElementReference _cancelButton;
    private ElementReference _confirmButton;
    private bool _wasOpen;

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string Eyebrow { get; set; } = "Xác nhận";

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Message { get; set; }

    [Parameter]
    public string ConfirmText { get; set; } = "Xác nhận";

    [Parameter]
    public string CancelText { get; set; } = "Hủy";

    [Parameter]
    public string Tone { get; set; } = "default";

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen && !_wasOpen)
        {
            _wasOpen = true;
            await FocusFirstActionAsync();
        }
        else if (!IsOpen)
        {
            _wasOpen = false;
        }
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Escape", StringComparison.Ordinal))
        {
            await OnCancel.InvokeAsync();
        }
    }

    private ValueTask FocusFirstActionAsync()
    {
        return _cancelButton.FocusAsync();
    }

    private ValueTask FocusLastActionAsync()
    {
        return _confirmButton.FocusAsync();
    }

    private static string NormalizeTone(string? tone)
    {
        return tone?.Trim().ToLowerInvariant() switch
        {
            "danger" => "danger",
            "warning" => "warning",
            "success" => "success",
            _ => "default"
        };
    }
}
