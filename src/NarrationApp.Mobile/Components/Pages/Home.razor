    private string GetDefaultProfileName()
    {
        if (_touristSession is null)
        {
            return "Guest Tourist";
        }

        var localPart = _touristSession.Email.Split('@', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        if (string.IsNullOrWhiteSpace(localPart))
        {
            return "Tourist User";
        }

        return string.Join(
            ' ',
            localPart
                .Split(['.', '_', '-'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(segment => char.ToUpperInvariant(segment[0]) + segment[1..]));
    }

