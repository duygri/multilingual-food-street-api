@page "/"
@using System.Globalization
@using System.Text
@using NarrationApp.Mobile.Features.Home
@using NarrationApp.Mobile.Components.Pages.Sections
@using NarrationApp.Shared.DTOs.Auth
@using NarrationApp.Shared.DTOs.Tour
@using NarrationApp.Shared.Enums
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject ITouristAuthApiService AuthApiService
@inject ITouristContentService ContentService
@inject ITouristAudioCatalogService AudioCatalogService
@inject ITouristQrApiService QrApiService
@inject ITouristTourSessionApiService TourSessionApiService
@inject ITouristDeviceIdentityProvider DeviceIdentityProvider
@inject IJSRuntime JS
@inject TouristMapOptions MapOptions

<PageTitle>Food Street Tourist</PageTitle>

@if (_state.CurrentStep != TouristIntroStep.Ready)
{
    <main class="tourist-app tourist-app--setup">
        <section class="setup-card">
            @switch (_state.CurrentStep)
            {
                case TouristIntroStep.Welcome:
                    <TouristAuthScreen
                        Title="Chào mừng!"
                        Subtitle="Đăng nhập để lưu tiến trình tour và nhận thuyết minh cá nhân hóa. Nếu chưa muốn đăng nhập, bạn vẫn có thể tiếp tục ở guest mode."
                        Session="_touristSession"
                        SessionStatusLabel="@GetSessionStatusLabel()"
                        SessionPrimaryLabel="Tiếp tục với tourist"
                        Email="@_touristEmail"
                        Password="@_touristPassword"
                        ConfirmPassword="@_touristConfirmPassword"
                        IsRegisterMode="@IsRegisterMode"
                        IsBusy="@_isAuthBusy"
                        ShowFeatureList="true"
                        ShowGuestContinue="true"
                        StatusMessage="@_authStatusMessage"
                        ErrorMessage="@_authErrorMessage"
                        OnModeChanged="SetAuthModeAsync"
                        OnEmailChanged="SetTouristEmailAsync"
                        OnPasswordChanged="SetTouristPasswordAsync"
                        OnConfirmPasswordChanged="SetTouristConfirmPasswordAsync"
                        OnSubmit="SubmitWelcomeAuthAsync"
                        OnForgotPassword="ShowForgotPasswordMessageAsync"
                        OnContinueGuest="ContinueFromSetupAsync"
                        OnContinueAuthenticated="ContinueFromSetupAsync"
                        OnLogout="LogoutTouristAsync" />
                    break;

                case TouristIntroStep.Language:
                    <div class="setup-stack">
                        <span class="eyebrow">Ngôn ngữ</span>
                        <h1>Chọn ngôn ngữ audio ưu tiên.</h1>
                        <p class="setup-copy">
                            Nội dung gốc là tiếng Việt, còn audio du lịch sẽ được phát theo ngôn ngữ bạn chọn.
                        </p>
                        <div class="language-grid">
                            @foreach (var language in _state.Languages)
                            {
                                <button
                                    type="button"
                                    class="language-tile @GetLanguageTileClass(language.Code)"
                                    @onclick="() => _state.SelectLanguage(language.Code)">
                                    <span class="language-chip">@language.ChipLabel</span>
                                    <strong>@language.Label</strong>
                                    <span>@language.SubLabel</span>
                                </button>
                            }
                        </div>
                    </div>
                    break;

                case TouristIntroStep.Permissions:
                    <div class="setup-stack">
                        <span class="eyebrow">Quyền truy cập</span>
                        <h1>Bật vị trí để nhận gợi ý POI gần bạn.</h1>
                        <p class="setup-copy">
                            App dùng vị trí cho map, geofence cơ bản và gợi ý phát audio khi bạn đến gần điểm tham quan.
                        </p>
                        <div class="permission-card">
                            <strong>Ngôn ngữ hiện tại: @_state.CurrentLanguage.Label</strong>
                            <span>Chế độ guest vẫn hoạt động nếu bạn chọn cho phép sau.</span>
                        </div>
                        <div class="setup-actions">
                            <button type="button" class="primary-pill" @onclick="EnableLocationAsync">
                                Bật vị trí
                            </button>
                            <button type="button" class="secondary-pill" @onclick="SkipLocationAsync">
                                Để sau
                            </button>
                        </div>
                    </div>
                    break;
            }
        </section>
    </main>
}
else
{
    <main class="tourist-app tourist-app--ready @GetTouristAppClass()">
        <div class="tourist-frame @GetTouristFrameClass()">
            @if (_state.CurrentTab == TouristTab.Settings && _state.CurrentSettingsScreen == TouristSettingsScreen.Overview)
            {
                <header class="mobile-topbar">
                    <div>
                        <span class="eyebrow">Food Street</span>
                        <h1>@GetHeaderTitle()</h1>
                    </div>
                    <div class="topbar-actions">
                        <button type="button" class="icon-button" @onclick="ToggleNotificationsPanel">🔔</button>
                        <button type="button" class="icon-button" @onclick="CycleLanguage">@_state.CurrentLanguage.ChipLabel</button>
                    </div>
                </header>
            }

            @if (_state.CurrentTab == TouristTab.Map)
            {
                <section class="map-screen">
                    <div class="map-shell">
                        <div class="map-canvas map-canvas--full">
                            <div id="discover-map" class="map-surface"></div>

                            <div class="map-top-overlay @(_state.ShowPoiSheet ? "map-top-overlay--sheet-open" : string.Empty)">
                                <div class="map-top-controls">
                                    <button type="button" class="map-icon-button" @onclick="ToggleNotificationsPanel">
                                        <svg class="map-icon-glyph" viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M12 4.5a3 3 0 0 0-3 3v.7a6.5 6.5 0 0 1-1.5 4.1L6 14.1v1.4h12v-1.4l-1.5-1.8A6.5 6.5 0 0 1 15 8.2v-.7a3 3 0 0 0-3-3Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" />
                                            <path d="M10.2 18a1.8 1.8 0 0 0 3.6 0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
                                        </svg>
                                    </button>
                                    <button type="button" class="map-icon-button" @onclick="CycleLanguage">
                                        <svg class="map-icon-glyph" viewBox="0 0 24 24" aria-hidden="true">
                                            <circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.8" />
                                            <path d="M4 12h16M12 4a13 13 0 0 1 0 16M12 4a13 13 0 0 0 0 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
                                        </svg>
                                    </button>
                                </div>

                                <div class="map-category-rail">
                                    <section class="category-strip category-strip--map">
                                        @foreach (var category in _state.Categories)
                                        {
                                            <button
                                                type="button"
                                                class="category-chip @GetCategoryChipClass(category.Id)"
                                                @onclick="() => _state.SelectCategory(category.Id)">
                                                <span>@GetCategoryIcon(category.Id)</span>
                                                <span>@category.Label</span>
                                            </button>
                                        }
                                    </section>
                                </div>

                                <div class="map-overlay-meta">
                                    <span class="map-pill">@_state.LocationStatusLabel</span>
                                    <span class="map-pill">@_state.DataSourceLabel</span>
                                    @if (_state.HasAutoNarrationPrompt)
                                    {
                                        <span class="map-pill">@GetAutoAudioStatus()</span>
                                    }
                                </div>

                                @if (_state.IsUsingFallbackData)
                                {
                                    <aside class="offline-banner">
                                        <strong>Offline mode</strong>
                                        <span>@_state.SyncMessage</span>
                                    </aside>
                                }
                            </div>

                            @if (_state.ShowNotifications)
                            {
                                <aside class="notification-panel">
                                    <div class="notification-panel__surface">
                                        <div class="panel-header">
                                            <div class="notification-panel__copy">
                                                <span class="eyebrow">Thông báo</span>
                                                <strong>Cập nhật gần đây</strong>
                                            </div>
                                            <button type="button" class="panel-close" @onclick="_state.ToggleNotifications">Đóng</button>
                                        </div>

                                        <div class="panel-list">
                                            @foreach (var notification in _state.Notifications)
                                            {
                                                <article class="panel-item">
                                                    <strong>@notification.Title</strong>
                                                    <p>@notification.Body</p>
                                                    <span>@notification.TimeLabel</span>
                                                </article>
                                            }
                                        </div>
                                    </div>
                                </aside>
                            }

                            <div class="map-fab-rail">
                                <button type="button" class="map-fab-button" @onclick="RefreshDiscoverAsync">↻</button>
                                <button type="button" class="map-fab-button map-fab-button--accent" @onclick="() => _state.SwitchTab(TouristTab.Tours)">🎧</button>
                            </div>

                            <button type="button" class="qr-fab" @onclick="OpenQrModal">📱</button>

                            @if (_isQrModalOpen)
                            {
                                <section class="qr-modal" @onclick="CloseQrModal">
                                    <div class="qr-modal__content qr-modal__panel" @onclick:stopPropagation="true">
                                        <div class="qr-modal__header">
                                            <div>
                                                <span class="eyebrow">Mô phỏng quét QR</span>
                                                <strong>Xem trước deep link</strong>
                                            </div>
                                            <button type="button" class="panel-close" @onclick="CloseQrModal">Đóng</button>
                                        </div>

                                        <div class="qr-preview">
                                            <div class="qr-preview__code">@GetQrPreviewCode()</div>
                                        </div>

                                        <div class="qr-targets">
                                            <button type="button" class="qr-target-btn" @onclick="() => TriggerQrPreviewAsync(TouristQrTargetKind.OpenApp)">
                                                <span class="qr-target-btn__icon">📱</span>
                                                <span class="qr-target-btn__copy">
                                                    <strong>Mở ứng dụng</strong>
                                                    <span>foodstreet://qr/open-app</span>
                                                </span>
                                            </button>

                                            @if (GetQrPreviewPoi() is { } previewPoi)
                                            {
                                                <button type="button" class="qr-target-btn" @onclick="() => TriggerQrPreviewAsync(TouristQrTargetKind.Poi)">
                                                    <span class="qr-target-btn__icon">@GetCategoryIcon(previewPoi.CategoryId)</span>
                                                    <span class="qr-target-btn__copy">
                                                        <strong>Xem POI: @previewPoi.Name</strong>
                                                        <span>foodstreet://qr/@previewPoi.Id</span>
                                                    </span>
                                                </button>
                                            }

                                            @if (GetQrPreviewTour() is { } previewTour)
                                            {
                                                <button type="button" class="qr-target-btn" @onclick="() => TriggerQrPreviewAsync(TouristQrTargetKind.Tour)">
                                                    <span class="qr-target-btn__icon">🗺️</span>
                                                    <span class="qr-target-btn__copy">
                                                        <strong>Xem Tour: @previewTour.Title</strong>
                                                        <span>foodstreet://qr/@previewTour.Id</span>
                                                    </span>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </section>
                            }

                            @if (_state.SelectedPoi is not null && _state.ShowPoiSheet)
                            {
                                <section class="poi-sheet poi-sheet--floating">
                                    <div class="poi-sheet__grabber"></div>
                                    <div class="poi-sheet__head">
                                        <div class="poi-sheet__icon">@GetCategoryIcon(_state.SelectedPoi.CategoryId)</div>
                                        <div class="poi-sheet__title">
                                            <h3>@_state.SelectedPoi.Name</h3>
                                            <span class="poi-sheet__badge">@GetPoiCategoryLabel(_state.SelectedPoi)</span>
                                            <p class="poi-sheet__location">📍 @_state.SelectedPoi.DistanceMeters m • @_state.SelectedPoi.District</p>
                                        </div>
                                        <button type="button" class="poi-sheet__close" @onclick="_state.ClosePoiSheet">Đóng</button>
                                    </div>

                                    <div class="poi-sheet__meta-chips">
                                        <span class="poi-meta-chip">🎯 Bán kính @_state.SelectedPoi.GeofenceRadiusMeters m</span>
                                        <span class="poi-meta-chip">⭐ Ưu tiên @_state.SelectedPoi.Priority</span>
                                        <span class="poi-meta-chip">🔊 @_state.SelectedPoi.StatusLabel</span>
                                        <span class="poi-meta-chip">🌐 @_state.SelectedPoi.AvailableLanguageCount ngôn ngữ</span>
                                    </div>

                                    <div class="poi-sheet__description">
                                        <p>@_state.SelectedPoi.Description</p>
                                        <strong>@_state.SelectedPoi.Highlight</strong>
                                    </div>

                                    <div class="sheet-actions sheet-actions--poi">
                                        <button type="button" class="secondary-pill" @onclick="_state.ClosePoiSheet">Ẩn</button>
                                        <button type="button" class="primary-pill" @onclick="PlaySelectedPoiAsync">Nghe ngay</button>
                                    </div>
                                </section>
                            }

                            @if (_state.ActiveProximity is not null)
                            {
                                <aside class="geofence-toast">
                                    <strong>Đang ở gần @_state.ActiveProximity.PoiName</strong>
                                    <span>@GetGeofenceToastMessage()</span>
                                </aside>
                            }
                        </div>
                    </div>
                </section>
            }
            else if (_state.CurrentTab == TouristTab.Discover)
            {
                @if (IsDiscoverPoiDetailVisible && _state.SelectedPoi is not null)
                {
                    <TouristPoiDetailScreen
                        Poi="_state.SelectedPoi"
                        Categories="_state.Categories"
                        Languages="_state.Languages"
                        RelatedPois="@GetRelatedPois()"
                        TranscriptParagraphs="@GetPoiTranscriptParagraphs()"
                        SelectedLanguageCode="@_state.SelectedLanguageCode"
                        IsPlaying="_state.IsAudioPlaying"
                        AudioAssetCount="@Math.Max(1, _state.SelectedPoi.AvailableLanguageCount / 2)"
                        AudioSubtitle="@GetPoiDetailAudioSubtitle()"
                        OnBack="ClosePoiDetail"
                        OnOpenMap="OpenSelectedPoiOnMapAsync"
                        OnOpenFullPlayer="OpenFullPlayer"
                        OnPlayToggle="TogglePlaybackAsync"
                        OnPrimaryAction="TogglePlaybackAsync"
                        OnSelectLanguage="SelectLanguageFromDetailAsync"
                        OnSelectRelatedPoi="OpenPoiDetailAsync" />
                }
                else
                {
                    <TouristDiscoverScreen
                        Pois="_state.FeaturedPois"
                        Categories="_state.Categories"
                        SelectedCategoryId="@_state.SelectedCategoryId"
                        SearchTerm="@_state.SearchTerm"
                        IsLoading="@_isContentLoading"
                        OnOpenSearch="OpenSearchOverlay"
                        OnRefresh="RefreshDiscoverAsync"
                        OnSelectCategory="SelectDiscoverCategory"
                        OnSelectPoi="OpenPoiDetailAsync" />
                }
            }
            else if (_state.CurrentTab == TouristTab.Tours)
            {
                @if (IsTourDetailVisible && _state.SelectedTour is not null)
                {
                    <TouristTourDetailScreen
                        Tour="_state.SelectedTour"
                        Stops="@GetSelectedTourStopItems()"
                        HeroIcon="@GetTourHeroIcon(_state.SelectedTour)"
                        ThemeClass="@GetTourHeroTone(_state.SelectedTour)"
                        RouteDistanceLabel="@GetTourRouteDistanceLabel(_state.SelectedTour)"
                        ParticipationLabel="@GetTourParticipationLabel(_state.SelectedTour)"
                        ProgressLabel="@GetTourProgressLabel()"
                        ProgressPercent="@GetTourProgressPercent()"
                        PrimaryActionLabel="@GetSelectedTourPrimaryActionLabel()"
                        OnBack="CloseTourDetail"
                        OnPrimaryAction="StartSelectedTourAsync" />
                }
                else
                {
                    <TouristTourListScreen
                        Tours="_state.Tours"
                        ShowGuestPrompt="@(_touristSession is null)"
                        IsLoading="@_isContentLoading"
                        OnOpenAuth="OpenRegisterOverlayAsync"
                        OnSelectTour="OpenTourDetail" />
                }
            }
            else
            {
                @if (_state.CurrentSettingsScreen == TouristSettingsScreen.Audio)
                {
                    <TouristAudioSettingsScreen
                        Preferences="_state.AudioPreferences"
                        SpeedOptions="AudioSpeedOptions"
                        OnBack="CloseSettingsScreen"
                        OnAutoPlayChanged="SetAudioAutoPlayEnabledAsync"
                        OnSpokenAnnouncementsChanged="SetAudioSpokenAnnouncementsEnabledAsync"
                        OnAutoAdvanceChanged="SetAudioAutoAdvanceEnabledAsync"
                        OnSourcePreferenceChanged="SetAudioSourcePreferenceAsync"
                        OnSpeedChanged="SetAudioPlaybackSpeedAsync" />
                }
                else if (_state.CurrentSettingsScreen == TouristSettingsScreen.Gps)
                {
                    <TouristGpsSettingsScreen
                        Preferences="_state.GpsPreferences"
                        StatusLabel="@(_state.LocationPermissionGranted ? "Vị trí đã bật" : "Vị trí đang tắt")"
                        OnBack="CloseSettingsScreen"
                        OnBackgroundTrackingChanged="SetGpsBackgroundTrackingEnabledAsync"
                        OnAutoFocusChanged="SetGpsAutoFocusEnabledAsync"
                        OnAccuracyModeChanged="SetGpsAccuracyModeAsync" />
                }
                else if (_state.CurrentSettingsScreen == TouristSettingsScreen.Cache)
                {
                    <TouristCacheManagerScreen
                        Items="_state.CachedAudioItems"
                        OnBack="CloseSettingsScreen"
                        OnRefresh="RefreshDiscoverAsync"
                        OnClearAll="ClearCachedAudioItemsAsync"
                        OnDeleteItem="DeleteCachedAudioItemAsync" />
                }
                else if (_state.CurrentSettingsScreen == TouristSettingsScreen.History)
                {
                    <TouristListenHistoryScreen
                        Days="_state.ListeningHistoryDays"
                        OnBack="CloseSettingsScreen"
                        OnOpenPoi="OpenPoiFromHistoryAsync" />
                }
                else if (_state.CurrentSettingsScreen == TouristSettingsScreen.About)
                {
                    <TouristAboutScreen
                        VersionLabel="@GetAboutVersionLabel()"
                        RuntimeLabel="@GetAboutRuntimeLabel()"
                        TechStack="@GetAboutTechStack()"
                        Languages="_state.Languages"
                        Links="@GetAboutLinks()"
                        StatusMessage="@_profileStatusMessage"
                        OnBack="CloseSettingsScreen"
                        OnOpenLink="OpenAboutLinkAsync" />
                }
                else if (_state.CurrentSettingsScreen == TouristSettingsScreen.Profile)
                {
                    <TouristEditProfileScreen
                        DisplayName="@GetProfileDisplayName()"
                        DisplayEmail="@GetProfileDisplayEmail()"
                        ModeLabel="@GetProfileModeLabel()"
                        Initials="@GetProfileInitials()"
                        Stats="@GetSettingsStats()"
                        Name="@_profileDraftName"
                        Email="@_profileDraftEmail"
                        CurrentPassword="@_profileCurrentPassword"
                        NewPassword="@_profileNewPassword"
                        ConfirmPassword="@_profileConfirmPassword"
                        SessionActionLabel="@GetProfileSessionActionLabel()"
                        ShowLogout="@(_touristSession is not null)"
                        StatusMessage="@_profileStatusMessage"
                        ErrorMessage="@_profileErrorMessage"
                        OnBack="CloseSettingsScreen"
                        OnSave="SaveProfileDraftAsync"
                        OnSessionAction="HandleProfileSessionActionAsync"
                        OnLogout="LogoutTouristAsync"
                        OnNameChanged="SetProfileDraftNameAsync"
                        OnEmailChanged="SetProfileDraftEmailAsync"
                        OnCurrentPasswordChanged="SetProfileCurrentPasswordAsync"
                        OnNewPasswordChanged="SetProfileNewPasswordAsync"
                        OnConfirmPasswordChanged="SetProfileConfirmPasswordAsync" />
                }
                else
                {
                    <section class="stack-section settings-screen">
                        <article class="setting-card settings-profile-card">
                            <div class="settings-profile-card__top">
                                <div class="settings-avatar">@GetProfileInitials()</div>
                                <div class="settings-row__copy">
                                    <span class="eyebrow">Tourist profile</span>
                                    <strong class="settings-row__title">@GetProfileDisplayName()</strong>
                                    <span class="settings-row__subtitle">@GetProfileDisplayEmail()</span>
                                    <span class="settings-row__subtitle">@GetProfileModeLabel()</span>
                                </div>
                                <button type="button" class="secondary-pill" @onclick="() => OpenSettingsScreen(TouristSettingsScreen.Profile)">Chỉnh sửa</button>
                            </div>

                            <div class="settings-stat-grid">
                                @foreach (var stat in GetSettingsStats())
                                {
                                    <div class="settings-stat">
                                        <strong>@stat.Value</strong>
                                        <span>@stat.Label</span>
                                    </div>
                                }
                            </div>
                        </article>

                        <article class="setting-card">
                            <span class="sheet-label">Ngôn ngữ ưu tiên</span>
                            <strong>@_state.CurrentLanguage.Label</strong>
                            <p>Nội dung thuyết minh sẽ ưu tiên ngôn ngữ này khi có recorded hoặc Google TTS phù hợp.</p>

                            <div class="settings-language-strip">
                                @foreach (var language in _state.Languages)
                                {
                                    <button
                                        type="button"
                                        class="language-chip @GetLanguageChipClass(language.Code)"
                                        @onclick="() => SelectSettingsLanguageAsync(language.Code)">
                                        @language.ChipLabel • @language.Label
                                    </button>
                                }
                            </div>
                        </article>

                        <div class="settings-nav-list">
                            <button type="button" class="setting-card settings-row" @onclick="() => OpenSettingsScreen(TouristSettingsScreen.Audio)">
                                <div class="settings-row__copy">
                                    <strong class="settings-row__title">Audio & thuyết minh</strong>
                                    <span class="settings-row__subtitle">@GetAudioSettingsSummary()</span>
                                </div>
                                <span class="settings-row__value">›</span>
                            </button>

                            <button type="button" class="setting-card settings-row" @onclick="() => OpenSettingsScreen(TouristSettingsScreen.Gps)">
                                <div class="settings-row__copy">
                                    <strong class="settings-row__title">Vị trí & GPS</strong>
                                    <span class="settings-row__subtitle">@GetGpsSettingsSummary()</span>
                                </div>
                                <span class="settings-row__value">›</span>
                            </button>

                            <button type="button" class="setting-card settings-row" @onclick="() => OpenSettingsScreen(TouristSettingsScreen.Cache)">
                                <div class="settings-row__copy">
                                    <strong class="settings-row__title">Audio đã cache</strong>
                                    <span class="settings-row__subtitle">@GetAudioCacheSummary()</span>
                                </div>
                                <span class="settings-row__value">›</span>
                            </button>

                            <button type="button" class="setting-card settings-row" @onclick="() => OpenSettingsScreen(TouristSettingsScreen.History)">
                                <div class="settings-row__copy">
                                    <strong class="settings-row__title">Lịch sử nghe</strong>
                                    <span class="settings-row__subtitle">@GetListeningHistoryHeadline()</span>
                                </div>
                                <span class="settings-row__value">›</span>
                            </button>

                            <button type="button" class="setting-card settings-row" @onclick="() => OpenSettingsScreen(TouristSettingsScreen.About)">
                                <div class="settings-row__copy">
                                    <strong class="settings-row__title">Về ứng dụng</strong>
                                    <span class="settings-row__subtitle">@GetAboutVersionLabel() • @GetAboutRuntimeLabel()</span>
                                </div>
                                <span class="settings-row__value">›</span>
                            </button>

                            <button type="button" class="setting-card settings-row" @onclick="() => OpenSettingsScreen(TouristSettingsScreen.Profile)">
                                <div class="settings-row__copy">
                                    <strong class="settings-row__title">Hồ sơ & tài khoản</strong>
                                    <span class="settings-row__subtitle">@GetAccountModeDescription()</span>
                                </div>
                                <span class="settings-row__value">›</span>
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_authStatusMessage))
                        {
                            <div class="auth-feedback auth-feedback--success">@_authStatusMessage</div>
                        }

                        @if (!string.IsNullOrWhiteSpace(_authErrorMessage))
                        {
                            <div class="auth-feedback auth-feedback--error">@_authErrorMessage</div>
                        }
                    </section>
                }
            }

            @if (_isSearchOverlayOpen)
            {
                <TouristSearchScreen
                    SearchTerm="@_state.SearchTerm"
                    SelectedCategoryId="@_state.SelectedCategoryId"
                    ResultCount="@GetSearchResultCount()"
                    Categories="_state.Categories"
                    PoiResults="@GetSearchPoiResults()"
                    TourResults="@GetSearchTourResults()"
                    OnClose="CloseSearchOverlay"
                    OnSearchChanged="OnSearchChanged"
                    OnSelectCategory="SelectSearchCategory"
                    OnSelectPoi="OpenPoiDetailFromSearchAsync"
                    OnSelectTour="OpenTourDetailFromSearch" />
            }

            @if (_isFullPlayerOpen && _state.SelectedPoi is not null && _state.CurrentAudioCue is not null)
            {
                <TouristFullPlayerScreen
                    Poi="_state.SelectedPoi"
                    Categories="_state.Categories"
                    IsPlaying="_state.IsAudioPlaying"
                    CurrentLanguageLabel="@GetCurrentAudioLanguageLabel()"
                    AudioStatusLabel="@_state.AudioStatusLabel"
                    ElapsedLabel="@_state.AudioElapsedLabel"
                    DurationLabel="@_state.AudioDurationLabel"
                    ProgressPercent="@_state.AudioProgressPercent"
                    SpeedLabel="@GetAudioSpeedLabel()"
                    ShowTranscript="@_showFullPlayerTranscript"
                    OnClose="CloseFullPlayer"
                    OnPlayToggle="TogglePlaybackAsync"
                    OnSeekBackward="SeekAudioBackwardAsync"
                    OnRestart="RestartAudioAsync"
                    OnCycleLanguage="CycleFullPlayerLanguageAsync"
                    OnSeekForward="SeekAudioForwardAsync"
                    OnToggleSpeed="ToggleAudioSpeedAsync"
                    OnToggleTranscript="ToggleFullPlayerTranscript" />
            }

            @if (_isAuthOverlayOpen)
            {
                <div class="auth-overlay">
                    <button type="button" class="auth-overlay__scrim" @onclick="CloseAuthOverlayAsync" aria-label="Đóng đăng nhập"></button>
                    <div class="auth-overlay__surface auth-overlay__card">
                        <TouristAuthScreen
                            Title="Đăng nhập tourist"
                            Subtitle="Lưu hành trình, tiếp tục tour đang nghe và đồng bộ ngôn ngữ yêu thích của bạn."
                            Session="_touristSession"
                            SessionStatusLabel="@GetSessionStatusLabel()"
                            SessionPrimaryLabel="Tiếp tục với tourist"
                            Email="@_touristEmail"
                            Password="@_touristPassword"
                            ConfirmPassword="@_touristConfirmPassword"
                            IsRegisterMode="@IsRegisterMode"
                            IsBusy="@_isAuthBusy"
                            ShowCloseButton="true"
                            IsOverlay="true"
                            StatusMessage="@_authStatusMessage"
                            ErrorMessage="@_authErrorMessage"
                            OnModeChanged="SetAuthModeAsync"
                            OnEmailChanged="SetTouristEmailAsync"
                            OnPasswordChanged="SetTouristPasswordAsync"
                            OnConfirmPasswordChanged="SetTouristConfirmPasswordAsync"
                            OnSubmit="SubmitWelcomeAuthAsync"
                            OnForgotPassword="ShowForgotPasswordMessageAsync"
                            OnContinueAuthenticated="CloseAuthOverlayAsync"
                            OnClose="CloseAuthOverlayAsync"
                            OnLogout="LogoutTouristAsync" />
                    </div>
                </div>
            }

            @if (ShouldShowGuestAuthSnackbar)
            {
                <aside class="guest-auth-snackbar">
                    <div class="guest-auth-snackbar__copy">
                        <span class="sheet-label">Guest mode</span>
                        <strong>Thích ứng dụng? Tạo tài khoản để lưu hành trình.</strong>
                        <p>Đăng ký tourist để đồng bộ tour, audio và lịch sử nghe giữa các phiên.</p>
                    </div>
                    <div class="guest-auth-snackbar__actions">
                        <button type="button" class="secondary-pill" @onclick="DismissGuestAuthSnackbar">Để sau</button>
                        <button type="button" class="primary-pill" @onclick="OpenRegisterOverlayAsync">Đăng ký</button>
                    </div>
                </aside>
            }

            @if (_state.CurrentTab == TouristTab.Map && _state.ShowMiniPlayer && _state.SelectedPoi is not null && !_state.ShowPoiSheet)
            {
                <section class="mini-player">
                    <button type="button" class="mini-play" @onclick="TogglePlaybackAsync">@GetMiniPlayIcon()</button>
                    <button type="button" class="mini-player__body-button" @onclick="OpenFullPlayer">
                        <div class="mini-meta">
                            <strong>@_state.SelectedPoi.Name</strong>
                            <span>@GetMiniPlayerSubtitle()</span>
                            <div class="mini-progress">
                                <div class="mini-progress__bar">
                                    <span class="mini-progress__fill" style="@GetMiniProgressStyle()"></span>
                                </div>
                                <div class="mini-progress__times">
                                    <span>@_state.AudioElapsedLabel</span>
                                    <span>@_state.AudioDurationLabel</span>
                                </div>
                            </div>
                        </div>
                    </button>
                    <button type="button" class="mini-toggle" @onclick="_state.ToggleMiniPlayer">Thu gọn</button>
                </section>
            }

            <nav class="bottom-nav">
                <button type="button" class="nav-pill @GetTabClass(TouristTab.Map)" @onclick="() => SwitchTabFromShell(TouristTab.Map)">
                    <span class="nav-pill__icon">🗺️</span>
                    <span>Bản đồ</span>
                </button>
                <button type="button" class="nav-pill @GetTabClass(TouristTab.Tours)" @onclick="() => SwitchTabFromShell(TouristTab.Tours)">
                    <span class="nav-pill__icon">🚶</span>
                    <span>Tour</span>
                </button>
                <button type="button" class="nav-pill @GetTabClass(TouristTab.Discover)" @onclick="() => SwitchTabFromShell(TouristTab.Discover)">
                    <span class="nav-pill__icon">📍</span>
                    <span>Khám phá</span>
                </button>
                <button type="button" class="nav-pill @GetTabClass(TouristTab.Settings)" @onclick="() => SwitchTabFromShell(TouristTab.Settings)">
                    <span class="nav-pill__icon">👤</span>
                    <span>Tôi</span>
                </button>
            </nav>
        </div>
    </main>
}

@code {
    private enum TouristWelcomeAuthMode
    {
        Login,
        Register
    }

    private readonly TouristShellState _state = TouristShellState.CreateDefault();
    private DotNetObjectReference<Home>? _mapBridge;
    private DotNetObjectReference<Home>? _audioBridge;
    private string? _lastAutoPlayedPoiId;
    private bool _isAutoPlayingFromProximity;
    private TouristAuthSession? _touristSession;
    private string _touristEmail = string.Empty;
    private string _touristPassword = string.Empty;
    private string _touristConfirmPassword = string.Empty;
    private string? _authStatusMessage;
    private string? _authErrorMessage;
    private bool _isAuthBusy;
    private bool _isContentLoading;
    private bool _isHandlingPendingDeepLink;
    private bool _pendingSelectedPoiAudioPreparationRequested;
    private bool _pendingSelectedPoiAutoPlay;
    private TouristWelcomeAuthMode _welcomeAuthMode = TouristWelcomeAuthMode.Login;
    private string? _discoverPoiDetailId;
    private string? _tourDetailId;
    private bool _isQrModalOpen;
    private bool _isSearchOverlayOpen;
    private bool _isFullPlayerOpen;
    private bool _isAuthOverlayOpen;
    private bool _isGuestAuthSnackbarDismissed;
    private bool _showFullPlayerTranscript;
    private int _audioSpeedIndex = 1;
    private string _profileDraftName = "Guest Tourist";
    private string _profileDraftEmail = string.Empty;
    private string _profileCurrentPassword = string.Empty;
    private string _profileNewPassword = string.Empty;
    private string _profileConfirmPassword = string.Empty;
    private string? _profileStatusMessage;
    private string? _profileErrorMessage;
    private static readonly double[] AudioSpeedOptions = [0.75d, 1d, 1.25d, 1.5d, 2d];

    private bool IsRegisterMode => _welcomeAuthMode == TouristWelcomeAuthMode.Register;

    private bool ShouldShowGuestAuthSnackbar =>
        _state.CurrentStep == TouristIntroStep.Ready
        && _touristSession is null
        && !_isAuthOverlayOpen
        && !_isGuestAuthSnackbarDismissed
        && (_state.CurrentTab == TouristTab.Tours || _state.CurrentTab == TouristTab.Discover);

    private bool IsDiscoverPoiDetailVisible =>
        _state.CurrentTab == TouristTab.Discover
        && !string.IsNullOrWhiteSpace(_discoverPoiDetailId)
        && string.Equals(_state.SelectedPoi?.Id, _discoverPoiDetailId, StringComparison.OrdinalIgnoreCase);

    private bool IsTourDetailVisible =>
        _state.CurrentTab == TouristTab.Tours
        && !string.IsNullOrWhiteSpace(_tourDetailId)
        && string.Equals(_state.SelectedTour?.Id, _tourDetailId, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        TouristMobileDiagnostics.Log("Home", "OnInitializedAsync start");
        TouristPendingDeepLinkStore.PendingChanged += HandlePendingDeepLinkChanged;
        await LoadContentAsync();
        TouristMobileDiagnostics.Log("Home", $"Content loaded; currentStep={_state.CurrentStep} pois={_state.Pois.Count} tours={_state.Tours.Count}");
        await RestoreTouristSessionAsync();
        SyncProfileDraftFromSession();
        TouristMobileDiagnostics.Log("Home", $"Session restored; touristSession={(_touristSession is null ? "guest" : _touristSession.Email)} currentStep={_state.CurrentStep}");
        await ProcessPendingDeepLinkAsync();
        TouristMobileDiagnostics.Log("Home", $"OnInitializedAsync end currentStep={_state.CurrentStep} currentTab={_state.CurrentTab}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _mapBridge = DotNetObjectReference.Create(this);
            _audioBridge = DotNetObjectReference.Create(this);
        }

        if (_pendingSelectedPoiAudioPreparationRequested && _audioBridge is not null)
        {
            var autoPlay = _pendingSelectedPoiAutoPlay;
            _pendingSelectedPoiAudioPreparationRequested = false;
            _pendingSelectedPoiAutoPlay = false;
            await PrepareSelectedPoiAudioAsync(autoPlay, forceAutoPlay: autoPlay);
            StateHasChanged();
        }

        if (_state.CurrentStep != TouristIntroStep.Ready || _state.CurrentTab != TouristTab.Map)
        {
            return;
        }

        var mapSnapshot = TouristMapSnapshotBuilder.Build(_state.FeaturedPois, _state.SelectedPoiId, _state.CurrentLocation);
        await JS.InvokeVoidAsync(
            "touristMap.render",
            "discover-map",
            MapOptions.AccessToken,
            MapOptions.StyleUrl,
            mapSnapshot,
            _mapBridge);
    }

    private void HandlePendingDeepLinkChanged()
    {
        TouristMobileDiagnostics.Log("Home", "PendingChanged event received");
        _ = InvokeAsync(async () =>
        {
            await ProcessPendingDeepLinkAsync();
            StateHasChanged();
        });
    }

    private string GetHeaderTitle() =>
        _state.CurrentTab switch
        {
            TouristTab.Map => "Bản đồ",
            TouristTab.Discover => "Khám phá",
            TouristTab.Tours => "Tour",
            _ => "Tôi"
        };

    private string GetTouristAppClass() =>
        _state.CurrentTab == TouristTab.Map ? "tourist-app--map" : string.Empty;

    private string GetTouristFrameClass() =>
        _state.CurrentTab == TouristTab.Map ? "tourist-frame--map" : string.Empty;

    private string GetLanguageTileClass(string languageCode) =>
        _state.SelectedLanguageCode == languageCode ? "is-selected" : string.Empty;

    private string GetLanguageChipClass(string languageCode) =>
        _state.SelectedLanguageCode == languageCode ? "is-selected" : string.Empty;

    private string GetCategoryChipClass(string categoryId) =>
        _state.SelectedCategoryId == categoryId ? "is-selected" : string.Empty;

    private string GetTabClass(TouristTab tab) =>
        _state.CurrentTab == tab ? "is-active" : string.Empty;

    private string GetTourCardClass(string tourId) =>
        _state.SelectedTourId == tourId ? "is-selected" : string.Empty;

    private string GetPoiCardClass(string poiId) =>
        _state.SelectedPoiId == poiId ? "is-selected" : string.Empty;

    private void OpenSettingsScreen(TouristSettingsScreen screen)
    {
        SyncProfileDraftFromSession();
        _authStatusMessage = null;
        _authErrorMessage = null;
        _profileStatusMessage = null;
        _profileErrorMessage = null;
        _state.OpenSettingsScreen(screen);
    }

    private Task CloseSettingsScreen()
    {
        _profileStatusMessage = null;
        _profileErrorMessage = null;
        _state.CloseSettingsScreen();
        return Task.CompletedTask;
    }

    private void SetWelcomeAuthMode(TouristWelcomeAuthMode mode)
    {
        _welcomeAuthMode = mode;
        _authErrorMessage = null;
        _authStatusMessage = null;

        if (mode == TouristWelcomeAuthMode.Login)
        {
            _touristConfirmPassword = string.Empty;
        }
    }

    private async Task SubmitWelcomeAuthAsync()
    {
        if (_welcomeAuthMode == TouristWelcomeAuthMode.Login)
        {
            await LoginTouristAsync();
            return;
        }

        await RegisterTouristAsync();
    }

    private Task SetAuthModeAsync(bool isRegister)
    {
        SetWelcomeAuthMode(isRegister ? TouristWelcomeAuthMode.Register : TouristWelcomeAuthMode.Login);
        return Task.CompletedTask;
    }

    private Task SetTouristEmailAsync(string value)
    {
        _touristEmail = value;
        return Task.CompletedTask;
    }

    private Task SetTouristPasswordAsync(string value)
    {
        _touristPassword = value;
        return Task.CompletedTask;
    }

    private Task SetTouristConfirmPasswordAsync(string value)
    {
        _touristConfirmPassword = value;
        return Task.CompletedTask;
    }

    private Task ContinueFromSetupAsync()
    {
        ContinueFromSetup();
        return Task.CompletedTask;
    }

    private Task OpenAuthOverlayAsync()
    {
        OpenAuthOverlay(TouristWelcomeAuthMode.Login);
        return Task.CompletedTask;
    }

    private Task OpenRegisterOverlayAsync()
    {
        OpenAuthOverlay(TouristWelcomeAuthMode.Register);
        return Task.CompletedTask;
    }

    private void OpenAuthOverlay(TouristWelcomeAuthMode mode)
    {
        SetWelcomeAuthMode(mode);
        _isQrModalOpen = false;
        _isSearchOverlayOpen = false;
        _isFullPlayerOpen = false;
        _isAuthOverlayOpen = _state.CurrentStep == TouristIntroStep.Ready;
        _isGuestAuthSnackbarDismissed = false;
    }

    private Task CloseAuthOverlayAsync()
    {
        _isAuthOverlayOpen = false;
        return Task.CompletedTask;
    }

    private void DismissGuestAuthSnackbar()
    {
        _isGuestAuthSnackbarDismissed = true;
    }

    private Task ShowForgotPasswordMessageAsync()
    {
        _authErrorMessage = null;
        _authStatusMessage = "Chức năng quên mật khẩu sẽ nối ở web admin/API thật. Tạm thời bạn có thể tạo tài khoản mới để tiếp tục demo.";
        return Task.CompletedTask;
    }

    private string GetCategoryIcon(string categoryId) =>
        categoryId switch
        {
            "all" => "🏷️",
            "food" => "🍜",
            "river" => "🏛️",
            "night" => "🍢",
            _ => "☕"
        };

    private string GetPoiCategoryLabel(TouristPoi poi) =>
        string.IsNullOrWhiteSpace(poi.CategoryLabel)
            ? _state.Categories.FirstOrDefault(category => category.Id == poi.CategoryId)?.Label ?? poi.District
            : poi.CategoryLabel;

    private void SwitchTabFromShell(TouristTab tab)
    {
        _isQrModalOpen = false;
        _isSearchOverlayOpen = false;
        _isFullPlayerOpen = false;
        _isAuthOverlayOpen = false;
        _discoverPoiDetailId = null;
        _tourDetailId = null;
        _state.CloseSettingsScreen();
        _state.SwitchTab(tab);
    }

    private void SelectDiscoverCategory(string categoryId)
    {
        _discoverPoiDetailId = null;
        _state.SelectCategory(categoryId);
    }

    private async Task OpenPoiDetailAsync(string poiId)
    {
        _isQrModalOpen = false;
        _isSearchOverlayOpen = false;
        _isFullPlayerOpen = false;
        _state.PreviewPoi(poiId);
        _discoverPoiDetailId = poiId;
        _tourDetailId = null;
        _isAutoPlayingFromProximity = false;
        await PrepareSelectedPoiAudioAsync();
    }

    private void ClosePoiDetail()
    {
        _discoverPoiDetailId = null;
    }

    private async Task OpenSelectedPoiOnMapAsync()
    {
        if (_state.SelectedPoi is null)
        {
            return;
        }

        _isFullPlayerOpen = false;
        _discoverPoiDetailId = null;
        _state.OpenPoi(_state.SelectedPoi.Id);
        _isAutoPlayingFromProximity = false;
        await PrepareSelectedPoiAudioAsync();
    }

    private async Task SelectLanguageFromDetailAsync(string languageCode)
    {
        await SelectAudioLanguageAsync(languageCode, keepPlayback: false);
    }

    private void OpenTourDetail(string tourId)
    {
        _isQrModalOpen = false;
        _isSearchOverlayOpen = false;
        _isFullPlayerOpen = false;
        _state.SelectTour(tourId);
        _tourDetailId = tourId;
        _discoverPoiDetailId = null;
    }

    private void OpenQrModal()
    {
        _isQrModalOpen = true;
    }

    private void CloseQrModal()
    {
        _isQrModalOpen = false;
    }

    private void OpenSearchOverlay()
    {
        _isQrModalOpen = false;
        _isFullPlayerOpen = false;
        _isSearchOverlayOpen = true;

        if (_state.ShowNotifications)
        {
            _state.ToggleNotifications();
        }
    }

    private void CloseSearchOverlay()
    {
        _isSearchOverlayOpen = false;
    }

    private void SelectSearchCategory(string categoryId)
    {
        _state.SelectCategory(categoryId);
        _isSearchOverlayOpen = true;
    }

    private async Task OpenPoiDetailFromSearchAsync(string poiId)
    {
        _state.SwitchTab(TouristTab.Discover);
        await OpenPoiDetailAsync(poiId);
    }

    private void OpenTourDetailFromSearch(string tourId)
    {
        _state.SwitchTab(TouristTab.Tours);
        OpenTourDetail(tourId);
    }

    private void OpenFullPlayer()
    {
        if (_state.SelectedPoi is null || _state.CurrentAudioCue is null)
        {
            return;
        }

        _isQrModalOpen = false;
        _isSearchOverlayOpen = false;
        _isFullPlayerOpen = true;
    }

    private void CloseFullPlayer()
    {
        _isFullPlayerOpen = false;
        _showFullPlayerTranscript = false;
    }

    private void ToggleFullPlayerTranscript()
    {
        _showFullPlayerTranscript = !_showFullPlayerTranscript;
    }

    private async Task ToggleAudioSpeedAsync()
    {
        _audioSpeedIndex = (_audioSpeedIndex + 1) % AudioSpeedOptions.Length;
        _state.SetAudioPlaybackSpeed(AudioSpeedOptions[_audioSpeedIndex]);
        await JS.InvokeVoidAsync("touristAudio.setRate", AudioSpeedOptions[_audioSpeedIndex]);
    }

    private async Task SeekAudioBackwardAsync()
    {
        await SeekAudioAsync(-15);
    }

    private async Task SeekAudioForwardAsync()
    {
        await SeekAudioAsync(15);
    }

    private async Task SeekAudioAsync(int offsetSeconds)
    {
        if (_state.CurrentAudioCue is null)
        {
            return;
        }

        await JS.InvokeVoidAsync("touristAudio.seek", offsetSeconds);
    }

    private async Task RestartAudioAsync()
    {
        if (_state.CurrentAudioCue is null)
        {
            return;
        }

        _state.UpdateAudioProgress(0, _state.AudioDurationSeconds);
        await JS.InvokeVoidAsync("touristAudio.restart");
    }

    private async Task CycleFullPlayerLanguageAsync()
    {
        if (_state.SelectedPoi is null || _state.Languages.Count == 0)
        {
            return;
        }

        var currentIndex = _state.Languages
            .Select((language, index) => new { language.Code, index })
            .First(item => item.Code == _state.SelectedLanguageCode)
            .index;

        var nextIndex = (currentIndex + 1) % _state.Languages.Count;
        await SelectAudioLanguageAsync(_state.Languages[nextIndex].Code, keepPlayback: true);
    }

    private TouristPoi? GetQrPreviewPoi() =>
        _state.SelectedPoi ?? _state.FeaturedPois.FirstOrDefault() ?? _state.Pois.FirstOrDefault();

    private TouristTourCard? GetQrPreviewTour() =>
        _state.SelectedTour ?? _state.Tours.FirstOrDefault();

    private string GetQrPreviewCode()
    {
        if (GetQrPreviewPoi() is { } poi)
        {
            return poi.Id.Replace("poi-", string.Empty, StringComparison.OrdinalIgnoreCase).ToUpperInvariant();
        }

        if (GetQrPreviewTour() is { } tour)
        {
            return tour.Id.Replace("tour-", string.Empty, StringComparison.OrdinalIgnoreCase).ToUpperInvariant();
        }

        return "OPEN-APP";
    }

    private async Task TriggerQrPreviewAsync(TouristQrTargetKind kind)
    {
        _isQrModalOpen = false;
        _discoverPoiDetailId = null;
        _tourDetailId = null;

        switch (kind)
        {
            case TouristQrTargetKind.Poi when GetQrPreviewPoi() is { } poi:
                _state.ApplyQrNavigationTarget(new TouristQrNavigationTarget($"PREVIEW-{poi.Id}", TouristQrTargetKind.Poi, poi.Id));
                await PrepareSelectedPoiAudioAsync(autoPlay: true, forceAutoPlay: true);
                break;

            case TouristQrTargetKind.Tour when GetQrPreviewTour() is { } tour:
                _state.ApplyQrNavigationTarget(new TouristQrNavigationTarget($"PREVIEW-{tour.Id}", TouristQrTargetKind.Tour, tour.Id));
                break;

            default:
                _state.SwitchTab(TouristTab.Map);
                _state.ClosePoiSheet();
                break;
        }
    }

    private void CloseTourDetail()
    {
        _tourDetailId = null;
    }

    private string GetCurrentAudioLanguageLabel() =>
        _state.CurrentAudioCue is null
            ? _state.CurrentLanguage.Label
            : _state.Languages.FirstOrDefault(language => language.Code == _state.CurrentAudioCue.LanguageCode)?.Label
                ?? _state.CurrentAudioCue.LanguageCode.ToUpperInvariant();

    private string GetAudioSpeedLabel() => FormatPlaybackSpeed(AudioSpeedOptions[_audioSpeedIndex]);

    private string GetExperienceModeLabel() =>
        _touristSession is null
            ? $"Guest mode • {_state.CurrentLanguage.Label}"
            : $"Tourist mode • {_state.CurrentLanguage.Label}";

    private string GetSessionStatusLabel() =>
        _touristSession is null
            ? string.Empty
            : $"JWT active tới {FormatExpiry(_touristSession.ExpiresAtUtc)}";

    private string GetAccountModeTitle() => _touristSession is null ? "Guest" : "Tourist";

    private string GetAccountModeDescription() =>
        _touristSession is null
            ? "Đăng nhập để dùng TourSession API thật và giữ tiến độ tour giữa các lần mở app."
            : "Phiên tourist đang hoạt động. TourSession sẽ ưu tiên đồng bộ với máy chủ.";

    private string GetAudioSettingsSummary() =>
        $"{(_state.AudioPreferences.AutoPlayEnabled ? "Tự phát bật" : "Tự phát tắt")} • {GetAudioSourcePreferenceLabel(_state.AudioPreferences.SourcePreference)} • {FormatPlaybackSpeed(_state.AudioPreferences.DefaultPlaybackSpeed)}";

    private string GetGpsSettingsSummary() =>
        $"{(_state.LocationPermissionGranted ? "Vị trí đã bật" : "Vị trí đang tắt")} • {GetGpsAccuracyLabel(_state.GpsPreferences.AccuracyMode)}";

    private IReadOnlyList<TouristSettingsStat> GetSettingsStats() =>
    [
        new TouristSettingsStat(
            _state.ListeningHistoryDays.SelectMany(day => day.Entries).Select(entry => entry.PoiId).Distinct(StringComparer.OrdinalIgnoreCase).Count().ToString(CultureInfo.InvariantCulture),
            "POI đã nghe"),
        new TouristSettingsStat(_state.Tours.Count.ToString(CultureInfo.InvariantCulture), "Tour có sẵn"),
        new TouristSettingsStat(_state.CachedAudioItems.Count.ToString(CultureInfo.InvariantCulture), "File cache")
    ];

    private string GetProfileDisplayName() =>
        string.IsNullOrWhiteSpace(_profileDraftName) ? GetDefaultProfileName() : _profileDraftName;

    private string GetProfileDisplayEmail() =>
        string.IsNullOrWhiteSpace(_profileDraftEmail) ? GetDefaultProfileEmail() : _profileDraftEmail;

    private string GetProfileModeLabel() =>
        _touristSession is null ? "Guest mode • local only" : "Tourist mode • đồng bộ với API";

    private string GetProfileInitials()
    {
        var source = GetProfileDisplayName();
        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "GT";
        }

        if (parts.Length == 1)
        {
            return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        }

        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    private string GetProfileSessionActionLabel() =>
        _touristSession is null ? "Đăng nhập tourist" : "Đồng bộ phiên";

    private IReadOnlyList<string> GetAboutTechStack() =>
    [
        "ASP.NET Core API",
        "Blazor Hybrid",
        ".NET 9",
        "Mapbox",
        "Google Cloud TTS",
        "Google Cloud Translation",
        "Cloudflare R2",
        "SignalR",
        "SQLite cache"
    ];

    private IReadOnlyList<TouristAboutLinkItem> GetAboutLinks() =>
    [
        new TouristAboutLinkItem("Điều khoản sử dụng", "Mở bản web hoặc help center để xem chi tiết."),
        new TouristAboutLinkItem("Chính sách quyền riêng tư", "Giải thích cách app dùng vị trí và audio history."),
        new TouristAboutLinkItem("Giấy phép mã nguồn mở", "Danh sách package và giấy phép đang dùng."),
        new TouristAboutLinkItem("Gửi phản hồi", "Dùng khi cần báo bug hoặc góp ý bản tourist.")
    ];

    private async Task HandleProfileSessionActionAsync()
    {
        if (_touristSession is null)
        {
            await OpenAuthOverlayAsync();
            return;
        }

        await RefreshTouristSessionAsync();
    }

    private Task SetProfileDraftNameAsync(string value)
    {
        _profileDraftName = value;
        return Task.CompletedTask;
    }

    private Task SetProfileDraftEmailAsync(string value)
    {
        _profileDraftEmail = value;
        return Task.CompletedTask;
    }

    private Task SetProfileCurrentPasswordAsync(string value)
    {
        _profileCurrentPassword = value;
        return Task.CompletedTask;
    }

    private Task SetProfileNewPasswordAsync(string value)
    {
        _profileNewPassword = value;
        return Task.CompletedTask;
    }

    private Task SetProfileConfirmPasswordAsync(string value)
    {
        _profileConfirmPassword = value;
        return Task.CompletedTask;
    }

    private Task SaveProfileDraftAsync()
    {
        _profileErrorMessage = null;
        _profileStatusMessage = null;

        _profileDraftName = string.IsNullOrWhiteSpace(_profileDraftName) ? GetDefaultProfileName() : _profileDraftName.Trim();
        _profileDraftEmail = string.IsNullOrWhiteSpace(_profileDraftEmail) ? GetDefaultProfileEmail() : _profileDraftEmail.Trim();

        var isChangingPassword =
            !string.IsNullOrWhiteSpace(_profileCurrentPassword)
            || !string.IsNullOrWhiteSpace(_profileNewPassword)
            || !string.IsNullOrWhiteSpace(_profileConfirmPassword);

        if (isChangingPassword && !string.Equals(_profileNewPassword, _profileConfirmPassword, StringComparison.Ordinal))
        {
            _profileErrorMessage = "Mật khẩu mới và xác nhận mật khẩu chưa khớp.";
            return Task.CompletedTask;
        }

        _profileCurrentPassword = string.Empty;
        _profileNewPassword = string.Empty;
        _profileConfirmPassword = string.Empty;
        _profileStatusMessage = "Đã lưu hồ sơ cục bộ cho bản mobile demo.";
