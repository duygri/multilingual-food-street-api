    private async Task RestoreTouristSessionAsync()
    {
        try
        {
            _touristSession = await AuthApiService.GetCurrentSessionAsync();
            if (_touristSession is null)
            {
                _state.ClearActiveTourSession();
                SyncProfileDraftFromSession(force: true);
                return;
            }

            if (_touristSession.Role != UserRole.Tourist)
            {
                _authErrorMessage = "Mobile này đang dành cho tài khoản tourist.";
                await LogoutTouristAsync();
                return;
            }

            _state.ChangeLanguage(_touristSession.PreferredLanguage);
            await SyncLatestTourSessionAsync();
            SyncProfileDraftFromSession(force: true);
        }
        catch (Exception ex)
        {
            _authErrorMessage = ex.Message;
        }
    }

    private async Task LoginTouristAsync()
    {
        if (string.IsNullOrWhiteSpace(_touristEmail) || string.IsNullOrWhiteSpace(_touristPassword))
        {
            _authErrorMessage = "Nhập email và mật khẩu để đăng nhập tourist.";
            _authStatusMessage = null;
            return;
        }

        await RunAuthActionAsync(async () =>
        {
            var session = await AuthApiService.LoginAsync(new LoginRequest
            {
                Email = _touristEmail.Trim(),
                Password = _touristPassword
            });

            await ApplyAuthenticatedTouristAsync(session, "Đăng nhập tourist thành công.");
        });
    }

    private async Task RegisterTouristAsync()
    {
        if (string.IsNullOrWhiteSpace(_touristEmail) || string.IsNullOrWhiteSpace(_touristPassword))
        {
            _authErrorMessage = "Nhập email và mật khẩu để tạo tourist.";
            _authStatusMessage = null;
            return;
        }

        if (!string.Equals(_touristPassword, _touristConfirmPassword, StringComparison.Ordinal))
        {
            _authErrorMessage = "Mật khẩu xác nhận chưa khớp.";
            _authStatusMessage = null;
            return;
        }

        await RunAuthActionAsync(async () =>
        {
            var session = await AuthApiService.RegisterAsync(new RegisterRequest
            {
                Email = _touristEmail.Trim(),
                Password = _touristPassword,
                PreferredLanguage = _state.SelectedLanguageCode
            });

            await ApplyAuthenticatedTouristAsync(session, "Tạo tài khoản tourist và đăng nhập thành công.");
        });
    }

    private async Task RefreshTouristSessionAsync()
    {
        await RunAuthActionAsync(async () =>
        {
            await RestoreTouristSessionAsync();
            _authStatusMessage = _touristSession is null
                ? "Chưa có phiên tourist hợp lệ."
                : "Đã đồng bộ lại phiên tourist.";
        });
    }

    private async Task LogoutTouristAsync()
    {
        await AuthApiService.LogoutAsync();
        _touristSession = null;
        _state.ClearActiveTourSession();
        _touristPassword = string.Empty;
        _touristConfirmPassword = string.Empty;
        _isAuthOverlayOpen = false;
        _isGuestAuthSnackbarDismissed = false;
        _authStatusMessage = "Đã đăng xuất tourist. App quay về guest mode.";
        _authErrorMessage = null;
        SyncProfileDraftFromSession(force: true);
    }

    private async Task RunAuthActionAsync(Func<Task> action)
    {
        _isAuthBusy = true;
        _authErrorMessage = null;
        _authStatusMessage = null;

        try
        {
            await action();
        }
        catch (TouristApiException ex)
        {
            _authErrorMessage = ex.Message;
            if (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                _touristSession = null;
            }
        }
        catch (Exception ex)
        {
            _authErrorMessage = ex.Message;
        }
        finally
        {
            _isAuthBusy = false;
        }
    }

    private async Task ApplyAuthenticatedTouristAsync(TouristAuthSession session, string successMessage)
    {
        if (session.Role != UserRole.Tourist)
        {
            await AuthApiService.LogoutAsync();
            _touristSession = null;
            throw new InvalidOperationException("Tài khoản này không phải tourist.");
        }

        _touristSession = session;
        _touristEmail = session.Email;
        _touristPassword = string.Empty;
        _touristConfirmPassword = string.Empty;
        _state.ChangeLanguage(session.PreferredLanguage);
        SyncProfileDraftFromSession(force: true);
        if (_state.CurrentStep != TouristIntroStep.Ready)
        {
            _state.ContinueFromWelcome();
        }
        else
        {
            _isAuthOverlayOpen = false;
            _isGuestAuthSnackbarDismissed = true;
        }

        await SyncLatestTourSessionAsync();
        _authStatusMessage = _state.CurrentStep == TouristIntroStep.Ready
            ? successMessage
            : $"{successMessage} Tiếp theo là chọn ngôn ngữ rồi bật vị trí để vào bản đồ.";
    }

    private async Task SyncLatestTourSessionAsync()
    {
        if (_touristSession?.Role != UserRole.Tourist)
        {
            _state.ClearActiveTourSession();
            return;
        }

        var latestSession = await TourSessionApiService.GetLatestAsync();
        if (latestSession is null)
        {
            _state.ClearActiveTourSession();
            return;
        }

        var mappedSession = MapServerTourSession(latestSession);
        if (mappedSession is null)
        {
            _authStatusMessage = "Đã đăng nhập nhưng chưa map được tour session vào dữ liệu hiện tại.";
            return;
        }

        _state.ApplyServerTourSession(mappedSession);
        if (_state.SelectedPoi is not null)
        {
            await PrepareSelectedPoiAudioAsync();
        }
    }

    private TouristTourSession? MapServerTourSession(TourSessionDto session)
    {
        var tour = _state.Tours.FirstOrDefault(item => item.Id == $"tour-{session.TourId}");
        return tour is null ? null : TouristTourSessionMapper.Map(tour, session, _state.Pois);
    }

    private static bool TryParseServerId(string? value, string prefix, out int id)
    {
        id = 0;
        return !string.IsNullOrWhiteSpace(value)
            && value.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
            && int.TryParse(value[prefix.Length..], out id);
    }

    private void SelectTour(string tourId)
    {
        _state.SelectTour(tourId);
    }

    private async Task StartSelectedTourAsync()
    {
        if (_state.SelectedTour is null)
        {
            return;
        }

        await StartTourAsync(_state.SelectedTour.Id);
    }

    private async Task StartTourAsync(string tourId)
    {
        _tourDetailId = null;
        _discoverPoiDetailId = null;
        _lastAutoPlayedPoiId = null;
        _isAutoPlayingFromProximity = false;

        if (_touristSession?.Role == UserRole.Tourist && TryParseServerId(tourId, "tour-", out var serverTourId))
        {
            try
            {
                var shouldResume = _state.ActiveTourSession is
                {
                    IsServerBacked: true,
                    IsCompleted: false
                } activeSession && string.Equals(activeSession.TourId, tourId, StringComparison.OrdinalIgnoreCase);

                var serverSession = shouldResume
                    ? await TourSessionApiService.ResumeAsync(serverTourId)
                    : await TourSessionApiService.StartAsync(serverTourId);

                var mappedSession = MapServerTourSession(serverSession);
                if (mappedSession is null)
                {
                    _authErrorMessage = "Tour đã start trên server nhưng chưa map được vào danh sách hiện tại.";
                    return;
                }

                _authErrorMessage = null;
                _state.ApplyServerTourSession(mappedSession);
            }
            catch (TouristApiException ex)
            {
                _authErrorMessage = ex.Message;
                return;
            }
        }
        else
        {
            _state.StartTour(tourId);
        }

        if (_state.SelectedPoi is not null)
        {
            await PrepareSelectedPoiAudioAsync();
        }
    }

    private async Task OpenNextTourStopAsync()
    {
        if (_state.ActiveTourSession?.NextPoiId is null)
        {
            return;
        }

        _tourDetailId = null;
        _state.OpenPoi(_state.ActiveTourSession.NextPoiId);
        _lastAutoPlayedPoiId = null;
        _isAutoPlayingFromProximity = false;
        await PrepareSelectedPoiAudioAsync();
    }

    private async Task OpenPoiFromDiscoverAsync(string poiId)
    {
        _state.OpenPoi(poiId);
        _isAutoPlayingFromProximity = false;
        await PrepareSelectedPoiAudioAsync();
    }

    private async Task AdvanceActiveTourAsync()
    {
        if (_state.SelectedPoi is null)
        {
            return;
        }

        _lastAutoPlayedPoiId = null;
        _isAutoPlayingFromProximity = false;

        if (_touristSession?.Role == UserRole.Tourist
            && _state.ActiveTourSession is
            {
                IsServerBacked: true,
                IsCompleted: false
            } activeSession
            && TryParseServerId(activeSession.TourId, "tour-", out var serverTourId)
            && TryParseServerId(_state.SelectedPoi.Id, "poi-", out var serverPoiId))
        {
            try
            {
                var serverSession = await TourSessionApiService.ProgressAsync(
                    serverTourId,
                    new UpdateTourProgressRequest
                    {
                        PoiId = serverPoiId,
                        Lat = _state.CurrentLocation.Latitude,
                        Lng = _state.CurrentLocation.Longitude
                    });

                var mappedSession = MapServerTourSession(serverSession);
                if (mappedSession is null)
                {
                    _authErrorMessage = "Tour đã cập nhật trên server nhưng chưa map được vào dữ liệu hiện tại.";
                    return;
                }

                _authErrorMessage = null;
                _state.ApplyServerTourSession(mappedSession);
            }
            catch (TouristApiException ex)
            {
                _authErrorMessage = ex.Message;
                return;
            }
        }
        else
        {
            var advanced = _state.AdvanceActiveTour(_state.SelectedPoi.Id);
            if (!advanced)
            {
                return;
            }
        }

        if (_state.ActiveTourSession?.IsCompleted == false && _state.SelectedPoi is not null)
        {
            await PrepareSelectedPoiAudioAsync();
        }
    }

    [JSInvokable]
    public Task SelectPoiFromMap(string poiId)
    {
        _state.OpenPoi(poiId);
        _isAutoPlayingFromProximity = false;
        return InvokeAsync(async () =>
        {
            await PrepareSelectedPoiAudioAsync();
            StateHasChanged();
        });
    }

    [JSInvokable]
    public Task OnAudioStateChanged(string state, string message)
    {
        return InvokeAsync(() =>
        {
            var playbackState = state switch
            {
                "playing" => TouristAudioPlaybackState.Playing,
                "paused" => TouristAudioPlaybackState.Paused,
                "ended" => TouristAudioPlaybackState.Paused,
                "error" => TouristAudioPlaybackState.Error,
                _ => TouristAudioPlaybackState.Ready
            };

            _state.SetAudioPlaybackState(playbackState, message);

            if (state is "ended" or "error")
            {
                _isAutoPlayingFromProximity = false;
            }

            StateHasChanged();
        });
    }

    [JSInvokable]
    public Task OnAudioProgressChanged(int currentSeconds, int durationSeconds)
    {
        return InvokeAsync(() =>
        {
            _state.UpdateAudioProgress(currentSeconds, durationSeconds);
            StateHasChanged();
        });
    }

    private static string FormatExpiry(DateTime expiresAtUtc)
    {
        return expiresAtUtc.ToLocalTime().ToString("HH:mm");
    }

    public async ValueTask DisposeAsync()
    {
        TouristPendingDeepLinkStore.PendingChanged -= HandlePendingDeepLinkChanged;

        try
        {
            await JS.InvokeVoidAsync("touristMap.dispose", "discover-map");
        }
        catch
        {
            // Best-effort cleanup while the page is tearing down.
        }

        try
        {
            await JS.InvokeVoidAsync("touristAudio.dispose");
        }
        catch
        {
            // Best-effort cleanup while the page is tearing down.
        }

        _mapBridge?.Dispose();
        _audioBridge?.Dispose();
    }

    private async Task ProcessPendingDeepLinkAsync()
    {
        if (_isHandlingPendingDeepLink)
        {
            TouristMobileDiagnostics.Log("Home", "ProcessPendingDeepLinkAsync skipped because handler is already running");
            return;
        }

        TouristMobileDiagnostics.Log("Home", $"ProcessPendingDeepLinkAsync start currentStep={_state.CurrentStep} currentTab={_state.CurrentTab}");
        _isHandlingPendingDeepLink = true;

        try
        {
            while (true)
            {
                var request = TouristPendingDeepLinkStore.Consume();
                if (request is null)
                {
                    TouristMobileDiagnostics.Log("Home", "No more pending deep links");
                    break;
                }

                try
                {
                    TouristMobileDiagnostics.Log("Home", $"Processing deep link code={request.Code} source={request.SourceUri}");
                    var deviceId = await DeviceIdentityProvider.GetDeviceIdAsync();
                    TouristMobileDiagnostics.Log("Home", $"Resolved device id={deviceId}");
                    var qrCode = await QrApiService.OpenAsync(request.Code, deviceId);
                    var navigationTarget = TouristQrNavigationTarget.FromQrCode(qrCode);
                    TouristMobileDiagnostics.Log(
                        "Home",
                        $"Navigation target kind={navigationTarget.Kind} targetId={navigationTarget.TargetId ?? "<null>"}");

                    _lastAutoPlayedPoiId = null;
                    _isAutoPlayingFromProximity = false;
                    _state.ApplyQrNavigationTarget(navigationTarget);
                    TouristMobileDiagnostics.Log(
                        "Home",
                        $"State after apply currentStep={_state.CurrentStep} currentTab={_state.CurrentTab} selectedPoi={_state.SelectedPoi?.Id ?? "<null>"} selectedTour={_state.SelectedTour?.Id ?? "<null>"}");

                    if (navigationTarget.Kind == TouristQrTargetKind.Poi && _state.SelectedPoi is not null)
                    {
                        if (_audioBridge is null)
                        {
                            _pendingSelectedPoiAudioPreparationRequested = true;
                            _pendingSelectedPoiAutoPlay = true;
                            TouristMobileDiagnostics.Log("Home", $"Queued audio preparation for poi={_state.SelectedPoi.Id} autoPlay=true");
                        }
                        else
                        {
                            TouristMobileDiagnostics.Log("Home", $"Preparing audio immediately for poi={_state.SelectedPoi.Id} autoPlay=true");
                            await PrepareSelectedPoiAudioAsync(autoPlay: true, forceAutoPlay: true);
                        }
                    }
                }
                catch (TouristApiException ex)
                {
                    TouristMobileDiagnostics.Log("Home", $"QR API error for code={request.Code}: {ex.Message}");
                    _authErrorMessage = $"Không mở được QR {request.Code}: {ex.Message}";
                }
                catch (Exception ex)
                {
                    TouristMobileDiagnostics.Log("Home", $"Deep link error for code={request.Code}: {ex}");
                    _authErrorMessage = $"Không xử lý được deep link: {ex.Message}";
                }
            }
        }
        finally
        {
            _isHandlingPendingDeepLink = false;
            TouristMobileDiagnostics.Log("Home", $"ProcessPendingDeepLinkAsync end currentStep={_state.CurrentStep} currentTab={_state.CurrentTab}");
        }
    }

    private async Task PrepareSelectedPoiAudioAsync(bool autoPlay = false, bool forceAutoPlay = false)
    {
        if (_state.SelectedPoi is null)
        {
            return;
        }

        var previousCue = _state.CurrentAudioCue;
        var previousElapsedSeconds = _state.AudioElapsedSeconds;
        var previousDurationSeconds = _state.AudioDurationSeconds;
        var previousPlaybackState = _state.AudioPlaybackState;

        _state.SetAudioPlaybackState(TouristAudioPlaybackState.Loading, "Đang kiểm tra audio...");
        var cue = await AudioCatalogService.LoadBestForPoiAsync(_state.SelectedPoi.Id, _state.SelectedLanguageCode);
        var isSameCue =
            previousCue is not null
            && cue.IsAvailable
            && previousCue.IsAvailable
            && previousCue.PoiId == cue.PoiId
            && string.Equals(previousCue.StreamUrl, cue.StreamUrl, StringComparison.OrdinalIgnoreCase);

        _state.SetAudioCue(cue);

        if (isSameCue)
        {
            _state.UpdateAudioProgress(previousElapsedSeconds, previousDurationSeconds);

            var restoredPlaybackState = previousPlaybackState switch
            {
                TouristAudioPlaybackState.Playing => TouristAudioPlaybackState.Playing,
                TouristAudioPlaybackState.Paused => TouristAudioPlaybackState.Paused,
                TouristAudioPlaybackState.Ready => TouristAudioPlaybackState.Ready,
                _ => TouristAudioPlaybackState.Ready
            };

            _state.SetAudioPlaybackState(restoredPlaybackState, cue.StatusLabel);
        }

        if (!cue.IsAvailable)
        {
            await JS.InvokeVoidAsync("touristAudio.dispose");
            return;
        }

        await JS.InvokeVoidAsync("touristAudio.preload", cue.StreamUrl, _audioBridge);
        await JS.InvokeVoidAsync("touristAudio.setRate", AudioSpeedOptions[_audioSpeedIndex]);

        var shouldAutoplay = TouristAudioAutoplayPolicy.ShouldAutoplay(
            autoPlayRequested: autoPlay,
            forceAutoPlay: forceAutoPlay,
            cuePoiId: cue.PoiId,
            activeProximityPoiId: _state.ActiveProximity?.PoiId,
            lastAutoPlayedPoiId: _lastAutoPlayedPoiId);

        TouristMobileDiagnostics.Log(
            "Audio",
            $"PrepareSelectedPoiAudioAsync poi={cue.PoiId} autoPlayRequested={autoPlay} forceAutoPlay={forceAutoPlay} activeProximity={_state.ActiveProximity?.PoiId ?? "<null>"} lastAutoPlayed={_lastAutoPlayedPoiId ?? "<null>"} shouldAutoplay={shouldAutoplay}");

        if (shouldAutoplay)
        {
            _lastAutoPlayedPoiId = cue.PoiId;
            _isAutoPlayingFromProximity = !forceAutoPlay;
            await JS.InvokeVoidAsync("touristAudio.play", cue.StreamUrl, _audioBridge);
            var playbackLabel = forceAutoPlay
                ? $"Đang phát từ QR • {cue.LanguageCode.ToUpperInvariant()}"
                : $"Đang phát tự động • {cue.LanguageCode.ToUpperInvariant()}";
            _state.SetAudioPlaybackState(TouristAudioPlaybackState.Playing, playbackLabel);
        }
    }

    private async Task PlaySelectedPoiAsync()
    {
        if (_state.SelectedPoi is null)
        {
            return;
        }

        if (_state.CurrentAudioCue is null || _state.CurrentAudioCue.PoiId != _state.SelectedPoi.Id)
        {
            await PrepareSelectedPoiAudioAsync();
        }

        if (!_state.CanPlayAudio || _state.CurrentAudioCue is null)
        {
            return;
        }

        _isAutoPlayingFromProximity = false;
        await JS.InvokeVoidAsync("touristAudio.play", _state.CurrentAudioCue.StreamUrl, _audioBridge);
        await JS.InvokeVoidAsync("touristAudio.setRate", AudioSpeedOptions[_audioSpeedIndex]);
        _state.SetAudioPlaybackState(TouristAudioPlaybackState.Playing, $"Đang phát • {_state.CurrentAudioCue.LanguageCode.ToUpperInvariant()}");
    }

    private async Task TogglePlaybackAsync()
    {
        if (_state.IsAudioPlaying)
        {
            await JS.InvokeVoidAsync("touristAudio.pause");
            _state.SetAudioPlaybackState(TouristAudioPlaybackState.Paused, "Đã tạm dừng");
            return;
        }

        await PlaySelectedPoiAsync();
    }

    private string GetMiniPlayIcon() => _state.IsAudioPlaying ? "❚❚" : "▶";

