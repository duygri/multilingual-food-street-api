@using NarrationApp.Mobile.Features.Home

<section class="tour-list-screen">
    <header class="tour-list-header">
        <div class="tour-list-header__copy">
            <h1>Tour khám phá</h1>
            <p>Lộ trình được vạch sẵn — chỉ cần đi theo</p>
        </div>
    </header>

    @if (ShowGuestPrompt)
    {
        <article class="tour-guest-prompt">
            <div>
                <span class="sheet-label">Guest mode</span>
                <strong>Lưu tiến trình tour và đánh dấu các điểm đã nghe.</strong>
                <p>Đăng nhập hoặc tạo tài khoản tourist để tiếp tục tour trên thiết bị khác và giữ lại lịch sử nghe.</p>
            </div>
            <button type="button" class="primary-pill" @onclick="() => OnOpenAuth.InvokeAsync()">Đăng nhập / Đăng ký</button>
        </article>
    }

    <section class="tour-showcase-list tour-showcase-list--stagger">
        @if (IsLoading && Tours.Count == 0)
        {
            @for (var index = 0; index < 3; index++)
            {
                <article class="tour-showcase-card tour-showcase-card--skeleton" aria-hidden="true">
                    <div class="tour-showcase-card__cover"></div>
                    <div class="tour-showcase-card__body">
                        <div class="tour-showcase-card__summary">
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--title"></span>
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--summary"></span>
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--summary short"></span>
                        </div>
                        <div class="tour-showcase-card__metrics">
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--pill"></span>
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--pill"></span>
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--pill"></span>
                        </div>
                    </div>
                </article>
            }
        }
        else
        {
            @foreach (var tour in Tours)
            {
                <button type="button" class="tour-showcase-card @GetTourTone(tour)" @onclick="() => OnSelectTour.InvokeAsync(tour.Id)">
                    <div class="tour-showcase-card__cover">
                        <span class="tour-showcase-card__badge">@GetTourBadge(tour)</span>
                        <span class="tour-showcase-card__icon">@GetTourIcon(tour)</span>
                    </div>
                    <div class="tour-showcase-card__body">
                        <div class="tour-showcase-card__summary">
                            <strong>@tour.Title</strong>
                            <p class="tour-showcase-card__description">@tour.Description</p>
                        </div>
                        <div class="tour-showcase-card__metrics">
                            <span>📍 @tour.StopCountLabel</span>
                            <span>⏱️ @tour.DurationLabel</span>
                            <span>👣 @GetParticipationLabel(tour)</span>
                        </div>
                    </div>
                </button>
            }
        }
    </section>

    <section class="tour-list-footer-stats">
        <article class="tour-list-footer-stats__item">
            <strong>@Tours.Count</strong>
            <span>Lộ trình sẵn sàng</span>
        </article>
        <article class="tour-list-footer-stats__item">
            <strong>@GetTotalStops()</strong>
            <span>Tổng điểm dừng</span>
        </article>
        <article class="tour-list-footer-stats__item">
            <strong>@GetAverageDurationLabel()</strong>
            <span>Nhịp tour trung bình</span>
        </article>
    </section>
</section>

@code {
    [Parameter] public IReadOnlyList<TouristTourCard> Tours { get; set; } = [];
    [Parameter] public bool ShowGuestPrompt { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback OnOpenAuth { get; set; }
    [Parameter] public EventCallback<string> OnSelectTour { get; set; }

    private static string GetTourIcon(TouristTourCard tour)
    {
        var text = $"{tour.Title} {tour.Description}".ToLowerInvariant();
        if (text.Contains("ẩm thực") || text.Contains("food"))
        {
            return "🍜";
        }

        if (text.Contains("đêm") || text.Contains("night"))
        {
            return "🌙";
        }

        return "🏛️";
    }

    private static string GetTourTone(TouristTourCard tour)
    {
        var text = $"{tour.Title} {tour.Description}".ToLowerInvariant();
        if (text.Contains("ẩm thực") || text.Contains("food"))
        {
            return "is-food";
        }

        if (text.Contains("đêm") || text.Contains("night"))
        {
            return "is-night";
        }

        return "is-history";
    }

    private static string GetTourBadge(TouristTourCard tour)
    {
        var text = $"{tour.Title} {tour.Description}".ToLowerInvariant();
        if (text.Contains("ẩm thực") || text.Contains("food"))
        {
            return "⭐ Phổ biến";
        }

        if (text.Contains("đêm") || text.Contains("night"))
        {
            return "🆕 Mới";
        }

        return "🏙️ Văn hóa";
    }

    private static string GetParticipationLabel(TouristTourCard tour)
    {
        var count = tour.StopPoiIds.Count switch
        {
            <= 3 => 124,
            4 => 148,
            5 => 168,
            _ => 187
        };

        return $"{count} đã tham gia";
    }

    private int GetTotalStops() => Tours.Sum(tour => ParseLeadingNumber(tour.StopCountLabel));

    private string GetAverageDurationLabel()
    {
        if (Tours.Count == 0)
        {
            return "0p";
        }

        var averageMinutes = Tours.Average(tour => ParseLeadingNumber(tour.DurationLabel));
        return $"{Math.Round(averageMinutes, MidpointRounding.AwayFromZero):0}p";
    }

    private static int ParseLeadingNumber(string value)
    {
        var digits = new string(value.TakeWhile(char.IsDigit).ToArray());
        return int.TryParse(digits, out var number) ? number : 0;
    }
}
