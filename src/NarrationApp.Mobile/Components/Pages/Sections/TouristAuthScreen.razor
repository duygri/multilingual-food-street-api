@using NarrationApp.Mobile.Features.Home

<section class="auth-screen @(IsOverlay ? "auth-screen--overlay" : "auth-screen--welcome")">
    <header class="auth-screen__head">
        <div class="auth-screen__copy auth-screen__intro">
            <span class="eyebrow">Food Street Tourist</span>
            <h1>@Title</h1>
            <p>@Subtitle</p>
        </div>

        @if (ShowCloseButton)
        {
            <button type="button" class="auth-screen__close" @onclick="() => OnClose.InvokeAsync()">✕</button>
        }
    </header>

    @if (ShowFeatureList)
    {
        <section class="auth-feature-list">
            <article class="auth-feature-card">
                <span class="auth-feature-card__icon">📍</span>
                <div class="auth-feature-card__copy">
                    <strong>Tự động phát</strong>
                    <p>Bật audio khi bạn vào đúng geofence của POI.</p>
                </div>
            </article>
            <article class="auth-feature-card">
                <span class="auth-feature-card__icon">🌐</span>
                <div class="auth-feature-card__copy">
                    <strong>5 ngôn ngữ</strong>
                    <p>Ưu tiên tiếng Việt nguồn, chuyển ngay sang ngôn ngữ bạn chọn.</p>
                </div>
            </article>
            <article class="auth-feature-card">
                <span class="auth-feature-card__icon">🗺️</span>
                <div class="auth-feature-card__copy">
                    <strong>Tour có sẵn</strong>
                    <p>Lưu tiến trình tour và tiếp tục ở lần mở app tiếp theo.</p>
                </div>
            </article>
        </section>
    }

    <article class="setup-auth-card auth-panel auth-screen__panel">
        @if (Session is null)
        {
            <div class="auth-mode-tabs">
                <button
                    type="button"
                    class="auth-mode-tab @(IsRegisterMode ? string.Empty : "is-active")"
                    @onclick="() => OnModeChanged.InvokeAsync(false)">
                    Đăng nhập
                </button>
                <button
                    type="button"
                    class="auth-mode-tab @(IsRegisterMode ? "is-active" : string.Empty)"
                    @onclick="() => OnModeChanged.InvokeAsync(true)">
                    Đăng ký
                </button>
            </div>

            <div class="auth-form">
                <label class="form-field">
                    <span class="field-label">Email</span>
                    <input
                        class="auth-inline__input"
                        type="email"
                        placeholder="you@example.com"
                        value="@Email"
                        @oninput="HandleEmailChangedAsync" />
                </label>
                <label class="form-field">
                    <span class="field-label">Mật khẩu</span>
                    <input
                        class="auth-inline__input"
                        type="password"
                        placeholder="••••••••"
                        value="@Password"
                        @oninput="HandlePasswordChangedAsync" />
                </label>

                @if (IsRegisterMode)
                {
                    <label class="form-field">
                        <span class="field-label">Xác nhận mật khẩu</span>
                        <input
                            class="auth-inline__input"
                            type="password"
                            placeholder="••••••••"
                            value="@ConfirmPassword"
                            @oninput="HandleConfirmPasswordChangedAsync" />
                    </label>
                }
            </div>

            <div class="auth-screen__actions">
                @if (!IsRegisterMode)
                {
                    <button type="button" class="auth-forgot-link" @onclick="() => OnForgotPassword.InvokeAsync()">
                        Quên mật khẩu?
                    </button>
                }

                <button type="button" class="primary-pill primary-pill--wide" @onclick="() => OnSubmit.InvokeAsync()" disabled="@IsBusy">
                    @(IsRegisterMode ? "Đăng ký" : "Đăng nhập")
                </button>
            </div>
        }
        else
        {
            <div class="auth-inline auth-inline--summary">
                <span>@Session.Email</span>
                <span>@SessionStatusLabel</span>
            </div>

            <div class="setup-actions">
                <button type="button" class="primary-pill" @onclick="() => OnContinueAuthenticated.InvokeAsync()">
                    @SessionPrimaryLabel
                </button>
                <button type="button" class="secondary-pill" @onclick="() => OnLogout.InvokeAsync()" disabled="@IsBusy">
                    Đăng xuất
                </button>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="auth-feedback auth-feedback--success">@StatusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="auth-feedback auth-feedback--error">@ErrorMessage</div>
        }
    </article>

    @if (ShowGuestContinue && Session is null)
    {
        <div class="auth-screen__guest">
            <button type="button" class="guest-link-button" @onclick="() => OnContinueGuest.InvokeAsync()">
                Không muốn đăng nhập? Tiếp tục khám phá →
            </button>
        </div>
    }
</section>

@code {
    [Parameter] public string Title { get; set; } = "Chào mừng!";
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public string Email { get; set; } = string.Empty;
    [Parameter] public string Password { get; set; } = string.Empty;
    [Parameter] public string ConfirmPassword { get; set; } = string.Empty;
    [Parameter] public bool IsRegisterMode { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public bool ShowFeatureList { get; set; }
    [Parameter] public bool ShowGuestContinue { get; set; }
    [Parameter] public bool ShowCloseButton { get; set; }
    [Parameter] public string? StatusMessage { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string SessionPrimaryLabel { get; set; } = "Tiếp tục với tourist";
    [Parameter] public string SessionStatusLabel { get; set; } = string.Empty;
    [Parameter] public TouristAuthSession? Session { get; set; }
    [Parameter] public bool IsOverlay { get; set; }
    [Parameter] public EventCallback<bool> OnModeChanged { get; set; }
    [Parameter] public EventCallback<string> OnEmailChanged { get; set; }
    [Parameter] public EventCallback<string> OnPasswordChanged { get; set; }
    [Parameter] public EventCallback<string> OnConfirmPasswordChanged { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback OnForgotPassword { get; set; }
    [Parameter] public EventCallback OnContinueGuest { get; set; }
    [Parameter] public EventCallback OnContinueAuthenticated { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnLogout { get; set; }

    private Task HandleEmailChangedAsync(ChangeEventArgs args) =>
        OnEmailChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandlePasswordChangedAsync(ChangeEventArgs args) =>
        OnPasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleConfirmPasswordChangedAsync(ChangeEventArgs args) =>
        OnConfirmPasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
}
