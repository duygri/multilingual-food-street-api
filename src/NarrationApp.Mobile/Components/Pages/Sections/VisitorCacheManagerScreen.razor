@using System.Globalization
@using NarrationApp.Mobile.Features.Home

<section class="settings-detail-screen">
    <header class="settings-detail-header">
        <button type="button" class="icon-button" @onclick="OnBack">←</button>
        <div>
            <span class="eyebrow">Cache manager</span>
            <h2>Audio đã cache</h2>
            <p>Quản lý các file audio đã lưu cục bộ để nghe offline và giải phóng bộ nhớ khi cần.</p>
        </div>
    </header>

    <article class="setting-card cache-summary-card">
        <span class="sheet-label">Dung lượng đang dùng</span>
        <strong>@GetUsedStorageLabel()</strong>
        <p>@Items.Count file audio thuộc @GetDistinctPoiCount() POI khác nhau.</p>
        <div class="settings-progress">
            <span class="settings-progress__fill" style="@GetProgressStyle()"></span>
        </div>
        <div class="sheet-actions">
            <button type="button" class="primary-pill" @onclick="OnPreload" disabled="@IsPreloadRunning">@PreloadActionLabel</button>
            <button type="button" class="secondary-pill" @onclick="OnRefresh">Quét lại cache</button>
            <button type="button" class="secondary-pill secondary-pill--danger" @onclick="OnClearAll" disabled="@(Items.Count == 0)">Xóa tất cả</button>
        </div>
        <div class="cache-preload-status @(IsPreloadRunning ? "is-running" : string.Empty)">
            <span>@PreloadStatusLabel</span>
            <div class="settings-progress">
                <span class="settings-progress__fill" style="@GetPreloadProgressStyle()"></span>
            </div>
        </div>
    </article>

    <div class="settings-nav-list">
        @if (Items.Count == 0)
        {
            <article class="setting-card cache-item cache-item--empty">
                <strong>Chưa có file audio cục bộ.</strong>
                <p>Tải hoặc nghe một vài POI để app lưu cache cho lần sau.</p>
            </article>
        }
        else
        {
            @foreach (var item in Items)
            {
                <article class="setting-card cache-item">
                    <div class="cache-item__copy">
                        <strong>@item.PoiName</strong>
                        <span>@item.LanguageCode.ToUpperInvariant() • @item.SourceLabel</span>
                        <span>@item.SizeMb.ToString("0.0", CultureInfo.InvariantCulture) MB • @item.UpdatedLabel</span>
                    </div>
                    <button type="button" class="secondary-pill secondary-pill--danger" @onclick="() => OnDeleteItem.InvokeAsync(item.Id)">Xóa</button>
                </article>
            }
        }
    </div>
</section>

@code {
    [Parameter] public IReadOnlyList<VisitorCachedAudioItem> Items { get; set; } = [];
    [Parameter] public double CapacityMb { get; set; } = 64d;
    [Parameter] public string PreloadActionLabel { get; set; } = "Tải trước audio";
    [Parameter] public string PreloadStatusLabel { get; set; } = "Sẵn sàng tải trước audio.";
    [Parameter] public double PreloadProgressPercent { get; set; }
    [Parameter] public bool IsPreloadRunning { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnPreload { get; set; }
    [Parameter] public EventCallback OnClearAll { get; set; }
    [Parameter] public EventCallback<string> OnDeleteItem { get; set; }

    private string GetUsedStorageLabel()
    {
        var usedStorage = Items.Sum(item => item.SizeMb);
        return $"{usedStorage.ToString("0.0", CultureInfo.InvariantCulture)} / {CapacityMb.ToString("0", CultureInfo.InvariantCulture)} MB";
    }

    private string GetProgressStyle()
    {
        var usedStorage = Items.Sum(item => item.SizeMb);
        var percent = CapacityMb <= 0 ? 0 : Math.Clamp(usedStorage * 100d / CapacityMb, 0d, 100d);
        return $"width:{percent.ToString("0.##", CultureInfo.InvariantCulture)}%;";
    }

    private string GetPreloadProgressStyle()
    {
        var percent = Math.Clamp(PreloadProgressPercent, 0d, 100d);
        return $"width:{percent.ToString("0.##", CultureInfo.InvariantCulture)}%;";
    }

    private int GetDistinctPoiCount() =>
        Items
            .Select(item => item.PoiId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();
}
