@using NarrationApp.Mobile.Features.Home

<section class="discover-screen">
    <header class="discover-header">
        <div class="discover-header__title">
            <span class="discover-header__icon">📍</span>
            <div>
                <h1>Khám phá</h1>
                <p>Tất cả điểm tham quan gần bạn</p>
            </div>
        </div>
        <button type="button" class="discover-refresh-button @(IsLoading ? "is-busy" : string.Empty)" @onclick="() => OnRefresh.InvokeAsync()">
            ↻
        </button>
    </header>

    <label class="discover-search discover-search--strict">
        <span class="search-icon">⌕</span>
        <input
            class="search-input"
            type="text"
            placeholder="Tìm theo tên, danh mục..."
            value="@SearchTerm"
            readonly
            @onclick="OnOpenSearch"
            @onfocus="OnOpenSearch" />
    </label>

    <section class="discover-chip-row">
        @foreach (var category in Categories)
        {
            <button
                type="button"
                class="category-chip @(SelectedCategoryId == category.Id ? "is-selected" : string.Empty)"
                @onclick="() => OnSelectCategory.InvokeAsync(category.Id)">
                <span>@GetCategoryIcon(category.Id)</span>
                <span>@category.Label</span>
            </button>
        }
    </section>

    @if (IsUsingFallbackData && !string.IsNullOrWhiteSpace(SyncMessage))
    {
        <aside class="discover-sync-banner">
            <strong>@DataSourceLabel</strong>
            <p>@SyncMessage</p>
        </aside>
    }

    <section class="discover-list discover-list--stagger">
        @if (IsLoading && Pois.Count == 0)
        {
            @for (var index = 0; index < 4; index++)
            {
                <article class="discover-poi-card discover-poi-card--skeleton" aria-hidden="true">
                    <div class="discover-poi-card__media discover-poi-card__media--skeleton"></div>
                    <div class="discover-poi-card__body">
                        <div class="discover-poi-card__topline">
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--title"></span>
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--pill"></span>
                        </div>
                        <div class="discover-poi-card__meta">
                            <span class="discover-poi-card__skeleton discover-poi-card__skeleton--badge"></span>
                            <div class="discover-poi-card__status">
                                <span class="discover-poi-card__skeleton discover-poi-card__skeleton--status"></span>
                                <span class="discover-poi-card__skeleton discover-poi-card__skeleton--status short"></span>
                            </div>
                        </div>
                        <span class="discover-poi-card__skeleton discover-poi-card__skeleton--summary"></span>
                        <span class="discover-poi-card__skeleton discover-poi-card__skeleton--summary short"></span>
                    </div>
                </article>
            }
        }
        else if (Pois.Count == 0)
        {
            <article class="discover-poi-card discover-poi-card--empty">
                <strong>Chưa có điểm phù hợp bộ lọc hiện tại.</strong>
                <p>Thử đổi từ khóa hoặc chọn danh mục khác.</p>
            </article>
        }
        else
        {
            @foreach (var poi in Pois)
            {
                <button type="button" class="discover-poi-card" @onclick="() => OnSelectPoi.InvokeAsync(poi.Id)">
                    <div class="discover-poi-card__media">
                        @if (!string.IsNullOrWhiteSpace(poi.ImageUrl))
                        {
                            <img class="discover-poi-card__image" src="@poi.ImageUrl" alt="@poi.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="discover-poi-card__image-fallback @GetPoiTone(poi.CategoryId)">
                                <span>@GetPoiIcon(poi)</span>
                            </div>
                        }
                    </div>
                    <div class="discover-poi-card__body">
                        <div class="discover-poi-card__topline">
                            <strong class="discover-poi-card__title">@poi.Name</strong>
                            <span class="discover-poi-card__distance">@poi.DistanceMeters m</span>
                        </div>
                        <div class="discover-poi-card__meta">
                            <span class="discover-badge">@GetCategoryLabel(poi)</span>
                            <div class="discover-poi-card__status">
                                <span>🔊 @poi.StatusLabel</span>
                                <span>🌐 @poi.AvailableLanguageCount ngôn ngữ</span>
                            </div>
                        </div>
                        <p class="discover-poi-card__summary">@Truncate(poi.Description, 88)</p>
                    </div>
                </button>
            }
        }
    </section>
</section>

@code {
    [Parameter] public IReadOnlyList<VisitorPoi> Pois { get; set; } = [];
    [Parameter] public IReadOnlyList<VisitorCategory> Categories { get; set; } = [];
    [Parameter] public string SelectedCategoryId { get; set; } = "all";
    [Parameter] public string SearchTerm { get; set; } = string.Empty;
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool IsUsingFallbackData { get; set; }
    [Parameter] public string DataSourceLabel { get; set; } = string.Empty;
    [Parameter] public string SyncMessage { get; set; } = string.Empty;
    [Parameter] public EventCallback OnOpenSearch { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback<string> OnSelectCategory { get; set; }
    [Parameter] public EventCallback<string> OnSelectPoi { get; set; }

    private string GetCategoryIcon(string categoryId) =>
        VisitorCategoryPresentationFormatter.GetCategoryIcon(categoryId, Categories);

    private string GetPoiIcon(VisitorPoi poi) =>
        VisitorCategoryPresentationFormatter.GetPoiIcon(poi, Categories);

    private string GetPoiTone(string categoryId) =>
        VisitorCategoryPresentationFormatter.GetCategoryTone(categoryId, Categories);

    private string GetCategoryLabel(VisitorPoi poi) =>
        string.IsNullOrWhiteSpace(poi.CategoryLabel)
            ? Categories.FirstOrDefault(category => category.Id == poi.CategoryId)?.Label ?? poi.District
            : poi.CategoryLabel;

    private static string Truncate(string text, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(text) || text.Length <= maxLength)
        {
            return text;
        }

        return $"{text[..maxLength].TrimEnd()}...";
    }
}
