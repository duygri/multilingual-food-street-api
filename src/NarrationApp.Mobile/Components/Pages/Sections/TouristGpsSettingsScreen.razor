@using NarrationApp.Mobile.Features.Home

<section class="settings-detail-screen">
    <header class="settings-detail-header">
        <button type="button" class="icon-button" @onclick="OnBack">←</button>
        <div>
            <span class="eyebrow">GPS settings</span>
            <h2>Vị trí & GPS</h2>
            <p>Điều chỉnh quyền truy cập, mức chính xác và cách map tự focus theo vị trí hiện tại.</p>
        </div>
    </header>

    <article class="setting-card settings-gps-status">
        <span class="sheet-label">Trạng thái hiện tại</span>
        <strong>@StatusLabel</strong>
        <p>@Preferences.StatusLabel</p>
        <div class="auth-inline auth-inline--summary">
            <span>Pin @Preferences.BatteryPercent%</span>
            <span>@Preferences.BatteryLabel</span>
        </div>
    </article>

    <article class="setting-card">
        <span class="sheet-label">Theo dõi nền</span>

        <button type="button" class="settings-toggle-row" @onclick="() => OnBackgroundTrackingChanged.InvokeAsync(!Preferences.BackgroundTrackingEnabled)">
            <div class="settings-row__copy">
                <strong class="settings-row__title">Cho phép geofence khi app nền</strong>
                <span class="settings-row__subtitle">Giữ trạng thái nhận biết POI gần bạn khi đang đi bộ hoặc khóa màn hình.</span>
            </div>
            <span class="settings-switch @(Preferences.BackgroundTrackingEnabled ? "is-on" : string.Empty)">@GetToggleLabel(Preferences.BackgroundTrackingEnabled)</span>
        </button>

        <button type="button" class="settings-toggle-row" @onclick="() => OnAutoFocusChanged.InvokeAsync(!Preferences.AutoFocusEnabled)">
            <div class="settings-row__copy">
                <strong class="settings-row__title">Tự focus vị trí hiện tại</strong>
                <span class="settings-row__subtitle">Map sẽ ưu tiên quay lại khu vực bạn đang đứng khi mở app hoặc đổi tab.</span>
            </div>
            <span class="settings-switch @(Preferences.AutoFocusEnabled ? "is-on" : string.Empty)">@GetToggleLabel(Preferences.AutoFocusEnabled)</span>
        </button>
    </article>

    <article class="setting-card">
        <span class="sheet-label">Mức chính xác GPS</span>
        <div class="settings-segment">
            @foreach (var mode in Enum.GetValues<TouristGpsAccuracyMode>())
            {
                <button
                    type="button"
                    class="settings-segment__button @(Preferences.AccuracyMode == mode ? "is-selected" : string.Empty)"
                    @onclick="() => OnAccuracyModeChanged.InvokeAsync(mode)">
                    @GetAccuracyLabel(mode)
                </button>
            }
        </div>
        <p>@GetAccuracyDescription(Preferences.AccuracyMode)</p>
    </article>
</section>

@code {
    [Parameter] public TouristGpsPreferences Preferences { get; set; } = new(true, true, TouristGpsAccuracyMode.Adaptive, 0, string.Empty, string.Empty);
    [Parameter] public string StatusLabel { get; set; } = string.Empty;
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback<bool> OnBackgroundTrackingChanged { get; set; }
    [Parameter] public EventCallback<bool> OnAutoFocusChanged { get; set; }
    [Parameter] public EventCallback<TouristGpsAccuracyMode> OnAccuracyModeChanged { get; set; }

    private static string GetToggleLabel(bool isEnabled) => isEnabled ? "Bật" : "Tắt";

    private static string GetAccuracyLabel(TouristGpsAccuracyMode mode) =>
        mode switch
        {
            TouristGpsAccuracyMode.High => "High",
            TouristGpsAccuracyMode.BatterySaver => "Battery",
            _ => "Adaptive"
        };

    private static string GetAccuracyDescription(TouristGpsAccuracyMode mode) =>
        mode switch
        {
            TouristGpsAccuracyMode.High => "Ưu tiên độ chính xác tối đa cho geofence và auto-play, đổi lại sẽ dùng pin nhiều hơn.",
            TouristGpsAccuracyMode.BatterySaver => "Giảm tần suất cập nhật vị trí khi bạn chỉ muốn theo tour nhẹ và ít hao pin.",
            _ => "Cân bằng giữa độ mượt khi đi bộ và mức tiêu thụ pin trong ngày."
        };
}
