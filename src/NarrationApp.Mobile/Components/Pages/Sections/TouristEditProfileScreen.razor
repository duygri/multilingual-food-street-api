@using NarrationApp.Mobile.Features.Home

<section class="settings-detail-screen">
    <header class="settings-detail-header">
        <button type="button" class="icon-button" @onclick="OnBack">←</button>
        <div>
            <span class="eyebrow">Profile</span>
            <h2>Chỉnh sửa hồ sơ</h2>
            <p>Cập nhật tên hiển thị, email liên hệ và quản lý phiên tourist hoặc guest mode.</p>
        </div>
    </header>

    <article class="setting-card profile-editor-card">
        <div class="settings-profile-card__top">
            <div class="settings-avatar settings-avatar--large">@Initials</div>
            <div class="settings-row__copy">
                <strong class="settings-row__title">@ModeLabel</strong>
                <span class="settings-row__subtitle">@DisplayName</span>
                <span class="settings-row__subtitle">@DisplayEmail</span>
            </div>
        </div>

        <div class="profile-editor-stats">
            @foreach (var stat in Stats)
            {
                <div class="settings-stat">
                    <strong>@stat.Value</strong>
                    <span>@stat.Label</span>
                </div>
            }
        </div>
    </article>

    <article class="setting-card profile-editor-card">
        <label class="form-field">
            <span class="field-label">Tên hiển thị</span>
            <input class="auth-inline__input" type="text" value="@Name" @oninput="HandleNameChangedAsync" />
        </label>

        <label class="form-field">
            <span class="field-label">Email</span>
            <input class="auth-inline__input" type="email" value="@Email" @oninput="HandleEmailChangedAsync" />
        </label>

        <label class="form-field">
            <span class="field-label">Mật khẩu hiện tại</span>
            <input class="auth-inline__input" type="password" value="@CurrentPassword" @oninput="HandleCurrentPasswordChangedAsync" />
        </label>

        <label class="form-field">
            <span class="field-label">Mật khẩu mới</span>
            <input class="auth-inline__input" type="password" value="@NewPassword" @oninput="HandleNewPasswordChangedAsync" />
        </label>

        <label class="form-field">
            <span class="field-label">Xác nhận mật khẩu mới</span>
            <input class="auth-inline__input" type="password" value="@ConfirmPassword" @oninput="HandleConfirmPasswordChangedAsync" />
        </label>

        <div class="sheet-actions">
            <button type="button" class="primary-pill" @onclick="OnSave">Lưu hồ sơ</button>
            <button type="button" class="secondary-pill" @onclick="OnSessionAction">@SessionActionLabel</button>
        </div>

        @if (ShowLogout)
        {
            <button type="button" class="secondary-pill secondary-pill--danger secondary-pill--wide" @onclick="OnLogout">Đăng xuất</button>
        }

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="auth-feedback auth-feedback--success">@StatusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="auth-feedback auth-feedback--error">@ErrorMessage</div>
        }
    </article>
</section>

@code {
    [Parameter] public string DisplayName { get; set; } = string.Empty;
    [Parameter] public string DisplayEmail { get; set; } = string.Empty;
    [Parameter] public string ModeLabel { get; set; } = string.Empty;
    [Parameter] public string Initials { get; set; } = "G";
    [Parameter] public IReadOnlyList<TouristSettingsStat> Stats { get; set; } = [];
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public string Email { get; set; } = string.Empty;
    [Parameter] public string CurrentPassword { get; set; } = string.Empty;
    [Parameter] public string NewPassword { get; set; } = string.Empty;
    [Parameter] public string ConfirmPassword { get; set; } = string.Empty;
    [Parameter] public string SessionActionLabel { get; set; } = "Mở đăng nhập";
    [Parameter] public bool ShowLogout { get; set; }
    [Parameter] public string? StatusMessage { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnSessionAction { get; set; }
    [Parameter] public EventCallback OnLogout { get; set; }
    [Parameter] public EventCallback<string> OnNameChanged { get; set; }
    [Parameter] public EventCallback<string> OnEmailChanged { get; set; }
    [Parameter] public EventCallback<string> OnCurrentPasswordChanged { get; set; }
    [Parameter] public EventCallback<string> OnNewPasswordChanged { get; set; }
    [Parameter] public EventCallback<string> OnConfirmPasswordChanged { get; set; }

    private Task HandleNameChangedAsync(ChangeEventArgs args) =>
        OnNameChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleEmailChangedAsync(ChangeEventArgs args) =>
        OnEmailChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleCurrentPasswordChangedAsync(ChangeEventArgs args) =>
        OnCurrentPasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleNewPasswordChangedAsync(ChangeEventArgs args) =>
        OnNewPasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task HandleConfirmPasswordChangedAsync(ChangeEventArgs args) =>
        OnConfirmPasswordChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
}
