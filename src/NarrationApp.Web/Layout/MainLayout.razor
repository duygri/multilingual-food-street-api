@inherits LayoutComponentBase
@using System.Security.Claims
@using Microsoft.Extensions.DependencyInjection
@using NarrationApp.SharedUI.Services
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AuthClientService AuthClientService
@inject NavigationManager NavigationManager
@inject IServiceProvider ServiceProvider

<PortalShell Brand="@_portalBrand"
             Eyebrow="@_portalEyebrow"
             Tagline="@_portalTagline"
             NavigationItems="_navigationItems"
             SidebarProfileContent="@(_isOwner ? OwnerSidebarProfileContent : null)">
    <HeaderContent>
        <div class="layout-header">
            <div class="layout-header__copy">
                <p class="layout-header__eyebrow">@_eyebrow</p>
                <h2>@_heading</h2>
                <p>@_summary</p>
            </div>

            <div class="layout-header__actions">
                @if (_isAuthenticated)
                {
                    <NotificationCenter AllNotificationsHref="@(_isOwner ? "/owner/notifications" : null)" />
                    <div class="layout-header__identity">
                        <span>@_roleLabel</span>
                        <strong>@_email</strong>
                    </div>
                    <button class="app-button app-button--ghost" type="button" @onclick="LogoutAsync">Đăng xuất</button>
                }
                else
                {
                    <NavLink class="app-button app-button--ghost" href="/auth/login">Đăng nhập</NavLink>
                    <NavLink class="app-button app-button--primary" href="/auth/register">Đăng ký owner</NavLink>
                }
            </div>
        </div>
    </HeaderContent>

    <ChildContent>
        @Body
    </ChildContent>
</PortalShell>
