<section class="layout-owner-card" aria-label="Owner profile summary">
    <div class="layout-owner-card__head">
        <div class="layout-owner-card__avatar" aria-hidden="true">@Initials</div>

        <div class="layout-owner-card__identity">
            <strong class="layout-owner-card__name">@DisplayName</strong>

            <div class="layout-owner-card__role">
                <span class="layout-owner-card__role-dot" aria-hidden="true"></span>
                <span class="layout-owner-card__role-label">POI Owner</span>
            </div>
        </div>
    </div>

    <div class="layout-owner-card__stats" role="list">
        <div class="layout-owner-card__stat" role="listitem">
            <span class="layout-owner-card__stat-value">@TotalPoisText</span>
            <span class="layout-owner-card__stat-label">POI</span>
        </div>
        <div class="layout-owner-card__stat" role="listitem">
            <span class="layout-owner-card__stat-value">@PublishedPoisText</span>
            <span class="layout-owner-card__stat-label">Published</span>
        </div>
        <div class="layout-owner-card__stat" role="listitem">
            <span class="layout-owner-card__stat-value">@PendingModerationText</span>
            <span class="layout-owner-card__stat-label">Pending</span>
        </div>
    </div>
</section>
