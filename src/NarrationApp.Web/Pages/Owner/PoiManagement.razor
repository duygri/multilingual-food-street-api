@page "/owner/poi-management"
@using System.Linq
@using NarrationApp.Shared.Constants
@attribute [Authorize(Roles = "poi_owner")]

@inject IOwnerPortalService OwnerPortalService
@inject ICategoryPortalService CategoryPortalService
@inject IAudioPortalService AudioPortalService
@inject IGeofencePortalService GeofencePortalService
@inject IModerationPortalService ModerationPortalService

<PageTitle>Quản lý POI</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">POI</p>
        <h2>Đang tải điều phối POI...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">POI</p>
        <h2>Không thể tải quản lý POI</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack">
        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <section class="panel-shell">
                <p class="panel-shell__copy">@_statusMessage</p>
            </section>
        }

        <section class="management-grid owner-poi-grid">
            <article class="panel-shell management-grid__column">
                <div class="section-header">
                    <div>
                        <p class="panel-shell__eyebrow">POI sở hữu</p>
                        <h2>Bàn điều phối POI</h2>
                    </div>

                    <button class="app-button app-button--ghost" data-action="new-poi" type="button" @onclick="BeginCreatePoi">
                        Tạo POI mới
                    </button>
                </div>

                @if (_pois.Count == 0)
                {
                    <p class="panel-shell__copy">Chưa có POI nào thuộc chủ sở hữu hiện tại. Hãy tạo POI đầu tiên để bắt đầu vận hành nội dung.</p>
                }
                else
                {
                    <div class="selection-list">
                        @foreach (var poi in _pois)
                        {
                            <button class="selection-card @GetSelectionClass(poi)"
                                    data-action="select-@poi.Id"
                                    type="button"
                                    @onclick="() => SelectPoiAsync(poi)">
                                <div>
                                    <strong>@poi.Name</strong>
                                    <p>@poi.Slug</p>
                                    <p>@(poi.CategoryName ?? "Chưa gán danh mục")</p>
                                </div>
                                <span class="status-pill">@GetPoiStatusLabel(poi.Status)</span>
                            </button>
                        }
                    </div>
                }
            </article>

            <div class="detail-stack owner-poi-grid__detail">
                @if (!_isCreateMode && _selectedPoi is not null)
                {
                    <SystemStatusRail Label="Trạng thái POI" Items="StatusItems" />
                }

                <article class="panel-shell detail-stack">
                    <p class="panel-shell__eyebrow">Trình biên tập POI</p>
                    <h2>@(_isCreateMode ? "Tạo POI mới" : _selectedPoi?.Name ?? "Chọn một POI")</h2>
                    <p class="panel-shell__copy">
                        @if (_isCreateMode)
                        {
                            <span>Tạo một bản nháp mới với đầy đủ thông tin nguồn để gửi admin duyệt khi sẵn sàng.</span>
                        }
                        else if (_selectedPoi is not null)
                        {
                            <span>Chỉnh tên, vị trí, danh mục, mô tả nguồn, script TTS và file audio nguồn của <strong>@_selectedPoi.Name</strong>.</span>
                        }
                    </p>

                    <div class="editor-grid">
                        <div class="editor-field">
                            <label for="poi-name">Tên POI</label>
                            <InputText id="poi-name" data-field="poi-name" @bind-Value="_editor.Name" />
                        </div>

                        <div class="editor-field">
                            <label for="poi-slug">Slug</label>
                            <InputText id="poi-slug" data-field="poi-slug" @bind-Value="_editor.Slug" />
                        </div>

                        <div class="editor-field">
                            <label for="poi-lat">Vĩ độ</label>
                            <InputNumber id="poi-lat" data-field="poi-lat" @bind-Value="_editor.Lat" />
                        </div>

                        <div class="editor-field">
                            <label for="poi-lng">Kinh độ</label>
                            <InputNumber id="poi-lng" data-field="poi-lng" @bind-Value="_editor.Lng" />
                        </div>

                        <div class="editor-field">
                            <label for="poi-priority">Độ ưu tiên</label>
                            <InputNumber id="poi-priority" data-field="poi-priority" @bind-Value="_editor.Priority" />
                        </div>

                        <div class="editor-field">
                            <label for="poi-category">Danh mục</label>
                            <InputSelect id="poi-category" data-field="poi-category" @bind-Value="_editor.CategoryId">
                                <option value="">Chưa gán danh mục</option>
                                @foreach (var category in _categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="editor-field">
                            <label for="poi-mode">Chế độ phát</label>
                            <InputSelect id="poi-mode" data-field="poi-mode" @bind-Value="_editor.NarrationMode">
                                @foreach (var mode in _narrationModes)
                                {
                                    <option value="@mode">@GetNarrationModeLabel(mode)</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="editor-field">
                            <label for="poi-map-link">Liên kết bản đồ</label>
                            <InputText id="poi-map-link" data-field="poi-map-link" @bind-Value="_editor.MapLink" />
                        </div>

                        <div class="editor-field editor-field--full">
                            <label for="poi-image-url">Liên kết hình ảnh</label>
                            <InputText id="poi-image-url" data-field="poi-image-url" @bind-Value="_editor.ImageUrl" />
                        </div>

                        <div class="editor-field editor-field--full">
                            <label for="poi-description">Mô tả văn bản</label>
                            <InputTextArea id="poi-description" data-field="poi-description" @bind-Value="_editor.Description" />
                        </div>

                        <div class="editor-field editor-field--full">
                            <label for="poi-tts-script">Kịch bản TTS tiếng Việt</label>
                            <InputTextArea id="poi-tts-script" data-field="poi-tts-script" @bind-Value="_editor.TtsScript" />
                        </div>
                    </div>

                    @if (!_isCreateMode && _selectedPoi is not null)
                    {
                        <section class="upload-surface">
                            <div class="editor-field">
                                <label for="poi-source-file">File audio nguồn tiếng Việt</label>
                                <InputFile id="poi-source-file" OnChange="HandleSourceAudioSelection" />
                            </div>

                            <div class="action-row">
                                <button class="app-button app-button--ghost"
                                        data-action="upload-source-audio"
                                        type="button"
                                        @onclick="UploadSourceAudioAsync"
                                        disabled="@(_selectedUploadFile is null)">
                                    Tải audio nguồn
                                </button>
                            </div>
                        </section>
                    }

                    <div class="action-row">
                        <button class="app-button app-button--primary" data-action="save-poi" type="button" @onclick="SavePoiAsync">
                            @(_isCreateMode ? "Tạo POI" : "Lưu thay đổi")
                        </button>

                        @if (!_isCreateMode && _selectedPoi is not null)
                        {
                            <button class="app-button app-button--ghost" data-action="delete-poi" type="button" @onclick="DeletePoiAsync">
                                Xóa POI
                            </button>
                        }

                        @if (!_isCreateMode && _selectedPoi is not null)
                        {
                            <button class="app-button app-button--ghost" data-action="request-review" type="button" @onclick="RequestReviewAsync">
                                Gửi duyệt
                            </button>
                        }
                    </div>
                </article>

                @if (!_isCreateMode && _selectedPoi is not null)
                {
                    <article class="panel-shell detail-stack">
                        <p class="panel-shell__eyebrow">Vùng kích hoạt mặc định</p>
                        <h2>Vùng kích hoạt chính</h2>
                        <p class="panel-shell__copy">Thiết lập vùng kích hoạt mặc định cho POI hiện tại để ứng dụng di động phát thuyết minh đúng theo bán kính và thời gian chờ mong muốn.</p>

                        <div class="editor-grid">
                            <div class="editor-field">
                                <label for="geofence-name">Tên vùng</label>
                                <InputText id="geofence-name" data-field="geofence-name" @bind-Value="_geofenceEditor.Name" />
                            </div>

                            <div class="editor-field">
                                <label for="geofence-trigger">Hành động kích hoạt</label>
                                <InputText id="geofence-trigger" data-field="geofence-trigger" @bind-Value="_geofenceEditor.TriggerAction" />
                            </div>

                            <div class="editor-field">
                                <label for="geofence-radius">Bán kính (m)</label>
                                <InputNumber id="geofence-radius" data-field="geofence-radius" @bind-Value="_geofenceEditor.RadiusMeters" />
                            </div>

                            <div class="editor-field">
                                <label for="geofence-priority">Độ ưu tiên</label>
                                <InputNumber id="geofence-priority" data-field="geofence-priority" @bind-Value="_geofenceEditor.Priority" />
                            </div>

                            <div class="editor-field">
                                <label for="geofence-debounce">Thời gian đệm (s)</label>
                                <InputNumber id="geofence-debounce" data-field="geofence-debounce" @bind-Value="_geofenceEditor.DebounceSeconds" />
                            </div>

                            <div class="editor-field">
                                <label for="geofence-cooldown">Thời gian chờ (s)</label>
                                <InputNumber id="geofence-cooldown" data-field="geofence-cooldown" @bind-Value="_geofenceEditor.CooldownSeconds" />
                            </div>

                            <div class="editor-field editor-field--toggle">
                                <label for="geofence-active">Đang hoạt động</label>
                                <InputCheckbox id="geofence-active" data-field="geofence-active" @bind-Value="_geofenceEditor.IsActive" />
                            </div>

                            <div class="editor-field editor-field--toggle">
                                <label for="geofence-nearest-only">Chỉ lấy điểm gần nhất</label>
                                <InputCheckbox id="geofence-nearest-only" data-field="geofence-nearest-only" @bind-Value="_geofenceEditor.NearestOnly" />
                            </div>
                        </div>

                        <div class="action-row">
                            <button class="app-button app-button--ghost" data-action="save-geofence" type="button" @onclick="SaveGeofenceAsync">
                                Lưu vùng kích hoạt
                            </button>
                        </div>
                    </article>
                }
            </div>
        </section>

        @if (!_isCreateMode && _selectedPoi is not null && _stats is not null)
        {
            <section class="metric-grid">
                <MetricCard Label="Lượt ghé" Value="@_stats.TotalVisits.ToString()" Hint="Lượt truy cập POI" />
                <MetricCard Label="Audio hiện có" Value="@_stats.AudioAssetCount.ToString()" Hint="File audio nguồn hiện có" />
                <MetricCard Label="Bản dịch" Value="@_stats.TranslationCount.ToString()" Hint="Bản dịch admin đã sinh" />
                <MetricCard Label="Vùng kích hoạt" Value="@_stats.GeofenceCount.ToString()" Hint="Số vùng đang dùng" />
                <MetricCard Label="Hàng chờ" Value="@PendingModerationCount.ToString()" Hint="Yêu cầu đang chờ" />
            </section>
        }

        @if (!_isCreateMode && _selectedPoi is not null)
        {
            <section class="panel-grid owner-poi-lane-grid">
                <article class="panel-shell">
                    <p class="panel-shell__eyebrow">Lịch sử kiểm duyệt</p>
                    <h2>Luồng phê duyệt gần đây</h2>

                    @if (_moderationItems.Count == 0)
                    {
                        <p class="panel-shell__copy">Chưa có yêu cầu kiểm duyệt</p>
                    }
                    else
                    {
                        <div class="timeline-list">
                            @foreach (var item in _moderationItems)
                            {
                                <article class="timeline-item">
                                    <div>
                                        <strong>@($"{GetModerationEntityLabel(item.EntityType)} #{item.EntityId}")</strong>
                                        <p>@GetModerationStatusLabel(item.Status)</p>
                                    </div>
                                    <small>@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM HH:mm")</small>
                                </article>
                            }
                        </div>
                    }
                </article>
            </section>
        }
    </div>
}

@code {
    private const long MaxUploadBytes = 20_000_000;

    private readonly NarrationMode[] _narrationModes = Enum.GetValues<NarrationMode>();

    private bool _isLoading = true;
    private bool _isCreateMode;
    private string? _errorMessage;
    private string? _statusMessage;
    private PoiEditorModel _editor = PoiEditorModel.CreateDefault();
    private GeofenceEditorModel _geofenceEditor = GeofenceEditorModel.CreateDefault();
    private IReadOnlyList<CategoryDto> _categories = Array.Empty<CategoryDto>();
    private IReadOnlyList<PoiDto> _pois = Array.Empty<PoiDto>();
    private IReadOnlyList<ModerationRequestDto> _moderationItems = Array.Empty<ModerationRequestDto>();
    private PoiDto? _selectedPoi;
    private OwnerPoiStatsDto? _stats;
    private IBrowserFile? _selectedUploadFile;

    private int PendingModerationCount => _moderationItems.Count(item => item.Status == ModerationStatus.Pending);

    private IReadOnlyList<SystemStatusItem> StatusItems =>
    [
        new() { Label = "POI", Value = GetPoiStatusLabel(_selectedPoi?.Status ?? PoiStatus.Draft), Tone = GetPoiStatusTone(_selectedPoi?.Status ?? PoiStatus.Draft) },
        new() { Label = "Danh mục", Value = _selectedPoi?.CategoryName ?? "Chưa gán", Tone = _selectedPoi?.CategoryId is null ? StatusTone.Warn : StatusTone.Info },
        new() { Label = "Vùng kích hoạt", Value = $"{_selectedPoi?.Geofences.Count ?? 0} vùng", Tone = (_selectedPoi?.Geofences.Count ?? 0) > 0 ? StatusTone.Good : StatusTone.Warn },
        new() { Label = "Hàng chờ", Value = $"{PendingModerationCount} chờ duyệt", Tone = PendingModerationCount > 0 ? StatusTone.Warn : StatusTone.Good }
    ];

    private static string GetPoiStatusLabel(PoiStatus status)
    {
        return status switch
        {
            PoiStatus.Published => "Đã xuất bản",
            PoiStatus.PendingReview => "Chờ duyệt",
            PoiStatus.Draft => "Nháp",
            PoiStatus.Rejected => "Bị từ chối",
            PoiStatus.Updated => "Đã cập nhật",
            PoiStatus.Archived => "Lưu trữ",
            _ => status.ToString()
        };
    }

    private static StatusTone GetPoiStatusTone(PoiStatus status)
    {
        return status switch
        {
            PoiStatus.Published => StatusTone.Good,
            PoiStatus.PendingReview => StatusTone.Warn,
            PoiStatus.Draft => StatusTone.Neutral,
            PoiStatus.Rejected => StatusTone.Warn,
            PoiStatus.Updated => StatusTone.Info,
            PoiStatus.Archived => StatusTone.Neutral,
            _ => StatusTone.Neutral
        };
    }

    private static string GetNarrationModeLabel(NarrationMode mode)
    {
        return mode switch
        {
            NarrationMode.TtsOnly => "Chỉ TTS",
            NarrationMode.RecordedOnly => "Chỉ audio nguồn",
            NarrationMode.Both => "Kết hợp",
            _ => mode.ToString()
        };
    }

    private static string GetModerationEntityLabel(string entityType)
    {
        return entityType switch
        {
            "poi" => "POI",
            _ => entityType
        };
    }

    private static string GetModerationStatusLabel(ModerationStatus status)
    {
        return status switch
        {
            ModerationStatus.Pending => "Chờ duyệt",
            ModerationStatus.Approved => "Đã duyệt",
            ModerationStatus.Rejected => "Bị từ chối",
            _ => status.ToString()
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _categories = await CategoryPortalService.GetAsync();
            _moderationItems = await ModerationPortalService.GetMineAsync();
            _pois = await OwnerPortalService.GetPoisAsync();

            if (_pois.Count > 0)
            {
                await SelectPoiAsync(_pois[0]);
            }
            else
            {
                BeginCreatePoi();
            }
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BeginCreatePoi()
    {
        _isCreateMode = true;
        _selectedPoi = null;
        _stats = null;
        _selectedUploadFile = null;
        _editor = PoiEditorModel.CreateDefault();
        _geofenceEditor = GeofenceEditorModel.CreateDefault();
        _statusMessage = null;
    }

    private async Task SelectPoiAsync(PoiDto poi)
    {
        _isCreateMode = false;
        _selectedPoi = poi;
        _selectedUploadFile = null;
        _editor = PoiEditorModel.FromPoi(poi);
        _geofenceEditor = GeofenceEditorModel.FromPoi(poi);
        _statusMessage = null;
        await LoadPoiDetailsAsync(poi.Id);
    }

    private async Task LoadPoiDetailsAsync(int poiId)
    {
        _stats = await OwnerPortalService.GetPoiStatsAsync(poiId);
    }

    private async Task SavePoiAsync()
    {
        try
        {
            if (_isCreateMode)
            {
                var created = await OwnerPortalService.CreatePoiAsync(_editor.ToCreateRequest());
                _pois = [created, .. _pois];
                await SelectPoiAsync(created);
                _statusMessage = $"Đã tạo POI mới: {created.Name}.";
                return;
            }

            if (_selectedPoi is null)
            {
                return;
            }

            var updated = await OwnerPortalService.UpdatePoiAsync(_selectedPoi.Id, _editor.ToUpdateRequest());
            _pois = _pois.Select(item => item.Id == updated.Id ? updated : item).ToArray();
            await SelectPoiAsync(updated);
            _statusMessage = $"Đã cập nhật POI: {updated.Name}.";
        }
        catch (ApiException exception)
        {
            _statusMessage = exception.Message;
        }
    }

    private async Task DeletePoiAsync()
    {
        if (_selectedPoi is null)
        {
            return;
        }

        try
        {
            var deletedId = _selectedPoi.Id;
            await OwnerPortalService.DeletePoiAsync(deletedId);
            _pois = _pois.Where(item => item.Id != deletedId).ToArray();

            if (_pois.Count > 0)
            {
                await SelectPoiAsync(_pois[0]);
            }
            else
            {
                BeginCreatePoi();
            }

            _statusMessage = "POI đã được xóa.";
        }
        catch (ApiException exception)
        {
            _statusMessage = exception.Message;
        }
    }

    private async Task RequestReviewAsync()
    {
        if (_selectedPoi is null)
        {
            return;
        }

        try
        {
            await ModerationPortalService.CreateAsync(new CreateModerationRequest
            {
                EntityType = "poi",
                EntityId = _selectedPoi.Id.ToString()
            });

            _moderationItems = await ModerationPortalService.GetMineAsync();
            _statusMessage = $"Đã gửi POI {_selectedPoi.Name} vào hàng chờ kiểm duyệt.";
        }
        catch (ApiException exception)
        {
            _statusMessage = exception.Message;
        }
    }

    private void HandleSourceAudioSelection(InputFileChangeEventArgs args)
    {
        _selectedUploadFile = args.File;
        _statusMessage = _selectedUploadFile is null ? null : $"Đã chọn file {_selectedUploadFile.Name}.";
    }

    private async Task UploadSourceAudioAsync()
    {
        if (_selectedPoi is null || _selectedUploadFile is null)
        {
            return;
        }

        try
        {
            await using var stream = _selectedUploadFile.OpenReadStream(MaxUploadBytes);
            await AudioPortalService.UploadAsync(new UploadAudioRequest
            {
                PoiId = _selectedPoi.Id,
                LanguageCode = "vi",
                FileName = _selectedUploadFile.Name
            }, stream);

            await LoadPoiDetailsAsync(_selectedPoi.Id);
            _statusMessage = $"Đã tải file audio nguồn {_selectedUploadFile.Name} cho {_selectedPoi.Name}.";
            _selectedUploadFile = null;
        }
        catch (ApiException exception)
        {
            _statusMessage = exception.Message;
        }
    }

    private async Task SaveGeofenceAsync()
    {
        if (_selectedPoi is null)
        {
            return;
        }

        try
        {
            var updated = await GeofencePortalService.UpdateAsync(_selectedPoi.Id, _geofenceEditor.ToRequest());
            ApplyGeofence(updated);
            _geofenceEditor = GeofenceEditorModel.FromGeofence(updated);
            _statusMessage = $"Đã cập nhật vùng kích hoạt cho {_selectedPoi.Name}.";
        }
        catch (ApiException exception)
        {
            _statusMessage = exception.Message;
        }
    }

    private string GetSelectionClass(PoiDto poi)
    {
        if (_isCreateMode)
        {
            return string.Empty;
        }

        return poi.Id == _selectedPoi?.Id ? "is-active" : string.Empty;
    }

    private void ApplyGeofence(GeofenceDto geofence)
    {
        if (_selectedPoi is null)
        {
            return;
        }

        var updatedPoi = new PoiDto
        {
            Id = _selectedPoi.Id,
            Name = _selectedPoi.Name,
            Slug = _selectedPoi.Slug,
            OwnerId = _selectedPoi.OwnerId,
            Lat = _selectedPoi.Lat,
            Lng = _selectedPoi.Lng,
            Priority = _selectedPoi.Priority,
            CategoryId = _selectedPoi.CategoryId,
            CategoryName = _selectedPoi.CategoryName,
            NarrationMode = _selectedPoi.NarrationMode,
            Description = _selectedPoi.Description,
            TtsScript = _selectedPoi.TtsScript,
            MapLink = _selectedPoi.MapLink,
            ImageUrl = _selectedPoi.ImageUrl,
            Status = _selectedPoi.Status,
            CreatedAtUtc = _selectedPoi.CreatedAtUtc,
            Translations = _selectedPoi.Translations,
            Geofences = [geofence]
        };

        _selectedPoi = updatedPoi;
        _pois = _pois.Select(item => item.Id == updatedPoi.Id ? updatedPoi : item).ToArray();

        if (_stats is not null)
        {
            _stats = new OwnerPoiStatsDto
            {
                PoiId = _stats.PoiId,
                TotalVisits = _stats.TotalVisits,
                AudioPlays = _stats.AudioPlays,
                TranslationCount = _stats.TranslationCount,
                AudioAssetCount = _stats.AudioAssetCount,
                GeofenceCount = updatedPoi.Geofences.Count
            };
        }
    }

    private sealed class PoiEditorModel
    {
        public string Name { get; set; } = string.Empty;

        public string Slug { get; set; } = string.Empty;

        public double Lat { get; set; }

        public double Lng { get; set; }

        public int Priority { get; set; } = 10;

        public int? CategoryId { get; set; }

        public NarrationMode NarrationMode { get; set; } = NarrationMode.TtsOnly;

        public string Description { get; set; } = string.Empty;

        public string TtsScript { get; set; } = string.Empty;

        public string? MapLink { get; set; }

        public string? ImageUrl { get; set; }

        public static PoiEditorModel CreateDefault()
        {
            return new PoiEditorModel
            {
                Lat = 10.758d,
                Lng = 106.701d
            };
        }

        public static PoiEditorModel FromPoi(PoiDto poi)
        {
            return new PoiEditorModel
            {
                Name = poi.Name,
                Slug = poi.Slug,
                Lat = poi.Lat,
                Lng = poi.Lng,
                Priority = poi.Priority,
                CategoryId = poi.CategoryId,
                NarrationMode = poi.NarrationMode,
                Description = poi.Description,
                TtsScript = poi.TtsScript,
                MapLink = poi.MapLink,
                ImageUrl = poi.ImageUrl
            };
        }

        public CreatePoiRequest ToCreateRequest()
        {
            return new CreatePoiRequest
            {
                Name = Name,
                Slug = Slug,
                Lat = Lat,
                Lng = Lng,
                Priority = Priority,
                CategoryId = CategoryId,
                NarrationMode = NarrationMode,
                Description = Description,
                TtsScript = TtsScript,
                MapLink = MapLink,
                ImageUrl = ImageUrl
            };
        }

        public UpdatePoiRequest ToUpdateRequest()
        {
            return new UpdatePoiRequest
            {
                Name = Name,
                Slug = Slug,
                Lat = Lat,
                Lng = Lng,
                Priority = Priority,
                CategoryId = CategoryId,
                NarrationMode = NarrationMode,
                Description = Description,
                TtsScript = TtsScript,
                MapLink = MapLink,
                ImageUrl = ImageUrl,
                Status = PoiStatus.Draft
            };
        }
    }

    private sealed class GeofenceEditorModel
    {
        public string Name { get; set; } = string.Empty;

        public int RadiusMeters { get; set; } = AppConstants.DefaultGeofenceRadiusMeters;

        public int Priority { get; set; } = 10;

        public int DebounceSeconds { get; set; } = AppConstants.DefaultDebounceSeconds;

        public int CooldownSeconds { get; set; } = AppConstants.DefaultCooldownSeconds;

        public bool IsActive { get; set; } = true;

        public string TriggerAction { get; set; } = "auto_play";

        public bool NearestOnly { get; set; } = true;

        public static GeofenceEditorModel CreateDefault()
        {
            return new GeofenceEditorModel();
        }

        public static GeofenceEditorModel FromPoi(PoiDto poi)
        {
            var geofence = poi.Geofences.FirstOrDefault();
            if (geofence is not null)
            {
                return FromGeofence(geofence);
            }

            return new GeofenceEditorModel
            {
                Name = $"Vùng kích hoạt {poi.Name}"
            };
        }

        public static GeofenceEditorModel FromGeofence(GeofenceDto geofence)
        {
            return new GeofenceEditorModel
            {
                Name = geofence.Name,
                RadiusMeters = geofence.RadiusMeters,
                Priority = geofence.Priority,
                DebounceSeconds = geofence.DebounceSeconds,
                CooldownSeconds = geofence.CooldownSeconds,
                IsActive = geofence.IsActive,
                TriggerAction = geofence.TriggerAction,
                NearestOnly = geofence.NearestOnly
            };
        }

        public UpdateGeofenceRequest ToRequest()
        {
            return new UpdateGeofenceRequest
            {
                Name = Name,
                RadiusMeters = RadiusMeters,
                Priority = Priority,
                DebounceSeconds = DebounceSeconds,
                CooldownSeconds = CooldownSeconds,
                IsActive = IsActive,
                TriggerAction = TriggerAction,
                NearestOnly = NearestOnly
            };
        }
    }
}
