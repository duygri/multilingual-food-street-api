@page "/owner/pois"
@attribute [Authorize(Roles = "poi_owner")]
@inject IOwnerPortalService OwnerPortalService

<PageTitle>Danh sách POI</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">POI</p>
        <h2>Đang tải danh sách POI...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">POI</p>
        <h2>Không thể tải danh sách POI</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="owner-workspace-page">
        <header class="owner-workspace-heading">
            <div>
                <div class="owner-workspace-breadcrumb">Owner / <strong>POI của tôi</strong> / Danh sách</div>
                <h1>Danh sách POI</h1>
                <p>Quản lý nhanh nội dung nguồn, trạng thái duyệt và hành động cần xử lý của từng POI.</p>
            </div>
        </header>

        <section class="owner-workspace-stats" aria-label="Owner POI stats">
            <article class="panel-shell owner-workspace-stat">
                <div class="owner-workspace-stat__icon">POI</div>
                <p class="owner-workspace-stat__value">@_workspace.Summary.TotalPois</p>
                <p class="owner-workspace-stat__label">Tổng POI</p>
                <p class="owner-workspace-stat__hint">Toàn bộ POI trong workspace</p>
            </article>

            <article class="panel-shell owner-workspace-stat owner-workspace-stat--published">
                <div class="owner-workspace-stat__icon">PUB</div>
                <p class="owner-workspace-stat__value">@_workspace.Summary.PublishedPois</p>
                <p class="owner-workspace-stat__label">Đang xuất bản</p>
                <p class="owner-workspace-stat__hint">Các điểm đang live</p>
            </article>

            <article class="panel-shell owner-workspace-stat owner-workspace-stat--pending">
                <div class="owner-workspace-stat__icon">REV</div>
                <p class="owner-workspace-stat__value">@_workspace.Summary.PendingReviewPois</p>
                <p class="owner-workspace-stat__label">Chờ duyệt</p>
                <p class="owner-workspace-stat__hint">Nội dung đang nằm trong queue</p>
            </article>

            <article class="panel-shell owner-workspace-stat owner-workspace-stat--audio">
                <div class="owner-workspace-stat__icon">FIX</div>
                <p class="owner-workspace-stat__value">@_workspace.Summary.DraftOrRejectedPois</p>
                <p class="owner-workspace-stat__label">Nháp / Từ chối</p>
                <p class="owner-workspace-stat__hint">Các mục cần hoàn thiện hoặc gửi lại</p>
            </article>
        </section>

        <article class="panel-shell owner-workspace-panel">
            <div class="owner-workspace-panel__header">
                <div class="owner-workspace-panel__title">
                    <div class="owner-workspace-stat__icon">POI</div>
                    <div>
                        <h2>Danh sách POI</h2>
                        <p>Bảng owner workspace cho toàn bộ POI</p>
                    </div>
                </div>
            </div>

            <div class="owner-workspace-panel__body">
                <div class="owner-workspace-toolbar">
                    <div class="owner-workspace-toolbar__group">
                        <label class="owner-workspace-field">
                            <span>Tìm kiếm</span>
                            <input data-field="poi-search"
                                   placeholder="Tên hoặc slug"
                                   @bind="_searchTerm" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Trạng thái</span>
                            <select data-field="poi-status-filter" @bind="_statusFilter">
                                <option value="">Tất cả trạng thái</option>
                                @foreach (var status in _statusOptions)
                                {
                                    <option value="@status.ToString()">@GetPoiStatusLabel(status)</option>
                                }
                            </select>
                        </label>
                    </div>

                    <div class="owner-workspace-actions">
                        <a class="app-button app-button--primary" data-action="create-poi" href="/owner/pois/new">
                            Tạo POI mới
                        </a>
                    </div>
                </div>

                @if (_workspace.Rows.Count == 0)
                {
                    <div class="owner-workspace-empty">
                        Chưa có POI nào trong workspace owner.
                    </div>
                }
                else if (FilteredRows.Count == 0)
                {
                    <div class="owner-workspace-empty">
                        Không có POI nào khớp bộ lọc hiện tại.
                    </div>
                }
                else
                {
                    <div class="owner-workspace-table-wrap">
                        <table class="owner-workspace-table" aria-label="Owner POI list">
                            <thead>
                                <tr>
                                    <th>POI</th>
                                    <th>DANH MỤC</th>
                                    <th>TỌA ĐỘ</th>
                                    <th>PRIORITY</th>
                                    <th>NỘI DUNG NGUỒN</th>
                                    <th>TRẠNG THÁI</th>
                                    <th>THAO TÁC</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in FilteredRows)
                                {
                                    <tr>
                                        <td>
                                            <div class="owner-workspace-cell">
                                                <div class="owner-workspace-cell__avatar">POI</div>
                                                <div>
                                                    <p class="owner-workspace-cell__title">@row.PoiName</p>
                                                    <p class="owner-workspace-cell__sub">@row.Slug</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="owner-workspace-badge owner-workspace-badge--category">@(row.CategoryName ?? "Chưa gán")</span>
                                        </td>
                                        <td>@GetCoordinateLabel(row)</td>
                                        <td>@row.Priority</td>
                                        <td>
                                            <span class="owner-workspace-badge owner-workspace-badge--source">@GetSourceContentLabel(row.SourceContentKind)</span>
                                        </td>
                                        <td>
                                            <span class="@GetStatusClass(row.Status)">@GetStatusText(row.Status)</span>
                                        </td>
                                        <td>
                                            <div class="owner-workspace-actions">
                                                <a class="app-button app-button--ghost" href="@($"/owner/pois/{row.PoiId}")">Xem</a>
                                                @if (row.CanResubmit)
                                                {
                                                    <a class="app-button app-button--primary" href="@($"/owner/pois/{row.PoiId}")">Sửa &amp; Gửi lại</a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </article>
    </div>
}
