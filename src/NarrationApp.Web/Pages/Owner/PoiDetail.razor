@page "/owner/pois/{Id:int}"
@attribute [Authorize(Roles = "poi_owner")]
@inject IOwnerPortalService OwnerPortalService
@inject IAudioPortalService AudioPortalService
@inject IGeofencePortalService GeofencePortalService
@inject IModerationPortalService ModerationPortalService
@inject ICategoryPortalService CategoryPortalService
@inject NavigationManager NavigationManager
@inject IServiceProvider ServiceProvider

<PageTitle>@(_poi?.Name ?? "Chi tiết POI")</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">POI</p>
        <h2>Đang tải chi tiết POI...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">POI</p>
        <h2>Không thể tải chi tiết POI</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
        <a class="app-button app-button--ghost" href="/owner/pois">Quay lại danh sách POI</a>
    </section>
}
else if (_poi is not null && _editor is not null && _geofenceEditor is not null && _workspace is not null)
{
    <div class="owner-workspace-page">
        <header class="owner-workspace-heading">
            <div>
                <div class="owner-workspace-breadcrumb">Owner / <strong>POI của tôi</strong> / Chi tiết</div>
                <h1>Chi tiết POI</h1>
                <p>Theo dõi trạng thái POI, chỉnh nội dung nguồn, cập nhật ảnh đại diện và làm việc trực tiếp với moderation/audio.</p>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <section class="panel-shell owner-poi-detail__status" role="status">
                <p class="panel-shell__copy">@_statusMessage</p>
            </section>
        }

        <section class="panel-shell owner-workspace-detail-hero">
            <div class="owner-workspace-detail-hero__media">
                <div class="owner-workspace-detail-hero__image">
                    @if (!string.IsNullOrWhiteSpace(_poi.ImageUrl))
                    {
                        <img src="@_poi.ImageUrl" alt="@_poi.Name" />
                    }
                    else
                    {
                        <span>POI</span>
                    }
                </div>

                <article class="owner-workspace-detail-hero__upload">
                    <div class="owner-workspace-panel__title">
                        <div class="owner-workspace-stat__icon">IMG</div>
                        <div>
                            <h2>Ảnh minh họa</h2>
                            <p>1 ảnh đại diện từ tệp, đồng bộ sang admin qua trường `ImageUrl` hiện tại.</p>
                        </div>
                    </div>

                    <div class="owner-workspace-upload">
                        <div class="owner-workspace-upload__placeholder">
                            <strong>Chọn ảnh từ tệp</strong>
                            <p>JPG, PNG hoặc WEBP. Tối đa 5MB.</p>
                        </div>
                        <InputFile data-field="poi-image-file"
                                   accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                                   OnChange="HandlePoiImageSelection" />
                    </div>

                    @if (_selectedImageFile is not null)
                    {
                        <div class="owner-workspace-file-card">
                            <p class="owner-workspace-file-card__title">@_selectedImageFile.Name</p>
                            <p class="owner-workspace-file-card__meta">@GetFileMetaLabel(_selectedImageFile)</p>
                        </div>
                    }

                    <div class="owner-workspace-actions">
                        <button class="app-button app-button--primary"
                                data-action="upload-poi-image"
                                type="button"
                                disabled="@(_isUploadingImage || _selectedImageFile is null)"
                                @onclick="UploadPoiImageAsync">
                            @(_isUploadingImage ? "Đang tải..." : "Cập nhật ảnh")
                        </button>

                        @if (!string.IsNullOrWhiteSpace(_poi.ImageUrl))
                        {
                            <button class="app-button app-button--ghost"
                                    data-action="remove-poi-image"
                                    type="button"
                                    disabled="@_isRemovingImage"
                                    @onclick="RemovePoiImageAsync">
                                @(_isRemovingImage ? "Đang xóa..." : "Gỡ ảnh")
                            </button>
                        }
                    </div>
                </article>
            </div>

            <div class="owner-workspace-detail-hero__body">
                <div class="owner-workspace-detail-hero__title">
                    <div>
                        <h2>@_poi.Name</h2>
                        <p>@_poi.Slug</p>
                    </div>
                    <span class="@GetPoiStatusClass(_poi.Status)">@GetPoiStatusLabel(_poi.Status)</span>
                </div>

                <div class="owner-workspace-detail-hero__meta">
                    <span class="owner-workspace-badge">@_poi.Lat.ToString("0.###"), @_poi.Lng.ToString("0.###")</span>
                    <span class="owner-workspace-badge">@GetRadiusSummary(_poi)</span>
                    <span class="owner-workspace-badge">Priority @_poi.Priority</span>
                    <span class="owner-workspace-badge owner-workspace-badge--category">@( _poi.CategoryName ?? "Chưa gán danh mục")</span>
                    <span class="owner-workspace-badge">POI #@_poi.Id</span>
                </div>

                <p class="owner-workspace-detail-hero__summary">@_poi.Description</p>

                <div class="owner-workspace-actions">
                    <button class="app-button app-button--ghost"
                            data-action="request-review"
                            type="button"
                            disabled="@_isRequestingReview"
                            @onclick="RequestReviewAsync">
                        @(_isRequestingReview ? "Đang gửi..." : "Gửi duyệt")
                    </button>
                    <a class="app-button app-button--ghost" href="@(_poi.MapLink ?? "#")">Mở bản đồ</a>
                    <button class="app-button app-button--ghost"
                            data-action="open-delete-poi"
                            type="button"
                            @onclick="OpenDeleteDialog">
                        Xóa POI
                    </button>
                </div>
            </div>
        </section>

        @if (ShouldShowRejectionSurface)
        {
            <section class="panel-shell owner-workspace-panel">
                <div class="owner-workspace-panel__header">
                    <div class="owner-workspace-panel__title">
                        <div class="owner-workspace-stat__icon">REV</div>
                        <div>
                            <h2>Cần chỉnh trước khi gửi lại</h2>
                            <p>Admin đã trả về phản hồi cần xử lý trước khi POI được đưa lại vào hàng chờ duyệt.</p>
                        </div>
                    </div>
                </div>

                <div class="owner-workspace-panel__body owner-workspace-panel__body--stack">
                    <p class="panel-shell__copy">@RejectionNote</p>
                    <div class="owner-workspace-actions">
                        <button class="app-button app-button--primary"
                                data-action="request-review-rejected"
                                type="button"
                                disabled="@_isRequestingReview"
                                @onclick="RequestReviewAsync">
                            Sửa &amp; gửi lại
                        </button>
                    </div>
                </div>
            </section>
        }

        <section class="owner-workspace-stats" aria-label="POI detail metrics">
            <article class="panel-shell owner-workspace-stat">
                <div class="owner-workspace-stat__icon">VIS</div>
                <p class="owner-workspace-stat__value">@_workspace.Metrics.TotalVisits</p>
                <p class="owner-workspace-stat__label">Lượt ghé</p>
                <p class="owner-workspace-stat__hint">Tổng lượt tương tác với POI</p>
            </article>

            <article class="panel-shell owner-workspace-stat owner-workspace-stat--audio">
                <div class="owner-workspace-stat__icon">AUD</div>
                <p class="owner-workspace-stat__value">@_workspace.Metrics.AudioPlays</p>
                <p class="owner-workspace-stat__label">Audio plays</p>
                <p class="owner-workspace-stat__hint">Lượt nghe audio nguồn và TTS</p>
            </article>

            <article class="panel-shell owner-workspace-stat owner-workspace-stat--published">
                <div class="owner-workspace-stat__icon">QR</div>
                <p class="owner-workspace-stat__value">@_workspace.Metrics.QrScans</p>
                <p class="owner-workspace-stat__label">QR scans</p>
                <p class="owner-workspace-stat__hint">Lượt mở POI qua mã QR</p>
            </article>

            <article class="panel-shell owner-workspace-stat owner-workspace-stat--pending">
                <div class="owner-workspace-stat__icon">TIME</div>
                <p class="owner-workspace-stat__value">@GetListenDurationLabel(_workspace.Metrics.TotalListenDurationSeconds)</p>
                <p class="owner-workspace-stat__label">Thời gian nghe</p>
                <p class="owner-workspace-stat__hint">Tổng thời lượng nghe ghi nhận</p>
            </article>
        </section>

        <section class="owner-workspace-grid owner-workspace-grid--detail">
            <article class="panel-shell owner-workspace-panel">
                <div class="owner-workspace-panel__header">
                    <div class="owner-workspace-panel__title">
                        <div class="owner-workspace-stat__icon">SRC</div>
                        <div>
                            <h2>Thông tin chỉnh sửa</h2>
                            <p>Nội dung nguồn, metadata và routing để owner cập nhật trước moderation.</p>
                        </div>
                    </div>
                </div>

                <div class="owner-workspace-panel__body owner-workspace-panel__body--stack">
                    <div class="owner-workspace-form-grid">
                        <label class="owner-workspace-field">
                            <span>Tên POI</span>
                            <input data-field="poi-name" @bind="_editor.Name" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Slug</span>
                            <input data-field="poi-slug" @bind="_editor.Slug" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Latitude</span>
                            <input data-field="poi-lat" type="number" step="0.000001" @bind="_editor.Lat" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Longitude</span>
                            <input data-field="poi-lng" type="number" step="0.000001" @bind="_editor.Lng" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Priority</span>
                            <input data-field="poi-priority" type="number" @bind="_editor.Priority" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Danh mục</span>
                            <select data-field="poi-category" @bind="_editor.CategoryId">
                                <option value="">Chưa gán danh mục</option>
                                @foreach (var category in _categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </label>

                        <label class="owner-workspace-field">
                            <span>Chế độ phát</span>
                            <select data-field="poi-mode" @bind="_editor.NarrationMode">
                                @foreach (var mode in _narrationModes)
                                {
                                    <option value="@mode">@GetNarrationLabel(mode)</option>
                                }
                            </select>
                        </label>

                        <label class="owner-workspace-field">
                            <span>Link bản đồ</span>
                            <input data-field="poi-map-link" @bind="_editor.MapLink" />
                        </label>
                    </div>

                    <label class="owner-workspace-field owner-workspace-field--full">
                        <span>Mô tả nguồn</span>
                        <textarea data-field="poi-description" @bind="_editor.Description"></textarea>
                    </label>

                    <label class="owner-workspace-field owner-workspace-field--full">
                        <span>Kịch bản TTS</span>
                        <textarea data-field="poi-tts-script" @bind="_editor.TtsScript"></textarea>
                    </label>

                    <div class="owner-workspace-actions owner-workspace-actions--end">
                        <button class="app-button app-button--primary"
                                data-action="save-poi"
                                type="button"
                                disabled="@_isSaving"
                                @onclick="SavePoiAsync">
                            @(_isSaving ? "Đang lưu..." : "Lưu thay đổi")
                        </button>
                    </div>
                </div>
            </article>

            <article class="panel-shell owner-workspace-panel">
                <div class="owner-workspace-panel__header">
                    <div class="owner-workspace-panel__title">
                        <div class="owner-workspace-stat__icon">AUD</div>
                        <div>
                            <h2>Audio đa ngôn ngữ</h2>
                            <p>Upload audio nguồn tiếng Việt hoặc theo dõi trạng thái audio do admin/TTS quản lý.</p>
                        </div>
                    </div>
                </div>

                <div class="owner-workspace-panel__body owner-workspace-panel__body--stack">
                    <div class="owner-workspace-upload">
                        <div class="owner-workspace-upload__placeholder">
                            <strong>Audio nguồn tiếng Việt</strong>
                            <p>Tải file MP3 hoặc WAV để admin dùng làm nguồn phát chính.</p>
                        </div>
                        <InputFile data-field="source-audio" OnChange="HandleSourceAudioSelection" />
                    </div>

                    @if (_selectedUploadFile is not null)
                    {
                        <div class="owner-workspace-file-card">
                            <p class="owner-workspace-file-card__title">@_selectedUploadFile.Name</p>
                            <p class="owner-workspace-file-card__meta">@GetFileMetaLabel(_selectedUploadFile)</p>
                        </div>
                    }

                    <div class="owner-workspace-actions">
                        <button class="app-button app-button--primary"
                                data-action="upload-source-audio"
                                type="button"
                                disabled="@(_isUploadingAudio || _selectedUploadFile is null)"
                                @onclick="UploadSourceAudioAsync">
                            @(_isUploadingAudio ? "Đang tải..." : "Upload audio nguồn")
                        </button>
                    </div>

                    @if (_audioItems.Count == 0)
                    {
                        <div class="owner-workspace-empty">
                            Chưa có audio cho POI này.
                        </div>
                    }
                    else
                    {
                        <div class="owner-workspace-table-wrap">
                            <table class="owner-workspace-table" aria-label="Owner POI audio table">
                                <thead>
                                    <tr>
                                        <th>NGÔN NGỮ</th>
                                        <th>LOẠI</th>
                                        <th>TRẠNG THÁI</th>
                                        <th>THỜI LƯỢNG</th>
                                        <th>BẢN DỊCH</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var audio in _audioItems)
                                    {
                                        <tr>
                                            <td>@audio.LanguageCode</td>
                                            <td>@GetAudioSourceLabel(audio.SourceType)</td>
                                            <td>
                                                <span class="@GetAudioStatusClass(audio.Status)">@audio.Status</span>
                                            </td>
                                            <td>@GetDurationLabel(audio.DurationSeconds)</td>
                                            <td>@(HasTranslation(audio.LanguageCode) ? "Có" : "Chưa có")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </article>
        </section>

        <section class="owner-workspace-grid owner-workspace-grid--detail">
            <article class="panel-shell owner-workspace-panel">
                <div class="owner-workspace-panel__header">
                    <div class="owner-workspace-panel__title">
                        <div class="owner-workspace-stat__icon">GEO</div>
                        <div>
                            <h2>Geofence</h2>
                            <p>Tinh chỉnh vùng kích hoạt chính để geofence và auto-play vận hành ổn định.</p>
                        </div>
                    </div>
                </div>

                <div class="owner-workspace-panel__body owner-workspace-panel__body--stack">
                    <div class="owner-workspace-form-grid">
                        <label class="owner-workspace-field">
                            <span>Tên vùng</span>
                            <input data-field="geofence-name" @bind="_geofenceEditor.Name" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Bán kính (m)</span>
                            <input data-field="geofence-radius" type="number" @bind="_geofenceEditor.RadiusMeters" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Độ ưu tiên</span>
                            <input data-field="geofence-priority" type="number" @bind="_geofenceEditor.Priority" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Debounce (giây)</span>
                            <input data-field="geofence-debounce" type="number" @bind="_geofenceEditor.DebounceSeconds" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Cooldown (giây)</span>
                            <input data-field="geofence-cooldown" type="number" @bind="_geofenceEditor.CooldownSeconds" />
                        </label>

                        <label class="owner-workspace-field">
                            <span>Trigger action</span>
                            <input data-field="geofence-trigger" @bind="_geofenceEditor.TriggerAction" />
                        </label>
                    </div>

                    <div class="owner-workspace-checks">
                        <label>
                            <input data-field="geofence-active" type="checkbox" @bind="_geofenceEditor.IsActive" />
                            <span>Đang hoạt động</span>
                        </label>
                        <label>
                            <input data-field="geofence-nearest-only" type="checkbox" @bind="_geofenceEditor.NearestOnly" />
                            <span>Chỉ kích hoạt POI gần nhất</span>
                        </label>
                    </div>

                    <div class="owner-workspace-actions owner-workspace-actions--end">
                        <button class="app-button app-button--primary"
                                data-action="save-geofence"
                                type="button"
                                disabled="@_isSavingGeofence"
                                @onclick="SaveGeofenceAsync">
                            @(_isSavingGeofence ? "Đang cập nhật..." : "Lưu geofence")
                        </button>
                    </div>
                </div>
            </article>

            <article class="panel-shell owner-workspace-panel">
                <div class="owner-workspace-panel__header">
                    <div class="owner-workspace-panel__title">
                        <div class="owner-workspace-stat__icon">MOD</div>
                        <div>
                            <h2>Moderation snapshot</h2>
                            <p>Lịch sử moderation gần nhất để owner hiểu POI đang ở đâu trong pipeline admin.</p>
                        </div>
                    </div>
                </div>

                <div class="owner-workspace-panel__body">
                    @if (PoiModerationItems.Count == 0)
                    {
                        <div class="owner-workspace-empty">
                            Chưa có yêu cầu kiểm duyệt cho POI này.
                        </div>
                    }
                    else
                    {
                        <div class="owner-workspace-activity-list">
                            @foreach (var item in PoiModerationItems)
                            {
                                <article class="owner-workspace-activity">
                                    <div class="owner-workspace-activity__title">
                                        <span class="owner-workspace-activity__dot"></span>
                                        <div>
                                            <h3>@GetModerationStatusLabel(item.Status)</h3>
                                            <p>@(item.ReviewNote ?? "Chưa có ghi chú phản hồi.")</p>
                                        </div>
                                    </div>
                                    <time>@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</time>
                                </article>
                            }
                        </div>
                    }
                </div>
            </article>
        </section>
    </div>

    <ConfirmDialog IsOpen="_isDeleteDialogOpen"
                   Eyebrow="POI"
                   Title="Xóa POI này?"
                   Message="@($"POI {_poi.Name} sẽ bị xóa khỏi workspace owner. Hành động này cần được xác nhận trước khi tiếp tục.")"
                   ConfirmText="Xóa POI"
                   CancelText="Giữ lại"
                   Tone="danger"
                   OnConfirm="DeletePoiAsync"
                   OnCancel="CloseDeleteDialog" />
}
