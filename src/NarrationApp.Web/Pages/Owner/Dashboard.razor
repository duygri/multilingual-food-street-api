@page "/owner/dashboard"
@attribute [Authorize(Roles = "poi_owner")]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IOwnerPortalService OwnerPortalService

<PageTitle>Dashboard chủ POI</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Owner</p>
        <h2>Đang tải dữ liệu POI...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Owner</p>
        <h2>Không thể tải bảng theo dõi POI</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack">
        <section class="owner-welcome-panel">
            <div class="owner-welcome-panel__copy">
                <p class="panel-shell__eyebrow">Owner operating overview</p>
                <h1>Chào @_ownerDisplayName</h1>
                <p>
                    Theo dõi nội dung đang phục vụ khách, việc cần gửi duyệt, và các tín hiệu mới nhất trong một màn tổng quan.
                </p>
            </div>

            <div class="owner-welcome-panel__counts" aria-label="Owner dashboard counts">
                <div>
                    <strong>@_dashboard.TotalPois</strong>
                    <span>@_dashboard.TotalPois POI đang quản lý</span>
                </div>
                <div>
                    <strong>@_dashboard.PendingReviewPois</strong>
                    <span>@_dashboard.PendingReviewPois chờ duyệt</span>
                </div>
                <div>
                    <strong>@_dashboard.UnreadNotifications</strong>
                    <span>@_dashboard.UnreadNotifications thông báo chưa đọc</span>
                </div>
            </div>
        </section>

        <section class="metric-grid">
            <MetricCard Label="POI quản lý" Value="@_dashboard.TotalPois.ToString()" Hint="Tổng tài nguyên" />
            <MetricCard Label="Đã xuất bản" Value="@_dashboard.PublishedPois.ToString()" Hint="Đang phục vụ" />
            <MetricCard Label="Nháp" Value="@_dashboard.DraftPois.ToString()" Hint="Đang biên tập" />
            <MetricCard Label="Chờ duyệt" Value="@_dashboard.PendingReviewPois.ToString()" Hint="Chờ admin phản hồi" />
            <MetricCard Label="Audio hiện có" Value="@_dashboard.TotalAudioAssets.ToString()" Hint="Kho audio" />
            <MetricCard Label="Cảnh báo chưa đọc" Value="@_dashboard.UnreadNotifications.ToString()" Hint="Notification center" />
        </section>

        <section class="owner-dashboard-grid">
            <div class="owner-dashboard-grid__main">
                <PanelShell Eyebrow="POI spotlight"
                            Title="Các điểm đang xuất bản"
                            BadgeLabel="@($"{_dashboard.PublishedPois} live")"
                            BadgeTone="StatusTone.Good">
                    @if (_spotlightPois.Count == 0)
                    {
                        <EmptyStateBlock Eyebrow="POI"
                                         Title="Chưa có điểm nổi bật"
                                         Message="Khi POI được xuất bản hoặc cập nhật, chúng sẽ xuất hiện ở đây để owner nhìn nhanh tình trạng vận hành." />
                    }
                    else
                    {
                        <div class="owner-spotlight-list">
                            @foreach (var poi in _spotlightPois)
                            {
                                <article class="owner-spotlight-card">
                                    <div class="owner-spotlight-card__header">
                                        <strong>@poi.Name</strong>
                                        <StatusBadge Label="@GetPoiStatusLabel(poi.Status)" Tone="@GetPoiStatusTone(poi.Status)" />
                                    </div>
                                    <p>@poi.Slug</p>
                                    <dl class="owner-spotlight-card__facts">
                                        <div>
                                            <dt>Geofence</dt>
                                            <dd>@GetGeofenceSummary(poi)</dd>
                                        </div>
                                        <div>
                                            <dt>Ngôn ngữ</dt>
                                            <dd>@GetTranslationSummary(poi)</dd>
                                        </div>
                                        <div>
                                            <dt>Narration</dt>
                                            <dd>
                                                <StatusBadge Label="@GetNarrationLabel(poi.NarrationMode)" Tone="@GetNarrationTone(poi.NarrationMode)" />
                                            </dd>
                                        </div>
                                    </dl>
                                    <div class="owner-spotlight-card__footer">
                                        <span>Priority @poi.Priority</span>
                                        <StatusBadge Label="@GetNarrationLabel(poi.NarrationMode)" Tone="@GetNarrationTone(poi.NarrationMode)" />
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </PanelShell>

                <PanelShell Eyebrow="Dòng hoạt động"
                            Title="Những tín hiệu mới nhất"
                            BadgeLabel="@($"{_activityItems.Count} cập nhật")"
                            BadgeTone="StatusTone.Info">
                    <div class="owner-activity-feed">
                        @foreach (var item in _activityItems)
                        {
                            <article class="owner-activity-feed__item">
                                <span class="owner-activity-feed__dot" aria-hidden="true"></span>
                                <div>
                                    <strong>@item.Title</strong>
                                    <p>@item.Description</p>
                                </div>
                                <StatusBadge Label="@item.Badge" Tone="@item.Tone" />
                            </article>
                        }
                    </div>
                </PanelShell>
            </div>

            <div class="owner-dashboard-grid__side">
                <SystemStatusRail Label="Trạng thái owner" Items="StatusItems" />

                <PanelShell Eyebrow="Moderation watch"
                            Title="Các việc cần theo dõi">
                    <div class="owner-watch-list">
                        <div class="owner-watch-row">
                            <div>
                                <strong>@_dashboard.PendingModerationRequests yêu cầu chờ xử lý</strong>
                                <p>Theo dõi queue moderation để biết khi nào admin phản hồi nội dung mới.</p>
                            </div>
                            <StatusBadge Label="@($"{_dashboard.PendingReviewPois} mục")" Tone="StatusTone.Warn" />
                        </div>

                        <div class="owner-watch-row">
                            <div>
                                <strong>@_dashboard.PendingReviewPois POI cần phản hồi kiểm duyệt</strong>
                                <p>Ưu tiên kiểm tra các POI đang chờ duyệt hoặc cần sửa trước khi xuất bản.</p>
                            </div>
                            <StatusBadge Label="@($"{_dashboard.PendingModerationRequests} chờ xử lý")" Tone="StatusTone.Warn" />
                        </div>

                        <div class="owner-watch-row">
                            <div>
                                <strong>Trung tâm thông báo</strong>
                                <p>@_dashboard.UnreadNotifications thông báo chưa đọc từ hệ thống vận hành và phản hồi admin.</p>
                            </div>
                            <StatusBadge Label="@($"{_dashboard.UnreadNotifications} chưa đọc")" Tone="StatusTone.Info" />
                        </div>

                        <div class="owner-watch-row">
                            <div>
                                <strong>Kho audio</strong>
                                <p>@_dashboard.TotalAudioAssets audio sẵn sàng cho narration và playback.</p>
                            </div>
                            <StatusBadge Label="@($"{_dashboard.TotalAudioAssets} tài sản")" Tone="StatusTone.Good" />
                        </div>

                        <NavLink class="app-button app-button--primary owner-watch-link" href="/owner/moderation">
                            Mở moderation
                        </NavLink>
                    </div>
                </PanelShell>
            </div>
        </section>
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _ownerDisplayName = "owner@narration.app";
    private OwnerDashboardDto _dashboard = new();
    private IReadOnlyList<PoiDto> _pois = Array.Empty<PoiDto>();
    private IReadOnlyList<PoiDto> _spotlightPois = Array.Empty<PoiDto>();
    private IReadOnlyList<ActivityItem> _activityItems = Array.Empty<ActivityItem>();

    private IReadOnlyList<SystemStatusItem> StatusItems =>
    [
        new() { Label = "Owner", Value = "Đồng bộ", Tone = StatusTone.Good },
        new() { Label = "Xuất bản", Value = $"{_dashboard.PublishedPois} POI", Tone = StatusTone.Good },
        new() { Label = "Chờ duyệt", Value = $"{_dashboard.PendingReviewPois} mục", Tone = _dashboard.PendingReviewPois > 0 ? StatusTone.Warn : StatusTone.Good },
        new() { Label = "Thông báo", Value = $"{_dashboard.UnreadNotifications} chưa đọc", Tone = _dashboard.UnreadNotifications > 0 ? StatusTone.Info : StatusTone.Good }
    ];

    private static string GetPoiStatusLabel(PoiStatus status) => status switch
    {
        PoiStatus.Published => "Đã xuất bản",
        PoiStatus.PendingReview => "Chờ duyệt",
        PoiStatus.Draft => "Nháp",
        PoiStatus.Rejected => "Bị từ chối",
        PoiStatus.Updated => "Đã cập nhật",
        PoiStatus.Archived => "Lưu trữ",
        _ => status.ToString()
    };

    private static StatusTone GetPoiStatusTone(PoiStatus status) => status switch
    {
        PoiStatus.Published => StatusTone.Good,
        PoiStatus.PendingReview => StatusTone.Warn,
        PoiStatus.Draft => StatusTone.Neutral,
        PoiStatus.Rejected => StatusTone.Warn,
        PoiStatus.Updated => StatusTone.Info,
        PoiStatus.Archived => StatusTone.Neutral,
        _ => StatusTone.Neutral
    };

    private static string GetNarrationLabel(NarrationMode mode) => mode switch
    {
        NarrationMode.TtsOnly => "Chỉ TTS",
        NarrationMode.RecordedOnly => "Chỉ audio nguồn",
        NarrationMode.Both => "Kết hợp",
        _ => mode.ToString()
    };

    private static StatusTone GetNarrationTone(NarrationMode mode) => mode switch
    {
        NarrationMode.Both => StatusTone.Good,
        NarrationMode.TtsOnly => StatusTone.Info,
        NarrationMode.RecordedOnly => StatusTone.Neutral,
        _ => StatusTone.Neutral
    };

    private static string GetGeofenceSummary(PoiDto poi) => $"{poi.Geofences.Count} vùng kích hoạt";

    private static string GetTranslationSummary(PoiDto poi) => $"{poi.Translations.Count} ngôn ngữ";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _ownerDisplayName = RouteHelper.GetDisplayName(authState.User);
            _dashboard = await OwnerPortalService.GetDashboardAsync();
            _pois = await OwnerPortalService.GetPoisAsync();
            _spotlightPois = BuildSpotlightPois(_pois);
            _activityItems = BuildActivityItems(_pois, _dashboard);
        }
        catch (ApiException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static IReadOnlyList<PoiDto> BuildSpotlightPois(IReadOnlyList<PoiDto> pois)
    {
        var published = pois
            .Where(poi => poi.Status == PoiStatus.Published)
            .OrderBy(poi => poi.Priority)
            .Take(3)
            .ToArray();

        return published.Length > 0
            ? published
            : pois.OrderBy(poi => poi.Priority).Take(3).ToArray();
    }

    private static IReadOnlyList<ActivityItem> BuildActivityItems(
        IReadOnlyList<PoiDto> pois,
        OwnerDashboardDto dashboard)
    {
        var items = new List<ActivityItem>();

        foreach (var poi in pois.OrderBy(poi => poi.Priority).Take(4))
        {
            items.Add(poi.Status switch
            {
                PoiStatus.Published => new ActivityItem(
                    $"{poi.Name} đang phục vụ khách",
                    $"{GetTranslationSummary(poi)} và {GetGeofenceSummary(poi)} đã sẵn sàng cho trải nghiệm tại chỗ.",
                    "Live",
                    StatusTone.Good),
                PoiStatus.PendingReview => new ActivityItem(
                    $"{poi.Name} đã gửi duyệt",
                    "Đang chờ admin kiểm tra nội dung, geofence và narration trước khi xuất bản.",
                    "Chờ duyệt",
                    StatusTone.Warn),
                PoiStatus.Rejected => new ActivityItem(
                    $"{poi.Name} cần sửa và gửi lại",
                    "Kiểm tra ghi chú phản hồi trước khi cập nhật nội dung POI.",
                    "Cần sửa",
                    StatusTone.Warn),
                PoiStatus.Draft => new ActivityItem(
                    $"{poi.Name} đang ở trạng thái nháp",
                    "Hoàn thiện mô tả, geofence và audio trước khi gửi duyệt.",
                    "Nháp",
                    StatusTone.Neutral),
                _ => new ActivityItem(
                    $"{poi.Name} đã cập nhật",
                    "Theo dõi lại trạng thái vận hành sau thay đổi mới nhất.",
                    GetPoiStatusLabel(poi.Status),
                    GetPoiStatusTone(poi.Status))
            });
        }

        items.Add(new ActivityItem(
            $"{dashboard.TotalAudioAssets} audio sẵn sàng",
            "Kho audio hiện có đang hỗ trợ các POI đã xuất bản và các bản nháp gần hoàn thiện.",
            "Audio",
            dashboard.TotalAudioAssets > 0 ? StatusTone.Info : StatusTone.Neutral));

        if (dashboard.UnreadNotifications > 0)
        {
            items.Add(new ActivityItem(
                $"{dashboard.UnreadNotifications} thông báo chưa đọc",
                "Mở notifications để xem phản hồi vận hành mới từ hệ thống.",
                "Unread",
                StatusTone.Info));
        }

        return items;
    }

    private sealed record ActivityItem(
        string Title,
        string Description,
        string Badge,
        StatusTone Tone);
}
