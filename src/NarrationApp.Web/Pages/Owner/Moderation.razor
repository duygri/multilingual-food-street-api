@page "/owner/moderation"
@attribute [Authorize(Roles = "poi_owner")]
@inject IOwnerPortalService OwnerPortalService

<PageTitle>Owner moderation</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Moderation</p>
        <h2>Đang tải trạng thái kiểm duyệt...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Moderation</p>
        <h2>Không thể tải moderation workspace</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="owner-workspace-page">
        <header class="owner-workspace-heading">
            <div>
                <div class="owner-workspace-breadcrumb">Owner / <strong>Trạng thái</strong> / Moderation</div>
                <h1>Trạng thái duyệt</h1>
                <p>Theo dõi queue moderation của owner, biết POI nào đang chờ admin và POI nào cần sửa để gửi lại.</p>
            </div>
        </header>

        <section class="owner-workspace-stats" aria-label="Moderation summary">
            <article class="panel-shell owner-workspace-stat owner-workspace-stat--pending">
                <div class="owner-workspace-stat__icon">REV</div>
                <p class="owner-workspace-stat__value">@_workspace.Summary.PendingCount</p>
                <p class="owner-workspace-stat__label">Đang chờ</p>
                <p class="owner-workspace-stat__hint">Các yêu cầu đang nằm trong hàng đợi</p>
            </article>

            <article class="panel-shell owner-workspace-stat owner-workspace-stat--published">
                <div class="owner-workspace-stat__icon">OK</div>
                <p class="owner-workspace-stat__value">@_workspace.Summary.ApprovedCount</p>
                <p class="owner-workspace-stat__label">Đã duyệt</p>
                <p class="owner-workspace-stat__hint">Các yêu cầu đã được admin duyệt</p>
            </article>

            <article class="panel-shell owner-workspace-stat">
                <div class="owner-workspace-stat__icon">FIX</div>
                <p class="owner-workspace-stat__value">@_workspace.Summary.RejectedCount</p>
                <p class="owner-workspace-stat__label">Bị từ chối</p>
                <p class="owner-workspace-stat__hint">Các yêu cầu cần owner chỉnh sửa</p>
            </article>
        </section>

        <article class="panel-shell owner-workspace-panel">
            <div class="owner-workspace-panel__header">
                <div class="owner-workspace-panel__title">
                    <div class="owner-workspace-stat__icon">FLOW</div>
                    <div>
                        <h2>Quy trình duyệt nội dung</h2>
                        <p>Ảnh chụp nhanh trạng thái pipeline moderation của workspace owner.</p>
                    </div>
                </div>
            </div>

            <div class="owner-workspace-panel__body">
                <div class="owner-workspace-flow">
                    <article class="owner-workspace-flow__step owner-workspace-flow__step--good">
                        <span class="owner-workspace-flow__dot">1</span>
                        <strong>Owner tạo / sửa POI</strong>
                        <p>@_workspace.FlowState.DraftCount mục đang ở trạng thái draft.</p>
                    </article>

                    <article class="owner-workspace-flow__step owner-workspace-flow__step--warn">
                        <span class="owner-workspace-flow__dot">2</span>
                        <strong>Gửi duyệt</strong>
                        <p>@_workspace.FlowState.PendingCount mục đang chờ admin xét duyệt.</p>
                    </article>

                    <article class="owner-workspace-flow__step owner-workspace-flow__step--danger">
                        <span class="owner-workspace-flow__dot">3</span>
                        <strong>Admin phản hồi</strong>
                        <p>@_workspace.FlowState.NeedsChangesCount mục cần owner chỉnh sửa.</p>
                    </article>

                    <article class="owner-workspace-flow__step owner-workspace-flow__step--info">
                        <span class="owner-workspace-flow__dot">4</span>
                        <strong>Xuất bản</strong>
                        <p>@_workspace.FlowState.ApprovedCount mục đã được duyệt.</p>
                    </article>
                </div>
            </div>
        </article>

        <article class="panel-shell owner-workspace-panel">
            <div class="owner-workspace-panel__header">
                <div class="owner-workspace-panel__title">
                    <div class="owner-workspace-stat__icon">PEND</div>
                    <div>
                        <h2>Yêu cầu đang chờ duyệt</h2>
                        <p>Các yêu cầu moderation active mà admin chưa xử lý.</p>
                    </div>
                </div>
            </div>

            <div class="owner-workspace-panel__body">
                @if (_workspace.PendingRows.Count == 0)
                {
                    <div class="owner-workspace-empty">
                        Chưa có yêu cầu đang chờ duyệt.
                    </div>
                }
                else
                {
                    <div class="owner-workspace-table-wrap">
                        <table class="owner-workspace-table" aria-label="Owner moderation pending table">
                            <thead>
                                <tr>
                                    <th>POI</th>
                                    <th>LOẠI YÊU CẦU</th>
                                    <th>GỬI LÚC</th>
                                    <th>CHỜ DUYỆT</th>
                                    <th>THAO TÁC</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _workspace.PendingRows)
                                {
                                    <tr>
                                        <td>
                                            <div class="owner-workspace-cell">
                                                <div class="owner-workspace-cell__avatar">POI</div>
                                                <div>
                                                    <p class="owner-workspace-cell__title">@row.PoiName</p>
                                                    <p class="owner-workspace-cell__sub">#@row.PoiId</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@row.RequestType</td>
                                        <td>@GetDateTimeLabel(row.SubmittedAtUtc)</td>
                                        <td>
                                            <span class="owner-workspace-badge owner-workspace-badge--warn">@row.WaitTimeLabel</span>
                                        </td>
                                        <td>
                                            <a class="app-button app-button--ghost" href="@GetPoiHref(row.PoiId)">@row.ActionLabel</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </article>

        <article class="panel-shell owner-workspace-panel">
            <div class="owner-workspace-panel__header">
                <div class="owner-workspace-panel__title">
                    <div class="owner-workspace-stat__icon">HIS</div>
                    <div>
                        <h2>Lịch sử duyệt</h2>
                        <p>Phản hồi moderation gần đây đã được admin xử lý.</p>
                    </div>
                </div>
            </div>

            <div class="owner-workspace-panel__body">
                <div class="owner-workspace-table-wrap">
                    <table class="owner-workspace-table" aria-label="Owner moderation history table">
                        <thead>
                            <tr>
                                <th>POI</th>
                                <th>LOẠI YÊU CẦU</th>
                                <th>GỬI LÚC</th>
                                <th>KẾT QUẢ</th>
                                <th>GHI CHÚ ADMIN</th>
                                <th>THAO TÁC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _workspace.HistoryRows)
                            {
                                <tr>
                                    <td>
                                        <div class="owner-workspace-cell">
                                            <div class="owner-workspace-cell__avatar">POI</div>
                                            <div>
                                                <p class="owner-workspace-cell__title">@row.PoiName</p>
                                                <p class="owner-workspace-cell__sub">#@row.PoiId</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@row.RequestType</td>
                                    <td>@GetDateTimeLabel(row.SubmittedAtUtc)</td>
                                    <td>
                                        <span class="@GetResultClass(row.Result)">@row.Result</span>
                                    </td>
                                    <td>@(row.AdminNote ?? "Chưa có ghi chú.")</td>
                                    <td>
                                        <a class="app-button app-button--ghost" href="@GetPoiHref(row.PoiId)">@row.ActionLabel</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </article>
    </div>
}
