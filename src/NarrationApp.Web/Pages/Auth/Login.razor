@page "/auth/login"
@attribute [AllowAnonymous]
@inject AuthClientService AuthClientService
@inject NavigationManager NavigationManager

<PageTitle>Đăng nhập</PageTitle>

<section class="auth-stage">
    <PageHeaderPanel Eyebrow="Truy cập hệ thống"
                  TitleLead="Điều phối vận hành"
                  TitleAccent="kiểm soát rõ."
                  Description="Đăng nhập vào portal để quản trị kiểm duyệt, POI, audio, bản dịch và toàn bộ luồng vận hành dành cho admin và owner."
                  Badges="HeroBadges"
                  PrimaryAction="RegisterAction" />

    <section class="auth-shell">
        <p class="auth-shell__eyebrow">Đăng nhập</p>
        <h2>Đăng nhập vào portal</h2>
        <p>Portal web chỉ dành cho admin và owner đã được duyệt. Tài khoản khách du lịch chỉ dùng trên ứng dụng di động.</p>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="auth-shell__success">@_statusMessage</div>
        }

        <EditForm class="auth-form" Model="_model" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="auth-form__field">
                <label for="email">Email</label>
                <InputText id="email" @bind-Value="_model.Email" />
            </div>

            <div class="auth-form__field">
                <label for="password">Mật khẩu</label>
                <InputText id="password" type="password" @bind-Value="_model.Password" />
            </div>

            <div class="auth-form__actions">
                <button class="app-button app-button--primary" type="submit" disabled="@_isSubmitting">Đăng nhập</button>
                <NavLink class="app-button app-button--ghost" href="/auth/register">Đăng ký owner</NavLink>
            </div>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="auth-shell__error">@_errorMessage</div>
        }
    </section>
</section>
