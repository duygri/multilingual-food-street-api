@page "/admin/dashboard"
@attribute [Authorize(Roles = "admin")]

@inject IAdminPortalService AdminPortalService
@inject ILanguagePortalService LanguagePortalService
@inject IQrPortalService QrPortalService

<PageTitle>Dashboard</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Admin</p>
        <h2>Đang tải dashboard...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Admin</p>
        <h2>Không thể tải dashboard</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack dashboard-surface">
        <section class="metric-grid dashboard-surface__metrics">
            <MetricCard Label="Tổng POI" Value="@_overview.TotalPois.ToString("N0")" Hint="@($"{_overview.PublishedPois:N0} đang xuất bản")" />
            <MetricCard Label="Audio Files" Value="@_overview.TotalAudioAssets.ToString("N0")" Hint="Kho audio đa ngôn ngữ" />
            <MetricCard Label="Ngôn ngữ" Value="@DistinctLanguageCount.ToString("N0")" Hint="@GetLanguageHint()" />
            <MetricCard Label="Lượt trigger / tháng" Value="@_analyticsSnapshot.CurrentMonthGeofenceTriggers.ToString("N0")" Hint="@CurrentMonthTriggerHint" />
            <MetricCard Label="Tour đã xuất bản" Value="@PublishedToursCount.ToString("N0")" Hint="@($"{_overview.TotalTours:N0} tour tổng")" />
            <MetricCard Label="QR Codes hoạt động" Value="@_qrItems.Count.ToString("N0")" Hint="POI và mở app" />
            <MetricCard Label="Thiết bị visitor" Value="@_visitorDevices.Count.ToString("N0")" Hint="@($"{OnlineVisitorCount:N0} đang online")" />
            <MetricCard Label="Chờ duyệt" Value="@_pendingModeration.Count.ToString("N0")" Hint="@($"{_overview.UnreadNotifications:N0} thông báo chưa đọc")" />
        </section>

        <section class="dashboard-surface__tables">
            <section class="panel-shell dashboard-table-card">
                <div class="sample-surface__header">
                    <div>
                        <p class="panel-shell__eyebrow">🥇 Nghe nhiều</p>
                        <h2>Top POI được nghe nhiều nhất</h2>
                    </div>
                    <a class="app-button app-button--ghost" href="/admin/analytics">Xem tất cả</a>
                </div>

                @if (RankedTopPois.Count == 0)
                {
                    <EmptyStateBlock Eyebrow="Dashboard"
                                     Title="Chưa có dữ liệu nghe"
                                     Message="Hệ thống chưa ghi nhận lượt nghe audio để xếp hạng POI." />
                }
                else
                {
                    <div class="table-wrap">
                        <table class="app-table dashboard-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>POI</th>
                                    <th>Lượt nghe</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var poi in RankedTopPois)
                                {
                                    <tr>
                                        <td>@poi.Rank</td>
                                        <td>
                                            <div class="dashboard-poi-cell">
                                                <strong>@poi.Item.PoiName</strong>
                                            </div>
                                        </td>
                                        <td>@poi.Item.Visits.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            <section class="panel-shell dashboard-table-card">
                <div class="sample-surface__header">
                    <div>
                        <p class="panel-shell__eyebrow">⏳ Điều phối</p>
                        <h2>Moderation Queue gần đây</h2>
                    </div>
                    <a class="app-button app-button--ghost" href="/admin/moderation-queue">Xem tất cả</a>
                </div>

                @if (_pendingModeration.Count == 0)
                {
                    <EmptyStateBlock Eyebrow="Moderation"
                                     Title="Không còn yêu cầu chờ duyệt"
                                     Message="Hàng chờ moderation hiện đang sạch." />
                }
                else
                {
                    <div class="table-wrap">
                        <table class="app-table dashboard-table">
                            <thead>
                                <tr>
                                    <th>POI</th>
                                    <th>Owner</th>
                                    <th>Loại</th>
                                    <th>Thời gian</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in RankedModeration)
                                {
                                    <tr>
                                        <td>@GetModerationEntityTitle(item.Item)</td>
                                        <td>@GetModerationOwnerLabel(item.Item, item.Index)</td>
                                        <td><StatusBadge Label="@GetModerationKind(item.Item)" Tone="StatusTone.Info" /></td>
                                        <td>@GetElapsedLabel(item.Item.CreatedAtUtc)</td>
                                        <td><StatusBadge Label="Pending" Tone="StatusTone.Warn" /></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </section>
    </div>
}
