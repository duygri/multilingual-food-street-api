@page "/admin/tour-management"
@attribute [Authorize(Roles = "admin")]
@using System.Linq

@inject ITourPortalService TourPortalService

<PageTitle>Tour Management</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Admin</p>
        <h2>Đang tải Tour Management...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Admin</p>
        <h2>Không thể tải Tour Management</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack tour-surface">
        <section class="sample-page-title">
            <h1>Tour Management</h1>
            <p>Admin / Quản lý nội dung &gt; Tour</p>
        </section>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <section class="panel-shell">
                <p class="panel-shell__copy">@_statusMessage</p>
            </section>
        }

        <section class="metric-grid tour-surface__metrics">
            <MetricCard Label="Tour xuất bản" Value="@_tours.Count(item => item.Status == TourStatus.Published).ToString("N0")" Hint="Đang hiển thị cho khách" />
            <MetricCard Label="Draft" Value="@_tours.Count(item => item.Status == TourStatus.Draft).ToString("N0")" Hint="Đang biên tập" />
            <MetricCard Label="Lượt tham gia" Value="@TotalParticipationEstimate.ToString("N0")" Hint="Ước lượng từ các tuyến đang có" />
            <MetricCard Label="TB thời gian tour" Value="@AverageDurationLabel" Hint="Thời lượng hành trình" />
        </section>

        <section class="panel-shell tour-table-shell">
            <div class="sample-surface__header">
                <div>
                    <p class="panel-shell__eyebrow">🗺️ Tour</p>
                    <h2>Quản lý Tour</h2>
                </div>
                <button class="app-button app-button--primary" data-action="new-tour" type="button" @onclick="BeginCreateTour">
                    + Tạo Tour mới
                </button>
            </div>

            @if (_tours.Count == 0)
            {
                <EmptyStateBlock Eyebrow="Tour"
                                 Title="Chưa có tour nào"
                                 Message="Hãy tạo tuyến đầu tiên để bắt đầu điều phối hành trình." />
            }
            else
            {
                <div class="table-wrap">
                    <table class="app-table tour-table">
                        <thead>
                            <tr>
                                <th>Tour</th>
                                <th>Số điểm dừng</th>
                                <th>Ước lượng</th>
                                <th>Lượt tham gia</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tour in _tours)
                            {
                                <tr class="@GetRowClass(tour)">
                                    <td>
                                        <div class="tour-cell">
                                            <strong>@tour.Title</strong>
                                            <span>@tour.Description</span>
                                        </div>
                                    </td>
                                    <td>@tour.Stops.Count POIs</td>
                                    <td>@tour.EstimatedMinutes phút</td>
                                    <td>@GetParticipationEstimate(tour)</td>
                                    <td>
                                        <StatusBadge Label="@GetTourStatusLabel(tour.Status)" Tone="@GetTourStatusTone(tour.Status)" />
                                    </td>
                                    <td>
                                        <div class="table-actions">
                                            <button class="app-button app-button--ghost"
                                                    data-action="edit-tour-@tour.Id"
                                                    type="button"
                                                    @onclick="() => SelectTour(tour)">
                                                Sửa
                                            </button>

                                            @if (tour.Status == TourStatus.Draft)
                                            {
                                                <button class="app-button app-button--primary"
                                                        data-action="publish-tour-@tour.Id"
                                                        type="button"
                                                        @onclick="() => QuickPublishAsync(tour)">
                                                    Xuất bản
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        @if (_showEditor)
        {
            <div class="admin-overlay-backdrop" @onclick="CloseEditor">
                <section class="panel-shell admin-overlay-shell admin-overlay-shell--wide tour-editor-shell"
                         data-panel="tour-editor"
                         @onclick:stopPropagation="true">
                    <div class="admin-overlay-shell__header">
                        <div>
                            <p class="panel-shell__eyebrow">✏️ Trình biên tập</p>
                            <h2>@(_isCreateMode ? "Tạo Tour mới" : _selectedTour?.Title ?? "Biên tập Tour")</h2>
                        </div>
                        <div class="sample-surface__header-actions">
                            @if (!_isCreateMode && _selectedTour is not null)
                            {
                                <StatusBadge Label="@GetTourStatusLabel(_editor.Status)" Tone="@GetTourStatusTone(_editor.Status)" />
                            }
                            <button class="app-button app-button--ghost" type="button" @onclick="CloseEditor">
                                Đóng
                            </button>
                        </div>
                    </div>

                    <div class="editor-grid">
                        <div class="editor-field">
                            <label for="tour-title">Tên tour</label>
                            <InputText id="tour-title" data-field="tour-title" @bind-Value="_editor.Title" />
                        </div>

                        <div class="editor-field">
                            <label for="tour-minutes">Số phút dự kiến</label>
                            <InputNumber id="tour-minutes" data-field="tour-minutes" @bind-Value="_editor.EstimatedMinutes" />
                        </div>

                        @if (!_isCreateMode)
                        {
                            <div class="editor-field">
                                <label for="tour-status">Trạng thái</label>
                                <InputSelect id="tour-status" data-field="tour-status" @bind-Value="_editor.Status">
                                    @foreach (var status in _tourStatuses)
                                    {
                                        <option value="@status">@GetTourStatusLabel(status)</option>
                                    }
                                </InputSelect>
                            </div>
                        }

                        <div class="editor-field editor-field--full">
                            <label for="tour-description">Mô tả</label>
                            <InputTextArea id="tour-description" data-field="tour-description" @bind-Value="_editor.Description" />
                        </div>

                        <div class="editor-field editor-field--full">
                            <label for="tour-cover-image">Ảnh bìa</label>
                            <InputText id="tour-cover-image" data-field="tour-cover-image" @bind-Value="_editor.CoverImage" />
                        </div>
                    </div>

                    <div class="sample-surface__header sample-surface__header--compact">
                        <div>
                            <p class="panel-shell__eyebrow">📍 Điểm dừng</p>
                            <h2>Thứ tự điểm dừng</h2>
                        </div>

                        <button class="app-button app-button--ghost" data-action="add-stop" type="button" @onclick="AddStop" disabled="@(_poiOptions.Count == 0)">
                            Thêm điểm dừng
                        </button>
                    </div>

                    @if (_poiOptions.Count == 0)
                    {
                        <p class="panel-shell__copy">Không có POI xuất bản để thêm vào tour.</p>
                    }
                    else
                    {
                        <div class="stop-stack">
                            @foreach (var stop in _editor.Stops.Select((item, index) => new { item, index }))
                            {
                                var token = stop.index + 1;
                                <article class="stop-editor">
                                    <div class="stop-editor__header">
                                        <strong>Điểm dừng @token</strong>
                                        @if (_editor.Stops.Count > 1)
                                        {
                                            <button class="app-button app-button--ghost"
                                                    data-action="remove-stop-@token"
                                                    type="button"
                                                    @onclick="() => RemoveStop(stop.index)">
                                                Xóa
                                            </button>
                                        }
                                    </div>

                                    <div class="editor-grid editor-grid--compact">
                                        <div class="editor-field">
                                            <label for="stop-poi-@token">POI</label>
                                            <select id="stop-poi-@token"
                                                    class="editor-select"
                                                    data-field="stop-poi-@token"
                                                    value="@stop.item.PoiId.ToString()"
                                                    @onchange="args => UpdateStopPoi(stop.index, args.Value?.ToString())">
                                                @foreach (var poi in _poiOptions)
                                                {
                                                    <option value="@poi.Id">@poi.Name</option>
                                                }
                                            </select>
                                        </div>

                                        <div class="editor-field">
                                            <label for="stop-radius-@token">Bán kính kích hoạt (m)</label>
                                            <input id="stop-radius-@token"
                                                   type="number"
                                                   class="editor-select"
                                                   data-field="stop-radius-@token"
                                                   value="@stop.item.RadiusMeters"
                                                   @onchange="args => UpdateStopRadius(stop.index, args.Value?.ToString())" />
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }

                    <div class="action-row">
                        <button class="app-button app-button--primary" data-action="save-tour" type="button" @onclick="SaveTourAsync">
                            @(_isCreateMode ? "Tạo tour" : "Lưu thay đổi")
                        </button>

                        @if (!_isCreateMode && _selectedTour is not null)
                        {
                            <button class="app-button app-button--ghost" data-action="delete-tour" type="button" @onclick="DeleteTourAsync">
                                Xóa tour
                            </button>
                        }
                    </div>
                </section>
            </div>
        }
    </div>
}
