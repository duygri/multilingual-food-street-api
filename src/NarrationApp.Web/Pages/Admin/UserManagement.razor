@page "/admin/user-management"
@page "/admin/visitor-devices"
@attribute [Authorize(Roles = "admin")]

@inject IAdminPortalService AdminPortalService

<PageTitle>Thiết bị visitor</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Admin</p>
        <h2>Đang tải thiết bị visitor...</h2>
    </section>
}
else
{
    <div class="visitor-page">
        <section class="visitor-page__hero">
            <div>
                <h1>Thiết bị visitor</h1>
                <p>Chỉ hiển thị những thiết bị visitor đang online gần realtime.</p>
                <p class="visitor-page__note">Danh sách bên dưới tự làm mới mỗi 5 giây và ưu tiên hiển thị mã thiết bị thật.</p>
            </div>

            <button class="visitor-page__refresh"
                    data-action="refresh-visitor-data"
                    type="button"
                    disabled="@_isRefreshing"
                    @onclick="RefreshAsync">
                @(_isRefreshing ? "Đang làm mới..." : "Làm mới dữ liệu")
            </button>
        </section>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <section class="visitor-page__error">
                <strong>Không thể tải thiết bị visitor.</strong>
                <span>@_errorMessage</span>
            </section>
        }

        <section class="visitor-page__metric-grid">
            <article class="visitor-page__metric-card">
                <span class="visitor-page__metric-label">Đang online</span>
                <strong class="visitor-page__metric-value visitor-page__metric-value--positive">@ActiveVisitorCount.ToString("N0")</strong>
                <span class="visitor-page__metric-copy">Các thiết bị đang còn tín hiệu hoạt động ở thời điểm hiện tại.</span>
            </article>
        </section>

        <section class="visitor-page__table-shell">
            @if (OnlineVisitors.Count == 0)
            {
                <div class="visitor-page__empty">
                    <strong>Chưa có visitor online</strong>
                    <span>Khi có thiết bị đang hoạt động, danh sách online sẽ xuất hiện tại đây.</span>
                </div>
            }
            else
            {
                <div class="visitor-page__table-wrap">
                    <table class="visitor-page__table">
                        <thead>
                            <tr>
                                <th>Thiết bị</th>
                                <th>Trạng thái</th>
                                <th>Ngôn ngữ</th>
                                <th>Lần cuối</th>
                                <th>Tracking</th>
                                <th>Visit</th>
                                <th>Trigger</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var visitor in OnlineVisitors)
                            {
                                <tr data-visitor-id="@visitor.Id">
                                    <td>
                                        <div class="visitor-page__identity">
                                            <strong>@GetPrimaryIdentityLine(visitor)</strong>
                                            @if (!string.IsNullOrWhiteSpace(GetSecondaryIdentityLine(visitor)))
                                            {
                                                <span>@GetSecondaryIdentityLine(visitor)</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="visitor-page__status @(visitor.IsOnline ? "is-online" : "is-offline")">
                                            @(visitor.IsOnline ? "Online" : "Offline")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="visitor-page__language">@GetLanguageLabel(visitor.PreferredLanguage)</span>
                                    </td>
                                    <td>
                                        <div class="visitor-page__last-seen">
                                            <span>@GetLastSeenAbsolute(visitor.LastSeenAtUtc)</span>
                                            <small>@GetLastSeenRelative(visitor.LastSeenAtUtc)</small>
                                        </div>
                                    </td>
                                    <td>@visitor.TrackingCount.ToString("N0")</td>
                                    <td>@visitor.VisitCount.ToString("N0")</td>
                                    <td>@visitor.TriggerCount.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
}
