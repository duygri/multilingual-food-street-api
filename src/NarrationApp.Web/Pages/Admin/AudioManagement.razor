@page "/admin/audio-management"
@attribute [Authorize(Roles = "admin")]

@inject IAdminPortalService AdminPortalService
@inject IAudioPortalService AudioPortalService
@inject ITranslationPortalService TranslationPortalService
@inject ILanguagePortalService LanguagePortalService
@inject IAudioRefreshPump AudioRefreshPump

<PageTitle>Audio Management</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Audio</p>
        <h2>Đang tải điều phối audio...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Audio</p>
        <h2>Không thể tải điều phối audio</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack audio-admin">
        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <section class="panel-shell">
                <p class="panel-shell__copy">@_statusMessage</p>
            </section>
        }

        <section class="panel-shell audio-command">
            <div class="audio-command__header">
                <div class="audio-command__copy">
                    <p class="panel-shell__eyebrow">Google stack audio room</p>
                    <h1>Audio Management</h1>
                    <p class="panel-shell__copy">Quản lý audio nguồn tiếng Việt và generate đa ngôn ngữ cho từng POI.</p>
                    @if (HasProcessingAudio)
                    {
                        <p class="audio-command__polling">Tự động cập nhật khi audio đang được tạo nền.</p>
                    }
                </div>

                <div class="audio-command__actions">
                    <button class="app-button app-button--ghost"
                            data-action="retry-all-failed-audio"
                            data-failed-pois="@FilteredFailedPoiCount"
                            type="button"
                            @onclick="RetryAllFailedAudioAsync"
                            disabled="@(FilteredFailedPoiCount == 0)">
                        Retry tất cả lỗi
                    </button>
                    <button class="app-button app-button--ghost"
                            data-action="open-batch-generate"
                            type="button"
                            @onclick="() => OpenGenerateModal()"
                            disabled="@(!HasAnyPoi)">
                        Batch Generate
                    </button>
                </div>
            </div>

            <div class="audio-kpi-grid">
                <article class="audio-kpi-card audio-kpi-card--good">
                    <strong>@ReadyAudioCount</strong>
                    <h2>Audio sẵn sàng</h2>
                    <p>ready / toàn hệ thống</p>
                    <div class="audio-kpi-card__progress">
                        <span style="width:@FormatPercent(GetAssetRatio(ReadyAudioCount), 0.32d)"></span>
                    </div>
                </article>

                <article class="audio-kpi-card audio-kpi-card--warn">
                    <strong>@ProcessingAudioCount</strong>
                    <h2>Đang xử lý</h2>
                    <p>generating / pending</p>
                    <div class="audio-kpi-card__progress">
                        <span style="width:@FormatPercent(GetAssetRatio(ProcessingAudioCount), 0.18d)"></span>
                    </div>
                </article>

                <article class="audio-kpi-card audio-kpi-card--danger">
                    <strong>@FailedAudioCount</strong>
                    <h2>Lỗi generate</h2>
                    <p>cần retry thủ công</p>
                    <div class="audio-kpi-card__progress">
                        <span style="width:@FormatPercent(GetAssetRatio(FailedAudioCount), 0.12d)"></span>
                    </div>
                </article>

                <article class="audio-kpi-card audio-kpi-card--info">
                    <strong>@TotalAudioCount</strong>
                    <h2>Tổng audio assets</h2>
                    <p>@DistinctLanguageCount ngôn ngữ × @_pois.Count POI</p>
                    <div class="audio-kpi-card__progress">
                        <span style="width:@FormatPercent(GetCoverageRatio(), 0.22d)"></span>
                    </div>
                </article>
            </div>
        </section>

        <section class="panel-shell audio-table">
            <div class="audio-table__header">
                <div>
                    <h2>Danh sách Audio Assets</h2>
                    <p>@FilteredPois.Count POI · @PoisWithVietnameseSourceCount có audio nguồn tiếng Việt</p>
                </div>
            </div>

            <div class="audio-table__controls">
                <label class="audio-toolbar__search">
                    <span>🔎</span>
                    <InputText data-field="search-audio"
                               @bind-Value="_searchTerm"
                               placeholder="Tìm theo tên POI..." />
                </label>

                <div class="audio-toolbar__filters">
                    <InputSelect class="audio-toolbar__select" data-field="status-filter" @bind-Value="_statusFilter">
                        <option value="all">Tất cả trạng thái</option>
                        <option value="ready">Audio sẵn sàng</option>
                        <option value="processing">Đang xử lý</option>
                        <option value="failed">Lỗi generate</option>
                        <option value="missing">Chưa có audio</option>
                    </InputSelect>

                    <InputSelect class="audio-toolbar__select" data-field="source-filter" @bind-Value="_sourceFilter">
                        <option value="all">Tất cả nguồn</option>
                        <option value="recorded">Upload audio</option>
                        <option value="tts">Google TTS</option>
                        <option value="missing">Chưa có nguồn VI</option>
                    </InputSelect>

                    <InputSelect class="audio-toolbar__select" data-field="category-filter" @bind-Value="_categoryFilter">
                        <option value="all">Tất cả danh mục</option>
                        @foreach (var category in CategoryOptions)
                        {
                            <option value="@category">@category</option>
                        }
                    </InputSelect>

                    <button class="app-button app-button--ghost" data-action="reset-filters" type="button" @onclick="ResetFilters">
                        Reset
                    </button>
                </div>
            </div>

            @if (_pois.Count == 0)
            {
                <EmptyStateBlock Eyebrow="Audio"
                                 Title="Chưa có POI nào"
                                 Message="Khi owner tạo POI và gửi duyệt, admin có thể vào đây để chuẩn bị audio nguồn và audio đa ngôn ngữ." />
            }
            else if (FilteredPois.Count == 0)
            {
                <EmptyStateBlock Eyebrow="Bộ lọc"
                                 Title="Không có dòng nào khớp"
                                 Message="Hãy nới bộ lọc hoặc xóa từ khóa tìm kiếm để xem lại toàn bộ audio asset." />
            }
            else
            {
                <div class="audio-table__scroller">
                    <table class="audio-table__grid">
                        <thead>
                            <tr>
                                <th>POI</th>
                                <th>Nguồn (VI)</th>
                                <th>Trạng thái</th>
                                <th>Ngôn ngữ</th>
                                <th>Nghe thử</th>
                                <th>Cập nhật</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var poi in FilteredPois)
                            {
                                var items = GetAudioItems(poi.Id);
                                var previewAudio = GetPreviewAudio(poi.Id, items);
                                var latestAudio = GetLatestAudio(items);
                                var sourceAudio = GetVietnameseSource(items);
                                var status = GetOverallAudioStatus(items);
                                var failedLanguageCodes = GetFailedLanguageCodes(items);

                                <tr class="@GetRowClass(poi)"
                                    data-row-poi="@poi.Id"
                                    @onclick="() => SelectPoi(poi)">
                                    <td>
                                        <div class="audio-table__poi">
                                            <strong>@poi.Name</strong>
                                            <p>ID: @poi.Slug · @(poi.CategoryName ?? poi.OwnerEmail)</p>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="audio-tag @GetSourceTagClass(sourceAudio)">
                                            @GetSourceTagLabel(sourceAudio)
                                        </span>
                                    </td>
                                    <td>
                                        <div class="audio-table__status">
                                            <span class="audio-tag @GetStatusTagClass(status)">
                                                @GetStatusLabel(status)
                                            </span>
                                            @if (failedLanguageCodes.Count > 0)
                                            {
                                                <small class="audio-table__muted">Lỗi: @string.Join(", ", failedLanguageCodes)</small>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="audio-language-chips">
                                            @foreach (var language in ActiveLanguageOptions)
                                            {
                                                <button class="audio-language-chip @GetLanguageChipClass(poi.Id, items, language.Code)"
                                                        data-action="select-preview-language-@poi.Id-@language.Code"
                                                        type="button"
                                                        disabled="@(!CanPreviewLanguage(items, language.Code))"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => SelectPreviewLanguage(poi.Id, language.Code)">
                                                    @language.Code
                                                </button>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        @if (previewAudio is null)
                                        {
                                            <span class="audio-table__muted">Chưa có file nghe thử</span>
                                        }
                                        else
                                        {
                                            <div class="audio-preview-stack">
                                                <button class="audio-preview"
                                                        data-action="toggle-preview-audio-@previewAudio.Id"
                                                        type="button"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => ToggleInlinePreview(previewAudio)">
                                                    <span class="audio-preview__play">@(IsPreviewingAudio(previewAudio) ? "❚❚" : "▶")</span>
                                                    <span class="audio-preview__wave">
                                                        <span></span>
                                                    </span>
                                                    <span class="audio-preview__time">@FormatDuration(previewAudio.DurationSeconds)</span>
                                                </button>
                                                @if (IsPreviewingAudio(previewAudio))
                                                {
                                                    <audio class="audio-preview__player"
                                                           data-role="inline-preview-audio-@previewAudio.Id"
                                                           src="@previewAudio.Url"
                                                           controls
                                                           autoplay
                                                           preload="metadata"
                                                           @onclick:stopPropagation="true"></audio>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <span class="audio-table__muted">@GetRelativeTimeLabel(latestAudio?.GeneratedAtUtc ?? poi.CreatedAtUtc)</span>
                                    </td>
                                    <td>
                                        <div class="audio-row-actions">
                                            <button class="audio-row-button audio-row-button--accent"
                                                    data-action="row-open-generate-@poi.Id"
                                                    title="Generate audio"
                                                    type="button"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => OpenGenerateModal(poi)">
                                                Generate
                                            </button>
                                            <button class="audio-row-button"
                                                    data-action="row-open-upload-@poi.Id"
                                                    title="Upload audio"
                                                    type="button"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => OpenUploadModal(poi)">
                                                Upload
                                            </button>
                                            <button class="audio-row-button audio-row-button--ghost"
                                                    data-action="row-refresh-poi-@poi.Id"
                                                    title="Refresh row"
                                                    type="button"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => RefreshPoiAudioAsync(poi)">
                                                Refresh
                                            </button>
                                            @if (failedLanguageCodes.Count > 0)
                                            {
                                                <button class="audio-row-button audio-row-button--danger"
                                                        data-action="row-retry-failed-@poi.Id"
                                                        title="Retry failed audio"
                                                        type="button"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => RetryFailedAudioAsync(poi)">
                                                    Retry lỗi
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
}

@if (_isGenerateModalOpen && _modalPoi is not null)
{
    <div class="audio-modal-backdrop" @onclick="CloseGenerateModal">
        <section class="audio-modal" role="dialog" aria-label="Generate Audio Đa Ngôn Ngữ" @onclick:stopPropagation="true">
            <div class="audio-modal__header">
                <div>
                    <p class="panel-shell__eyebrow">⚡ Generate</p>
                    <h2>Generate Audio Đa Ngôn Ngữ</h2>
                </div>

                <button class="audio-modal__close" data-action="close-generate-modal" type="button" @onclick="CloseGenerateModal">×</button>
            </div>

            <article class="audio-modal__poi-card">
                <strong>@_modalPoi.Name</strong>
                <p>ID: @_modalPoi.Slug · @(_modalPoi.CategoryName ?? _modalPoi.OwnerEmail)</p>
            </article>

            <article class="audio-modal__banner">
                <p>
                    Hệ thống dùng <strong>Google Cloud TTS</strong> để tạo audio. Với các ngôn ngữ ngoài tiếng Việt,
                    audio chỉ được generate khi POI đã có bản dịch lưu sẵn.
                </p>
            </article>

            <div class="audio-modal__section">
                <p class="panel-shell__eyebrow">Chọn ngôn ngữ</p>
                <div class="audio-language-grid">
                    @foreach (var language in GenerateLanguageOptions)
                    {
                        <label class="audio-language-option @(_selectedLanguages.Contains(language.Code) ? "is-selected" : string.Empty)">
                            <input type="checkbox"
                                   data-field="language-@language.Code"
                                   checked="@_selectedLanguages.Contains(language.Code)"
                                   @onchange="args => ToggleLanguage(language.Code, args.Value)" />
                            <span>@language.Flag @language.Code</span>
                        </label>
                    }
                </div>
                @if (GenerateLanguageOptions.Count == 0)
                {
                    <p class="panel-shell__copy">Không còn ngôn ngữ nào cần generate: các ngôn ngữ đã có audio hoặc chưa có bản dịch sẽ không hiện ở đây.</p>
                }
            </div>

            <div class="audio-modal__section">
                <label class="editor-field" for="voice-profile">
                    <span>Giọng đọc (mỗi ngôn ngữ)</span>
                    <InputSelect id="voice-profile" class="audio-modal__select" data-field="voice-profile" @bind-Value="_selectedVoiceProfile">
                        @foreach (var profile in VoiceProfiles)
                        {
                            <option value="@profile.Value">@profile.Label</option>
                        }
                    </InputSelect>
                </label>
            </div>

            <div class="audio-modal__actions">
                <button class="app-button app-button--ghost" type="button" @onclick="CloseGenerateModal">Đóng</button>
                <button class="app-button app-button--primary"
                        data-action="generate-selected-audio"
                        type="button"
                        disabled="@(_isGenerating || _selectedLanguages.Count == 0)"
                        @onclick="GenerateSelectedAudioAsync">
                    @(_isGenerating ? "Đang generate..." : $"Generate {_selectedLanguages.Count} ngôn ngữ")
                </button>
            </div>
        </section>
    </div>
}

@if (_isUploadModalOpen && _uploadPoi is not null)
{
    <div class="audio-modal-backdrop" @onclick="CloseUploadModal">
        <section class="audio-modal audio-modal--compact" role="dialog" aria-label="Upload Audio" @onclick:stopPropagation="true">
            <div class="audio-modal__header">
                <div>
                    <p class="panel-shell__eyebrow">↑ Upload</p>
                    <h2>Tải audio nguồn tiếng Việt</h2>
                </div>

                <button class="audio-modal__close" data-action="close-upload-modal" type="button" @onclick="CloseUploadModal">×</button>
            </div>

            <article class="audio-modal__poi-card">
                <strong>@_uploadPoi.Name</strong>
                <p>Tải file nguồn VI để ưu tiên phát audio gốc trước khi generate thêm ngôn ngữ.</p>
            </article>

            <label class="editor-field audio-upload-field" for="audio-upload-file">
                <span>Chọn file MP3/WAV</span>
                <InputFile id="audio-upload-file" OnChange="HandleUploadSelection" />
            </label>

            @if (_selectedUploadFile is not null)
            {
                <p class="panel-shell__copy">Đã chọn: @_selectedUploadFile.Name</p>
            }

            <div class="audio-modal__actions">
                <button class="app-button app-button--ghost" type="button" @onclick="CloseUploadModal">Đóng</button>
                <button class="app-button app-button--primary"
                        data-action="upload-selected-audio"
                        type="button"
                        disabled="@(_isUploading || _selectedUploadFile is null)"
                        @onclick="UploadSelectedAudioAsync">
                    @(_isUploading ? "Đang tải..." : "Upload Audio")
                </button>
            </div>
        </section>
    </div>
}
