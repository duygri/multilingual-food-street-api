@page "/admin/analytics"
@attribute [Authorize(Roles = "admin")]

@using NarrationApp.Web.Configuration
@using NarrationApp.Shared.Enums
@using Microsoft.JSInterop
@inject IAdminPortalService AdminPortalService
@inject IJSRuntime JsRuntime
@inject AnalyticsMapOptions MapOptions

<PageTitle>Analytics Dashboard</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Analytics</p>
        <h2>Đang tải analytics dashboard...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Analytics</p>
        <h2>Không thể tải analytics dashboard</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack analytics-dashboard">
        <section class="metric-grid">
            <MetricCard Label="Geofence triggers" Value="@_snapshot.GeofenceTriggers.ToString("N0")" Hint="@($"{_overview.TotalPois:N0} POI đang được theo dõi")" />
            <MetricCard Label="Audio plays" Value="@_snapshot.AudioPlays.ToString("N0")" Hint="@($"{_overview.PublishedPois:N0} POI đã xuất bản")" />
            <MetricCard Label="QR scans" Value="@_snapshot.QrScans.ToString("N0")" Hint="@($"{_overview.TotalTours:N0} tour đang hoạt động")" />
            <MetricCard Label="TB thời gian nghe" Value="@FormatDurationShort(_snapshot.AverageListenDurationSeconds)" Hint="@($"{_averageListenByPoi.Count:N0} POI có đủ dữ liệu nghe")" />
        </section>

        <section class="analytics-map-grid">
            <PanelShell Eyebrow="Bản đồ tín hiệu"
                        Title="Heatmap vị trí người dùng"
                        Description="Heatmap Mapbox từ unique session đã snap grid 50m, clamp 50 và Gaussian smoothing."
                        BadgeLabel="@($"{_heatmap.Count:N0} điểm")"
                        BadgeTone="StatusTone.Info">
                <HeaderActions>
                    <div class="analytics-filter-toolbar">
                        @foreach (var option in HeatmapEventTypeOptions)
                        {
                            <button type="button"
                                    class="analytics-filter-chip @(Equals(option.EventType, _selectedHeatmapEventType) ? "is-active" : null)"
                                    data-heatmap-event="@option.Key"
                                    disabled="@_isHeatmapLoading"
                                    @onclick="() => ChangeHeatmapEventTypeAsync(option.EventType)">
                                @option.Label
                            </button>
                        }

                        @foreach (var option in HeatmapRangeOptions)
                        {
                            <button type="button"
                                    class="analytics-filter-chip @(option.Range == _selectedHeatmapTimeRange ? "is-active" : null)"
                                    data-heatmap-range="@option.Range"
                                    disabled="@_isHeatmapLoading"
                                    @onclick="() => ChangeHeatmapTimeRangeAsync(option.Range)">
                                @option.Label
                            </button>
                        }

                        <button type="button"
                                class="analytics-filter-chip analytics-filter-chip--decay @(_useHeatmapDecay ? "is-active" : null)"
                                data-heatmap-decay="@_useHeatmapDecay"
                                disabled="@_isHeatmapLoading"
                                @onclick="ToggleHeatmapDecayAsync">
                            Decay @(_useHeatmapDecay ? "bật" : "tắt")
                        </button>
                    </div>
                </HeaderActions>
                <ChildContent>
                    <div class="analytics-map-card">
                        @if (!string.IsNullOrWhiteSpace(_heatmapErrorMessage))
                        {
                            <div class="analytics-map-placeholder">
                                <strong>Không tải được heatmap</strong>
                                <p>@_heatmapErrorMessage</p>
                            </div>
                        }
                        else if (!MapOptions.HasAccessToken)
                        {
                            <div class="analytics-map-placeholder">
                                <strong>Chưa có Mapbox access token</strong>
                                <p>Điền `Mapbox:AccessToken` để bật heatmap trực tiếp trong admin portal.</p>
                            </div>
                        }
                        else if (_isHeatmapLoading && _heatmap.Count == 0)
                        {
                            <div class="analytics-map-placeholder">
                                <strong>Đang làm mới heatmap</strong>
                                <p>Bộ lọc thời gian và decay đang được áp dụng lên unique session mới nhất.</p>
                            </div>
                        }
                        else if (_heatmap.Count == 0)
                        {
                            <div class="analytics-map-placeholder">
                                <strong>Chưa có tín hiệu vị trí</strong>
                                <p>Heatmap sẽ hiển thị khi hệ thống ghi nhận đủ visit events có lat/lng.</p>
                            </div>
                        }
                        else
                        {
                            <div id="@HeatmapContainerId" class="analytics-map-canvas" data-map-surface="heatmap"></div>
                        }

                        <div class="analytics-map-meta">
                            <span>@($"{HighestHeatWeight:N1} peak sau clamp")</span>
                            <span>@HeatmapModeSummary</span>
                        </div>
                    </div>
                </ChildContent>
            </PanelShell>

            <PanelShell Eyebrow="Luồng di chuyển"
                        Title="Tuyến di chuyển ẩn danh"
                        Description="Route polyline tổng hợp giữa các POI, không hiển thị device_id raw."
                        BadgeLabel="@($"{_movementFlows.Count:N0} luồng")"
                        BadgeTone="StatusTone.Good">
                <HeaderActions>
                    <div class="analytics-filter-toolbar">
                        @foreach (var option in HeatmapEventTypeOptions)
                        {
                            <button type="button"
                                    class="analytics-filter-chip @(Equals(option.EventType, _selectedMovementFlowEventType) ? "is-active" : null)"
                                    data-flow-event="@option.Key"
                                    disabled="@_isMovementFlowLoading"
                                    @onclick="() => ChangeMovementFlowEventTypeAsync(option.EventType)">
                                @option.Label
                            </button>
                        }

                        @foreach (var option in HeatmapRangeOptions)
                        {
                            <button type="button"
                                    class="analytics-filter-chip @(option.Range == _selectedMovementFlowTimeRange ? "is-active" : null)"
                                    data-flow-range="@option.Range"
                                    disabled="@_isMovementFlowLoading"
                                    @onclick="() => ChangeMovementFlowTimeRangeAsync(option.Range)">
                                @option.Label
                            </button>
                        }

                        @foreach (var minimumSessions in MovementFlowMinimumSessionOptions)
                        {
                            <button type="button"
                                    class="analytics-filter-chip @(minimumSessions == _minimumMovementFlowSessions ? "is-active" : null)"
                                    data-flow-min-sessions="@minimumSessions"
                                    disabled="@_isMovementFlowLoading"
                                    @onclick="() => ChangeMovementFlowMinimumSessionsAsync(minimumSessions)">
                                Min @minimumSessions
                            </button>
                        }
                    </div>
                </HeaderActions>
                <ChildContent>
                    <div class="analytics-map-card">
                        @if (!string.IsNullOrWhiteSpace(_movementFlowErrorMessage))
                        {
                            <div class="analytics-map-placeholder">
                                <strong>Không tải được tuyến di chuyển</strong>
                                <p>@_movementFlowErrorMessage</p>
                            </div>
                        }
                        else if (!MapOptions.HasAccessToken)
                        {
                            <div class="analytics-map-placeholder">
                                <strong>Chưa có Mapbox access token</strong>
                                <p>Map flow sẽ bật ngay khi admin portal có token Mapbox hợp lệ.</p>
                            </div>
                        }
                        else if (_isMovementFlowLoading && _movementFlows.Count == 0)
                        {
                            <div class="analytics-map-placeholder">
                                <strong>Đang làm mới tuyến di chuyển</strong>
                                <p>Bộ lọc event, thời gian và ngưỡng ẩn danh đang được áp dụng.</p>
                            </div>
                        }
                        else if (_movementFlows.Count == 0)
                        {
                            <div class="analytics-map-placeholder">
                                <strong>Chưa đủ ngưỡng ẩn danh</strong>
                                <p>Chỉ hiển thị những luồng có đủ số session tổng hợp để tránh trace theo thiết bị.</p>
                            </div>
                        }
                        else
                        {
                            <div id="@MovementContainerId" class="analytics-map-canvas" data-map-surface="flows"></div>
                        }

                        <div class="analytics-map-meta">
                            <span>@($"{TotalFlowTraversals:N0} lượt chuyển giữa các POI")</span>
                            <span>@MovementFlowModeSummary</span>
                        </div>
                    </div>
                </ChildContent>
            </PanelShell>
        </section>

        <section class="analytics-ranking-grid">
            <PanelShell Eyebrow="Hotspot"
                        Title="Top địa điểm được nghe nhiều nhất"
                        Description="Bar chart xếp hạng lượt nghe theo POI.">
                @if (_topPois.Count == 0)
                {
                    <EmptyStateBlock Eyebrow="Hotspot"
                                     Title="Chưa có dữ liệu nghe"
                                     Message="Các POI sẽ được xếp hạng khi hệ thống ghi nhận audio plays." />
                }
                else
                {
                    <div class="analytics-ranking-list">
                        @foreach (var poi in RankedTopPois)
                        {
                            <article class="analytics-ranking-row">
                                <div class="analytics-ranking-head">
                                    <div>
                                        <strong>#@poi.Rank @poi.Item.PoiName</strong>
                                        <p>@poi.Item.Visits.ToString("N0") lượt ghé nghe</p>
                                    </div>
                                    <StatusBadge Label="@GetHeatLabel(poi.Item.Visits)" Tone="@GetHeatTone(poi.Item.Visits)" />
                                </div>
                                <div class="analytics-bar-track">
                                    <span class="analytics-bar-fill" style="@($"width: {BuildTopPoiBarWidth(poi.Item.Visits):0.##}%")"></span>
                                </div>
                            </article>
                        }
                    </div>
                }
            </PanelShell>

            <PanelShell Eyebrow="Lắng nghe"
                        Title="Thời gian trung bình nghe 1 POI"
                        Description="Horizontal bar chart theo AVG(listen_duration_seconds) của audio plays.">
                @if (_averageListenByPoi.Count == 0)
                {
                    <EmptyStateBlock Eyebrow="Listening"
                                     Title="Chưa có dữ liệu thời lượng"
                                     Message="Hệ thống sẽ hiển thị thời gian nghe trung bình khi đã có audio play events." />
                }
                else
                {
                    <div class="analytics-ranking-list">
                        @foreach (var poi in _averageListenByPoi)
                        {
                            <article class="analytics-ranking-row">
                                <div class="analytics-ranking-head analytics-ranking-head--compact">
                                    <div>
                                        <strong>@poi.PoiName</strong>
                                        <p>@($"{Math.Round(poi.AverageListenDurationSeconds):N0} giây TB")</p>
                                    </div>
                                    <small>@($"{poi.AudioPlayCount:N0} lượt phát")</small>
                                </div>
                                <div class="analytics-bar-track">
                                    <span class="analytics-bar-fill analytics-bar-fill--accent" style="@($"width: {BuildAverageListenBarWidth(poi.AverageListenDurationSeconds):0.##}%")"></span>
                                </div>
                            </article>
                        }
                    </div>
                }
            </PanelShell>
        </section>
    </div>
}
