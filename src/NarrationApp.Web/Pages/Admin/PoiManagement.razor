@page "/admin/poi-management"
@using System.Globalization
@attribute [Authorize(Roles = "admin")]

@inject IAdminPortalService AdminPortalService
@inject IAdminPoiOperationsService AdminPoiOperationsService

<PageTitle>Quản lý POI</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">POI</p>
        <h2>Đang tải POI toàn hệ thống...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">POI</p>
        <h2>Không thể tải POI management</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack admin-poi-page">
        <section class="admin-poi-page__intro">
            <p class="admin-poi-page__crumb">Admin / <strong>Quản lý POI</strong></p>

            <div class="admin-poi-page__title-wrap">
                <span class="admin-poi-page__title-mark" aria-hidden="true">◎</span>

                <div class="admin-poi-page__title-copy">
                    <h2>Quản lý POI</h2>
                    <p>Duyệt, từ chối và quản lý toàn bộ điểm tham quan</p>
                </div>
            </div>
        </section>

        @if (PendingPoiCount > 0)
        {
            <section class="admin-poi-banner">
                <strong>@PendingPoiCount POI đang chờ duyệt</strong>
                <span>kiểm tra và xử lý trong tab Moderation</span>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <section class="panel-shell admin-poi-status">
                <p class="panel-shell__copy">@_statusMessage</p>
            </section>
        }

        <section class="admin-poi-toolbar">
            <div class="admin-poi-filters" role="tablist" aria-label="Bộ lọc POI">
                @foreach (var filter in FilterTabs)
                {
                    <button class="admin-poi-filter @(filter == _activeFilter ? "is-active" : string.Empty)"
                            data-action="@($"filter-{GetFilterActionName(filter)}")"
                            type="button"
                            @onclick="() => SetFilter(filter)">
                        @($"{GetFilterLabel(filter)} ({GetFilterCount(filter)})")
                    </button>
                }
            </div>

            <label class="admin-poi-search">
                <span class="admin-poi-search__icon" aria-hidden="true">⌕</span>
                <input class="admin-poi-search__input"
                       data-field="poi-search"
                       type="text"
                       placeholder="Tìm kiếm POI..."
                       value="@_searchText"
                       @oninput="HandleSearchChanged"
                       @onchange="HandleSearchChanged" />
            </label>
        </section>

        <section class="panel-shell admin-poi-table-shell">
            @if (VisibleRows.Count == 0)
            {
                <EmptyStateBlock Eyebrow="POI"
                                 Title="Không có POI phù hợp"
                                 Message="Bộ lọc hiện tại chưa có bản ghi nào khớp để hiển thị." />
            }
            else
            {
                <div class="admin-poi-table__scroll">
                    <table class="app-table admin-poi-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Tên POI</th>
                                <th>Tọa độ</th>
                                <th>Trạng thái</th>
                                <th>Ngôn ngữ</th>
                                <th>Audio</th>
                                <th>Ngày tạo</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in VisibleRows)
                            {
                                <tr class="@(IsSelected(row.Item) ? "admin-poi-table__row--selected" : string.Empty)"
                                    @key="row.Item.Id">
                                    <td>@row.Number.ToString("00", CultureInfo.InvariantCulture)</td>
                                    <td>
                                        <div class="admin-poi-table__poi">
                                            <strong>@row.Item.Name</strong>
                                            <span>@row.Item.Slug</span>
                                            <small>@row.Item.OwnerEmail</small>
                                        </div>
                                    </td>
                                    <td>@FormatCoordinates(row.Item)</td>
                                    <td>
                                        <StatusBadge Label="@GetStatusLabel(row.Item.Status)"
                                                     Tone="@GetStatusTone(row.Item.Status)" />
                                    </td>
                                    <td>
                                        <StatusBadge Label="@GetLanguageLabel(row.Item.TranslationCount)"
                                                     Tone="StatusTone.Info" />
                                    </td>
                                    <td>
                                        <StatusBadge Label="@GetAudioLabel(row.Item)"
                                                     Tone="@GetAudioTone(row.Item)" />
                                    </td>
                                    <td>@row.Item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy", CultureInfo.InvariantCulture)</td>
                                    <td>
                                        <div class="admin-poi-actions">
                                            @if (row.Item.PendingModerationId is int moderationRequestId
                                                && row.Item.Status == PoiStatus.PendingReview)
                                            {
                                                <button class="admin-poi-action"
                                                        data-action="view-poi-@row.Item.Id"
                                                        type="button"
                                                        @onclick="() => SelectPoi(row.Item)"
                                                        @onclick:stopPropagation="true">
                                                    Xem
                                                </button>
                                                <button class="admin-poi-action admin-poi-action--approve"
                                                        data-action="approve-poi-@row.Item.Id"
                                                        type="button"
                                                        @onclick="() => ApprovePoiAsync(row.Item, moderationRequestId)"
                                                        @onclick:stopPropagation="true">
                                                    ✓ Duyệt
                                                </button>
                                                <button class="admin-poi-action admin-poi-action--reject"
                                                        data-action="reject-poi-@row.Item.Id"
                                                        type="button"
                                                        @onclick="() => RejectPoiAsync(row.Item, moderationRequestId)"
                                                        @onclick:stopPropagation="true">
                                                    × Từ chối
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="admin-poi-action"
                                                        data-action="view-poi-@row.Item.Id"
                                                        type="button"
                                                        @onclick="() => SelectPoi(row.Item)"
                                                        @onclick:stopPropagation="true">
                                                    Xem
                                                </button>

                                                @if (CanEdit(row.Item))
                                                {
                                                    <button class="admin-poi-action"
                                                            data-action="edit-poi-@row.Item.Id"
                                                            type="button"
                                                            @onclick="() => SelectPoi(row.Item)"
                                                            @onclick:stopPropagation="true">
                                                        Sửa
                                                    </button>
                                                }

                                                <button class="admin-poi-action admin-poi-action--danger"
                                                        data-action="delete-poi-@row.Item.Id"
                                                        type="button"
                                                        @onclick="() => DeletePoiAsync(row.Item)"
                                                        @onclick:stopPropagation="true">
                                                    Xóa
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="admin-poi-table__footer">
                    <span>Hiển thị @VisibleRangeLabel</span>

                    @if (PageCount > 1)
                    {
                        <div class="admin-poi-pagination">
                            <button class="admin-poi-pagination__button"
                                    data-action="page-prev"
                                    type="button"
                                    disabled="@(CurrentPage <= 1)"
                                    @onclick="PreviousPage">
                                ‹ Trước
                            </button>

                            @foreach (var pageNumber in PageNumbers)
                            {
                                <button class="admin-poi-pagination__button @(pageNumber == CurrentPage ? "is-active" : string.Empty)"
                                        data-action="@($"page-{pageNumber}")"
                                        type="button"
                                        @onclick="() => GoToPage(pageNumber)">
                                    @pageNumber
                                </button>
                            }

                            <button class="admin-poi-pagination__button"
                                    data-action="page-next"
                                    type="button"
                                    disabled="@(CurrentPage >= PageCount)"
                                    @onclick="NextPage">
                                Tiếp ›
                            </button>
                        </div>
                    }
                </div>
            }
        </section>

        @if (_selectedPoi is not null)
        {
            <div class="admin-overlay-backdrop" @onclick="ClosePoiDetail">
                <section class="panel-shell admin-overlay-shell admin-overlay-shell--wide admin-poi-detail-shell"
                         data-panel="poi-detail"
                         @onclick:stopPropagation="true">
                    <div class="admin-overlay-shell__header">
                        <div>
                            <p class="panel-shell__eyebrow">POI detail</p>
                            <h2>@_selectedPoi.Name</h2>
                            <p class="panel-shell__copy">@_selectedPoi.OwnerName · @_selectedPoi.OwnerEmail</p>
                        </div>

                        <button class="app-button app-button--ghost" type="button" @onclick="ClosePoiDetail">
                            Đóng
                        </button>
                    </div>

                    <div class="admin-poi-detail__header">
                        <StatusBadge Label="@GetStatusLabel(_selectedPoi.Status)"
                                     Tone="@GetStatusTone(_selectedPoi.Status)" />
                    </div>

                    <div class="admin-poi-detail__grid">
                        <article class="admin-poi-detail__card">
                            <span>Danh mục</span>
                            <strong>@(_selectedPoi.CategoryName ?? "Chưa gán danh mục")</strong>
                            <p>@_selectedPoi.Slug</p>
                        </article>

                        <article class="admin-poi-detail__card">
                            <span>Tọa độ</span>
                            <strong>@FormatCoordinates(_selectedPoi)</strong>
                            <p>Priority @_selectedPoi.Priority</p>
                        </article>

                        <article class="admin-poi-detail__card">
                            <span>Ngôn ngữ</span>
                            <strong>@GetLanguageLabel(_selectedPoi.TranslationCount)</strong>
                            <p>@_selectedPoi.GeofenceCount geofence</p>
                        </article>

                        <article class="admin-poi-detail__card">
                            <span>Audio</span>
                            <strong>@GetAudioLabel(_selectedPoi)</strong>
                            <p>@_selectedPoi.AudioAssetCount asset</p>
                        </article>
                    </div>

                    <div class="admin-poi-detail__story-grid">
                        <article class="admin-poi-detail__story">
                            <span>Mô tả văn bản</span>
                            <p>@_selectedPoi.Description</p>
                        </article>

                        <article class="admin-poi-detail__story">
                            <span>Kịch bản nguồn</span>
                            <p>@_selectedPoi.TtsScript</p>
                        </article>
                    </div>
                </section>
            </div>
        }
    </div>
}
