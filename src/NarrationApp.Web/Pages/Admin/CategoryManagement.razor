@page "/admin/category-management"
@using System.Linq
@attribute [Authorize(Roles = "admin")]

@inject ICategoryPortalService CategoryPortalService

<PageTitle>Quản lý danh mục</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Danh mục</p>
        <h2>Đang tải danh mục...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Danh mục</p>
        <h2>Không thể tải quản lý danh mục</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack category-page">
        <section class="sample-page-title">
            <h1>Danh mục</h1>
            <p>Admin / Quản lý nội dung &gt; Danh mục</p>
        </section>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <section class="panel-shell">
                <p class="panel-shell__copy">@_statusMessage</p>
            </section>
        }

        <section class="panel-shell category-table-shell">
            <div class="category-table-shell__header">
                <div>
                    <h2>Quản lý danh mục POI</h2>
                </div>
                <button class="app-button app-button--primary"
                        data-action="new-category"
                        type="button"
                        @onclick="BeginCreate">
                    + Tạo danh mục
                </button>
            </div>

            @if (_categories.Count == 0)
            {
                <EmptyStateBlock Eyebrow="Danh mục"
                                 Title="Chưa có danh mục nào"
                                 Message="Hãy tạo nhóm đầu tiên để owner có thể phân loại POI." />
            }
            else
            {
                <div class="table-wrap">
                    <table class="app-table category-table">
                        <thead>
                            <tr>
                                <th>Icon</th>
                                <th>Tên danh mục</th>
                                <th>Slug</th>
                                <th>Thứ tự</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in _categories)
                            {
                                <tr @key="category.Id">
                                    <td class="category-table__icon">@GetIcon(category)</td>
                                    <td>
                                        <div class="category-table__name">
                                            <strong>@category.Name</strong>
                                            <span>@category.Description</span>
                                        </div>
                                    </td>
                                    <td>@category.Slug</td>
                                    <td>@category.DisplayOrder</td>
                                    <td>
                                        <StatusBadge Label="@(category.IsActive ? "Active" : "Inactive")"
                                                     Tone="@(category.IsActive ? StatusTone.Good : StatusTone.Neutral)" />
                                    </td>
                                    <td>
                                        <div class="category-actions">
                                            <button class="category-action"
                                                    data-action="edit-category-@category.Id"
                                                    type="button"
                                                    @onclick="() => SelectCategory(category)">
                                                Sửa
                                            </button>
                                            <button class="category-action category-action--danger"
                                                    data-action="delete-category-@category.Id"
                                                    type="button"
                                                    @onclick="() => DeleteAsync(category)">
                                                Xóa
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        @if (_isEditorOpen)
        {
            <div class="admin-overlay-backdrop" @onclick="CloseEditor">
                <section class="panel-shell admin-overlay-shell category-editor-shell"
                         data-panel="category-editor"
                         @onclick:stopPropagation="true">
                    <div class="admin-overlay-shell__header">
                        <div>
                            <p class="panel-shell__eyebrow">Trình biên tập</p>
                            <h2>@(_isCreateMode ? "Tạo danh mục mới" : _selectedCategory?.Name ?? "Biên tập danh mục")</h2>
                        </div>
                        <button class="app-button app-button--ghost" type="button" @onclick="CloseEditor">
                            Đóng
                        </button>
                    </div>

                    <div class="editor-grid">
                        <div class="editor-field">
                            <label for="category-name">Tên danh mục</label>
                            <InputText id="category-name" data-field="category-name" @bind-Value="_editor.Name" />
                        </div>

                        <div class="editor-field">
                            <label for="category-slug">Slug</label>
                            <InputText id="category-slug" data-field="category-slug" @bind-Value="_editor.Slug" />
                        </div>

                        <div class="editor-field">
                            <label for="category-icon">Biểu tượng</label>
                            <InputText id="category-icon" data-field="category-icon" @bind-Value="_editor.Icon" />
                        </div>

                        <div class="editor-field">
                            <label for="category-order">Thứ tự hiển thị</label>
                            <InputNumber id="category-order" data-field="category-order" @bind-Value="_editor.DisplayOrder" />
                        </div>

                        <div class="editor-field editor-field--toggle">
                            <label for="category-active">Đang hoạt động</label>
                            <InputCheckbox id="category-active" data-field="category-active" @bind-Value="_editor.IsActive" />
                        </div>

                        <div class="editor-field editor-field--full">
                            <label for="category-description">Mô tả</label>
                            <InputTextArea id="category-description" data-field="category-description" @bind-Value="_editor.Description" />
                        </div>
                    </div>

                    <div class="action-row">
                        <button class="app-button app-button--primary" data-action="save-category" type="button" @onclick="SaveAsync">
                            @(_isCreateMode ? "Tạo danh mục" : "Lưu danh mục")
                        </button>
                    </div>
                </section>
            </div>
        }
    </div>
}
