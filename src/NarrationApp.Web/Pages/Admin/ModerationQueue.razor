@page "/admin/moderation-queue"
@attribute [Authorize(Roles = "admin")]

@inject IAdminPortalService AdminPortalService

<PageTitle>Moderation Queue</PageTitle>

@if (_isLoading)
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Admin</p>
        <h2>Đang tải Moderation Queue...</h2>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <section class="panel-shell">
        <p class="panel-shell__eyebrow">Admin</p>
        <h2>Không thể tải Moderation Queue</h2>
        <p class="panel-shell__copy">@_errorMessage</p>
    </section>
}
else
{
    <div class="dashboard-stack moderation-surface">
        <section class="sample-page-title">
            <h1>Moderation Queue</h1>
            <p>Admin / Vận hành &gt; Moderation</p>
        </section>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <section class="panel-shell">
                <p class="panel-shell__copy">@_statusMessage</p>
            </section>
        }

        <section class="metric-grid moderation-surface__metrics">
            <MetricCard Label="Chờ duyệt" Value="@_items.Count.ToString("N0")" Hint="Yêu cầu đang trong queue" />
            <MetricCard Label="Yêu cầu POI" Value="@CountByEntityType("poi").ToString("N0")" Hint="Tạo mới hoặc cập nhật nội dung" />
            <MetricCard Label="Owner mới" Value="@CountByEntityType("owner_registration").ToString("N0")" Hint="Yêu cầu cấp quyền truy cập" />
            <MetricCard Label="Yêu cầu cũ nhất" Value="@OldestRequestLabel" Hint="Để ưu tiên xử lý" />
        </section>

        @if (_items.Count == 0)
        {
            <section class="panel-shell">
                <EmptyStateBlock Eyebrow="Moderation"
                                 Title="Hàng đợi moderation đã trống"
                                 Message="Queue hiện chưa có yêu cầu nào cần admin xử lý thêm." />
            </section>
        }
        else
        {
            <div class="moderation-list">
                @foreach (var item in _items)
                {
                    <article class="panel-shell moderation-card">
                        <div class="moderation-card__copy">
                            <div>
                                <strong>@GetEntityTitle(item)</strong>
                                <p>@GetEntityMeta(item)</p>
                            </div>
                        </div>

                        <div class="moderation-card__actions">
                            <button class="app-button app-button--ghost" data-action="view-@item.Id" type="button">
                                Xem
                            </button>
                            <button class="app-button app-button--primary" data-action="approve-@item.Id" type="button" @onclick="() => ReviewAsync(item.Id, true)">
                                Duyệt
                            </button>
                            <button class="app-button app-button--ghost" data-action="reject-@item.Id" type="button" @onclick="() => ReviewAsync(item.Id, false)">
                                Từ chối
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
}
