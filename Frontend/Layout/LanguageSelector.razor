@using FoodStreet.Client.Services
@inject IFoodClientService FoodService

<div class="dropdown">
    <button class="btn btn-secondary dropdown-toggle" type="button" @onclick="ToggleDropdown">
        🌐 @CurrentLabel
    </button>
    <div class="dropdown-menu @(isOpen ? "show" : "")">
        <button class="dropdown-item" @onclick='() => ChangeLanguage("vi-VN")'>🇻🇳 Tiếng Việt</button>
        <button class="dropdown-item" @onclick='() => ChangeLanguage("en-US")'>🇺🇸 English</button>
    </div>
</div>

@code {
    private bool isOpen = false;
    private string CurrentLabel => FoodService.CurrentLanguage == "vi-VN" ? "Tiếng Việt" : "English";

    private void ToggleDropdown() => isOpen = !isOpen;

    private void ChangeLanguage(string lang)
    {
        FoodService.SetLanguage(lang);
        isOpen = false;
    }
}
