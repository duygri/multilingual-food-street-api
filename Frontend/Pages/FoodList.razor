@page "/foods"
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@inject IFoodClientService FoodService

<PageTitle>Food Street Guide</PageTitle>

<h1>Food Street Guide 🍜</h1>

<p>Discover delicious street food near you!</p>

@if (foods == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        @foreach (var food in foods.Items)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@food.Name</h5>
                        <p class="card-text">@food.Description</p>
                        <p class="card-text"><strong>Price:</strong> @food.Price.ToString("N0") VND</p>
                        <p class="card-text"><small class="text-muted">Distance: @food.Distance @food.Unit</small></p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@implements IDisposable

@code {
    private PagedResult<FoodDto>? foods;

    protected override async Task OnInitializedAsync()
    {
        FoodService.OnLanguageChanged += HandleLanguageChanged;
        await LoadFoods();
    }

    private async void HandleLanguageChanged()
    {
        await LoadFoods();
        StateHasChanged();
    }

    private async Task LoadFoods()
    {
        // Hardcoded location (HCM City) for testing
        double lat = 10.762622;
        double lng = 106.660172;
        foods = await FoodService.GetNearestFoods(lat, lng, 1, 10);
    }

    public void Dispose()
    {
        FoodService.OnLanguageChanged -= HandleLanguageChanged;
    }
}
