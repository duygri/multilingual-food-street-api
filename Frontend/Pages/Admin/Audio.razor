@page "/admin/audio"
@layout AdminLayout
@inject IAudioService AudioService
@inject IFoodClientService FoodService
@using FoodStreet.Client.DTOs

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">🎵 Audio Management</h3>
    <button class="btn btn-admin btn-admin-primary" @onclick="ShowUploadModal">
        ➕ Upload Audio
    </button>
</div>

<!-- Stats Cards -->
@if (stats != null)
{
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="admin-card text-center py-3">
                <div style="font-size: 2rem;">📁</div>
                <div class="fw-bold fs-4">@stats.TotalFiles</div>
                <small class="text-muted">Total Files</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center py-3">
                <div style="font-size: 2rem;">✅</div>
                <div class="fw-bold fs-4 text-success">@stats.Assigned</div>
                <small class="text-muted">Assigned to POI</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center py-3">
                <div style="font-size: 2rem;">❓</div>
                <div class="fw-bold fs-4 text-warning">@stats.Unassigned</div>
                <small class="text-muted">Unassigned</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="admin-card text-center py-3">
                <div style="font-size: 2rem;">💾</div>
                <div class="fw-bold fs-4">@stats.TotalSizeMB MB</div>
                <small class="text-muted">Total Size</small>
            </div>
        </div>
    </div>
}

<!-- Filter -->
<div class="admin-card mb-4">
    <div class="row align-items-center">
        <div class="col-md-4">
            <label class="form-label">Filter by POI</label>
            <select class="form-select" @onchange="OnFilterChanged">
                <option value="">All Audio Files</option>
                <option value="-1">Unassigned Only</option>
                @if (foods != null)
                {
                    @foreach (var food in foods)
                    {
                        <option value="@food.Id">@food.Name</option>
                    }
                }
            </select>
        </div>
    </div>
</div>

<!-- Audio List -->
<div class="admin-card">
    @if (audioFiles == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2">Loading audio files...</p>
        </div>
    }
    else if (!audioFiles.Any())
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem;">🎵</div>
            <p class="text-muted">No audio files found</p>
            <button class="btn btn-admin btn-admin-primary" @onclick="ShowUploadModal">
                Upload your first audio
            </button>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover admin-table">
                <thead>
                    <tr>
                        <th>File</th>
                        <th>Assigned To</th>
                        <th>Size</th>
                        <th>Uploaded</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var audio in audioFiles)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span style="font-size: 1.5rem;">🎵</span>
                                    <div>
                                        <div class="fw-bold">@(audio.OriginalName ?? audio.FileName)</div>
                                        <small class="text-muted">@audio.ContentType</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (audio.FoodId.HasValue)
                                {
                                    <span class="badge bg-success">@audio.FoodName</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Unassigned</span>
                                }
                            </td>
                            <td>@FormatSize(audio.Size)</td>
                            <td>@audio.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary" @onclick="() => PlayAudio(audio)" title="Play">
                                        ▶️
                                    </button>
                                    <button class="btn btn-outline-info" @onclick="() => ShowAssignModal(audio)" title="Assign">
                                        🔗
                                    </button>
                                    <button class="btn btn-outline-danger" @onclick="() => DeleteAudio(audio.Id)" title="Delete">
                                        🗑️
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Audio Player -->
@if (!string.IsNullOrEmpty(playingUrl))
{
    <div class="position-fixed bottom-0 start-0 end-0 bg-dark text-white p-3" style="z-index: 1050;">
        <div class="container d-flex align-items-center gap-3">
            <span>🎵 @playingName</span>
            <audio controls autoplay src="@playingUrl" class="flex-grow-1" style="height: 40px;"></audio>
            <button class="btn btn-outline-light btn-sm" @onclick="StopPlaying">✕</button>
        </div>
    </div>
}

<!-- Assign Modal -->
@if (showAssignModal && selectedAudio != null)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">🔗 Assign Audio to POI</h5>
                    <button type="button" class="btn-close" @onclick="CloseAssignModal"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Audio:</strong> @selectedAudio.OriginalName</p>
                    <div class="mb-3">
                        <label class="form-label">Select POI</label>
                        <select class="form-select" @bind="assignToFoodId">
                            <option value="">-- No Assignment --</option>
                            @if (foods != null)
                            {
                                @foreach (var food in foods)
                                {
                                    <option value="@food.Id">@food.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseAssignModal">Cancel</button>
                    <button class="btn btn-admin btn-admin-primary" @onclick="AssignAudio">💾 Save</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Upload Modal -->
@if (showUploadModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">➕ Upload Audio</h5>
                    <button type="button" class="btn-close" @onclick="CloseUploadModal"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center py-4">
                        <div style="font-size: 3rem;">🎤</div>
                        <p class="mt-2">Select audio files (MP3, WAV, OGG)</p>
                        <InputFile OnChange="@OnFilesSelected" class="form-control" accept="audio/*" multiple />
                        @if (uploading)
                        {
                            <div class="mt-3">
                                <div class="spinner-border spinner-border-sm text-primary"></div>
                                <span class="ms-2">Uploading...</span>
                            </div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Assign to POI (optional)</label>
                        <select class="form-select" @bind="uploadToFoodId">
                            <option value="">-- Upload without assignment --</option>
                            @if (foods != null)
                            {
                                @foreach (var food in foods)
                                {
                                    <option value="@food.Id">@food.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<AudioFileDto>? audioFiles;
    private List<FoodDto>? foods;
    private AudioStatsDto? stats;
    
    private AudioFileDto? selectedAudio;
    private bool showAssignModal;
    private bool showUploadModal;
    private bool uploading;
    
    private string? assignToFoodId;
    private string? uploadToFoodId;
    private int? currentFilter;
    
    private string? playingUrl;
    private string? playingName;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        audioFiles = await AudioService.GetAllAudioAsync(currentFilter);
        stats = await AudioService.GetStatsAsync();
        
        var foodResult = await FoodService.GetFoods();
        foods = foodResult?.Items ?? new();
    }

    private async Task OnFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrEmpty(value))
            currentFilter = null;
        else if (value == "-1")
            currentFilter = null; // Will need custom handling for unassigned
        else
            currentFilter = int.Parse(value);
            
        await LoadData();
    }

    private void ShowUploadModal() => showUploadModal = true;
    private void CloseUploadModal() => showUploadModal = false;
    
    private void ShowAssignModal(AudioFileDto audio)
    {
        selectedAudio = audio;
        assignToFoodId = audio.FoodId?.ToString() ?? "";
        showAssignModal = true;
    }
    private void CloseAssignModal() => showAssignModal = false;

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        uploading = true;
        StateHasChanged();

        // Note: Actual upload would need MultipartFormDataContent
        // This is simplified - in real app use HttpClient with form data
        
        uploading = false;
        showUploadModal = false;
        await LoadData();
    }

    private async Task AssignAudio()
    {
        if (selectedAudio == null) return;
        
        int? foodId = string.IsNullOrEmpty(assignToFoodId) ? null : int.Parse(assignToFoodId);
        await AudioService.AssignToFoodAsync(selectedAudio.Id, foodId);
        
        CloseAssignModal();
        await LoadData();
    }

    private async Task DeleteAudio(int id)
    {
        await AudioService.DeleteAudioAsync(id);
        await LoadData();
    }

    private void PlayAudio(AudioFileDto audio)
    {
        playingUrl = audio.Url;
        playingName = audio.OriginalName ?? audio.FileName;
    }

    private void StopPlaying()
    {
        playingUrl = null;
        playingName = null;
    }

    private string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}
