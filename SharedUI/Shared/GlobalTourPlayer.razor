@using FoodStreet.Client.Services
@inject TourPlayerService PlayerService
@implements IDisposable

@if (PlayerService.IsVisible && PlayerService.CurrentItem != null)
{
    <div class="global-audio-player shadow-lg animate__animated animate__slideInUp">
        <div class="player-content">
            <div class="poi-thumb">
                @if (!string.IsNullOrEmpty(PlayerService.CurrentItem.ImageUrl))
                {
                    <img src="@PlayerService.CurrentItem.ImageUrl" alt="POI" />
                }
                else
                {
                    <div class="placeholder-icon">📍</div>
                }
                @if (PlayerService.IsPlaying)
                {
                    <div class="audio-waves">
                        <span></span><span></span><span></span><span></span>
                    </div>
                }
            </div>

            <div class="poi-info">
                <div class="poi-name">@PlayerService.CurrentItem.Title</div>
                <div class="poi-status">
                    @if (PlayerService.IsTtsMode)
                    {
                        <span class="badge bg-info-subtle text-info"><i class="bi bi-robot"></i> Đang đọc thuyết minh AI...</span>
                    }
                    else
                    {
                        <span class="badge bg-success-subtle text-success"><i class="bi bi-vinyl-fill"></i> Đang phát Audio gốc...</span>
                    }
                </div>
            </div>

            <div class="player-controls">
                <button class="btn-control toggle" @onclick="PlayerService.TogglePlay">
                    @if (PlayerService.IsPlaying)
                    {
                        <i class="bi bi-pause-fill"></i>
                    }
                    else
                    {
                        <i class="bi bi-play-fill"></i>
                    }
                </button>
                <button class="btn-control close" @onclick="PlayerService.Close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    </div>
}

<style>
    .global-audio-player {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 90%;
        max-width: 500px;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px;
        z-index: 2000;
        padding: 12px 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }

    .player-content {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .poi-thumb {
        position: relative;
        width: 50px;
        height: 50px;
        border-radius: 12px;
        overflow: hidden;
        background: #f1f5f9;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .poi-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .placeholder-icon {
        font-size: 24px;
    }

    .audio-waves {
        position: absolute;
        bottom: 5px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: flex-end;
        gap: 2px;
        height: 15px;
    }

    .audio-waves span {
        width: 3px;
        background: #ff6b35;
        border-radius: 3px;
        animation: wave-animation 1s ease-in-out infinite;
    }

    .audio-waves span:nth-child(2) { animation-delay: 0.2s; height: 10px; }
    .audio-waves span:nth-child(3) { animation-delay: 0.4s; height: 14px; }
    .audio-waves span:nth-child(4) { animation-delay: 0.6s; height: 8px; }

    @@keyframes wave-animation {
        0%, 100% { height: 5px; }
        50% { height: 15px; }
    }

    .poi-info {
        flex: 1;
        min-width: 0;
    }

    .poi-name {
        font-weight: 700;
        font-size: 15px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #1e293b;
    }

    .poi-status {
        font-size: 11px;
    }

    .player-controls {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-control {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn-control.toggle {
        background: #ff6b35;
        color: white;
        font-size: 20px;
    }

    .btn-control.toggle:hover {
        background: #e85a2a;
        transform: scale(1.1);
    }

    .btn-control.close {
        background: #f1f5f9;
        color: #64748b;
        font-size: 14px;
    }

    .btn-control.close:hover {
        background: #e2e8f0;
        color: #1e293b;
    }

    /* Animation class if animate.css is not present */
    .animate__animated { animation-duration: 0.5s; }
    @@keyframes slideInUp {
        from { transform: translate(-50%, 150%); opacity: 0; }
        to { transform: translate(-50%, 0); opacity: 1; }
    }
    .animate__slideInUp { animation-name: slideInUp; }
</style>

@code {
    protected override void OnInitialized()
    {
        PlayerService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        PlayerService.OnChange -= StateHasChanged;
    }
}
