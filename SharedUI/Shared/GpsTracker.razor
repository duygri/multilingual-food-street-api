@using FoodStreet.Client.Services
@inject IGpsTrackingService GpsService
@implements IDisposable

<div class="gps-tracker">
    <div class="gps-header">
        <h3>📍 GPS Tracking</h3>
        <button class="btn-gps @(GpsService.IsTracking ? "active" : "")" @onclick="ToggleTracking">
            @(GpsService.IsTracking ? "⏹ Dừng" : "▶ Bắt đầu")
        </button>
    </div>

    @if (GpsService.CurrentLatitude.HasValue)
    {
        <div class="gps-coords">
            <span class="coord-label">Vĩ độ:</span>
            <span class="coord-value">@GpsService.CurrentLatitude?.ToString("F6")</span>
            <span class="coord-label">Kinh độ:</span>
            <span class="coord-value">@GpsService.CurrentLongitude?.ToString("F6")</span>
            @if (GpsService.Accuracy.HasValue)
            {
                <span class="coord-label">Độ chính xác:</span>
                <span class="coord-value">±@GpsService.Accuracy?.ToString("F0")m</span>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(GpsService.LastError))
    {
        <div class="gps-error">
            ⚠️ @GpsService.LastError
        </div>
    }

    @if (nearbyPois.Count > 0)
    {
        <div class="nearby-pois">
            <h4>🍜 Địa điểm gần đây</h4>
            @foreach (var poi in nearbyPois)
            {
                <div class="poi-item @(poi.IsInGeofence ? "in-geofence" : "")">
                    <span class="poi-name">@poi.Name</span>
                    <span class="poi-distance">@poi.Distance.ToString("F0")m</span>
                    @if (poi.IsInGeofence)
                    {
                        <span class="poi-badge">📍 Đang ở đây</span>
                    }
                </div>
            }
        </div>
    }
</div>

<style>
    .gps-tracker {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        border-radius: 16px;
        padding: 20px;
        color: #fff;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .gps-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .gps-header h3 {
        margin: 0;
        font-size: 1.2rem;
    }

    .btn-gps {
        background: linear-gradient(135deg, #00d9ff, #0099ff);
        border: none;
        padding: 10px 20px;
        border-radius: 25px;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-gps:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 15px rgba(0, 217, 255, 0.4);
    }

    .btn-gps.active {
        background: linear-gradient(135deg, #ff4757, #ff6b7a);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255, 71, 87, 0.4); }
        50% { box-shadow: 0 0 0 10px rgba(255, 71, 87, 0); }
    }

    .gps-coords {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 8px 16px;
        background: rgba(255, 255, 255, 0.1);
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 16px;
    }

    .coord-label {
        color: #888;
        font-size: 0.85rem;
    }

    .coord-value {
        font-family: 'Fira Code', monospace;
        color: #00d9ff;
    }

    .gps-error {
        background: rgba(255, 71, 87, 0.2);
        border: 1px solid #ff4757;
        padding: 12px;
        border-radius: 8px;
        color: #ff6b7a;
    }

    .nearby-pois h4 {
        margin: 0 0 12px;
        font-size: 1rem;
    }

    .poi-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        margin-bottom: 8px;
        transition: all 0.3s ease;
    }

    .poi-item:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .poi-item.in-geofence {
        background: rgba(0, 217, 255, 0.15);
        border: 1px solid rgba(0, 217, 255, 0.3);
    }

    .poi-name {
        flex: 1;
        font-weight: 500;
    }

    .poi-distance {
        color: #888;
        font-size: 0.85rem;
    }

    .poi-badge {
        background: #00d9ff;
        color: #000;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
    }
</style>

@code {
    private List<NearbyPoiDto> nearbyPois = new();

    protected override void OnInitialized()
    {
        GpsService.OnPositionUpdated += HandlePositionUpdated;
        GpsService.OnGeofenceEntered += HandleGeofenceEntered;
        GpsService.OnError += HandleError;
    }

    private async Task ToggleTracking()
    {
        if (GpsService.IsTracking)
        {
            await GpsService.StopTrackingAsync();
        }
        else
        {
            await GpsService.StartTrackingAsync();
        }
        StateHasChanged();
    }

    private void HandlePositionUpdated(double lat, double lng)
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleGeofenceEntered(List<NearbyPoiDto> pois)
    {
        nearbyPois = pois;
        InvokeAsync(StateHasChanged);
    }

    private void HandleError(string error)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        GpsService.OnPositionUpdated -= HandlePositionUpdated;
        GpsService.OnGeofenceEntered -= HandleGeofenceEntered;
        GpsService.OnError -= HandleError;
    }
}
