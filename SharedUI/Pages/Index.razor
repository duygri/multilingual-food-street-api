@page "/"
@inject NavigationManager Navigation
<GpsTracker />
@code {
    protected override void OnInitialized()
    {
        if (OperatingSystem.IsAndroid() || OperatingSystem.IsIOS())
        {
            Navigation.NavigateTo("explore");
        }
        else 
        {
            Navigation.NavigateTo("admin/login");
        }
    }
}
