@page "/"
@inject NavigationManager Navigation
@inject IPlatformDetector PlatformDetector
@using FoodStreet.Client.Services
<GpsTracker />
@code {
    private bool _redirected;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || _redirected)
        {
            return;
        }

        _redirected = true;
        Navigation.NavigateTo(PlatformDetector.IsMobile ? "/explore" : "/admin/login", replace: true);
    }
}
