@page "/admin/stats"
@layout AdminLayout
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Analytics Dashboard</h3>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <select class="form-select" style="min-width: 260px;" @bind="selectedLocationId" @bind:after="OnPoiChangedAsync">
            <option value="0">Tất cả POI</option>
            @foreach (var poi in poiOptions)
            {
                <option value="@poi.Id">@poi.Name</option>
            }
        </select>
        <div class="btn-group">
            <button class="btn @(selectedPeriod == 7 ? "btn-admin btn-admin-primary" : "btn-outline-secondary")"
                    @onclick="() => LoadData(7)">7 ngày</button>
            <button class="btn @(selectedPeriod == 30 ? "btn-admin btn-admin-primary" : "btn-outline-secondary")"
                    @onclick="() => LoadData(30)">30 ngày</button>
            <button class="btn @(selectedPeriod == 90 ? "btn-admin btn-admin-primary" : "btn-outline-secondary")"
                    @onclick="() => LoadData(90)">90 ngày</button>
        </div>
        <button class="btn btn-outline-primary" @onclick="ExportSummaryAsync">
            Export Summary
        </button>
    </div>
</div>

<!-- Stats Cards -->
@if (stats != null)
{
    <div class="row mb-4">
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#3b82f6;"></div>
                <div class="fw-bold fs-2 text-primary">@stats.TotalPlays</div>
                <small class="text-muted">Tổng lượt nghe</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#22c55e;"></div>
                <div class="fw-bold fs-2 text-success">@stats.TodayPlays</div>
                <small class="text-muted">Hôm nay</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#0ea5e9;"></div>
                <div class="fw-bold fs-2 text-info">@stats.WeekPlays</div>
                <small class="text-muted">Tuần này</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#f59e0b;"></div>
                <div class="fw-bold fs-2 text-warning">@stats.UniqueSessions</div>
                <small class="text-muted">Unique Sessions</small>
            </div>
        </div>
    </div>

    <!-- Extra info row -->
    <div class="row mb-4">
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-3">
                <div class="stat-dot" style="background:#ff6b35;"></div>
                <div class="fw-bold fs-3">@stats.TotalPOIs</div>
                <small class="text-muted">Tổng POIs</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-3">
                <div class="stat-dot" style="background:#6366f1;"></div>
                <div class="fw-bold fs-3">@stats.POIsWithAudio</div>
                <small class="text-muted">POIs có audio</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-3">
                <div class="stat-dot" style="background:#22c55e;"></div>
                <div class="fw-bold fs-3 text-success">@stats.MonthPlays</div>
                <small class="text-muted">Tháng này</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-3">
                <div class="stat-dot" style="background:#94a3b8;"></div>
                <div class="fw-bold fs-3 text-secondary">
                    @(stats.TotalPlays > 0 && stats.UniqueSessions > 0
                        ? (stats.TotalPlays / stats.UniqueSessions).ToString("F1")
                        : "0")
                </div>
                <small class="text-muted">Nghe/session TB</small>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card text-center py-3 h-100">
                <div class="stat-dot" style="background:#3b82f6;"></div>
                <div class="fw-bold fs-3 text-primary">@stats.ActiveTourSessions</div>
                <small class="text-muted">Phiên tour đang dở</small>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card text-center py-3 h-100">
                <div class="stat-dot" style="background:#64748b;"></div>
                <div class="fw-bold fs-3 text-secondary">@stats.TourStartsInWindow</div>
                <small class="text-muted">Bắt đầu tour (@stats.PeriodDays ngày)</small>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card text-center py-3 h-100">
                <div class="stat-dot" style="background:#0ea5e9;"></div>
                <div class="fw-bold fs-3 text-info">@stats.TourResumesInWindow</div>
                <small class="text-muted">Tiếp tục tour</small>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card text-center py-3 h-100">
                <div class="stat-dot" style="background:#22c55e;"></div>
                <div class="fw-bold fs-3 text-success">@stats.TourCompletionsInWindow</div>
                <small class="text-muted">Hoàn tất tour</small>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card text-center py-3 h-100">
                <div class="stat-dot" style="background:#ef4444;"></div>
                <div class="fw-bold fs-3 text-danger">@stats.TourDismissalsInWindow</div>
                <small class="text-muted">Bỏ dở tour</small>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card text-center py-3 h-100">
                <div class="stat-dot" style="background:#1e2a3a;"></div>
                <div class="fw-bold fs-3 text-dark">@stats.TourCompletionRate.ToString("0.#")%</div>
                <small class="text-muted">Tỉ lệ hoàn tất</small>
            </div>
        </div>
    </div>
}

<!-- Timeline Chart -->
<div class="row mb-4">
    <div class="col-12">
        <div class="admin-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Lượt nghe theo ngày (@selectedPeriod ngày qua)</h5>
                @if (isLoadingTimeline)
                {
                    <span class="spinner-border spinner-border-sm text-secondary" role="status"></span>
                }
            </div>
            <div style="height: 260px; position: relative;">
                <canvas id="timeline-chart"></canvas>
            </div>
            @if (!isLoadingTimeline && (timeline == null || !timeline.Any()))
            {
                <p class="text-muted text-center mt-2 mb-0"><em>Chưa có dữ liệu</em></p>
            }
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="admin-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Nhịp nguồn phát theo ngày</h5>
                <small class="text-muted">Tách theo QR, Tour, GPS và phát thủ công</small>
            </div>
            @if (sourceTimeline != null && sourceTimeline.Any())
            {
                <div class="source-timeline">
                    @foreach (var day in sourceTimeline.OrderByDescending(item => item.Date).Take(Math.Min(selectedPeriod, 12)))
                    {
                        <div class="source-timeline-row">
                            <div class="source-timeline-date">
                                <strong>@day.Date.ToString("dd/MM")</strong>
                                <small>@day.Total lượt</small>
                            </div>
                            <div class="source-timeline-metrics">
                                <span class="metric-chip qr">QR @day.QrScan</span>
                                <span class="metric-chip tour">Tour @day.TourStart</span>
                                @if (day.TourResume > 0)
                                {
                                    <span class="metric-chip resume">Tiếp @day.TourResume</span>
                                }
                                <span class="metric-chip gps">GPS @day.Geofence</span>
                                <span class="metric-chip manual">Manual @day.Manual</span>
                                @if (day.TourProgress > 0)
                                {
                                    <span class="metric-chip progress">Đi tiếp @day.TourProgress</span>
                                }
                                @if (day.TourComplete > 0)
                                {
                                    <span class="metric-chip complete">Xong @day.TourComplete</span>
                                }
                                @if (day.TourDismiss > 0)
                                {
                                    <span class="metric-chip dismiss">Bỏ @day.TourDismiss</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted text-center mt-2 mb-0"><em>Chưa có dữ liệu breakdown theo nguồn</em></p>
            }
        </div>
    </div>
</div>

<div class="row">
    <!-- Top POIs -->
    <div class="col-md-6 mb-4">
        <div class="admin-card h-100">
            <h5 class="mb-3">Top Điểm Được Nghe Nhiều</h5>
            @if (topPois != null && topPois.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>POI</th>
                                <th>Lượt nghe</th>
                                <th>TB (giây)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var poi in topPois)
                            {
                                <tr>
                                    <td>
                                        @rank
                                    </td>
                                    <td class="fw-bold">@poi.LocationName</td>
                                    <td>@poi.PlayCount</td>
                                    <td>@poi.AvgDuration.ToString("F1")</td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center py-4">Chưa có dữ liệu</p>
            }
        </div>
    </div>

    <!-- Recent Plays -->
    <div class="col-md-6 mb-4">
        <div class="admin-card h-100">
            <h5 class="mb-3">Lượt Nghe Gần Đây</h5>
            @if (recentPlays != null && recentPlays.Any())
            {
                <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                    @foreach (var play in recentPlays.Take(10))
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <div class="fw-bold">@play.LocationName</div>
                                <small class="text-muted">@play.PlayedAt.ToString("dd/MM HH:mm") • @GetSourceLabel(play.Source) • @(NormalizeLanguageLabel(play.Language))</small>
                            </div>
                            <span class="badge bg-secondary">@play.DurationSeconds.ToString("F0")s</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted text-center py-4">Chưa có lượt nghe</p>
            }
        </div>
    </div>
</div>

<!-- Doughnut charts: Sources & Devices -->
<div class="row">
    <!-- Source Breakdown -->
    <div class="col-md-4 mb-4">
        <div class="admin-card h-100">
            <h5 class="mb-3">Nguồn Phát</h5>
            @if (sources != null && sources.Any())
            {
                <div style="height: 220px; position: relative;">
                    <canvas id="sources-chart"></canvas>
                </div>
                <div class="mt-3">
                    @foreach (var source in sources)
                    {
                        var periodTotal = GetCurrentPeriodTotal(sources?.Sum(item => item.Count) ?? 0);
                        var percentage = periodTotal > 0 ? (source.Count * 100.0 / periodTotal) : 0;
                        var label = GetSourceLabel(source.Source);
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>@label</span>
                            <span class="fw-semibold text-dark">@source.Count (@percentage.ToString("F1")%)</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted text-center py-4">Chưa có dữ liệu</p>
            }
        </div>
    </div>

    <!-- Device Breakdown -->
    <div class="col-md-4 mb-4">
        <div class="admin-card h-100">
            <h5 class="mb-3">Thiết bị</h5>
            @if (devices != null && devices.Any())
            {
                <div style="height: 220px; position: relative;">
                    <canvas id="devices-chart"></canvas>
                </div>
                <div class="mt-3">
                    @foreach (var device in devices)
                    {
                        var periodTotal = GetCurrentPeriodTotal(devices?.Sum(item => item.Count) ?? 0);
                        var percentage = periodTotal > 0 ? (device.Count * 100.0 / periodTotal) : 0;
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>@device.Device</span>
                            <span class="fw-semibold text-dark">@device.Count (@percentage.ToString("F1")%)</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted text-center py-4">Chưa có dữ liệu</p>
            }
        </div>
    </div>

    <!-- Language Breakdown -->
    <div class="col-md-4 mb-4">
        <div class="admin-card h-100">
            <h5 class="mb-3">Ngôn ngữ sử dụng</h5>
            @if (languages != null && languages.Any())
            {
                <div style="height: 220px; position: relative;">
                    <canvas id="languages-chart"></canvas>
                </div>
                <div class="mt-3">
                    @foreach (var language in languages)
                    {
                        var periodTotal = GetCurrentPeriodTotal(languages?.Sum(item => item.Count) ?? 0);
                        var percentage = periodTotal > 0 ? (language.Count * 100.0 / periodTotal) : 0;
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>@GetLanguageFlag(language.Language) @NormalizeLanguageLabel(language.Language)</span>
                            <span class="fw-semibold text-dark">@language.Count (@percentage.ToString("F1")%)</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted text-center py-4">Chưa có dữ liệu</p>
            }
        </div>
    </div>
</div>

<!-- Heatmap Section -->
<div class="row mt-2">
    <div class="col-12">
        <div class="admin-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Heatmap vị trí người dùng</h5>
                <div>
                    <span class="badge bg-primary me-2">@heatmapUserCount điểm GPS</span>
                    <span class="badge bg-success">@heatmapPlayCount điểm nghe</span>
                </div>
            </div>
            <div id="heatmap-container" style="height: 450px; border-radius: 12px; overflow: hidden; background: #f1f5f9;"></div>
            @if (heatmapUserCount == 0 && heatmapPlayCount == 0)
            {
                <p class="text-muted text-center mt-3 mb-0">
                    <em>Chưa có dữ liệu vị trí. Khi người dùng sử dụng app với GPS, heatmap sẽ hiển thị mật độ di chuyển ở đây.</em>
                </p>
            }
        </div>
    </div>
</div>

<style>
    .source-timeline {
        display: flex;
        flex-direction: column;
        gap: var(--space-2-5);
    }

    .source-timeline-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-3) var(--space-3-5);
        border-radius: var(--radius-lg);
        background: var(--surface-inset);
    }

    .source-timeline-date {
        min-width: 86px;
    }

    .source-timeline-date strong,
    .source-timeline-date small {
        display: block;
    }

    .source-timeline-date small {
        color: var(--text-secondary);
    }

    .source-timeline-metrics {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: var(--space-2);
    }

    .metric-chip {
        display: inline-flex;
        align-items: center;
        padding: var(--space-1-5) var(--space-2-5);
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        font-weight: var(--weight-semibold);
    }

    .metric-chip.qr { background: rgba(249, 115, 22, 0.14); color: var(--color-warning-dark); }
    .metric-chip.tour { background: rgba(99, 102, 241, 0.14); color: #4338ca; }
    .metric-chip.resume { background: rgba(14, 165, 233, 0.14); color: #0369a1; }
    .metric-chip.gps { background: rgba(16, 185, 129, 0.14); color: var(--color-success-dark); }
    .metric-chip.manual { background: rgba(100, 116, 139, 0.14); color: var(--text-secondary); }
    .metric-chip.progress { background: rgba(168, 85, 247, 0.14); color: #7c3aed; }
    .metric-chip.complete { background: rgba(34, 197, 94, 0.14); color: var(--color-success-dark); }
    .metric-chip.dismiss { background: rgba(239, 68, 68, 0.14); color: var(--color-danger-dark); }

    @@media (max-width: 768px) {
        .source-timeline-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .source-timeline-metrics {
            justify-content: flex-start;
        }
    }
</style>

@code {
    private StatsDto? stats;
    private List<PoiFilterOption> poiOptions = new();
    private List<TopPoiDto>? topPois;
    private List<SourceDto>? sources;
    private List<DeviceDto>? devices;
    private List<LanguageDto>? languages;
    private List<RecentPlayDto>? recentPlays;
    private List<TimelineDto>? timeline;
    private List<SourceTimelineDto>? sourceTimeline;
    private int selectedPeriod = 30;
    private int selectedLocationId;
    private int heatmapUserCount = 0;
    private int heatmapPlayCount = 0;
    private bool heatmapRendered = false;
    private bool isLoadingTimeline = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadPoiOptionsAsync();
        await LoadData(30);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || !heatmapRendered)
        {
            await LoadHeatmap();
            heatmapRendered = true;
        }

        // Render charts after DOM is ready
        await RenderCharts();
    }

    private async Task LoadData(int days)
    {
        selectedPeriod = days;
        isLoadingTimeline = true;
        StateHasChanged();
        var locationQuery = selectedLocationId > 0 ? $"&locationId={selectedLocationId}" : string.Empty;

        try
        {
            stats        = await Http.GetFromJsonAsync<StatsDto>($"api/admin/analytics/stats?days={days}{locationQuery}");
            topPois      = await Http.GetFromJsonAsync<List<TopPoiDto>>($"api/admin/analytics/top-pois?days={days}{locationQuery}");
            sources      = await Http.GetFromJsonAsync<List<SourceDto>>($"api/admin/analytics/sources?days={days}{locationQuery}");
            devices      = await Http.GetFromJsonAsync<List<DeviceDto>>($"api/admin/analytics/devices?days={days}{locationQuery}");
            languages    = await Http.GetFromJsonAsync<List<LanguageDto>>($"api/admin/analytics/languages?days={days}{locationQuery}");
            recentPlays  = await Http.GetFromJsonAsync<List<RecentPlayDto>>($"api/admin/analytics/recent?days={days}{locationQuery}");
            timeline     = await Http.GetFromJsonAsync<List<TimelineDto>>($"api/admin/analytics/timeline?days={days}{locationQuery}");
            sourceTimeline = await Http.GetFromJsonAsync<List<SourceTimelineDto>>($"api/admin/analytics/timeline-sources?days={days}{locationQuery}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading analytics: {ex.Message}");
        }

        isLoadingTimeline = false;
        StateHasChanged();

        await LoadHeatmap();
        await RenderCharts();
    }

    private async Task ExportSummaryAsync()
    {
        var url = $"api/admin/analytics/export-summary?days={selectedPeriod}";
        if (selectedLocationId > 0)
        {
            url += $"&locationId={selectedLocationId}";
        }

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task OnPoiChangedAsync()
    {
        await LoadData(selectedPeriod);
    }

    private async Task LoadPoiOptionsAsync()
    {
        try
        {
            poiOptions = await Http.GetFromJsonAsync<List<PoiFilterOption>>("api/maps/locations/admin/all") ?? new();
            poiOptions = poiOptions.OrderBy(poi => poi.Name).ToList();
        }
        catch
        {
            poiOptions = new();
        }
    }

    private async Task RenderCharts()
    {
        // Timeline line chart
        if (timeline != null && timeline.Any())
        {
            var labels = timeline.Select(t => t.Date.ToString("dd/MM")).ToArray();
            var data   = timeline.Select(t => t.Count).ToArray();
            await JS.InvokeVoidAsync("ChartHelper.renderTimeline", "timeline-chart", labels, data);
        }

        // Sources doughnut
        if (sources != null && sources.Any())
        {
            var srcLabels = sources.Select(s => s.Source switch
            {
                "qr_scan"  => "Quét QR",
                "geofence" => "GPS / Geofence",
                "tour_start" => "Bắt đầu tour",
                "tour_resume" => "Tiếp tục tour",
                "tour_progress" => "Đi tiếp tour",
                "tour_complete" => "Hoàn tất tour",
                "tour_dismiss" => "Bỏ dở tour",
                "manual"   => "Mở thủ công",
                _          => s.Source
            }).ToArray();
            var srcData   = sources.Select(s => s.Count).ToArray();
            string[] srcColors = ["#6366f1", "#0ea5e9", "#a855f7", "#22c55e", "#ef4444", "#10b981", "#f59e0b"];
            await JS.InvokeVoidAsync("ChartHelper.renderDoughnut", "sources-chart", srcLabels, srcData, srcColors);
        }

        // Devices doughnut
        if (devices != null && devices.Any())
        {
            var devLabels = devices.Select(d => d.Device ?? "Unknown").ToArray();
            var devData   = devices.Select(d => d.Count).ToArray();
            string[] devColors = ["#3b82f6", "#8b5cf6", "#ec4899", "#14b8a6"];
            await JS.InvokeVoidAsync("ChartHelper.renderDoughnut", "devices-chart", devLabels, devData, devColors);
        }

        // Languages doughnut
        if (languages != null && languages.Any())
        {
            var langLabels = languages.Select(l => $"{GetLanguageFlag(l.Language)} {NormalizeLanguageLabel(l.Language)}").ToArray();
            var langData = languages.Select(l => l.Count).ToArray();
            string[] langColors = ["#0ea5e9", "#22c55e", "#f97316", "#a855f7", "#ef4444", "#64748b"];
            await JS.InvokeVoidAsync("ChartHelper.renderDoughnut", "languages-chart", langLabels, langData, langColors);
        }
    }

    private async Task LoadHeatmap()
    {
        try
        {
            var heatmapData = await Http.GetFromJsonAsync<HeatmapResponse>(
                $"api/admin/analytics/heatmap?days={selectedPeriod}{(selectedLocationId > 0 ? $"&locationId={selectedLocationId}" : string.Empty)}");

            if (heatmapData != null)
            {
                heatmapUserCount = heatmapData.TotalUserLocations;
                heatmapPlayCount = heatmapData.TotalPlayLocations;
                StateHasChanged();

                await JS.InvokeVoidAsync("HeatmapHelper.render",
                    "heatmap-container",
                    heatmapData.Center.Lat,
                    heatmapData.Center.Lng,
                    heatmapData.Points);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Heatmap error: {ex.Message}");
        }
    }

    private string GetSourceLabel(string? source) => source?.ToLower() switch
    {
        "qr_scan" => "QR Code",
        "tour_start" => "Tour",
        "tour_resume" => "Tiếp tục tour",
        "tour_progress" => "Đi tiếp tour",
        "tour_complete" => "Hoàn tất tour",
        "tour_dismiss" => "Bỏ dở tour",
        "geofence" => "GPS",
        "manual" => "Thủ công",
        _ => source ?? "Unknown"
    };

    private string GetLanguageFlag(string? lang) => lang?.ToLower() switch
    {
        "vi-vn" or "vi" => "VN",
        "en-us" or "en" => "US",
        "zh-cn" or "zh" => "CN",
        "ja-jp" or "ja" => "JP",
        "ko-kr" or "ko" => "KR",
        _ => ""
    };

    private string NormalizeLanguageLabel(string? lang) => lang?.ToLower() switch
    {
        "vi-vn" or "vi" => "Tiếng Việt",
        "en-us" or "en" => "English",
        "zh-cn" or "zh" => "中文",
        "ja-jp" or "ja" => "日本語",
        "ko-kr" or "ko" => "한국어",
        null or "" => "Unknown",
        _ => lang
    };

