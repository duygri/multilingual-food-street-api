@page "/owner/login"
@inject FoodStreet.Client.Services.IAuthService AuthService
@inject NavigationManager Navigation
@inject FoodStreet.Client.Services.ILocalizationService L
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<div class="auth-page">
    <div class="auth-container">
        <!-- Left Side - Branding -->
        <div class="auth-branding seller-branding">
            <div class="branding-content">
                <div class="brand-logo">
                    <span class="logo-icon">🏪</span>
                </div>
                <h1 class="brand-title">Vĩnh Khánh POI Owner</h1>
                <p class="brand-tagline">Quản lý POI của bạn cho trải nghiệm thuyết minh đa ngôn ngữ</p>
                <div class="brand-features">
                    <div class="feature-item">
                        <span class="feature-icon">📈</span>
                        <span>Quản lý POI và menu dễ dàng</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-icon">🔊</span>
                        <span>Auto-TTS đa ngôn ngữ miễn phí</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-icon">📍</span>
                        <span>Xuất hiện trực tiếp trên bản đồ du lịch</span>
                    </div>
                </div>
            </div>
            <div class="branding-footer">
                <span>Cổng thông tin dành cho POI Owner và đối tác vận hành</span>
            </div>
        </div>
        
        <!-- Right Side - Form -->
        <div class="auth-form-container">
            <div class="auth-form-wrapper">
                <div class="auth-header">
                    <h2>Đăng nhập POI Owner</h2>
                    <p>Dành cho POI Owner / Quản lý địa điểm</p>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert-box @(isError ? "alert-error" : "alert-success")">
                        <span class="alert-icon">@(isError ? "⚠️" : "✅")</span>
                        <div class="alert-content">
                            @if (errorList != null && errorList.Any())
                            {
                                <ul>
                                    @foreach (var err in errorList)
                                    {
                                        <li>@err</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span>@message</span>
                            }
                        </div>
                    </div>
                }

                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                    <div class="form-group">
                        <label>Email đăng nhập</label>
                        <div class="input-wrapper @(validationErrors.ContainsKey("Email") ? "has-error" : "")">
                            <span class="input-icon">✉️</span>
                            <input type="email" @bind="model.Email" placeholder="partner@example.com" />
                        </div>
                        @if (validationErrors.ContainsKey("Email"))
                        {
                            <span class="error-text">@validationErrors["Email"]</span>
                        }
                    </div>
                    
                    <div class="form-group">
                        <label>Mật khẩu</label>
                        <div class="input-wrapper @(validationErrors.ContainsKey("Password") ? "has-error" : "")">
                            <span class="input-icon">🔒</span>
                            <input type="password" @bind="model.Password" placeholder="••••••••" />
                        </div>
                        @if (validationErrors.ContainsKey("Password"))
                        {
                            <span class="error-text">@validationErrors["Password"]</span>
                        }
                    </div>

                    <button type="submit" class="btn-submit" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                        }
                        <span>Truy cập cổng POI Owner</span>
                    </button>
                    
                    <div class="auth-switch mt-3 text-center">
                        <span style="font-size: 0.9rem; color: #666;">Chưa có tài khoản POI Owner? Vui lòng liên hệ Admin để cấp quyền.</span>
                    </div>
                </form>

                <div class="auth-footer d-flex flex-column gap-2 mt-4">
                    <a href="/admin/login" style="color: #64748b;"><i class="bi bi-shield-lock"></i> Đăng nhập bằng quyền Admin</a>
                    <a href="/" style="color: #64748b;"><i class="bi bi-arrow-left"></i> Về trang chủ ứng dụng</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .seller-branding {
        background: linear-gradient(135deg, #27ae60 0%, #1e8449 100%) !important;
    }
    .seller-branding::before {
        background: radial-gradient(circle, rgba(241,196,15,0.15) 0%, transparent 70%) !important;
    }
    .brand-logo .logo-icon {
        background: linear-gradient(135deg, #f1c40f 0%, #f39c12 100%) !important;
        box-shadow: 0 12px 40px rgba(241,196,15,0.4) !important;
    }
    .btn-submit {
        background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%) !important;
    }
    .btn-submit:hover:not(:disabled) {
        box-shadow: 0 8px 25px rgba(39,174,96,0.35) !important;
    }
    
    .auth-page {
        min-height: 100vh;
        background: #f0f2f5;
    }
    
    .auth-container {
        display: flex;
        min-height: 100vh;
    }
    
    /* Branding Side */
    .auth-branding {
        width: 45%;
        padding: 48px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    
    .auth-branding::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 100%;
        height: 100%;
    }
    
    .branding-content {
        position: relative;
        z-index: 1;
    }
    
    .brand-logo {
        margin-bottom: 24px;
    }
    
    .brand-logo .logo-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 80px;
        height: 80px;
        border-radius: 20px;
        font-size: 40px;
    }
    
    .brand-title {
        font-size: 48px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 8px;
        letter-spacing: -1px;
    }
    
    .brand-tagline {
        font-size: 20px;
        color: rgba(255,255,255,0.8);
        margin: 0 0 48px;
    }
    
    .brand-features {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    
    .feature-item {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.9);
        font-size: 16px;
    }
    
    .feature-icon {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }
    
    .branding-footer {
        position: absolute;
        bottom: 32px;
        left: 48px;
        color: rgba(255,255,255,0.6);
        font-size: 13px;
    }
    
    /* Form Side */
    .auth-form-container {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px;
    }
    
    .auth-form-wrapper {
        width: 100%;
        max-width: 420px;
    }
    
    .auth-header {
        margin-bottom: 32px;
    }
    
    .auth-header h2 {
        font-size: 28px;
        font-weight: 700;
        color: #1e2a3a;
        margin: 0 0 8px;
    }
    
    .auth-header p {
        color: #64748b;
        margin: 0;
    }
    
    .alert-box {
        display: flex;
        gap: 12px;
        padding: 16px;
        border-radius: 12px;
        margin-bottom: 24px;
    }
    
    .alert-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
    }
    
    .alert-success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
    }
    
    .alert-icon {
        font-size: 20px;
    }
    
    .alert-content {
        flex: 1;
        font-size: 14px;
    }
    
    .alert-content ul {
        margin: 0;
        padding-left: 16px;
    }
    
    .form-group {
        margin-bottom: 20px;
    }
    
    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #1e2a3a;
        margin-bottom: 8px;
    }
    
    .input-wrapper {
        display: flex;
        align-items: center;
        background: #fff;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 0 16px;
        transition: all 0.2s ease;
    }
    
    .input-wrapper:focus-within {
        border-color: #27ae60;
        box-shadow: 0 0 0 3px rgba(39,174,96,0.1);
    }
    
    .input-wrapper.has-error {
        border-color: #ef4444;
    }
    
    .input-icon {
        font-size: 16px;
        margin-right: 12px;
    }
    
    .input-wrapper input {
        flex: 1;
        border: none;
        padding: 14px 0;
        font-size: 15px;
        background: transparent;
        outline: none;
    }
    
    .error-text {
        display: block;
        color: #ef4444;
        font-size: 13px;
        margin-top: 6px;
    }
    
    .btn-submit {
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: 12px;
        color: #fff;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s ease;
    }
    
    .btn-submit:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }
    
    .spinner {
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
    
    .auth-footer {
        text-align: center;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #e2e8f0;
    }
    
    .auth-footer a {
        text-decoration: none;
        font-size: 14px;
        display: block;
        padding: 8px 0;
        transition: 0.2s ease;
    }
    
    .auth-footer a:hover {
        color: #27ae60 !important;
    }
    
    @@media (max-width: 900px) {
        .auth-branding {
            display: none;
        }
        
        .auth-form-container {
            padding: 24px;
        }
    }
</style>

@code {
    private AuthModel model = new();
    private bool isLoading = false;
    private string? message;
    private List<string>? errorList;
    private bool isError = false;
    private Dictionary<string, string> validationErrors = new();

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLanguageChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        message = null;
        errorList = null;
        validationErrors.Clear();
        model = new AuthModel();
        StateHasChanged();
    }

    private void OnLanguageChanged()
    {
        message = null;
        errorList = null;
        validationErrors.Clear();
        StateHasChanged();
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private bool ValidateForm()
    {
        validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(model.Email))
        {
            validationErrors["Email"] = "Vui lòng nhập email đăng nhập";
        }
        else if (!model.Email.Contains("@") || !model.Email.Contains("."))
        {
            validationErrors["Email"] = "Email bị sai định dạng";
        }

        if (string.IsNullOrWhiteSpace(model.Password))
        {
            validationErrors["Password"] = "Mật khẩu không được để trống";
        }

        return validationErrors.Count == 0;
    }

    private async Task HandleSubmit()
    {
        if (!ValidateForm())
        {
            return;
        }

        isLoading = true;
        message = null;
        errorList = null;

        try
        {
            var result = await AuthService.LoginAsync(model.Email, model.Password);

            if (result.Success)
            {
                var authState = await ((Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider)AuthStateProvider).GetAuthenticationStateAsync();
                var user = authState.User;

                if (!UiRoles.IsPoiOwner(user) && !user.IsInRole(UiRoles.Admin))
                {
                    await AuthService.ClearTokensAsync();
                    isError = true;
                    message = "Tài khoản của bạn chưa được cấp quyền POI Owner!";
                    return;
                }
                
                AuthService.NotifyStateChanged();
                
                if (UiRoles.IsPoiOwner(user))
                {
                    Navigation.NavigateTo("/owner/dashboard");
                }
                else 
                {
                    Navigation.NavigateTo("/admin/locations");
                }
            }
            else
            {
                isError = true;
                message = result.Message ?? "Tài khoản hoặc mật khẩu không chính xác.";
                errorList = result.Errors;
            }
        }
        catch (Exception ex)
        {
            isError = true;
            message = "Không thể kết nối với máy chủ: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    public class AuthModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
