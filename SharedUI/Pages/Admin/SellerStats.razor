@page "/owner/stats"
@layout AdminLayout
@inject IOwnerPortalService OwnerPortal
@inject ILocationClientService LocationService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@using Microsoft.AspNetCore.Components
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = UiRoles.PoiOwnerCompat)]

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">Thống kê POI của tôi</h3>
        <p class="text-muted mb-0">Theo dõi lượt nghe thuyết minh, quét QR và hiệu suất nội dung của các điểm bạn quản lý.</p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <select class="form-select" style="min-width: 260px;" @bind="selectedLocationId" @bind:after="OnPoiChangedAsync">
            <option value="0">Tất cả POI của tôi</option>
            @foreach (var poi in myPoiOptions)
            {
                <option value="@poi.Id">@poi.Name</option>
            }
        </select>
        <div class="btn-group">
            <button class="btn @(selectedPeriod == 7 ? "btn-admin btn-admin-primary" : "btn-outline-secondary")"
                    @onclick="() => LoadDataAsync(7)">7 ngày</button>
            <button class="btn @(selectedPeriod == 30 ? "btn-admin btn-admin-primary" : "btn-outline-secondary")"
                    @onclick="() => LoadDataAsync(30)">30 ngày</button>
            <button class="btn @(selectedPeriod == 90 ? "btn-admin btn-admin-primary" : "btn-outline-secondary")"
                    @onclick="() => LoadDataAsync(90)">90 ngày</button>
        </div>
        <button class="btn btn-outline-primary" @onclick="ExportSummaryAsync">
            Export Summary
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="admin-card text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Đang tải thống kê owner...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (analytics == null)
{
    <div class="alert alert-warning">Không thể tải dữ liệu thống kê owner ở thời điểm này.</div>
}
else
{
    <div class="row mb-4">
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#6B21A8;"></div>
                <div class="fw-bold fs-2 text-primary">@analytics.TotalPois</div>
                <small class="text-muted">POI đang quản lý</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#22c55e;"></div>
                <div class="fw-bold fs-2 text-success">@analytics.ApprovedPois</div>
                <small class="text-muted">Đã duyệt</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#3b82f6;"></div>
                <div class="fw-bold fs-2 text-info">@analytics.TotalPlays</div>
                <small class="text-muted">Lượt nghe (@selectedPeriod ngày)</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#f59e0b;"></div>
                <div class="fw-bold fs-2 text-warning">@analytics.PoisWithAudio</div>
                <small class="text-muted">POI có audio sẵn sàng</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#0ea5e9;"></div>
                <div class="fw-bold fs-2 text-primary">@analytics.TotalPoiTranslations</div>
                <small class="text-muted">@analytics.FullyLocalizedPois/@analytics.TotalPois POI đủ bộ</small>
            </div>
        </div>
        <div class="col-6 col-md-3 mb-3">
            <div class="admin-card text-center py-4">
                <div class="stat-dot" style="background:#14b8a6;"></div>
                <div class="fw-bold fs-2 text-success">@analytics.TotalMenuTranslations</div>
                <small class="text-muted">@analytics.FullyLocalizedMenuItems/@analytics.TotalMenuItems menu đủ bộ</small>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="admin-card h-100">
                <div class="small text-muted mb-2">Quét QR</div>
                <div class="fw-bold fs-3 text-primary">@analytics.TotalQrScans</div>
                <div class="small text-muted">Từ quét mã tại chỗ</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="admin-card h-100">
                <div class="small text-muted mb-2">Bắt đầu tour</div>
                <div class="fw-bold fs-3 text-primary">@analytics.TotalTourStarts</div>
                <div class="small text-muted">Khởi động từ tour trải nghiệm</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="admin-card h-100">
                <div class="small text-muted mb-2">Nghe trung bình</div>
                <div class="fw-bold fs-3 text-primary">@analytics.AvgListenDurationSeconds.ToString("0.#")s</div>
                <div class="small text-muted">Mỗi lượt nghe</div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card h-100">
                <div class="small text-muted mb-2">Phiên tour đang dở</div>
                <div class="fw-bold fs-3 text-primary">@analytics.ActiveTourSessions</div>
                <div class="small text-muted">Đang dừng ở một POI thuộc phạm vi của bạn</div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card h-100">
                <div class="small text-muted mb-2">Tiếp tục tour</div>
                <div class="fw-bold fs-3 text-info">@analytics.TotalTourResumes</div>
                <div class="small text-muted">Du khách quay lại hành trình</div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card h-100">
                <div class="small text-muted mb-2">Hoàn tất tour</div>
                <div class="fw-bold fs-3 text-success">@analytics.TotalTourCompletions</div>
                <div class="small text-muted">Kết thúc trọn vẹn hành trình</div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card h-100">
                <div class="small text-muted mb-2">Bỏ dở tour</div>
                <div class="fw-bold fs-3 text-danger">@analytics.TotalTourDismissals</div>
                <div class="small text-muted">Phiên bị đóng trước khi hoàn tất</div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl mb-3">
            <div class="admin-card h-100">
                <div class="small text-muted mb-2">Tỉ lệ hoàn tất</div>
                <div class="fw-bold fs-3 text-dark">@analytics.TourCompletionRate.ToString("0.#")%</div>
                <div class="small text-muted">So với số phiên đã bắt đầu</div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="admin-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="small text-muted">Độ phủ bản dịch POI</div>
                    <strong>@analytics.PoiTranslationCoveragePercent.ToString("0.#")%</strong>
                </div>
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: @($"{analytics.PoiTranslationCoveragePercent}%")"></div>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="admin-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="small text-muted">Độ phủ bản dịch menu</div>
                    <strong>@analytics.MenuTranslationCoveragePercent.ToString("0.#")%</strong>
                </div>
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @($"{analytics.MenuTranslationCoveragePercent}%")"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="admin-card h-100">
                <h6 class="mb-3">Ngôn ngữ được dùng nhiều</h6>
                @if (analytics.Languages.Any())
                {
                    @foreach (var item in analytics.Languages.Take(5))
                    {
                        var total = analytics.Languages.Sum(x => x.Count);
                        var percent = total > 0 ? item.Count * 100d / total : 0;
                        <div class="d-flex justify-content-between small text-muted mb-2">
                            <span>@GetLanguageFlag(item.Label) @NormalizeLanguageLabel(item.Label)</span>
                            <span class="fw-semibold text-dark">@item.Count (@percent.ToString("0.#")%)</span>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted small">Chưa có dữ liệu ngôn ngữ.</div>
                }
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="admin-card h-100">
                <h6 class="mb-3">Nguồn tương tác chính</h6>
                @if (analytics.Sources.Any())
                {
                    @foreach (var item in analytics.Sources.Take(5))
                    {
                        var total = analytics.Sources.Sum(x => x.Count);
                        var percent = total > 0 ? item.Count * 100d / total : 0;
                        <div class="d-flex justify-content-between small text-muted mb-2">
                            <span>@GetSourceLabel(item.Label)</span>
                            <span class="fw-semibold text-dark">@item.Count (@percent.ToString("0.#")%)</span>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted small">Chưa có dữ liệu nguồn tương tác.</div>
                }
            </div>
        </div>
    </div>

    <div class="admin-card">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div>
                <h5 class="mb-1">Hiệu suất từng POI</h5>
                <div class="small text-muted">Sắp xếp theo lượng tương tác trong @selectedPeriod ngày gần nhất.</div>
            </div>
            @if (analytics.LastPlayedAt.HasValue)
            {
                <span class="badge bg-light text-dark border">
                    Hoạt động gần nhất: @analytics.LastPlayedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </span>
            }
        </div>

        @if (analytics.Pois.Count == 0)
        {
            <div class="text-center py-5">
                <div class="text-muted" style="font-size: 1.5rem;">POI</div>
                <p class="text-muted mt-2 mb-3">Bạn chưa có POI nào để thống kê.</p>
                <a href="/owner/dashboard" class="btn btn-admin btn-admin-primary">Tạo POI đầu tiên</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle admin-table">
                    <thead>
                        <tr>
                            <th>POI</th>
                            <th>Trạng thái</th>
                            <th>Audio</th>
                            <th>Bản dịch</th>
                            <th>Lượt nghe</th>
                            <th>QR / Hành trình</th>
                            <th>Ngôn ngữ phổ biến</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var poi in analytics.Pois)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(poi.ImageUrl))
                                        {
                                            <img src="@poi.ImageUrl" alt="@poi.Name" style="width: 44px; height: 44px; object-fit: cover; border-radius: 10px;" />
                                        }
                                        else
                                        {
                                            <div style="width: 44px; height: 44px; border-radius: 10px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 12px; color: #94a3b8;">POI</div>
                                        }
                                        <div>
                                            <strong>@poi.Name</strong>
                                            <div class="small text-muted">@(poi.Address ?? "Chưa có địa chỉ")</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (poi.IsApproved)
                                    {
                                        <span class="badge bg-success">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                    }
                                </td>
                                <td>
                                    @if (poi.HasAudio)
                                    {
                                        <span class="badge bg-info text-dark">@poi.AudioStatus</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <div class="small"><strong>POI:</strong> @poi.TranslationCoveragePercent.ToString("0.#")% (@poi.TranslationCount/4)</div>
                                    <div class="small text-muted"><strong>Menu:</strong> @poi.MenuTranslationCoveragePercent.ToString("0.#")% (@poi.FullyLocalizedMenuItems/@poi.MenuItemCount đủ bộ)</div>
                                </td>
                                <td>
                                    <div class="fw-bold">@poi.PlayCount</div>
                                    <div class="small text-muted">@poi.AvgListenDurationSeconds.ToString("0.#") giây / lượt</div>
                                </td>
                                <td>
                                    <div class="small"><strong>QR:</strong> @poi.QrScanCount</div>
                                    <div class="small text-muted"><strong>Start / Resume:</strong> @poi.TourStartCount / @poi.TourResumeCount</div>
                                    <div class="small text-muted"><strong>Done / Dismiss:</strong> @poi.TourCompletionCount / @poi.TourDismissCount</div>
                                    <div class="small text-muted"><strong>Tỉ lệ HT:</strong> @poi.TourCompletionRate.ToString("0.#")%</div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(poi.TopLanguage))
                                    {
                                        <span class="badge bg-secondary">@poi.TopLanguage</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "locationId")]
    public int? QueryLocationId { get; set; }

    private OwnerAnalyticsDto? analytics;
    private List<LocationDto> myPoiOptions = new();
    private int selectedPeriod = 30;
    private int selectedLocationId;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadPoiOptionsAsync();
        if (QueryLocationId.HasValue && QueryLocationId.Value > 0 && myPoiOptions.Any(poi => poi.Id == QueryLocationId.Value))
        {
            selectedLocationId = QueryLocationId.Value;
        }
        await LoadDataAsync(selectedPeriod);
    }

    private async Task LoadDataAsync(int days)
    {
        selectedPeriod = days;
        isLoading = true;
        errorMessage = null;

        try
        {
            analytics = await OwnerPortal.GetAnalyticsAsync(days, selectedLocationId > 0 ? selectedLocationId : null);
            SyncQueryString();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải thống kê owner: {ex.Message}";
            analytics = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExportSummaryAsync()
    {
        var url = $"api/owner/analytics/export?days={selectedPeriod}";
        if (selectedLocationId > 0)
        {
            url += $"&locationId={selectedLocationId}";
        }

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task OnPoiChangedAsync()
    {
        await LoadDataAsync(selectedPeriod);
    }

    private async Task LoadPoiOptionsAsync()
    {
        try
        {
            var locations = await LocationService.GetMyLocations();
            myPoiOptions = locations.OrderBy(location => location.Name).ToList();
        }
        catch
        {
            myPoiOptions = new();
        }
    }

    private void SyncQueryString()
    {
        var target = selectedLocationId > 0
            ? $"/owner/stats?locationId={selectedLocationId}"
            : "/owner/stats";

        if (!string.Equals(Navigation.Uri, Navigation.ToAbsoluteUri(target).ToString(), StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo(target, replace: true);
        }
    }

    private string GetSourceLabel(string? source) => source?.ToLower() switch
    {
        "qr_scan" => "QR Code",
        "tour_start" => "Tour",
        "tour_resume" => "Tiếp tục tour",
        "tour_progress" => "Đi tiếp tour",
        "tour_complete" => "Hoàn tất tour",
        "tour_dismiss" => "Bỏ dở tour",
        "geofence" => "GPS / Geofence",
        "manual" => "Thủ công",
        _ => source ?? "Unknown"
    };

    private string GetLanguageFlag(string? lang) => lang?.ToLower() switch
    {
        "vi-vn" or "vi" => "VN",
        "en-us" or "en" => "US",
        "zh-cn" or "zh" => "CN",
        "ja-jp" or "ja" => "JP",
        "ko-kr" or "ko" => "KR",
        _ => "--"
    };

    private string NormalizeLanguageLabel(string? lang) => lang?.ToLower() switch
    {
        "vi-vn" or "vi" => "Tiếng Việt",
        "en-us" or "en" => "English",
        "zh-cn" or "zh" => "中文",
        "ja-jp" or "ja" => "日本語",
        "ko-kr" or "ko" => "한국어",
        null or "" => "Unknown",
        _ => lang
    };
}
