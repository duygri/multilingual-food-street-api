@page "/admin/locations"
@layout AdminLayout

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">📍 Quản lý Địa điểm</h3>
    <button class="btn btn-admin btn-admin-primary" @onclick="ShowCreateModal">
        ➕ Thêm địa điểm mới
    </button>
</div>

<div class="admin-card">
    @if (locations == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
            <p class="mt-3 text-muted">Đang tải danh sách địa điểm...</p>
        </div>
    }
    else if (locations.Count == 0)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem;">🗺️</div>
            <h5 class="mt-3">Chưa có địa điểm nào</h5>
            <p class="text-muted">Nhấn "Thêm địa điểm mới" để tạo mới.</p>
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Tên địa điểm</th>
                    <th>Mô tả</th>
                    <th>Vĩ độ</th>
                    <th>Kinh độ</th>
                    <th>Bán kính (m)</th>
                    <th style="width: 150px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loc in locations)
                {
                    <tr>
                        <td><strong>@loc.Name</strong></td>
                        <td class="text-muted">@(loc.Description?.Length > 40 ? loc.Description.Substring(0, 40) + "..." : loc.Description)</td>
                        <td><code>@loc.Latitude.ToString("F6")</code></td>
                        <td><code>@loc.Longitude.ToString("F6")</code></td>
                        <td><span class="badge bg-info">@loc.Radius m</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditModal(loc)">✏️ Sửa</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLocation(loc.Id)">🗑️</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tên địa điểm</label>
                        <input type="text" class="form-control" @bind="editingLocation.Name" placeholder="VD: Vĩnh Khánh" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" rows="3" @bind="editingLocation.Description" placeholder="Mô tả địa điểm..."></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Vĩ độ (Latitude)</label>
                            <input type="number" step="0.000001" class="form-control" @bind="editingLocation.Latitude" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kinh độ (Longitude)</label>
                            <input type="number" step="0.000001" class="form-control" @bind="editingLocation.Longitude" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bán kính kích hoạt (m)</label>
                        <input type="number" class="form-control" @bind="editingLocation.Radius" />
                        <small class="text-muted">Phạm vi kích hoạt geofence</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Hủy</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveLocation">Lưu</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LocationModel>? locations;
    private bool showModal = false;
    private string modalTitle = "";
    private LocationModel editingLocation = new();
    private bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadLocations();
    }

    private async Task LoadLocations()
    {
        // Placeholder data - in real app, load from API
        locations = new List<LocationModel>
        {
            new LocationModel 
            { 
                Id = 1, 
                Name = "Vĩnh Khánh", 
                Description = "Thiên đường ẩm thực Quận 4", 
                Latitude = 10.7580, 
                Longitude = 106.7034, 
                Radius = 500 
            }
        };
        await Task.CompletedTask;
    }

    private void ShowCreateModal()
    {
        editingLocation = new LocationModel();
        modalTitle = "Thêm địa điểm mới";
        isEditing = false;
        showModal = true;
    }

    private void ShowEditModal(LocationModel loc)
    {
        editingLocation = new LocationModel
        {
            Id = loc.Id,
            Name = loc.Name,
            Description = loc.Description,
            Latitude = loc.Latitude,
            Longitude = loc.Longitude,
            Radius = loc.Radius
        };
        modalTitle = "Sửa địa điểm";
        isEditing = true;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveLocation()
    {
        if (isEditing)
        {
            var existing = locations?.FirstOrDefault(l => l.Id == editingLocation.Id);
            if (existing != null)
            {
                existing.Name = editingLocation.Name;
                existing.Description = editingLocation.Description;
                existing.Latitude = editingLocation.Latitude;
                existing.Longitude = editingLocation.Longitude;
                existing.Radius = editingLocation.Radius;
            }
        }
        else
        {
            editingLocation.Id = (locations?.Max(l => l.Id) ?? 0) + 1;
            locations?.Add(editingLocation);
        }
        showModal = false;
        await Task.CompletedTask;
    }

    private async Task DeleteLocation(int id)
    {
        locations?.RemoveAll(l => l.Id == id);
        await Task.CompletedTask;
    }

    public class LocationModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int Radius { get; set; } = 100;
    }
}
