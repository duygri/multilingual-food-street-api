@page "/admin/locations"
@layout AdminLayout
@inject FoodStreet.Client.Services.ILocationClientService LocationService
@inject FoodStreet.Client.Services.INotificationService NotificationSvc
@inject IAudioService AudioService
@inject TourPlayerService TourService
@inject IJSRuntime JS
@inject IPlatformDetector PlatformDetector
@inject IMobileNativeMapService NativeMapService
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@inject NavigationManager Navigation
@implements IDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Quản lý POI</h3>
    <button class="btn btn-admin btn-admin-primary" @onclick="ShowCreateModal">
        Thêm POI mới
    </button>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (successMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="d-flex gap-2 mb-3 flex-wrap">
    <button class="btn @(activeFilter == "all" ? "btn-admin btn-admin-primary" : "btn-outline-secondary")" @onclick='() => SetFilter("all")'>
        Tất cả (@AllCount)
    </button>
    <button class="btn @(activeFilter == "pending" ? "btn-admin btn-admin-primary" : "btn-outline-secondary")" @onclick='() => SetFilter("pending")'>
        Chờ duyệt (@PendingCount)
    </button>
    <button class="btn @(activeFilter == "approved" ? "btn-admin btn-admin-primary" : "btn-outline-secondary")" @onclick='() => SetFilter("approved")'>
        Đã duyệt (@ApprovedCount)
    </button>
</div>

<div class="admin-card">
    @if (displayedLocations == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
            <p class="mt-3 text-muted">Đang tải...</p>
        </div>
    }
    else if (displayedLocations.Count == 0)
    {
        <div class="text-center py-5">
            <div class="text-muted" style="font-size: 1.5rem;">POI</div>
            <h5 class="mt-3">Chưa có POI nào</h5>
            <p class="text-muted">Nhấn "Thêm POI mới" để bắt đầu.</p>
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width: 80px;">Ảnh</th>
                    <th>Tên POI</th>
                    <th>Trạng thái</th>
                    <th>Địa chỉ</th>
                    <th>Tọa độ & Bán kính</th>
                    <th>Audio</th>
                    <th style="width: 220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loc in displayedLocations)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(loc.ImageUrl))
                            {
                                <img src="@loc.ImageUrl" alt="@loc.Name" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                            }
                            else
                            {
                                <div style="width: 60px; height: 60px; border-radius: 8px; background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; border: 1px dashed #ccc;">
                                    <span style="font-size: 1rem; color: #adb5bd;">IMG</span>
                                </div>
                            }
                        </td>
                        <td>
                            <strong style="font-size: 1.1rem; color: #2c3e50;">@loc.Name</strong>
                            @{
                                switch (loc.Priority)
                                {
                                    case 3:
                                        <span class="badge bg-danger rounded-pill fw-normal ms-2" title="Ưu tiên phát đè mọi audio">Cảnh báo / Chỉ đường</span>
                                        break;
                                    case 2:
                                        <span class="badge bg-warning text-dark rounded-pill fw-normal ms-2" title="Trạm nên ghé qua">Điểm nhấn nổi bật</span>
                                        break;
                                    case 1:
                                        <span class="badge bg-primary bg-opacity-75 rounded-pill fw-normal ms-2">Trạm tiêu chuẩn</span>
                                        break;
                                    case 0:
                                    default:
                                        <span class="badge bg-secondary bg-opacity-50 text-dark rounded-pill fw-normal ms-2">Trạm tùy chọn</span>
                                        break;
                                }
                            }
                            @if (!string.IsNullOrEmpty(loc.Description))
                            {
                                <br /><small class="text-muted">@(loc.Description.Length > 50 ? loc.Description.Substring(0, 50) + "..." : loc.Description)</small>
                            }
                        </td>
                        <td>
                            @if (loc.IsApproved)
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">Đã duyệt</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Chờ duyệt</span>
                                <div class="small text-muted mt-1">Cần Admin kiểm duyệt</div>
                            }
                        </td>
                        <td class="text-muted">
                            <div class="d-flex flex-column gap-1">
                                <span>@(string.IsNullOrEmpty(loc.Address) ? "—" : loc.Address)</span>
                                @if (!string.IsNullOrEmpty(loc.MapLink))
                                {
                                    <a href="@loc.MapLink" target="_blank" class="small text-decoration-none">Xem bản đồ</a>
                                }
                            </div>
                        </td>
                        <td>
                            <div class="small text-secondary mb-1"><code>@loc.Latitude.ToString("F4"), @loc.Longitude.ToString("F4")</code></div>
                            <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-2">Kích hoạt: @loc.Radius m</span>
                        </td>
                        <td>
                            @if (loc.HasAudio)
                            {
                                <span class="badge bg-success rounded-pill">Có audio</span>
                            }
                            else if (!string.IsNullOrEmpty(loc.TtsScript))
                            {
                                <span class="badge bg-secondary rounded-pill">TTS</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                @if (!loc.IsApproved)
                                {
                                    <button class="btn btn-sm btn-success shadow-sm" style="border-radius: 6px;" @onclick="() => ApproveLocation(loc)" title="Duyệt POI">OK</button>
                                    <button class="btn btn-sm btn-warning text-dark shadow-sm" style="border-radius: 6px;" @onclick="() => RejectLocation(loc)" title="Từ chối POI">No</button>
                                }
                                <button class="btn btn-sm btn-outline-primary shadow-sm" style="border-radius: 6px;" @onclick="() => ShowEditModal(loc)" title="Sửa">Edit</button>
                                <button class="btn btn-sm btn-outline-info shadow-sm" style="border-radius: 6px;" @onclick="() => ShowDetailsModal(loc)" title="Xem">View</button>
                                <button class="btn btn-sm btn-outline-danger shadow-sm" style="border-radius: 6px;" @onclick="() => DeleteLocation(loc.Id)" title="Xóa">Del</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@* Modal thêm/sửa POI *@
@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tên POI *</label>
                            <input type="text" class="form-control" @bind="editingLocation.Name" placeholder="VD: Quán Phở Vĩnh Khánh" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Địa chỉ</label>
                            <input type="text" class="form-control" @bind="editingLocation.Address" placeholder="VD: 123 Đường Vĩnh Khánh, Q.4" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" rows="2" @bind="editingLocation.Description" placeholder="Mô tả ngắn về POI..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Chọn vị trí trên bản đồ</label>
                        @if (UseNativePicker)
                        {
                            <div class="alert alert-info border-0 bg-opacity-10 mb-3">
                                <i class="bi bi-phone me-2"></i> Trên mobile, hệ thống sẽ mở bản đồ Android native để chọn tọa độ POI.
                            </div>
                            <button type="button" class="btn btn-outline-primary mb-2" @onclick="OpenNativePickerAsync">
                                Mở picker Android native
                            </button>
                            <div><small class="text-muted">Chạm bản đồ hoặc kéo marker trong màn native để lấy tọa độ.</small></div>
                        }
                        else
                        {
                            <div class="position-relative">
                                <div class="input-group mb-2">
                                    <input type="text" class="form-control" placeholder="Nhập địa chỉ cần tìm (VD: Chợ Bến Thành)..." @bind="mapSearchQuery" @bind:event="oninput" @onkeydown="@(async e => { if (e.Key == "Enter") await SearchLocationMap(); })" />
                                    <button class="btn btn-outline-secondary" type="button" @onclick="SearchLocationMap" disabled="@isSearchingMap">
                                        @if (isSearchingMap) { <span class="spinner-border spinner-border-sm"></span> } else { <span>Tìm</span> }
                                    </button>
                                </div>
                                @if (mapSearchResults != null && mapSearchResults.Any())
                                {
                                    <ul class="list-group shadow-sm" style="position: absolute; z-index: 1050; width: 100%; max-height: 250px; overflow-y: auto; top: 100%; left: 0;">
                                        @foreach (var res in mapSearchResults)
                                        {
                                            <li class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => SelectSearchResult(res)">
                                                <div class="fw-bold">@res.text</div>
                                                <small class="text-muted">@res.place_name</small>
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                            <div id="poi-map-picker" style="height: 250px; width: 100%; border-radius: 8px; border: 1px solid #e2e8f0; z-index: 1;"></div>
                            <small class="text-muted">Kéo thả marker hoặc click điểm trên bản đồ để cập nhật tọa độ</small>
                        }
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Vĩ độ (Latitude)</label>
                            <input type="number" step="0.000001" class="form-control" @bind="editingLocation.Latitude" @onblur="SyncMapToInputs" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Kinh độ (Longitude)</label>
                            <input type="number" step="0.000001" class="form-control" @bind="editingLocation.Longitude" @onblur="SyncMapToInputs" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Bán kính (m)</label>
                            <input type="number" class="form-control" @bind="editingLocation.Radius" />
                            <small class="text-muted">Phạm vi geofence</small>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phân cấp điểm đến (Mức độ ưu tiên)</label>
                            <select class="form-select" @bind="editingLocation.Priority">
                                <option value="0">Trạm tùy chọn (Mức 0)</option>
                                <option value="1">Trạm tiêu chuẩn (Mức 1)</option>
                                <option value="2">Điểm nhấn nổi bật (Mức 2)</option>
                                <option value="3">Cảnh báo / Chỉ đường (Mức 3)</option>
                            </select>
                            <small class="text-muted">Audio của cấp cao hơn sẽ luôn phát đè cấp thấp.</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Link Google Map (Tùy chọn)</label>
                            <input type="text" class="form-control" @bind="editingLocation.MapLink" placeholder="https://maps.google.com/..." />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hình ảnh minh họa</label>
                        <div class="card p-3 bg-light border-0 shadow-sm">
                            <div class="row align-items-center">
                                <div class="col-md-3 text-center mb-3 mb-md-0">
                                    @if (!string.IsNullOrEmpty(editingLocation.ImageUrl))
                                    {
                                        <img src="@editingLocation.ImageUrl" class="img-fluid rounded shadow-sm" style="max-height: 100px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center bg-white rounded border border-dashed" style="height: 100px; color: #ccc;">
                                            <span style="font-size: 1rem; color: #ccc;">IMG</span>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-9">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control" @bind="editingLocation.ImageUrl" placeholder="Nhập link ảnh (https://...)" />
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <label class="btn btn-sm btn-outline-primary mb-0 me-2" style="cursor: pointer; border-radius: 6px;">
                                            Tải ảnh lên từ máy
                                            <InputFile OnChange="UploadImage" accept="image/*" style="display: none;" />
                                        </label>
                                        @if (isUploadingImage)
                                        {
                                            <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                                            <small class="text-muted">Đang xử lý...</small>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung đọc tự động (TTS Script)</label>
                        <textarea class="form-control" rows="3" @bind="editingLocation.TtsScript" placeholder="Nội dung sẽ được đọc lên khi du khách đi vào vùng Geofence (nếu không có sẵn Audio file)..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Hủy</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveLocation" disabled="@saving">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @(isEditing ? "Lưu" : "Gửi yêu cầu")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Modal Xem chi tiết (Read-only cho Admin) *@
@if (showDetailsModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">Chi tiết POI</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetailsModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Tên POI</label>
                            <p class="fw-bold fs-5">@viewLocation.Name</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">Địa chỉ</label>
                            <p>@(string.IsNullOrEmpty(viewLocation.Address) ? "—" : viewLocation.Address)</p>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">Mô tả</label>
                        <p class="border p-2 rounded bg-light">@(string.IsNullOrEmpty(viewLocation.Description) ? "—" : viewLocation.Description)</p>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label text-muted">Vĩ độ (Latitude)</label>
                            <p><code>@viewLocation.Latitude</code></p>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label text-muted">Kinh độ (Longitude)</label>
                            <p><code>@viewLocation.Longitude</code></p>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label text-muted">Bán kính (m)</label>
                            <p><span class="badge bg-info">@viewLocation.Radius m</span></p>
                        </div>
                    </div>
                    <div class="row px-2">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted mb-1"><small>Phân cấp điểm đến</small></label>
                            <div>
                                @switch (viewLocation.Priority)
                                {
                                    case 3:
                                        <span class="badge bg-danger rounded-pill fw-medium fs-6">Cảnh báo / Chỉ đường khẩn</span>
                                        break;
                                    case 2:
                                        <span class="badge bg-warning text-dark rounded-pill fw-medium fs-6">Điểm nhấn nổi bật</span>
                                        break;
                                    case 1:
                                        <span class="badge bg-primary bg-opacity-75 rounded-pill fw-medium fs-6">Trạm tiêu chuẩn</span>
                                        break;
                                    case 0:
                                    default:
                                        <span class="badge bg-secondary bg-opacity-50 text-dark rounded-pill fw-medium fs-6">Trạm tùy chọn</span>
                                        break;
                                }
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted mb-1"><small>Bản đồ</small></label>
                            <div>
                                @if (!string.IsNullOrEmpty(viewLocation.MapLink))
                                {
                                    <a href="@viewLocation.MapLink" target="_blank" class="btn btn-sm btn-outline-info shadow-sm rounded-pill px-3">
                                        Mở Google Map
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(viewLocation.ImageUrl))
                    {
                        <div class="mb-4 text-center bg-light p-3 rounded border shadow-sm">
                            <img src="@viewLocation.ImageUrl" alt="@viewLocation.Name" class="img-fluid rounded" style="max-height: 250px; object-fit: contain;" />
                        </div>
                    }

                    <div class="mb-3 p-3 bg-light rounded shadow-sm">
                        <label class="form-label text-muted mb-2 fw-bold">TTS Script (Kịch bản đọc máy)</label>
                        <p class="mb-0 text-dark" style="font-style: italic;">
                            "@(string.IsNullOrEmpty(viewLocation.TtsScript) ? "Chưa có kịch bản Text-to-speech." : viewLocation.TtsScript)"
                        </p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">Audio Files</label>
                        @if (viewLocationAudios != null && viewLocationAudios.Any())
                        {
                            <div class="list-group">
                                @foreach (var audio in viewLocationAudios)
                                {
                                    <div class="list-group-item d-flex align-items-center gap-2">
                                        <span style="color:#64748b;">♪</span>
                                        <div class="flex-grow-1">
                                            <div class="fw-bold small">@(audio.OriginalName ?? audio.FileName)</div>
                                            <small class="text-muted">@FormatSize(audio.Size)</small>
                                        </div>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => PlayAudioInDetail(audio)" title="Play">Play</button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có audio. Gán audio trong trang <a href="/admin/audio">Audio Management</a>.</p>
                    }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDetailsModal">Đóng</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LocationDto>? allLocations;
    private List<LocationDto>? displayedLocations;
    private string activeFilter = "all";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool showModal = false;
    private string modalTitle = "";
    private LocationDto editingLocation = new();
    private bool isEditing = false;
    private bool saving = false;
    private bool isUploadingImage = false;
    
    private bool showDetailsModal = false;
    private LocationDto viewLocation = new();
    private List<AudioFileDto>? viewLocationAudios;

    private System.Threading.Timer? _pollingTimer;
    private bool _isPolling = false;
    private DotNetObjectReference<Locations>? objRef;

    private string? errorMessage;
    private string? successMessage;

    private string mapSearchQuery = "";
    private bool isSearchingMap = false;
    private List<MapSearchResult> mapSearchResults = new();
    private bool UseNativePicker => PlatformDetector.IsMobile;

    public class MapSearchResult {
        public double lat { get; set; }
        public double lng { get; set; }
        public string? placeId { get; set; }
        public string text { get; set; } = "";
        public string place_name { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this);
        NotificationSvc.OnRealtimeActivity += HandleRealtimeActivity;
        await LoadData();

        // Auto-refresh mỗi 15 giây
        _pollingTimer = new System.Threading.Timer(async _ =>
        {
            if (saving || showModal || _isPolling) return;
            _isPolling = true;
            await InvokeAsync(async () =>
            {
                try
                {
                    await SilentReload();
                    StateHasChanged();
                }
                catch { }
                finally { _isPolling = false; }
            });
        }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
    }

    /// <summary>
    /// Tải lại dữ liệu mà không hiển thị lỗi (dùng cho polling)
    /// </summary>
    private async Task SilentReload()
    {
        try
        {
            allLocations = await LocationService.GetAllLocations();
            ApplyFilter();
        }
        catch { }
    }

    private async Task LoadData()
    {
        try
        {
            allLocations = await LocationService.GetAllLocations();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải dữ liệu: {ex.Message}";
            allLocations = new();
            displayedLocations = new();
        }
    }

    private int AllCount => allLocations?.Count ?? 0;
    private int PendingCount => allLocations?.Count(l => !l.IsApproved) ?? 0;
    private int ApprovedCount => allLocations?.Count(l => l.IsApproved) ?? 0;

    private void SetFilter(string filter)
    {
        activeFilter = filter;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        displayedLocations = activeFilter switch
        {
            "pending" => allLocations?.Where(l => !l.IsApproved).ToList() ?? new(),
            "approved" => allLocations?.Where(l => l.IsApproved).ToList() ?? new(),
            _ => allLocations ?? new()
        };
    }

