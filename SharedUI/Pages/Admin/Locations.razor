@page "/admin/locations"
@layout AdminLayout
@inject FoodStreet.Client.Services.ILocationClientService LocationService
@inject IJSRuntime JS
@using FoodStreet.Client.DTOs
@inject NavigationManager Navigation
@implements IDisposable

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">📍 Quản lý POI</h3>
    <button class="btn btn-admin btn-admin-primary" @onclick="ShowCreateModal">
        ➕ Thêm POI mới
    </button>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        ❌ @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (successMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        ✅ @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="admin-card">
    @if (displayedLocations == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
            <p class="mt-3 text-muted">Đang tải...</p>
        </div>
    }
    else if (displayedLocations.Count == 0)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem;">🗺️</div>
            <h5 class="mt-3">Chưa có POI nào</h5>
            <p class="text-muted">Nhấn "Thêm POI mới" để bắt đầu.</p>
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Tên POI</th>
                    <th>Địa chỉ</th>
                    <th>Tọa độ</th>
                    <th>Bán kính</th>
                    <th>Món ăn</th>
                    <th style="width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loc in displayedLocations)
                {
                    <tr>
                        <td>
                            <strong>@loc.Name</strong>
                            @if (!string.IsNullOrEmpty(loc.Description))
                            {
                                <br /><small class="text-muted">@(loc.Description.Length > 40 ? loc.Description.Substring(0, 40) + "..." : loc.Description)</small>
                            }
                        </td>
                        <td class="text-muted">@(loc.Address ?? "—")</td>
                        <td><code>@loc.Latitude.ToString("F4"), @loc.Longitude.ToString("F4")</code></td>
                        <td><span class="badge bg-info">@loc.Radius m</span></td>
                        <td><span class="badge bg-secondary">@loc.FoodCount món</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditModal(loc)" title="Sửa">✏️</button>
                            <button class="btn btn-sm btn-outline-info me-1" @onclick="() => ShowDetailsModal(loc)" title="Xem">👁️</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLocation(loc.Id)" title="Xóa">🗑️</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@* Modal thêm/sửa POI *@
@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">📍 Tên POI *</label>
                            <input type="text" class="form-control" @bind="editingLocation.Name" placeholder="VD: Quán Phở Vĩnh Khánh" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">🏠 Địa chỉ</label>
                            <input type="text" class="form-control" @bind="editingLocation.Address" placeholder="VD: 123 Đường Vĩnh Khánh, Q.4" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">📝 Mô tả</label>
                        <textarea class="form-control" rows="2" @bind="editingLocation.Description" placeholder="Mô tả ngắn về POI..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">🗺️ Chọn vị trí trên bản đồ</label>
                        <div class="input-group mb-2">
                            <input type="text" class="form-control" placeholder="Nhập địa chỉ cần tìm (VD: Chợ Bến Thành)..." @bind="mapSearchQuery" @bind:event="oninput" @onkeydown="@(e => { if (e.Key == "Enter") SearchLocationMap(); })" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="SearchLocationMap" disabled="@isSearchingMap">
                                @if (isSearchingMap) { <span class="spinner-border spinner-border-sm"></span> } else { <span>🔍 Tìm</span> }
                            </button>
                        </div>
                        <div id="poi-map-picker" style="height: 250px; width: 100%; border-radius: 8px; border: 1px solid #e2e8f0; z-index: 1;"></div>
                        <small class="text-muted">Kéo thả icon 📍 hoặc click điểm trên bản đồ để cập nhật tọa độ</small>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">🌐 Vĩ độ (Latitude)</label>
                            <input type="number" step="0.000001" class="form-control" @bind="editingLocation.Latitude" @onblur="SyncMapToInputs" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">🌐 Kinh độ (Longitude)</label>
                            <input type="number" step="0.000001" class="form-control" @bind="editingLocation.Longitude" @onblur="SyncMapToInputs" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">📏 Bán kính (m)</label>
                            <input type="number" class="form-control" @bind="editingLocation.Radius" />
                            <small class="text-muted">Phạm vi geofence</small>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">⭐ Độ ưu tiên</label>
                            <input type="number" class="form-control" @bind="editingLocation.Priority" />
                            <small class="text-muted">Số cao hơn = ưu tiên hơn</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">🖼️ Link hình ảnh</label>
                            <div class="input-group mb-2">
                                <input type="text" class="form-control" @bind="editingLocation.ImageUrl" placeholder="https://example.com/image.jpg" />
                            </div>
                            <div class="d-flex align-items-center mt-2">
                                <label class="btn btn-sm btn-outline-secondary mb-0 me-2" style="cursor: pointer;">
                                    📸 Chọn từ máy
                                    <InputFile OnChange="UploadImage" accept="image/*" style="display: none;" />
                                </label>
                                @if (isUploadingImage)
                                {
                                    <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                                    <small class="text-muted">Đang tải ảnh lên...</small>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">🔊 TTS Script (tùy chọn)</label>
                        <textarea class="form-control" rows="2" @bind="editingLocation.TtsScript" placeholder="Nội dung đọc tự động khi vào vùng geofence..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Hủy</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveLocation" disabled="@saving">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @(isEditing ? "💾 Lưu" : "📤 Gửi yêu cầu")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Modal Xem chi tiết (Read-only cho Admin) *@
@if (showDetailsModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">👁️ Chi tiết POI</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetailsModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">📍 Tên POI</label>
                            <p class="fw-bold fs-5">@viewLocation.Name</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">🏠 Địa chỉ</label>
                            <p>@(string.IsNullOrEmpty(viewLocation.Address) ? "—" : viewLocation.Address)</p>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">📝 Mô tả</label>
                        <p class="border p-2 rounded bg-light">@(string.IsNullOrEmpty(viewLocation.Description) ? "—" : viewLocation.Description)</p>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label text-muted">🌐 Vĩ độ (Latitude)</label>
                            <p><code>@viewLocation.Latitude</code></p>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label text-muted">🌐 Kinh độ (Longitude)</label>
                            <p><code>@viewLocation.Longitude</code></p>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label text-muted">📏 Bán kính (m)</label>
                            <p><span class="badge bg-info">@viewLocation.Radius m</span></p>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">⭐ Độ ưu tiên</label>
                            <p>@viewLocation.Priority</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted">🖼️ Hình ảnh</label>
                            <div class="mt-1">
                                @if (!string.IsNullOrEmpty(viewLocation.ImageUrl))
                                {
                                    <a href="@viewLocation.ImageUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                        👁️ Xem hình ảnh
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted">🔊 TTS Script (Đọc tự động)</label>
                        <p class="border p-2 rounded bg-light">@(string.IsNullOrEmpty(viewLocation.TtsScript) ? "—" : viewLocation.TtsScript)</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDetailsModal">Đóng</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LocationDto>? allLocations;
    private List<LocationDto>? displayedLocations;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool showModal = false;
    private string modalTitle = "";
    private LocationDto editingLocation = new();
    private bool isEditing = false;
    private bool saving = false;
    private bool isUploadingImage = false;
    
    private bool showDetailsModal = false;
    private LocationDto viewLocation = new();

    private System.Threading.Timer? _pollingTimer;
    private bool _isPolling = false;
    private DotNetObjectReference<Locations>? objRef;

    private string? errorMessage;
    private string? successMessage;

    private string mapSearchQuery = "";
    private bool isSearchingMap = false;

    public class MapSearchResult {
        public string lat { get; set; } = "";
        public string lng { get; set; } = "";
        public string display_name { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this);
        await LoadData();

        // Auto-refresh mỗi 15 giây
        _pollingTimer = new System.Threading.Timer(async _ =>
        {
            if (saving || showModal || _isPolling) return;
            _isPolling = true;
            await InvokeAsync(async () =>
            {
                try
                {
                    await SilentReload();
                    StateHasChanged();
                }
                catch { }
                finally { _isPolling = false; }
            });
        }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
    }

    /// <summary>
    /// Tải lại dữ liệu mà không hiển thị lỗi (dùng cho polling)
    /// </summary>
    private async Task SilentReload()
    {
        try
        {
            allLocations = await LocationService.GetAllLocations();
            displayedLocations = allLocations;
        }
        catch { }
    }

    private async Task LoadData()
    {
        try
        {
            allLocations = await LocationService.GetAllLocations();
            displayedLocations = allLocations;
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải dữ liệu: {ex.Message}";
            allLocations = new();
            displayedLocations = new();
        }
    }

    private async Task ShowCreateModal()
    {
        editingLocation = new LocationDto { Radius = 50, Latitude = 10.7680, Longitude = 106.7034 };
        modalTitle = "➕ Thêm POI mới";
        isEditing = false;
        showModal = true;
        await InitMapPicker();
    }

    private async Task ShowEditModal(LocationDto loc)
    {
        editingLocation = new LocationDto
        {
            Id = loc.Id,
            Name = loc.Name,
            Description = loc.Description,
            Address = loc.Address,
            Latitude = loc.Latitude,
            Longitude = loc.Longitude,
            Radius = loc.Radius,
            Priority = loc.Priority,
            ImageUrl = loc.ImageUrl,
            TtsScript = loc.TtsScript,
            CategoryId = loc.CategoryId
        };
        modalTitle = "✏️ Sửa POI";
        isEditing = true;
        showModal = true;
        await InitMapPicker();
    }

    private void CloseModal() => showModal = false;

    private void ShowDetailsModal(LocationDto loc)
    {
        viewLocation = loc;
        showDetailsModal = true;
    }

    private void CloseDetailsModal() => showDetailsModal = false;

    private async Task SaveLocation()
    {
        saving = true;
        try
        {
            if (isEditing)
            {
                await LocationService.UpdateLocation(editingLocation.Id, editingLocation);
                successMessage = $"Đã cập nhật \"{editingLocation.Name}\"";
            }
            else
            {
                await LocationService.CreateLocation(editingLocation);
                successMessage = $"Đã tạo POI \"{editingLocation.Name}\"";
            }
            showModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeleteLocation(int id)
    {
        try
        {
            await LocationService.DeleteLocation(id);
            successMessage = "Đã xóa POI";
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể xóa: {ex.Message}";
        }
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        isUploadingImage = true;
        errorMessage = null;

        try
        {
            // Limit to 5MB
            if (file.Size > 5 * 1024 * 1024)
            {
                errorMessage = "File ảnh quá lớn (tối đa 5MB).";
                return;
            }

            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var url = await LocationService.UploadImageAsync(content);
            if (!string.IsNullOrEmpty(url))
            {
                // Update text input with the returned URL from the server
                editingLocation.ImageUrl = Navigation.BaseUri.TrimEnd('/') + url;
            }
            else
            {
                errorMessage = "Tải ảnh lên thất bại, vui lòng thử lại.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi khi tải ảnh: {ex.Message}";
        }
        finally
        {
            isUploadingImage = false;
            StateHasChanged();
        }
    }



    public void Dispose()
    {
        _pollingTimer?.Dispose();
        objRef?.Dispose();
    }

    [JSInvokable]
    public void UpdateCoordinatesFromMap(double lat, double lng)
    {
        editingLocation.Latitude = lat;
        editingLocation.Longitude = lng;
        StateHasChanged();
    }

    private async Task SyncMapToInputs()
    {
        try { await JS.InvokeVoidAsync("LeafletMap.updatePickerMarker", editingLocation.Latitude, editingLocation.Longitude); } catch { }
    }
    
    private async Task SearchLocationMap()
    {
        if (string.IsNullOrWhiteSpace(mapSearchQuery)) return;
        isSearchingMap = true;
        try 
        {
            var result = await JS.InvokeAsync<MapSearchResult>("LeafletMap.searchAddress", mapSearchQuery);
            if (result != null)
            {
                if (double.TryParse(result.lat, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat) &&
                    double.TryParse(result.lng, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lng))
                {
                    editingLocation.Latitude = lat;
                    editingLocation.Longitude = lng;
                    await SyncMapToInputs();
                    
                    if (string.IsNullOrWhiteSpace(editingLocation.Address)) {
                        editingLocation.Address = result.display_name;
                    }
                }
            }
        }
        catch { }
        finally {
            isSearchingMap = false;
        }
    }

    private async Task InitMapPicker()
    {
        await Task.Delay(300); // Tăng thời gian chờ modal animation
        try 
        { 
            double lat = editingLocation.Latitude != 0 ? editingLocation.Latitude : 10.7680;
            double lng = editingLocation.Longitude != 0 ? editingLocation.Longitude : 106.7034;
            editingLocation.Latitude = lat;
            editingLocation.Longitude = lng;
            await JS.InvokeVoidAsync("LeafletMap.initPicker", "poi-map-picker", lat, lng, 16, objRef); 
            StateHasChanged();
        } 
        catch { }
    }
}
