    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        isUploadingImage = true;
        errorMessage = null;

        try
        {
            // Limit to 5MB
            if (file.Size > 5 * 1024 * 1024)
            {
                errorMessage = "File ảnh quá lớn (tối đa 5MB).";
                return;
            }

            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var url = await LocationService.UploadImageAsync(content);
            if (!string.IsNullOrEmpty(url))
            {
                // Update text input with the returned URL from the server
                editingLocation.ImageUrl = Navigation.BaseUri.TrimEnd('/') + url;
            }
            else
            {
                errorMessage = "Tải ảnh lên thất bại, vui lòng thử lại.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi khi tải ảnh: {ex.Message}";
        }
        finally
        {
            isUploadingImage = false;
            StateHasChanged();
        }
    }



    public void Dispose()
    {
        NotificationSvc.OnRealtimeActivity -= HandleRealtimeActivity;
        _pollingTimer?.Dispose();
        objRef?.Dispose();
    }

    private void HandleRealtimeActivity(RealtimeActivityDto activity)
    {
        if (activity.EntityType != "poi")
        {
            return;
        }

        if (activity.EventName is RealtimeEventNames.PoiUpdated
            or RealtimeEventNames.ModerationChanged
            or RealtimeEventNames.AudioReady)
        {
            _ = InvokeAsync(async () =>
            {
                await SilentReload();
                StateHasChanged();
            });
        }
    }

