    private string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }

    private async Task SaveLocation()
    {
        saving = true;
        try
        {
            if (isEditing)
            {
                await LocationService.UpdateLocation(editingLocation.Id, editingLocation);
                successMessage = $"Đã cập nhật \"{editingLocation.Name}\"";
            }
            else
            {
                await LocationService.CreateLocation(editingLocation);
                successMessage = $"Đã tạo POI \"{editingLocation.Name}\"";
            }
            showModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

