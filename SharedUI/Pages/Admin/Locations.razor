    private async Task SyncMapToInputs()
    {
        if (UseNativePicker)
        {
            return;
        }

        try { await JS.InvokeVoidAsync("AppMapHelper.updatePickerMarker", editingLocation.Latitude, editingLocation.Longitude); } catch { }
    }

    private async Task OpenNativePickerAsync()
    {
        var result = await NativeMapService.OpenPickerAsync(new MobileNativeMapRequest
        {
            Mode = MobileNativeMapMode.Picker,
            ScreenTitle = "Chọn vị trí POI",
            CenterLatitude = editingLocation.Latitude != 0 ? editingLocation.Latitude : 10.7680,
            CenterLongitude = editingLocation.Longitude != 0 ? editingLocation.Longitude : 106.7034,
            Zoom = 17f
        });

        if (result?.Confirmed == true && result.SelectedLatitude.HasValue && result.SelectedLongitude.HasValue)
        {
            editingLocation.Latitude = result.SelectedLatitude.Value;
            editingLocation.Longitude = result.SelectedLongitude.Value;
            await InvokeAsync(StateHasChanged);
        }
    }
    
    private async Task SearchLocationMap()
    {
        if (string.IsNullOrWhiteSpace(mapSearchQuery)) return;
        isSearchingMap = true;
        mapSearchResults.Clear();
        try
        {
            if (!await JS.InvokeAsync<bool>("AppMapHelper.hasConfiguredApiKey"))
            {
                errorMessage = "Chưa cấu hình Google Maps browser key trong runtime-config.js.";
                return;
            }

            var results = await JS.InvokeAsync<List<MapSearchResult>>("AppMapHelper.searchAddress", mapSearchQuery);
            if (results != null && results.Any())
            {
                mapSearchResults = results;
                StateHasChanged();
            }
        }
        catch
        {
            errorMessage = await GetMapHelperErrorAsync("Không thể tìm địa chỉ trên Google Maps.");
        }
        finally {
            isSearchingMap = false;
        }
    }

    private async Task SelectSearchResult(MapSearchResult res)
    {
        var selected = res;

        if (!string.IsNullOrWhiteSpace(res.placeId))
        {
            try
            {
                var resolved = await JS.InvokeAsync<MapSearchResult?>("AppMapHelper.resolveSelectedPlace", res.placeId);
                if (resolved != null && resolved.lat != 0 && resolved.lng != 0)
                {
                    selected = resolved;
                }
            }
            catch { }
        }

        editingLocation.Latitude = selected.lat;
        editingLocation.Longitude = selected.lng;
        if (string.IsNullOrWhiteSpace(editingLocation.Address)) {
            editingLocation.Address = selected.place_name;
        }
        if (string.IsNullOrWhiteSpace(editingLocation.Name)) {
            editingLocation.Name = selected.text;
        }
        mapSearchResults.Clear();
        mapSearchQuery = selected.text;
        await SyncMapToInputs();
    }

    private async Task InitMapPicker()
    {
        if (UseNativePicker)
        {
            await OpenNativePickerAsync();
            return;
        }

        await Task.Delay(300); // Tăng thời gian chờ modal animation
        try
        {
            if (!await JS.InvokeAsync<bool>("AppMapHelper.hasConfiguredApiKey"))
            {
                errorMessage = "Chưa cấu hình Google Maps browser key trong runtime-config.js.";
                return;
            }

            double lat = editingLocation.Latitude != 0 ? editingLocation.Latitude : 10.7680;
            double lng = editingLocation.Longitude != 0 ? editingLocation.Longitude : 106.7034;
            editingLocation.Latitude = lat;
            editingLocation.Longitude = lng;
            var initialized = await JS.InvokeAsync<bool>("AppMapHelper.initPicker", "poi-map-picker", lat, lng, 16, objRef, string.Empty);
            if (!initialized)
            {
                errorMessage = await GetMapHelperErrorAsync("Không thể mở bản đồ chọn vị trí POI.");
                return;
            }

            await Task.Delay(150);
            try { await JS.InvokeVoidAsync("AppMapHelper.resize"); } catch { }
            StateHasChanged();
        } 
        catch
        {
            errorMessage = await GetMapHelperErrorAsync("Không thể mở bản đồ chọn vị trí POI.");
        }
    }

    private async Task<string> GetMapHelperErrorAsync(string fallbackMessage)
    {
        try
        {
            var helperError = await JS.InvokeAsync<string>("AppMapHelper.getLastError", fallbackMessage);
            return string.IsNullOrWhiteSpace(helperError) ? fallbackMessage : helperError;
        }
        catch
        {
            return fallbackMessage;
        }
    }
