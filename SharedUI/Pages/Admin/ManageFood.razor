@page "/admin/foods"
@page "/seller/foods"
@layout AdminLayout
@inject FoodStreet.Client.Services.IFoodClientService FoodService
@inject FoodStreet.Client.Services.ILocationClientService LocationService
@inject ILocalizationService L
@using FoodStreet.Client.DTOs
@inject HttpClient Http

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">🍜 Quản lý Món ăn</h3>
    <button class="btn btn-admin btn-admin-primary" @onclick="ShowCreateModal">
        ➕ Thêm món mới
    </button>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        ❌ @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}
@if (successMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        ✅ @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="admin-card">
    @if (foods == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
            <p class="mt-3 text-muted">Đang tải...</p>
        </div>
    }
    else if (foods.Count == 0)
    {
        <div class="text-center py-5">
            <div style="font-size: 4rem;">🍽️</div>
            <h5 class="mt-3">Chưa có món ăn nào</h5>
            <p class="text-muted">Nhấn "Thêm món mới" để bắt đầu.</p>
        </div>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Tên món</th>
                    <th>Phân loại</th>
                    <th>Địa điểm</th>
                    <th>Mô tả</th>
                    <th>Giá</th>
                    <th style="width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var food in foods)
                {
                    <tr>
                        <td><strong>@food.Name</strong></td>
                        <td>
                            @if (!string.IsNullOrEmpty(food.CategoryName))
                            {
                                <span class="badge bg-info">@food.CategoryName</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(food.LocationName))
                            {
                                <span class="badge bg-secondary">📍 @food.LocationName</span>
                            }
                            else
                            {
                                <span class="text-muted">Chưa gán</span>
                            }
                        </td>
                        <td class="text-muted">@(food.Description?.Length > 40 ? food.Description.Substring(0, 40) + "..." : food.Description)</td>
                        <td><span class="badge bg-success">@food.Price.ToString("N0") VND</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditModal(food.Id)" title="Sửa">✏️</button>
                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => ShowAudioModal(food.Id)" title="Audio">🎵</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFood(food.Id)" title="Xóa">🗑️</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@* Modal thêm/sửa món ăn *@
@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@editingFood" OnValidSubmit="SaveFood">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">🍜 Tên món *</label>
                            <InputText @bind-Value="editingFood.Name" class="form-control" placeholder="VD: Phở Bò" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">📝 Mô tả</label>
                            <InputTextArea @bind-Value="editingFood.Description" class="form-control" rows="2" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">💰 Giá (VND)</label>
                            <InputNumber @bind-Value="editingFood.Price" class="form-control" placeholder="50000" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">📍 Địa điểm</label>
                            <InputSelect @bind-Value="editingFood.LocationId" class="form-select">
                                <option value="">-- Chọn địa điểm --</option>
                                @if (locations != null)
                                {
                                    @foreach (var loc in locations)
                                    {
                                        <option value="@loc.Id">📍 @loc.Name</option>
                                    }
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">📂 Phân loại</label>
                            <InputSelect @bind-Value="editingFood.CategoryId" class="form-select">
                                <option value="">-- Chọn phân loại --</option>
                                @if (categories != null)
                                {
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id">@cat.Icon @cat.Name</option>
                                    }
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">🖼️ Link hình ảnh</label>
                            <InputText @bind-Value="editingFood.ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-admin btn-admin-primary flex-grow-1">💾 Lưu</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">Hủy</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@* Modal upload audio *@
@if (showAudioModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">🎵 @L["UploadAudio"]</h5>
                    <button type="button" class="btn-close" @onclick="CloseAudioModal"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center py-4">
                        <div style="font-size: 3rem;">🎤</div>
                        <p class="mt-2">@L["SelectAudioFile"]</p>
                        <InputFile OnChange="@LoadFiles" class="form-control" accept="audio/*" />
                        @if (uploading)
                        {
                            <div class="mt-3">
                                <div class="spinner-border spinner-border-sm text-primary"></div>
                                <span class="ms-2">@L["Uploading"]</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<FoodDto>? foods;
    private List<CategoryDto>? categories;
    private List<LocationDto>? locations;
    private bool showModal = false;
    private bool showAudioModal = false;
    private string modalTitle = "";
    private FoodDto editingFood = new() { Name = "" };
    private int selectedFoodIdForAudio;
    private bool uploading = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadFoods();
        await LoadCategories();
        await LoadLocations();
    }

    private async Task LoadFoods()
    {
        try { foods = await FoodService.GetAllFoods(); }
        catch { foods = new(); }
    }

    private async Task LoadCategories()
    {
        try { categories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/category"); }
        catch { categories = new(); }
    }

    private async Task LoadLocations()
    {
        try { locations = await LocationService.GetAllLocations(); }
        catch { locations = new(); }
    }

    private void ShowCreateModal()
    {
        editingFood = new FoodDto { Name = "", Description = "" };
        modalTitle = "➕ Thêm món mới";
        showModal = true;
    }

    private async Task ShowEditModal(int id)
    {
        var dto = await FoodService.GetFood(id);
        if (dto != null)
        {
            editingFood = new FoodDto
            {
                Id = dto.Id,
                Name = dto.Name,
                Description = dto.Description,
                Price = dto.Price,
                ImageUrl = dto.ImageUrl,
                LocationId = dto.LocationId,
                CategoryId = dto.CategoryId
            };
        }
        modalTitle = "✏️ Sửa món ăn";
        showModal = true;
    }

    private void ShowAudioModal(int id) { selectedFoodIdForAudio = id; showAudioModal = true; }
    private void CloseModal() => showModal = false;
    private void CloseAudioModal() => showAudioModal = false;

    private async Task SaveFood()
    {
        try
        {
            if (editingFood.Id == 0)
            {
                await FoodService.CreateFood(editingFood);
                successMessage = $"Đã tạo \"{editingFood.Name}\"";
            }
            else
            {
                await FoodService.UpdateFood(editingFood.Id, editingFood);
                successMessage = $"Đã cập nhật \"{editingFood.Name}\"";
            }
            showModal = false;
            await LoadFoods();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
    }

    private async Task DeleteFood(int id)
    {
        try
        {
            await FoodService.DeleteFood(id);
            successMessage = "Đã xóa món ăn";
            await LoadFoods();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể xóa: {ex.Message}";
        }
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        uploading = true;
        try
        {
            using var content = new MultipartFormDataContent();
            var file = e.File;
            var fileContent = new StreamContent(file.OpenReadStream(10 * 1024 * 1024));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            await FoodService.UploadAudio(selectedFoodIdForAudio, content);
            showAudioModal = false;
            successMessage = "Đã tải lên audio";
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi upload: {ex.Message}";
        }
        finally
        {
            uploading = false;
        }
    }
}
