@page "/admin/qrcodes"
@layout AdminLayout
@inject HttpClient Http
@inject FoodStreet.Client.Services.ILocationClientService LocationService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@using FoodStreet.Client.DTOs

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">QR Code Generator</h3>
    <div class="btn-group">
        <button class="btn btn-admin btn-admin-primary" @onclick="DownloadSelected" disabled="@(!selectedIds.Any())">
            Download Selected (@selectedIds.Count)
        </button>
        <button class="btn btn-outline-secondary" @onclick="PrintSelected" disabled="@(!selectedIds.Any())">
            Print Sheet
        </button>
    </div>
</div>

<!-- Info Card -->
<div class="alert alert-info mb-4">
    <strong>Hướng dẫn:</strong> QR code này khi quét sẽ mở đúng trang POI và ghi nhận nguồn vào từ QR.
    Bạn có thể dán tại từng quán hoặc điểm giới thiệu để du khách đăng nhập rồi nghe thuyết minh ngay.
</div>

<!-- QR Code Grid -->
<div class="admin-card">
    @if (locations == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2">Loading POIs...</p>
        </div>
    }
    else if (!locations.Any())
    {
        <div class="text-center py-5">
            <div class="text-muted" style="font-size: 1.5rem;">QR</div>
            <p class="text-muted">Chưa có địa điểm. Tạo địa điểm trước!</p>
        </div>
    }
    else
    {
        <!-- Select All -->
        <div class="mb-4 d-flex align-items-center gap-3">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="selectAll" 
                       checked="@(selectedIds.Count == locations.Count)"
                       @onchange="ToggleSelectAll" />
                <label class="form-check-label" for="selectAll">
                    Chọn tất cả (@locations.Count địa điểm)
                </label>
            </div>
        </div>

        <!-- QR Grid -->
        <div class="row g-4">
            @foreach (var loc in locations)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 @(selectedIds.Contains(loc.Id) ? "border-primary border-2" : "")">
                        <div class="card-header d-flex align-items-center gap-2">
                            <input type="checkbox" class="form-check-input" 
                                   checked="@selectedIds.Contains(loc.Id)"
                                   @onchange="() => ToggleSelection(loc.Id)" />
                            <span class="fw-bold text-truncate">@loc.Name</span>
                        </div>
                        <div class="card-body text-center">
                            <!-- QR Code Image -->
                            <img src="@GetQrCodeUrl(loc.Id)" 
                                 alt="QR Code for @loc.Name" 
                                 class="img-fluid mb-3"
                                 style="max-width: 200px;" />
                            
                            <p class="small text-muted mb-2">
                                @loc.Latitude.ToString("F4"), @loc.Longitude.ToString("F4")
                            </p>
                            
                            @if (loc.HasAudio)
                            {
                                <span class="badge bg-success">Có audio</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Chưa có audio</span>
                            }
                        </div>
                        <div class="card-footer">
                            <div class="btn-group btn-group-sm w-100">
                                <a href="@GetQrCodeUrl(loc.Id)" download="@($"qr-loc-{loc.Id}.png")" 
                                   class="btn btn-outline-primary" title="Download PNG">
                                    PNG
                                </a>
                                <button class="btn btn-outline-info" @onclick="async () => await CopyLink(loc.Id)" title="Copy Link">
                                    Copy
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Print Preview Modal -->
@if (showPrintModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content admin-modal">
                <div class="modal-header">
                    <h5 class="modal-title">Print Sheet Preview</h5>
                    <button type="button" class="btn-close" @onclick="ClosePrintModal"></button>
                </div>
                <div class="modal-body" id="printArea">
                    <div class="row g-3">
                        @foreach (var id in selectedIds)
                        {
                            var loc = locations?.FirstOrDefault(l => l.Id == id);
                            if (loc != null)
                            {
                                <div class="col-6 col-md-4 text-center border p-3">
                                    <img src="@GetQrCodeUrl(id, 150)" alt="QR" style="width: 150px; height: 150px;" />
                                    <p class="fw-bold mb-0 mt-2">@loc.Name</p>
                                    <small class="text-muted">ID: @id</small>
                                </div>
                            }
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="ClosePrintModal">Close</button>
                    <button class="btn btn-admin btn-admin-primary" onclick="window.print()">Print</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LocationDto>? locations;
    private HashSet<int> selectedIds = new();
    private bool showPrintModal;

    protected override async Task OnInitializedAsync()
    {
        await LoadLocations();
    }

    private async Task LoadLocations()
    {
        try
        {
            locations = await LocationService.GetAllLocations();
        }
        catch
        {
            locations = new();
        }
    }

    private string GetQrCodeUrl(int locationId, int size = 200)
    {
        // Derive base URL from the current NavigationManager instead of hardcoding
        var baseUri = Http.BaseAddress ?? new Uri(NavigationManager.BaseUri);
        var apiBase = $"{baseUri.Scheme}://{baseUri.Host}:{baseUri.Port}";
        return $"{apiBase}/api/qrcode/{locationId}?size={size}";
    }

    private string GetPoiEntryUrl(int locationId)
    {
        var baseUri = Http.BaseAddress ?? new Uri(NavigationManager.BaseUri);
        var appBase = $"{baseUri.Scheme}://{baseUri.Host}:{baseUri.Port}";
        return $"{appBase}/poi/{locationId}?entry=qr_scan";
    }

    private void ToggleSelection(int id)
    {
        if (selectedIds.Contains(id))
            selectedIds.Remove(id);
        else
            selectedIds.Add(id);
    }

    private void ToggleSelectAll()
    {
        if (locations == null) return;
        
        if (selectedIds.Count == locations.Count)
            selectedIds.Clear();
        else
            selectedIds = locations.Select(l => l.Id).ToHashSet();
    }

    private void DownloadSelected()
    {
        // In real app, would trigger batch download
        // For now, user can right-click and save each QR
    }

    private void PrintSelected()
    {
        if (selectedIds.Any())
            showPrintModal = true;
    }

    private void ClosePrintModal() => showPrintModal = false;

    private async Task CopyLink(int locationId)
    {
        var url = GetPoiEntryUrl(locationId);
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
    }
}

<style>
    @@media print {
        .admin-sidebar, .admin-header, .modal-header, .modal-footer, 
        .btn, button, .form-check {
            display: none !important;
        }
        .modal {
            position: static !important;
            background: white !important;
        }
        .modal-dialog {
            max-width: 100% !important;
            margin: 0 !important;
        }
        .modal-content {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>

