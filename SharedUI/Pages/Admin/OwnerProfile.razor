@page "/owner/profile"
@layout AdminLayout
@inject IOwnerPortalService OwnerPortal
@inject NavigationManager Navigation
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = UiRoles.PoiOwnerCompat)]

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h3 class="mb-1">Hồ sơ POI Owner</h3>
        <p class="text-muted mb-0">Cập nhật thông tin liên hệ và theo dõi nhanh tình trạng nội dung của các POI bạn đang quản lý.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="/owner/dashboard" class="btn btn-outline-secondary">Quản lý POI</a>
        <a href="/owner/stats" class="btn btn-admin btn-admin-primary">Xem thống kê</a>
    </div>
</div>

@if (isLoading)
{
    <div class="admin-card text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted mb-0">Đang tải hồ sơ POI Owner...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (profile == null)
{
    <div class="alert alert-warning">Không tìm thấy hồ sơ owner ở thời điểm này.</div>
}
else
{
    <div class="row mb-4">
        <div class="col-12 col-xl-5 mb-4">
            <div class="admin-card profile-hero h-100">
                <div class="profile-avatar">@GetInitials(profile.DisplayName)</div>
                <div>
                    <div class="badge bg-light text-dark border mb-3">@profile.RoleDisplayName</div>
                    <h4 class="mb-1">@profile.DisplayName</h4>
                    <div class="text-muted mb-2">@(profile.Email ?? "Chưa cập nhật email")</div>
                    <div class="small text-muted">ID owner: @profile.OwnerId</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-7 mb-4">
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <div class="admin-card text-center py-4 h-100">
                        <div class="stat-dot" style="background:#6B21A8;"></div>
                        <div class="fw-bold fs-3 text-primary">@profile.TotalPois</div>
                        <small class="text-muted">POI quản lý</small>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="admin-card text-center py-4 h-100">
                        <div class="stat-dot" style="background:var(--color-success);"></div>
                        <div class="fw-bold fs-3 text-success">@profile.ApprovedPois</div>
                        <small class="text-muted">Đã duyệt</small>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="admin-card text-center py-4 h-100">
                        <div class="stat-dot" style="background:var(--color-warning);"></div>
                        <div class="fw-bold fs-3 text-warning">@profile.PendingPois</div>
                        <small class="text-muted">Chờ duyệt</small>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="admin-card text-center py-4 h-100">
                        <div class="stat-dot" style="background:var(--color-info);"></div>
                        <div class="fw-bold fs-3 text-info">@profile.PoisWithAudio</div>
                        <small class="text-muted">Có audio</small>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="admin-card text-center py-4 h-100">
                        <div class="stat-dot" style="background:#a855f7;"></div>
                        <div class="fw-bold fs-3 text-primary">@profile.TotalMenuItems</div>
                        <small class="text-muted">Món trong menu</small>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="admin-card text-center py-4 h-100">
                        <div class="stat-dot" style="background:var(--color-success);"></div>
                        <div class="fw-bold fs-3 text-success">@profile.AvailableMenuItems</div>
                        <small class="text-muted">Đang phục vụ</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="row">
        <div class="col-12 col-lg-7 mb-4">
            <div class="admin-card h-100">
                <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
                    <div>
                        <h5 class="mb-1">Cập nhật hồ sơ liên hệ</h5>
                        <div class="small text-muted">Thông tin này được dùng cho quản trị tài khoản owner và liên hệ vận hành.</div>
                    </div>
                    <span class="badge bg-light text-dark border">Đồng bộ với tài khoản đăng nhập</span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-medium">Tên hiển thị</label>
                    <input class="form-control" @bind="model.DisplayName" placeholder="Ví dụ: POI Owner Vĩnh Khánh" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-medium">Email liên hệ</label>
                        <input class="form-control" type="email" @bind="model.Email" placeholder="owner@example.com" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-medium">Số điện thoại</label>
                        <input class="form-control" @bind="model.PhoneNumber" placeholder="09xx xxx xxx" />
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap mt-2">
                    <button class="btn btn-admin btn-admin-primary" @onclick="SaveProfileAsync" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Lưu hồ sơ
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="ResetForm" disabled="@isSaving">Khôi phục</button>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5 mb-4">
            <div class="admin-card h-100">
                <h5 class="mb-3">Gợi ý vận hành</h5>
                <div class="owner-tip mb-3">
                    <div class="owner-tip-icon">●</div>
                    <div>
                        <div class="fw-semibold">Bổ sung bản dịch</div>
                        <div class="small text-muted">Cập nhật nội dung đa ngôn ngữ để audio và QR hiển thị đúng ngôn ngữ của du khách.</div>
                    </div>
                </div>
                <div class="owner-tip mb-3">
                    <div class="owner-tip-icon">♪</div>
                    <div>
                        <div class="fw-semibold">Kiểm tra trạng thái audio</div>
                        <div class="small text-muted">Ưu tiên hoàn tất audio cho các POI đã duyệt để cải thiện trải nghiệm thuyết minh tại chỗ.</div>
                    </div>
                </div>
                <div class="owner-tip">
                    <div class="owner-tip-icon">↑</div>
                    <div>
                        <div class="fw-semibold">Theo dõi hiệu suất</div>
                        <div class="small text-muted">Dùng trang thống kê owner để xem nguồn truy cập từ QR, tour và ngôn ngữ phổ biến.</div>
                    </div>
                </div>

                <hr />

                <div class="small text-muted mb-2">Lối tắt</div>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary text-start" @onclick='() => Navigation.NavigateTo("/owner/audio")'>Audio & TTS</button>
                    <button class="btn btn-outline-primary text-start" @onclick='() => Navigation.NavigateTo("/owner/translations")'>Ngôn ngữ & Bản dịch</button>
                    <button class="btn btn-outline-primary text-start" @onclick='() => Navigation.NavigateTo("/owner/dashboard")'>Danh sách POI của tôi</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .profile-hero {
        display: flex;
        gap: 20px;
        align-items: center;
        background: linear-gradient(135deg, rgba(255, 107, 53, 0.08), rgba(247, 147, 30, 0.14));
        border: 1px solid rgba(255, 107, 53, 0.12);
    }

    .profile-avatar {
        width: 88px;
        height: 88px;
        border-radius: 24px;
        background: linear-gradient(135deg, var(--color-accent), #f7931e);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        box-shadow: 0 12px 30px rgba(255, 107, 53, 0.22);
        flex-shrink: 0;
    }

    .owner-tip {
        display: flex;
        gap: 14px;
        align-items: flex-start;
    }

    .owner-tip-icon {
        width: 42px;
        height: 42px;
        border-radius: var(--radius-lg);
        background: var(--surface-card);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    @@media (max-width: 767.98px) {
        .profile-hero {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    private OwnerProfileDto? profile;
    private UpdateOwnerProfileDto model = new();
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            profile = await OwnerPortal.GetProfileAsync();
            if (profile != null)
            {
                model = new UpdateOwnerProfileDto
                {
                    DisplayName = profile.DisplayName,
                    Email = profile.Email,
                    PhoneNumber = profile.PhoneNumber
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải hồ sơ owner: {ex.Message}";
            profile = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(model.DisplayName))
        {
            errorMessage = "Tên hiển thị không được để trống.";
            successMessage = null;
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var updated = await OwnerPortal.UpdateProfileAsync(model);
            if (!updated)
            {
                errorMessage = "Không thể cập nhật hồ sơ POI Owner ở thời điểm này.";
                return;
            }

            await LoadProfileAsync();
            successMessage = "Hồ sơ POI Owner đã được cập nhật.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Cập nhật hồ sơ thất bại: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ResetForm()
    {
        if (profile == null)
        {
            return;
        }

        model = new UpdateOwnerProfileDto
        {
            DisplayName = profile.DisplayName,
            Email = profile.Email,
            PhoneNumber = profile.PhoneNumber
        };

        errorMessage = null;
        successMessage = null;
    }

    private static string GetInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "PO";
        }

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]));

        return string.Concat(parts);
    }
}

