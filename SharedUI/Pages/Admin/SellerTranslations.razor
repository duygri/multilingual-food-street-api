@page "/owner/translations"
@layout AdminLayout
@inject HttpClient Http
@inject FoodStreet.Client.Services.ILocationClientService LocationService
@using FoodStreet.Client.DTOs
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = UiRoles.PoiOwnerCompat)]

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h3 class="mb-1">Trung tâm bản dịch</h3>
        <p class="text-muted mb-0">Theo dõi và gửi yêu cầu cập nhật bản dịch cho `POI` và `menu` của bạn trong một nơi.</p>
    </div>
    <div class="btn-group" role="group" aria-label="Translation mode">
        <button class="btn @(contentMode == ContentMode.Poi ? "btn-admin btn-admin-primary" : "btn-outline-secondary")" @onclick='() => SwitchModeAsync(ContentMode.Poi)'>
            POI
        </button>
        <button class="btn @(contentMode == ContentMode.Menu ? "btn-admin btn-admin-primary" : "btn-outline-secondary")" @onclick='() => SwitchModeAsync(ContentMode.Menu)'>
            Menu
        </button>
    </div>
</div>

<div class="alert alert-info d-flex align-items-center mb-4" role="alert" style="border-radius: var(--radius-lg); border: 1px solid #bae6fd; background: #f0f9ff;">
    <div style="font-size: 1.2rem; margin-right: 15px; color: var(--color-info);">●</div>
    <div>
        <strong>Dịch tự động theo nội dung gốc:</strong> Bạn chỉ cần chuẩn bị nội dung Tiếng Việt cho POI hoặc món ăn.
        Hệ thống sẽ hỗ trợ sinh bản dịch đa ngôn ngữ; nếu thấy chưa tự nhiên, bạn có thể gửi yêu cầu rà soát để Admin xử lý.
    </div>
</div>

<div class="admin-card mb-4">
    <div class="row align-items-end g-3">
        <div class="col-md-4">
            <label class="form-label fw-medium">Chọn POI</label>
            <select class="form-select" @bind="selectedPlaceId" @bind:after="OnPlaceChangedAsync">
                <option value="0">-- Chọn POI --</option>
                @foreach (var poi in myLocations)
                {
                    <option value="@poi.Id">@poi.Name</option>
                }
            </select>
        </div>
        @if (contentMode == ContentMode.Menu)
        {
            <div class="col-md-4">
                <label class="form-label fw-medium">Chọn món trong menu</label>
                <select class="form-select" @bind="selectedMenuItemId">
                    <option value="0">-- Chọn món --</option>
                    @foreach (var item in menuItems)
                    {
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
            </div>
        }
        <div class="col-md-4">
            <label class="form-label fw-medium">Ngôn ngữ</label>
            <select class="form-select" @bind="selectedLanguage">
                <option value="">Tất cả ngôn ngữ</option>
                @foreach (var option in languageOptions)
                {
                    <option value="@option.Code">@option.Label</option>
                }
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button class="btn btn-outline-primary flex-grow-1" @onclick="LoadTranslationsAsync">
                Xem bản dịch
            </button>
            <button class="btn btn-admin btn-admin-primary" @onclick="RequestAutoTranslateAsync" disabled="@(!CanAutoTranslate || isTranslating)">
                @if (isTranslating)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Đang dịch...</span>
                }
                else
                {
                    <span>Dịch tự động</span>
                }
            </button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="admin-card">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-3 text-muted mb-0">Đang tải bản dịch...</p>
        </div>
    }
    else if (selectedPlaceId == 0)
    {
        <div class="text-center py-5">
            <div class="text-muted" style="font-size: 1.5rem;">POI</div>
            <h5 class="mt-3">Chọn một POI để bắt đầu</h5>
            <p class="text-muted mb-0">Bạn có thể xem bản dịch của nội dung giới thiệu POI hoặc chuyển sang mode menu để rà từng món ăn.</p>
        </div>
    }
    else if (contentMode == ContentMode.Menu && selectedMenuItemId == 0)
    {
        <div class="text-center py-5">
            <div class="text-muted" style="font-size: 1.5rem;">Menu</div>
            <h5 class="mt-3">Chọn một món trong menu</h5>
            <p class="text-muted mb-0">Translation center của owner sẽ hiển thị từng bản dịch menu, giúp bạn dịch nhanh hoặc báo lỗi dịch cho Admin.</p>
        </div>
    }
    else if (translations.Count == 0)
    {
        <div class="text-center py-5">
            <div class="text-muted" style="font-size: 1.5rem;">Translations</div>
            <h5 class="mt-3">Chưa có bản dịch nào</h5>
            <p class="text-muted mb-0">
                @(contentMode == ContentMode.Poi
                    ? "Hãy dùng nút Dịch tự động để sinh bản dịch cho nội dung POI của bạn."
                    : "Hãy dùng nút Dịch tự động để sinh bản dịch cho món ăn đang chọn.")
            </p>
        </div>
    }
    else
    {
        <table class="table admin-table align-middle">
            <thead>
                <tr>
                    <th>Ngôn ngữ</th>
                    @if (contentMode == ContentMode.Menu)
                    {
                        <th>Món</th>
                    }
                    <th>POI</th>
                    <th>Tên bản dịch</th>
                    <th>Mô tả</th>
                    <th>Trạng thái</th>
                    <th style="width: 160px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var translation in translations)
                {
                    <tr>
                        <td>
                            <span class="badge bg-light text-dark border p-2">@GetLanguageLabel(translation.LanguageCode)</span>
                        </td>
                        @if (contentMode == ContentMode.Menu)
                        {
                            <td>
                                <div class="fw-semibold">@translation.ItemName</div>
                            </td>
                        }
                        <td>@translation.ContextName</td>
                        <td><strong>@translation.Name</strong></td>
                        <td class="text-muted">@(TrimText(translation.Description, 90))</td>
                        <td>
                            @if (translation.IsFallback)
                            {
                                <span class="badge bg-warning text-dark">Fallback</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đã sinh</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => RequestReview(translation)" title="Báo lỗi dịch">
                                Báo lỗi dịch
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (showRequestModal && selectedTranslation is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content admin-modal">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold text-warning">Yêu cầu rà soát bản dịch</h5>
                    <button type="button" class="btn-close" @onclick="CloseRequestModal"></button>
                </div>
                <div class="modal-body bg-white">
                    <p class="mb-3 text-muted">
                        Bạn đang gửi yêu cầu rà soát cho bản dịch
                        <strong>@GetLanguageLabel(selectedTranslation.LanguageCode)</strong>
                        của
                        <strong>@(contentMode == ContentMode.Poi ? "POI" : "món ăn")</strong>.
                    </p>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Tên bản dịch hiện tại</label>
                        <div class="p-3 bg-light rounded">@selectedTranslation.Name</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Mô tả hiện tại</label>
                        <div class="p-3 bg-light rounded translation-preview">
                            @(string.IsNullOrWhiteSpace(selectedTranslation.Description) ? "—" : selectedTranslation.Description)
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">Ghi chú cho Admin</label>
                        <textarea class="form-control" rows="3" @bind="reviewNote" placeholder="Ví dụ: đoạn mô tả này nên mang sắc thái tự nhiên hơn hoặc cần sửa tên món chính xác hơn."></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 pt-0">
                    <button type="button" class="btn btn-secondary" @onclick="CloseRequestModal">Hủy</button>
                    <button type="button" class="btn btn-warning text-dark" @onclick="SubmitRequestAsync" disabled="@isSubmittingRequest">
                        @if (isSubmittingRequest)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Gửi yêu cầu
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .translation-preview {
        max-height: 120px;
        overflow-y: auto;
        white-space: pre-wrap;
    }
</style>

@code {
    private static readonly LanguageOption[] languageOptions =
    [
        new("en-US", "Tiếng Anh"),
        new("ja-JP", "Tiếng Nhật"),
        new("ko-KR", "Tiếng Hàn"),
        new("zh-CN", "Tiếng Trung")
    ];

    private readonly List<LocationDto> myLocations = new();
    private readonly List<MenuItemDto> menuItems = new();
    private readonly List<TranslationRow> translations = new();

    private ContentMode contentMode = ContentMode.Poi;
    private int selectedPlaceId;
    private int selectedMenuItemId;
    private string selectedLanguage = string.Empty;
    private bool isLoading;
    private bool isTranslating;
    private bool showRequestModal;
    private bool isSubmittingRequest;
    private string? errorMessage;
    private string? successMessage;
    private string reviewNote = string.Empty;
    private TranslationRow? selectedTranslation;

    protected override async Task OnInitializedAsync()
    {
        await LoadLocationsAsync();
    }

    private bool CanAutoTranslate => contentMode == ContentMode.Poi
        ? selectedPlaceId > 0
        : selectedMenuItemId > 0;

    private async Task LoadLocationsAsync()
    {
        try
        {
            var locations = await LocationService.GetMyLocations();
            myLocations.Clear();
            myLocations.AddRange(locations.OrderBy(location => location.Name));
        }
        catch
        {
            myLocations.Clear();
        }
    }

    private async Task SwitchModeAsync(ContentMode mode)
    {
        if (contentMode == mode)
        {
            return;
        }

        contentMode = mode;
        errorMessage = null;
        successMessage = null;
        translations.Clear();
        selectedTranslation = null;
        showRequestModal = false;

        if (contentMode == ContentMode.Poi)
        {
            selectedMenuItemId = 0;
            menuItems.Clear();
            return;
        }

        if (selectedPlaceId > 0)
        {
            await LoadMenuItemsAsync(selectedPlaceId);
        }
    }

    private async Task OnPlaceChangedAsync()
    {
        errorMessage = null;
        successMessage = null;
        translations.Clear();
        selectedTranslation = null;
        showRequestModal = false;
        selectedMenuItemId = 0;

        if (selectedPlaceId > 0 && contentMode == ContentMode.Menu)
        {
            await LoadMenuItemsAsync(selectedPlaceId);
        }
        else
        {
            menuItems.Clear();
        }
    }

    private async Task LoadMenuItemsAsync(int locationId)
    {
        try
        {
            var items = await Http.GetFromJsonAsync<List<MenuItemDto>>($"api/owner/menu?locationId={locationId}") ?? new();
            menuItems.Clear();
            menuItems.AddRange(items.OrderBy(item => item.SortOrder).ThenBy(item => item.Name));
        }
        catch
        {
            menuItems.Clear();
        }
    }

    private async Task LoadTranslationsAsync()
    {
        errorMessage = null;
        successMessage = null;

        if (selectedPlaceId == 0)
        {
            translations.Clear();
            return;
        }

        if (contentMode == ContentMode.Menu && selectedMenuItemId == 0)
        {
            translations.Clear();
            return;
        }

        isLoading = true;

        try
        {
            translations.Clear();

            if (contentMode == ContentMode.Poi)
            {
                var url = $"api/localization/locations/{selectedPlaceId}/translations";
                if (!string.IsNullOrWhiteSpace(selectedLanguage))
                {
                    url += $"?lang={selectedLanguage}";
                }

                var items = await Http.GetFromJsonAsync<List<PoiTranslationItem>>(url) ?? new();
                translations.AddRange(items.Select(item => new TranslationRow
                {
                    Id = item.Id,
                    ContextName = item.LocationName,
                    ItemName = item.LocationName,
                    LanguageCode = item.LanguageCode,
                    Name = item.Name,
                    Description = item.Description,
                    IsFallback = item.IsFallback
                }));
            }
            else
            {
                var url = $"api/localization/menu-items/{selectedMenuItemId}/translations";
                if (!string.IsNullOrWhiteSpace(selectedLanguage))
                {
                    url += $"?lang={selectedLanguage}";
                }

                var items = await Http.GetFromJsonAsync<List<MenuTranslationItemDto>>(url) ?? new();
                translations.AddRange(items.Select(item => new TranslationRow
                {
                    Id = item.Id,
                    ContextName = item.LocationName,
                    ItemName = item.MenuItemName,
                    LanguageCode = item.LanguageCode,
                    Name = item.Name,
                    Description = item.Description,
                    IsFallback = item.IsFallback
                }));
            }
        }
        catch (Exception ex)
        {
            translations.Clear();
            errorMessage = $"Không thể tải bản dịch: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RequestAutoTranslateAsync()
    {
        if (!CanAutoTranslate)
        {
            return;
        }

        isTranslating = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            if (contentMode == ContentMode.Poi)
            {
                var response = await Http.PostAsJsonAsync(
                    $"api/localization/locations/{selectedPlaceId}/translate",
                    new { lang = string.IsNullOrWhiteSpace(selectedLanguage) ? null : selectedLanguage });
                response.EnsureSuccessStatusCode();
            }
            else
            {
                var response = await Http.PostAsJsonAsync(
                    $"api/localization/menu-items/{selectedMenuItemId}/translate",
                    new { lang = string.IsNullOrWhiteSpace(selectedLanguage) ? null : selectedLanguage });
                response.EnsureSuccessStatusCode();
            }

            successMessage = contentMode == ContentMode.Poi
                ? "Đã gửi yêu cầu dịch tự động cho POI."
                : "Đã gửi yêu cầu dịch tự động cho món trong menu.";
            await LoadTranslationsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể gửi yêu cầu dịch tự động: {ex.Message}";
        }
        finally
        {
            isTranslating = false;
        }
    }

    private void RequestReview(TranslationRow translation)
    {
        selectedTranslation = translation;
        reviewNote = string.Empty;
        showRequestModal = true;
        errorMessage = null;
        successMessage = null;
    }

    private void CloseRequestModal()
    {
        showRequestModal = false;
        selectedTranslation = null;
        reviewNote = string.Empty;
    }

    private async Task SubmitRequestAsync()
    {
        if (selectedTranslation is null)
        {
            return;
        }

        isSubmittingRequest = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var endpoint = contentMode == ContentMode.Poi
                ? $"api/localization/translations/{selectedTranslation.Id}/request-review"
                : $"api/localization/menu-translations/{selectedTranslation.Id}/request-review";

            var response = await Http.PostAsJsonAsync(endpoint, new { note = reviewNote });
            response.EnsureSuccessStatusCode();

            successMessage = contentMode == ContentMode.Poi
                ? "Đã gửi yêu cầu rà soát bản dịch POI."
                : "Đã gửi yêu cầu rà soát bản dịch menu.";
            CloseRequestModal();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể gửi yêu cầu rà soát: {ex.Message}";
        }
        finally
        {
            isSubmittingRequest = false;
        }
    }

    private static string GetLanguageLabel(string code) => code switch
    {
        "vi-VN" => "VI",
        "en-US" => "EN",
        "ja-JP" => "JA",
        "ko-KR" => "KO",
        "zh-CN" => "ZH",
        _ => code
    };

    private static string TrimText(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "—";
        }

        return value.Length <= maxLength ? value : $"{value[..maxLength]}...";
    }

    private enum ContentMode
    {
        Poi,
        Menu
    }

    private sealed record LanguageOption(string Code, string Label);

    private sealed class PoiTranslationItem
    {
        public int Id { get; set; }
        public int LocationId { get; set; }
        public string LocationName { get; set; } = string.Empty;
        public string LanguageCode { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsFallback { get; set; }
    }

    private sealed class TranslationRow
    {
        public int Id { get; set; }
        public string ContextName { get; set; } = string.Empty;
        public string ItemName { get; set; } = string.Empty;
        public string LanguageCode { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsFallback { get; set; }
    }
}

