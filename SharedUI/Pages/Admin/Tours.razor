</style>

@code {
    private List<TourDto> tours = new();
    private List<PlaceSimpleDto> availablePlaces = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool showItemsModal = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private TourEditDto editingTour = new();
    private TourDto? selectedTour;
    private int selectedPlaceId = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadTours();
        await LoadPlaces();
    }

    private async Task LoadTours()
    {
        isLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<List<TourDto>>("api/tour");
            tours = result ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tours: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPlaces()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<PlaceSimpleDto>>("api/places");
            availablePlaces = result ?? new();
        }
        catch { }
    }

    private void OpenCreateModal()
    {
        isEditing = false;
        editingTour = new TourEditDto
        {
            EstimatedDurationMinutes = 60,
            EstimatedDistanceKm = 1.0,
            IsActive = true
        };
        showModal = true;
    }

    private void EditTour(TourDto tour)
    {
        isEditing = true;
        editingTour = new TourEditDto
        {
            Id = tour.Id,
            Name = tour.Name,
            Description = tour.Description,
            EstimatedDurationMinutes = tour.EstimatedDurationMinutes,
            EstimatedDistanceKm = tour.EstimatedDistanceKm,
            IsActive = tour.IsActive
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveTour()
    {
        if (string.IsNullOrWhiteSpace(editingTour.Name)) return;

        isSaving = true;
        try
        {
            HttpResponseMessage response;
            if (isEditing)
            {
                response = await Http.PutAsJsonAsync($"api/tour/{editingTour.Id}", editingTour);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/tour", editingTour);
            }

            if (response.IsSuccessStatusCode)
            {
                await LoadTours();
                CloseModal();
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleTour(int id)
    {
        try
        {
            await Http.PatchAsync($"api/tour/{id}/toggle", null);
            await LoadTours();
        }
        catch { }
    }

    private async Task DeleteTour(int id)
    {
        try
        {
            await Http.DeleteAsync($"api/tour/{id}");
            await LoadTours();
        }
        catch { }
    }

    private async Task ManageTourItems(TourDto tour)
    {
        selectedTour = tour;
        selectedPlaceId = 0;
        showItemsModal = true;
    }

    private void CloseItemsModal()
    {
        showItemsModal = false;
        selectedTour = null;
    }

    private async Task AddItemToTour()
    {
        if (selectedTour == null || selectedPlaceId == 0) return;

        try
        {
            var request = new { PlaceId = selectedPlaceId, EstimatedStopMinutes = 15 };
            var response = await Http.PostAsJsonAsync($"api/tour/{selectedTour.Id}/items", request);
            if (response.IsSuccessStatusCode)
            {
                await LoadTours();
                selectedTour = tours.FirstOrDefault(t => t.Id == selectedTour.Id);
                selectedPlaceId = 0;
            }
        }
        catch { }
    }

    private async Task RemoveItem(int itemId)
    {
        if (selectedTour == null) return;

        try
        {
            await Http.DeleteAsync($"api/tour/{selectedTour.Id}/items/{itemId}");
            await LoadTours();
            selectedTour = tours.FirstOrDefault(t => t.Id == selectedTour.Id);
        }
        catch { }
    }

    private async Task MoveItemUp(TourItemDto item)
    {
        await ReorderItem(item, -1);
    }

    private async Task MoveItemDown(TourItemDto item)
    {
        await ReorderItem(item, 1);
    }

    private async Task ReorderItem(TourItemDto item, int direction)
    {
        if (selectedTour == null) return;

        var items = selectedTour.Items.OrderBy(i => i.Order).ToList();
        var index = items.FindIndex(i => i.Id == item.Id);
        var newIndex = index + direction;

        if (newIndex < 0 || newIndex >= items.Count) return;

        // Swap orders
        var temp = items[index].Order;
        items[index].Order = items[newIndex].Order;
        items[newIndex].Order = temp;

        var reorderRequest = new
        {
            ItemOrders = items.Select(i => new { ItemId = i.Id, i.Order }).ToList()
        };

        try
        {
            await Http.PutAsJsonAsync($"api/tour/{selectedTour.Id}/items/reorder", reorderRequest);
            await LoadTours();
            selectedTour = tours.FirstOrDefault(t => t.Id == selectedTour.Id);
        }
        catch { }
    }

    // DTOs
    class TourDto
    {
        public int Id { get; set; }
