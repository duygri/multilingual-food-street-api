@page "/admin/tours"
@layout AdminLayout
@inject HttpClient Http
@inject ILocalizationService L

<div class="tours-page">
    <!-- Header Actions -->
    <div class="page-actions">
        <button class="btn-primary" @onclick="OpenCreateModal">
            <span>➕</span> Tạo Tour mới
        </button>
    </div>

    <!-- Tours Grid -->
    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Đang tải danh sách tour...</p>
        </div>
    }
    else if (!tours.Any())
    {
        <div class="empty-state-card">
            <span class="empty-icon">🗺️</span>
            <h3>Chưa có tour nào</h3>
            <p>Tạo tour đầu tiên để bắt đầu</p>
            <button class="btn-primary" @onclick="OpenCreateModal">
                <span>➕</span> Tạo Tour
            </button>
        </div>
    }
    else
    {
        <div class="tours-grid">
            @foreach (var tour in tours)
            {
                <div class="tour-card @(tour.IsActive ? "" : "inactive")">
                    <div class="tour-header">
                        <div class="tour-status @(tour.IsActive ? "active" : "paused")">
                            @(tour.IsActive ? "Đang hoạt động" : "Tạm dừng")
                        </div>
                        <div class="tour-actions">
                            <button class="action-btn" title="Sửa" @onclick="() => EditTour(tour)">✏️</button>
                            <button class="action-btn" title="@(tour.IsActive ? "Tạm dừng" : "Kích hoạt")" 
                                    @onclick="() => ToggleTour(tour.Id)">
                                @(tour.IsActive ? "⏸️" : "▶️")
                            </button>
                            <button class="action-btn danger" title="Xóa" @onclick="() => DeleteTour(tour.Id)">🗑️</button>
                        </div>
                    </div>
                    
                    <div class="tour-body">
                        <h3 class="tour-name">@tour.Name</h3>
                        <p class="tour-description">@(tour.Description ?? "Không có mô tả")</p>
                        
                        <div class="tour-stats">
                            <div class="stat">
                                <span class="stat-icon">📍</span>
                                <span class="stat-value">@tour.ItemCount điểm dừng</span>
                            </div>
                            <div class="stat">
                                <span class="stat-icon">⏱️</span>
                                <span class="stat-value">@tour.EstimatedDurationMinutes phút</span>
                            </div>
                            <div class="stat">
                                <span class="stat-icon">📏</span>
                                <span class="stat-value">@tour.EstimatedDistanceKm.ToString("0.#") km</span>
                            </div>
                        </div>

                        @if (tour.Items.Any())
                        {
                            <div class="tour-stops">
                                <h4>Lộ trình:</h4>
                                <div class="stops-timeline">
                                    @foreach (var item in tour.Items.Take(5))
                                    {
                                        <div class="stop-item">
                                            <span class="stop-number">@item.Order</span>
                                            <span class="stop-name">@item.PlaceName</span>
                                        </div>
                                    }
                                    @if (tour.Items.Count > 5)
                                    {
                                        <div class="stop-more">+@(tour.Items.Count - 5) điểm khác</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="tour-footer">
                        <span class="created-date">Tạo: @tour.CreatedAt.ToString("dd/MM/yyyy")</span>
                        <button class="btn-manage" @onclick="() => ManageTourItems(tour)">
                            Quản lý điểm dừng →
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Create/Edit Modal -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(isEditing ? "Chỉnh sửa Tour" : "Tạo Tour mới")</h3>
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Tên Tour *</label>
                    <input type="text" @bind="editingTour.Name" placeholder="VD: Tour ốc Vĩnh Khánh" />
                </div>
                <div class="form-group">
                    <label>Mô tả</label>
                    <textarea @bind="editingTour.Description" rows="3" placeholder="Mô tả ngắn về tour..."></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Thời gian (phút)</label>
                        <input type="number" @bind="editingTour.EstimatedDurationMinutes" min="15" />
                    </div>
                    <div class="form-group">
                        <label>Khoảng cách (km)</label>
                        <input type="number" @bind="editingTour.EstimatedDistanceKm" step="0.1" min="0.1" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="editingTour.IsActive" />
                        <span>Kích hoạt ngay</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Hủy</button>
                <button class="btn-primary" @onclick="SaveTour" disabled="@isSaving">
                    @(isSaving ? "Đang lưu..." : (isEditing ? "Cập nhật" : "Tạo Tour"))
                </button>
            </div>
        </div>
    </div>
}

<!-- Manage Items Modal -->
@if (showItemsModal && selectedTour != null)
{
    <div class="modal-overlay" @onclick="CloseItemsModal">
        <div class="modal-content large" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Quản lý điểm dừng - @selectedTour.Name</h3>
                <button class="modal-close" @onclick="CloseItemsModal">✕</button>
            </div>
            <div class="modal-body">
                <!-- Current Items -->
                <div class="items-section">
                    <h4>Các điểm dừng hiện tại (@selectedTour.Items.Count)</h4>
                    @if (selectedTour.Items.Any())
                    {
                        <div class="items-list">
                            @foreach (var item in selectedTour.Items.OrderBy(i => i.Order))
                            {
                                <div class="item-row">
                                    <span class="item-order">@item.Order</span>
                                    <span class="item-name">📍 @item.PlaceName</span>
                                    <div class="item-actions">
                                        <button class="btn-sm" @onclick="() => MoveItemUp(item)" disabled="@(item.Order <= 1)">⬆️</button>
                                        <button class="btn-sm" @onclick="() => MoveItemDown(item)" disabled="@(item.Order >= selectedTour.Items.Count)">⬇️</button>
                                        <button class="btn-sm danger" @onclick="() => RemoveItem(item.Id)">🗑️</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="no-items">Chưa có điểm dừng nào</p>
                    }
                </div>

                <!-- Add New Item -->
                <div class="add-item-section">
                    <h4>Thêm điểm dừng mới</h4>
                    <div class="add-item-form">
                        <select @bind="selectedPlaceId">
                            <option value="0">-- Chọn địa điểm --</option>
                            @foreach (var place in availablePlaces.Where(p => !selectedTour.Items.Any(i => i.PlaceId == p.Id)))
                            {
                                <option value="@place.Id">@place.Name</option>
                            }
                        </select>
                        <button class="btn-primary" @onclick="AddItemToTour" disabled="@(selectedPlaceId == 0)">
                            Thêm
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseItemsModal">Đóng</button>
            </div>
        </div>
    </div>
}

<style>
