    }

    .device-badge.mobile {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .device-badge.desktop {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
    }

    .device-badge.tablet {
        background: rgba(139, 92, 246, 0.1);
        color: #8b5cf6;
    }

    .source-badge.qr {
        background: rgba(255, 107, 53, 0.1);
        color: #ff6b35;
    }

    .source-badge.geofence {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .source-badge.tour {
        background: rgba(99, 102, 241, 0.1);
        color: #4338ca;
    }

    .source-badge.resume {
