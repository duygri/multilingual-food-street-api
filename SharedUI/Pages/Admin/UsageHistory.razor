@page "/admin/history"
@layout AdminLayout
@inject HttpClient Http
@inject ILocalizationService L
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<div class="history-page">
    <!-- Filters Section -->
    <div class="filters-card">
        <div class="filters-header">
            <h3>Bộ lọc</h3>
            <button class="btn-reset" @onclick="ResetFilters">Đặt lại</button>
        </div>
        <div class="filters-grid">
            <div class="filter-item">
                <label>Từ ngày</label>
                <input type="date" @bind="fromDate" />
            </div>
            <div class="filter-item">
                <label>Đến ngày</label>
                <input type="date" @bind="toDate" />
            </div>
            <div class="filter-item">
                <label>Thiết bị</label>
                <select @bind="deviceFilter">
                    <option value="">Tất cả</option>
                    <option value="mobile">Mobile</option>
                    <option value="desktop">Desktop</option>
                    <option value="tablet">Tablet</option>
                </select>
            </div>
            <div class="filter-item">
                <label>Nguồn</label>
                <select @bind="sourceFilter">
                    <option value="">Tất cả</option>
                    <option value="qr_scan">Quét QR</option>
                    <option value="tour_start">Bắt đầu tour</option>
                    <option value="tour_resume">Tiếp tục tour</option>
                    <option value="tour_progress">Đi tiếp tour</option>
                    <option value="tour_complete">Hoàn tất tour</option>
                    <option value="tour_dismiss">Bỏ dở tour</option>
                    <option value="geofence">GPS / Geofence</option>
                    <option value="manual">Mở thủ công</option>
                </select>
            </div>
            <div class="filter-item">
                <label>Ngôn ngữ</label>
                <select @bind="languageFilter">
                    <option value="">Tất cả</option>
                    <option value="vi-VN">Tiếng Việt</option>
                    <option value="en-US">English</option>
                    <option value="ja-JP">日本語</option>
                    <option value="ko-KR">한국어</option>
                    <option value="zh-CN">中文</option>
                </select>
            </div>
            <div class="filter-item">
                <label>POI</label>
                <select @bind="locationFilter">
                    <option value="">Tất cả</option>
                    @foreach (var poi in poiOptions)
                    {
                        <option value="@poi.Id">@poi.Name</option>
                    }
                </select>
            </div>
            <div class="filter-actions">
                <button class="btn-filter" @onclick="ApplyFilters">
                    Lọc
                </button>
                <button class="btn-export" @onclick="ExportCsv">
                    Export CSV
                </button>
            </div>
        </div>
    </div>

    <!-- Stats Summary -->
    <div class="stats-summary">
        <div class="summary-item">
            <span class="summary-value">@pagination.TotalCount</span>
            <span class="summary-label">Tổng lượt phát</span>
        </div>
        <div class="summary-item">
            <span class="summary-value">@pagination.TotalPages</span>
            <span class="summary-label">Trang</span>
        </div>
    </div>

    <!-- History Table -->
    <div class="table-card">
        <div class="table-header">
            <h3>Lịch sử sử dụng</h3>
        </div>
        
        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Đang tải dữ liệu...</p>
            </div>
        }
        else if (!historyItems.Any())
        {
            <div class="empty-state">
                <span class="text-muted" style="font-size: 48px;">History</span>
                <p>Chưa có dữ liệu lịch sử</p>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Địa điểm</th>
                            <th>Thiết bị</th>
                            <th>Nguồn</th>
                            <th>Thời lượng</th>
                            <th>Ngôn ngữ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in historyItems)
                        {
                            <tr>
                                <td class="time-cell">
                                    <span class="date">@item.PlayedAt.ToString("dd/MM/yyyy")</span>
                                    <span class="time">@item.PlayedAt.ToString("HH:mm:ss")</span>
                                </td>
                                <td class="food-cell">
                                    <span class="food-icon text-muted">POI</span>
                                    @item.LocationName
                                </td>
                                <td>
                                    <span class="device-badge @GetDeviceClass(item.DeviceType)">
                                        @item.DeviceType
                                    </span>
                                </td>
                                <td>
                                    <span class="source-badge @GetSourceClass(item.Source)">
                                        @GetSourceLabel(item.Source)
                                    </span>
                                </td>
                                <td class="duration-cell">
                                    @FormatDuration(item.DurationSeconds)
                                </td>
                                <td class="language-cell">
                                    @item.Language
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination">
                <button class="page-btn" disabled="@(pagination.CurrentPage <= 1)" @onclick="PrevPage">
                    ← Trước
                </button>
                <span class="page-info">
                    Trang @pagination.CurrentPage / @pagination.TotalPages
                </span>
                <button class="page-btn" disabled="@(pagination.CurrentPage >= pagination.TotalPages)" @onclick="NextPage">
                    Sau →
                </button>
            </div>
        }
    </div>
</div>

<style>
    .history-page {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    /* Filters Card */
    .filters-card {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

    .filters-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .filters-header h3 {
        margin: 0;
        font-size: 16px;
        color: #1e2a3a;
    }

    .btn-reset {
        background: transparent;
        border: none;
        color: #64748b;
        cursor: pointer;
        font-size: 13px;
    }

    .btn-reset:hover {
        color: #ff6b35;
    }

    .filters-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
        align-items: end;
    }

    .filter-item label {
        display: block;
        font-size: 12px;
        color: #64748b;
        margin-bottom: 6px;
        font-weight: 500;
    }

    .filter-item input,
    .filter-item select {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        font-size: 14px;
        background: #f8fafc;
        transition: all 0.2s;
    }

    .filter-item input:focus,
