    .page-info {
        font-size: 14px;
        color: #64748b;
    }

    /* Loading & Empty States */
    .loading-state,
    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: #64748b;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #f1f5f9;
        border-top-color: #ff6b35;
        border-radius: 50%;
        margin: 0 auto 16px;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .empty-state span {
        font-size: 48px;
        display: block;
        margin-bottom: 12px;
    }
</style>

@code {
    private List<HistoryItem> historyItems = new();
    private PaginationInfo pagination = new();
    private bool isLoading = true;

    // Filters
    private DateTime? fromDate;
    private DateTime? toDate;
    private string deviceFilter = "";
    private string sourceFilter = "";
    private string languageFilter = "";
    private string locationFilter = "";
    private List<PoiFilterOption> poiOptions = new();
    private int currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadPoiOptionsAsync();
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        isLoading = true;
        try
        {
            var queryParams = new List<string> { $"page={currentPage}", "pageSize=20" };
            
            if (fromDate.HasValue)
                queryParams.Add($"fromDate={fromDate.Value:yyyy-MM-dd}");
            if (toDate.HasValue)
                queryParams.Add($"toDate={toDate.Value:yyyy-MM-dd}");
            if (!string.IsNullOrEmpty(deviceFilter))
                queryParams.Add($"deviceType={deviceFilter}");
            if (!string.IsNullOrEmpty(sourceFilter))
                queryParams.Add($"source={sourceFilter}");
            if (!string.IsNullOrEmpty(languageFilter))
                queryParams.Add($"language={languageFilter}");
            if (!string.IsNullOrEmpty(locationFilter))
                queryParams.Add($"locationId={locationFilter}");

            var url = $"api/admin/analytics/history?{string.Join("&", queryParams)}";
            var response = await Http.GetFromJsonAsync<HistoryResponse>(url);

            if (response != null)
            {
                historyItems = response.Items ?? new();
                pagination = response.Pagination ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading history: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        currentPage = 1;
        await LoadHistory();
    }

    private async Task ResetFilters()
    {
        fromDate = null;
        toDate = null;
        deviceFilter = "";
        sourceFilter = "";
        languageFilter = "";
        locationFilter = "";
        currentPage = 1;
        await LoadHistory();
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadHistory();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < pagination.TotalPages)
        {
            currentPage++;
            await LoadHistory();
        }
    }

    private async Task ExportCsv()
    {
        var queryParams = new List<string>();
        if (fromDate.HasValue)
            queryParams.Add($"fromDate={fromDate.Value:yyyy-MM-dd}");
        if (toDate.HasValue)
            queryParams.Add($"toDate={toDate.Value:yyyy-MM-dd}");
        if (!string.IsNullOrEmpty(deviceFilter))
            queryParams.Add($"deviceType={deviceFilter}");
        if (!string.IsNullOrEmpty(sourceFilter))
            queryParams.Add($"source={sourceFilter}");
        if (!string.IsNullOrEmpty(languageFilter))
            queryParams.Add($"language={languageFilter}");
        if (!string.IsNullOrEmpty(locationFilter))
            queryParams.Add($"locationId={locationFilter}");

        var url = $"api/admin/analytics/export";
        if (queryParams.Any())
            url += "?" + string.Join("&", queryParams);

        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task LoadPoiOptionsAsync()
    {
        try
        {
            poiOptions = await Http.GetFromJsonAsync<List<PoiFilterOption>>("api/maps/locations/admin/all") ?? new();
            poiOptions = poiOptions.OrderBy(poi => poi.Name).ToList();
        }
        catch
        {
            poiOptions = new();
        }
    }

    private string GetDeviceIcon(string? device) => "";

    private string GetDeviceClass(string? device) => device?.ToLower() ?? "unknown";

    private string GetSourceIcon(string? source) => "";

    private string GetSourceLabel(string? source) => source?.ToLower() switch
    {
        "qr_scan" => "Quét QR",
        "tour_start" => "Bắt đầu tour",
        "tour_resume" => "Tiếp tục tour",
        "tour_progress" => "Đi tiếp tour",
        "tour_complete" => "Hoàn tất tour",
        "tour_dismiss" => "Bỏ dở tour",
        "geofence" => "GPS / Geofence",
        "manual" => "Mở thủ công",
        _ => source ?? "Unknown"
    };

    private string GetSourceClass(string? source) => source?.ToLower() switch
    {
        "qr_scan" => "qr",
        "tour_start" or "tour_progress" => "tour",
        "tour_resume" => "resume",
        "tour_complete" => "complete",
        "tour_dismiss" => "dismiss",
        "geofence" => "geofence",
        _ => "manual"
    };

    private string FormatDuration(double seconds)
    {
        if (seconds < 60)
            return $"{seconds:0}s";
        var minutes = Math.Floor(seconds / 60);
        var secs = seconds % 60;
        return $"{minutes:0}m {secs:0}s";
    }

    // DTOs
    class HistoryResponse
    {
        public List<HistoryItem>? Items { get; set; }
        public PaginationInfo? Pagination { get; set; }
    }

    class HistoryItem
    {
        public int Id { get; set; }
        public int LocationId { get; set; }
        public string LocationName { get; set; } = "";
        public DateTime PlayedAt { get; set; }
        public double DurationSeconds { get; set; }
        public string? Source { get; set; }
        public string? DeviceType { get; set; }
        public string? Language { get; set; }
        public string? SessionId { get; set; }
    }

    class PaginationInfo
    {
        public int CurrentPage { get; set; } = 1;
        public int PageSize { get; set; } = 20;
        public int TotalCount { get; set; } = 0;
        public int TotalPages { get; set; } = 0;
    }

    class PoiFilterOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
}
