@page "/admin/dashboard"
@layout AdminLayout
@using Microsoft.AspNetCore.Authorization
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject INotificationService NotificationSvc
@inject NavigationManager Navigation
@implements IDisposable

<div class="dashboard-page">
    <section class="dashboard-hero">
        <div>
            <span class="hero-tag">Admin Control Center</span>
            <h2>Dashboard vận hành Vĩnh Khánh</h2>
            <p>Theo dõi POI, menu ẩm thực, kiểm duyệt, audio TTS, quét QR, tour và trạng thái realtime của toàn hệ thống.</p>
        </div>
        <div class="hero-actions">
            <div class="hero-status">
                <span class="status-dot @(GetConnectionClass())"></span>
                <span>Realtime @NotificationSvc.ConnectionStatus</span>
            </div>
            <button class="btn-refresh" @onclick="ReloadAsync" disabled="@isLoading">
                @(isLoading ? "Đang tải..." : "Làm mới")
            </button>
        </div>
    </section>

    @if (NotificationSvc.LastActivity != null)
    {
        <div class="realtime-banner">
            <strong>@(NotificationSvc.LastActivity.Title ?? "Realtime update")</strong>
            <span>@(NotificationSvc.LastActivity.Message ?? "Có thay đổi mới từ hệ thống.")</span>
        </div>
    }

    @if (isLoading && dashboard == null)
    {
        <div class="dashboard-state">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Đang tải dashboard quản trị...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (dashboard != null)
    {
        <section class="stats-grid primary">
            <article class="stat-card">
                <span class="stat-icon poi">📍</span>
                <div>
                    <div class="stat-value">@dashboard.TotalPois</div>
                    <div class="stat-label">Tổng POI</div>
                    <div class="stat-meta">@dashboard.ApprovedPois đã duyệt</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon pending">⏳</span>
                <div>
                    <div class="stat-value">@dashboard.PendingPois</div>
                    <div class="stat-label">POI chờ duyệt</div>
                    <div class="stat-meta">Ưu tiên moderation</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon audio">🎧</span>
                <div>
                    <div class="stat-value">@dashboard.PoisWithAudio</div>
                    <div class="stat-label">POI có audio</div>
                    <div class="stat-meta">@dashboard.TotalAudios file âm thanh</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon translate">🌐</span>
                <div>
                    <div class="stat-value">@dashboard.TotalPoiTranslations</div>
                    <div class="stat-label">Bản dịch POI</div>
                    <div class="stat-meta">@dashboard.FullyLocalizedPois/@dashboard.TotalPois đủ bộ • @dashboard.PoiTranslationCoveragePercent.ToString("0.#")%</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon owners">🏪</span>
                <div>
                    <div class="stat-value">@dashboard.ActivePoiOwners</div>
                    <div class="stat-label">POI Owner hoạt động</div>
                    <div class="stat-meta">@dashboard.PendingPoiOwners tài khoản chờ duyệt</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon qr">🍽️</span>
                <div>
                    <div class="stat-value">@dashboard.TotalMenuItems</div>
                    <div class="stat-label">Món trong menu</div>
                    <div class="stat-meta">@dashboard.AvailableMenuItems đang phục vụ</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon translate">🈯</span>
                <div>
                    <div class="stat-value">@dashboard.TotalMenuTranslations</div>
                    <div class="stat-label">Bản dịch menu</div>
                    <div class="stat-meta">@dashboard.FullyLocalizedMenuItems/@dashboard.TotalMenuItems đủ bộ • @dashboard.MenuTranslationCoveragePercent.ToString("0.#")%</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon plays">▶️</span>
                <div>
                    <div class="stat-value">@dashboard.TotalPlays30Days</div>
                    <div class="stat-label">Lượt nghe 30 ngày</div>
                    <div class="stat-meta">@dashboard.TodayPlays hôm nay</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon qr">📱</span>
                <div>
                    <div class="stat-value">@dashboard.QrScans30Days</div>
                    <div class="stat-label">Quét QR 30 ngày</div>
                    <div class="stat-meta">@dashboard.TourStarts30Days bắt đầu • @dashboard.TourResumes30Days tiếp tục</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon journey">🧭</span>
                <div>
                    <div class="stat-value">@dashboard.ActiveTourSessions</div>
                    <div class="stat-label">Phiên tour đang dở</div>
                    <div class="stat-meta">@dashboard.TourCompletionRate30Days.ToString("0.#")% hoàn tất trong 30 ngày</div>
                </div>
            </article>
            <article class="stat-card">
                <span class="stat-icon success">🏁</span>
                <div>
                    <div class="stat-value">@dashboard.TourCompletions30Days</div>
                    <div class="stat-label">Tour hoàn tất</div>
                    <div class="stat-meta">@dashboard.TourDismissals30Days bỏ dở • @dashboard.TourDismissRate30Days.ToString("0.#")% dismiss</div>
                </div>
            </article>
        </section>

        <section class="stats-grid secondary">
            <article class="mini-card">
                <span class="mini-label">Tour đang hoạt động</span>
                <strong>@dashboard.ActiveTours / @dashboard.TotalTours</strong>
            </article>
            <article class="mini-card">
                <span class="mini-label">Thông báo admin chưa đọc</span>
                <strong>@dashboard.UnreadAdminNotifications</strong>
            </article>
            <article class="mini-card">
                <span class="mini-label">Người dùng toàn hệ thống</span>
                <strong>@dashboard.TotalUsers</strong>
            </article>
            <article class="mini-card">
                <span class="mini-label">Hoạt động gần nhất</span>
                <strong>@FormatTime(dashboard.LastActivityAt)</strong>
            </article>
        </section>

        <section class="dashboard-grid">
            <article class="panel-card">
                <div class="panel-header">
                    <div>
                        <h3>Thao tác nhanh</h3>
                        <p>Đi thẳng tới các khu vực cần xử lý nhiều nhất.</p>
                    </div>
                </div>
                <div class="quick-actions">
                    <a href="/admin/locations" class="action-tile">
                        <span class="action-dot poi"></span>
                        <strong>Kiểm duyệt POI</strong>
                        <small>@dashboard.PendingPois mục đang chờ</small>
                    </a>
                    <a href="/admin/users" class="action-tile">
                        <span class="action-dot owners"></span>
                        <strong>Duyệt POI Owner</strong>
                        <small>@dashboard.PendingPoiOwners tài khoản chờ</small>
                    </a>
                    <a href="/admin/menu" class="action-tile">
                        <span class="action-dot menu"></span>
                        <strong>Quản lý Menu</strong>
                        <small>@dashboard.AvailableMenuItems món đang phục vụ</small>
                    </a>
                    <a href="/admin/translations" class="action-tile">
                        <span class="action-dot translate"></span>
                        <strong>Trung tâm bản dịch</strong>
                        <small>@dashboard.PoiTranslationCoveragePercent.ToString("0.#")% POI • @dashboard.MenuTranslationCoveragePercent.ToString("0.#")% menu</small>
                    </a>
                    <a href="/admin/tours" class="action-tile">
                        <span class="action-dot tour"></span>
                        <strong>Quản lý Tour</strong>
                        <small>@dashboard.ActiveTours tour đang bật</small>
                    </a>
                    <a href="/admin/notifications" class="action-tile">
                        <span class="action-dot notif"></span>
                        <strong>Notification Center</strong>
                        <small>@dashboard.UnreadAdminNotifications chưa đọc</small>
                    </a>
                </div>
            </article>

            <article class="panel-card">
                <div class="panel-header">
                    <div>
                        <h3>Hàng chờ kiểm duyệt</h3>
                        <p>Các POI mới hoặc vừa chỉnh sửa đang cần admin xử lý.</p>
                    </div>
                    <a href="/admin/locations">Mở moderation →</a>
                </div>
                @if (dashboard.PendingReviewPois.Any())
                {
                    <div class="list-stack">
                        @foreach (var poi in dashboard.PendingReviewPois)
                        {
                            <button class="list-item" @onclick="@(() => Navigation.NavigateTo("/admin/locations"))">
                                <div>
                                    <strong>@poi.Name</strong>
                                    <span>@(poi.Address ?? "Chưa có địa chỉ")</span>
                                </div>
                                <div class="item-meta">
                                    <span class="pill pending">Chờ duyệt</span>
                                    @if (!string.IsNullOrWhiteSpace(poi.OwnerEmail))
                                    {
                                        <small>@poi.OwnerEmail</small>
                                    }
                                </div>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-panel">Không có POI nào đang chờ duyệt.</div>
                }
            </article>

            <article class="panel-card">
                <div class="panel-header">
                    <div>
                        <h3>POI gần đây</h3>
                        <p>Những điểm vừa xuất hiện hoặc vừa được cập nhật trong hệ thống.</p>
                    </div>
                    <a href="/admin/locations">Xem tất cả →</a>
                </div>
                <div class="list-stack">
                    @foreach (var poi in dashboard.RecentPois)
                    {
                        <button class="list-item" @onclick="@(() => Navigation.NavigateTo("/admin/locations"))">
                            <div>
                                <strong>@poi.Name</strong>
                                <span>@(poi.Address ?? "Chưa có địa chỉ")</span>
                            </div>
                            <div class="item-meta">
                                <span class="pill @(poi.IsApproved ? "approved" : "pending")">
                                    @(poi.IsApproved ? "Đã duyệt" : "Chờ duyệt")
                                </span>
                                <small>@(poi.HasAudio ? $"Audio {poi.AudioStatus}" : "Chưa có audio")</small>
                            </div>
                        </button>
                    }
                </div>
            </article>

            <article class="panel-card">
                <div class="panel-header">
                    <div>
                        <h3>Sức khỏe đa ngôn ngữ</h3>
                        <p>Theo dõi mức phủ bản dịch hiện tại cho POI và menu trong hệ thống.</p>
                    </div>
                    <a href="/admin/translations">Mở translation center →</a>
                </div>
                <div class="source-list">
                    <div class="source-row">
                        <div class="source-copy">
                            <strong>POI</strong>
                            <span>@dashboard.TotalPoiTranslations slot dịch • @dashboard.FullyLocalizedPois/@dashboard.TotalPois POI đủ bộ</span>
                        </div>
                        <div class="source-bar">
                            <div class="source-fill" style="width:@($"{dashboard.PoiTranslationCoveragePercent}%")"></div>
                        </div>
                    </div>
                    <div class="source-row">
                        <div class="source-copy">
                            <strong>Menu</strong>
                            <span>@dashboard.TotalMenuTranslations slot dịch • @dashboard.FullyLocalizedMenuItems/@dashboard.TotalMenuItems món đủ bộ</span>
                        </div>
                        <div class="source-bar">
                            <div class="source-fill" style="width:@($"{dashboard.MenuTranslationCoveragePercent}%")"></div>
                        </div>
                    </div>
                </div>
            </article>

            <article class="panel-card">
                <div class="panel-header">
                    <div>
                        <h3>Nguồn tương tác</h3>
                        <p>Phân rã theo nguồn phát trong 30 ngày gần nhất.</p>
                    </div>
                </div>
                @if (dashboard.SourceBreakdown.Any())
                {
                    <div class="source-list">
                        @foreach (var source in dashboard.SourceBreakdown)
                        {
                            <div class="source-row">
                                <div class="source-copy">
                                    <strong>@GetSourceLabel(source.Source)</strong>
                                    <span>@source.Count lượt</span>
                                </div>
                                <div class="source-bar">
                                    <div class="source-fill" style="width:@($"{GetSourcePercent(source.Count)}%")"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-panel">Chưa có dữ liệu tương tác.</div>
                }
            </article>

            <article class="panel-card">
                <div class="panel-header">
                    <div>
                        <h3>Hoạt động gần đây</h3>
                        <p>Luồng moderation và các thông báo hệ thống mới nhất.</p>
                    </div>
                    <a href="/admin/notifications">Mở trung tâm thông báo →</a>
                </div>
                @if (dashboard.RecentNotifications.Any())
                {
                    <div class="activity-list">
                        @foreach (var item in dashboard.RecentNotifications)
                        {
                            <button class="activity-item" @onclick="@(() => OpenNotification(item))">
                                <div class="activity-icon">@GetNotificationIcon(item.Type)</div>
                                <div class="activity-copy">
                                    <strong>@item.Title</strong>
                                    <span>@item.Message</span>
                                    <small>@FormatTime(item.CreatedAt) @(string.IsNullOrWhiteSpace(item.SenderName) ? "" : $"• {item.SenderName}")</small>
                                </div>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-panel">Chưa có thông báo nào cho admin.</div>
                }
            </article>

            <article class="panel-card">
                <div class="panel-header">
                    <div>
                        <h3>Vùng sản phẩm & kiến trúc</h3>
                        <p>Tóm tắt đúng định vị hiện tại của hệ thống.</p>
                    </div>
                </div>
                <div class="area-box">
                    <div class="area-map">Vĩnh Khánh, Quận 4</div>
                    <div class="area-details">
                        <div><span>Khu vực</span><strong>Phố ẩm thực Vĩnh Khánh</strong></div>
                        <div><span>Tọa độ trung tâm</span><strong>10.7580, 106.7034</strong></div>
                        <div><span>Stack</span><strong>C# / .NET / PostgreSQL</strong></div>
                        <div><span>Realtime</span><strong>SignalR @NotificationSvc.ConnectionStatus</strong></div>
                        <div><span>Client</span><strong>Blazor WASM + .NET MAUI</strong></div>
                        <div><span>Tính năng lõi</span><strong>POI, Audio TTS, QR, Tour, GPS/Geofence</strong></div>
                    </div>
                </div>
            </article>
        </section>
    }
</div>

<style>
    .dashboard-page {
        display: flex;
        flex-direction: column;
        gap: 22px;
    }

    .dashboard-hero {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        padding: 24px 28px;
        border-radius: 22px;
        background: radial-gradient(circle at top left, rgba(251, 146, 60, 0.22), transparent 35%), linear-gradient(135deg, #132238, #1e293b 60%, #334155);
        color: white;
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.16);
    }

    .dashboard-hero h2 {
        margin: 6px 0 8px;
        font-size: 32px;
        font-weight: 800;
    }

    .dashboard-hero p {
        margin: 0;
        max-width: 680px;
        color: rgba(255,255,255,0.82);
        line-height: 1.6;
    }

    .hero-tag {
        display: inline-flex;
        padding: 6px 12px;
        border-radius: 999px;
        background: rgba(255,255,255,0.14);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .hero-actions {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-end;
        min-width: 220px;
    }

    .hero-status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.12);
        font-size: 13px;
        font-weight: 600;
    }

    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #f59e0b;
    }

    .status-dot.online { background: #22c55e; }
    .status-dot.warning { background: #f59e0b; }
    .status-dot.offline { background: #ef4444; }

    .btn-refresh {
        border: none;
        border-radius: 12px;
        padding: 12px 18px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #f97316, #fb923c);
        box-shadow: 0 10px 22px rgba(249, 115, 22, 0.25);
    }

    .btn-refresh:disabled {
        opacity: 0.75;
    }

    .realtime-banner {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 14px 18px;
        border-radius: 16px;
        background: rgba(56, 189, 248, 0.1);
        border: 1px solid rgba(56, 189, 248, 0.18);
        color: #0f172a;
    }

    .dashboard-state {
        min-height: 240px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        color: #64748b;
    }

    .stats-grid {
        display: grid;
        gap: 16px;
    }

    .stats-grid.primary {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .stats-grid.secondary {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .stat-card,
    .mini-card,
    .panel-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px;
    }

    .stat-icon {
        display: none;
    }

    .stat-icon.poi { background: rgba(249, 115, 22, 0.12); }
    .stat-icon.pending { background: rgba(245, 158, 11, 0.14); }
    .stat-icon.audio { background: rgba(59, 130, 246, 0.12); }
    .stat-icon.owners { background: rgba(34, 197, 94, 0.12); }
    .stat-icon.plays { background: rgba(14, 165, 233, 0.12); }
    .stat-icon.qr { background: rgba(168, 85, 247, 0.12); }
    .stat-icon.translate { background: rgba(34, 197, 94, 0.12); }
    .stat-icon.journey { background: rgba(14, 165, 233, 0.12); }
    .stat-icon.success { background: rgba(34, 197, 94, 0.12); }

    .stat-value {
        font-size: 30px;
        line-height: 1;
        font-weight: 800;
        color: #0f172a;
    }

    .stat-label {
        margin-top: 4px;
        font-size: 14px;
        font-weight: 700;
        color: #334155;
    }

    .stat-meta {
        margin-top: 4px;
        font-size: 12px;
        color: #64748b;
    }

    .mini-card {
        padding: 16px 18px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .mini-card strong {
        font-size: 24px;
        color: #0f172a;
    }

    .mini-label {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        font-weight: 700;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .panel-card {
        padding: 20px;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 16px;
    }

    .panel-header h3 {
        margin: 0 0 4px;
        font-size: 18px;
        font-weight: 800;
        color: #0f172a;
    }

    .panel-header p {
        margin: 0;
        color: #64748b;
        font-size: 13px;
    }

    .panel-header a {
        font-size: 13px;
        font-weight: 700;
        color: #f97316;
        text-decoration: none;
        white-space: nowrap;
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .action-tile {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 16px;
        border-radius: 16px;
        background: linear-gradient(180deg, #fff7ed, #ffffff);
        border: 1px solid #fed7aa;
        text-decoration: none;
        color: inherit;
    }

    .action-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    .action-dot.poi { background: #f97316; }
    .action-dot.owners { background: #22c55e; }
    .action-dot.menu { background: #a855f7; }
    .action-dot.translate { background: #3b82f6; }
    .action-dot.tour { background: #0ea5e9; }
    .action-dot.notif { background: #ef4444; }

    .action-tile strong {
        color: #0f172a;
    }

    .action-tile small {
        color: #64748b;
    }

    .list-stack,
    .activity-list,
    .source-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .list-item,
    .activity-item {
        width: 100%;
        text-align: left;
        border: none;
        background: #f8fafc;
        border-radius: 14px;
        padding: 14px 16px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
    }

    .list-item strong,
    .activity-copy strong {
        display: block;
        color: #0f172a;
        font-size: 14px;
    }

    .list-item span,
    .activity-copy span,
    .activity-copy small {
        display: block;
        color: #64748b;
        font-size: 12px;
    }

    .item-meta {
        text-align: right;
        min-width: 120px;
    }

    .pill {
        display: inline-flex;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .pill.pending {
        background: rgba(245, 158, 11, 0.14);
        color: #b45309;
    }

    .pill.approved {
        background: rgba(34, 197, 94, 0.14);
        color: #15803d;
    }

