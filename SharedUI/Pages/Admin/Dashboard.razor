@code {
    private AdminDashboardDto? dashboard;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        NotificationSvc.OnRealtimeActivity += HandleRealtimeActivity;
        await NotificationSvc.InitializeAsync();
        await LoadDashboardAsync();
    }

    private async Task ReloadAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            dashboard = await Http.GetFromJsonAsync<AdminDashboardDto>("api/admin/dashboard");
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể tải dashboard quản trị: {ex.Message}";
            dashboard = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleRealtimeActivity(RealtimeActivityDto activity)
    {
        if (activity.EventName is RealtimeEventNames.PoiUpdated
            or RealtimeEventNames.MenuUpdated
            or RealtimeEventNames.ModerationChanged
            or RealtimeEventNames.AudioReady
            or RealtimeEventNames.TourPublished
            or RealtimeEventNames.TranslationUpdated
            or RealtimeEventNames.QrScanned)
        {
            _ = InvokeAsync(async () =>
            {
                await LoadDashboardAsync();
                StateHasChanged();
            });
        }
    }

    private void OpenNotification(AdminDashboardNotificationDto notification)
    {
        if (notification.Type.StartsWith("POI", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/admin/locations");
            return;
        }

        if (UiNotificationTypes.IsMenuNotification(notification.Type))
        {
            Navigation.NavigateTo("/admin/menu");
            return;
        }

        if (notification.Title.Contains("bản dịch", StringComparison.OrdinalIgnoreCase)
            || notification.Message.Contains("bản dịch", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/admin/translations");
            return;
        }

        if (notification.Message.Contains("tài khoản", StringComparison.OrdinalIgnoreCase)
            || notification.Title.Contains("POI Owner", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/admin/users");
            return;
        }

        Navigation.NavigateTo("/admin/notifications");
    }

    private string GetConnectionClass()
    {
        return NotificationSvc.ConnectionStatus switch
        {
            "●" or "🟢" => "online",
            "◐" or "🟡" => "warning",
            "◌" or "⏳" => "warning",
            _ => "offline"
        };
    }

    private string GetSourceLabel(string source) => source switch
    {
        "qr_scan" => "Quét QR",
        "tour_start" => "Bắt đầu tour",
        "tour_resume" => "Tiếp tục tour",
        "tour_progress" => "Đi tiếp tour",
        "tour_complete" => "Hoàn tất tour",
        "tour_dismiss" => "Bỏ dở tour",
        "geofence" => "GPS / Geofence",
        "manual" => "Mở thủ công",
        _ => source
    };

    private double GetSourcePercent(int count)
    {
        if (dashboard == null || dashboard.TotalPlays30Days <= 0)
        {
            return 0;
        }

        return Math.Round(count * 100d / dashboard.TotalPlays30Days, 1);
    }

    private string GetNotificationIcon(string type) => type switch
    {
        "POI_Created" => "●",
        "POI_Updated" => "✎",
        "POI_Approved" => "✓",
        "POI_Rejected" => "✗",
        "POI_AudioReady" => "♪",
        _ => "•"
    };

    private string FormatTime(DateTime? value)
    {
        if (value == null)
        {
            return "Chưa có";
        }

        var local = value.Value.ToLocalTime();
        var diff = DateTime.Now - local;

        if (diff.TotalMinutes < 1) return "Vừa xong";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút trước";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ trước";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} ngày trước";

        return local.ToString("dd/MM/yyyy HH:mm");
    }

    public void Dispose()
    {
        NotificationSvc.OnRealtimeActivity -= HandleRealtimeActivity;
    }
}
