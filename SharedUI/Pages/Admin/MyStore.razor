@page "/owner/dashboard"
@layout AdminLayout
@inject FoodStreet.Client.Services.ILocationClientService LocationService
@inject IOwnerPortalService OwnerPortal
@inject INotificationService NotificationSvc
@inject IAudioService AudioService
@inject TourPlayerService TourService
@inject IJSRuntime JS
@inject HttpClient Http
@inject IPlatformDetector PlatformDetector
@inject IMobileNativeMapService NativeMapService
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = UiRoles.PoiOwnerCompat)]
@implements IDisposable

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-1">Quản lý POI của tôi</h3>
        <p class="text-muted mb-0">Quản lý nội dung hiển thị POI của bạn trên bản đồ thuyết minh ẩm thực Vĩnh Khánh.</p>
    </div>
    <button class="btn btn-admin btn-admin-primary shadow-sm" style="border-radius: 10px;" @onclick="ShowCreateModal">
        Đăng ký POI mới
    </button>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

@if (successMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

@if (dashboard != null)
{
    <div class="row mb-4">
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#6B21A8;"></div>
                <div class="fw-bold fs-3 text-primary">@dashboard.TotalPois</div>
                <small class="text-muted">POI đang quản lý</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#22c55e;"></div>
                <div class="fw-bold fs-3 text-success">@dashboard.ApprovedPois</div>
                <small class="text-muted">Đã duyệt</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#3b82f6;"></div>
                <div class="fw-bold fs-3 text-info">@dashboard.PoisWithAudio</div>
                <small class="text-muted">Audio sẵn sàng</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#f59e0b;"></div>
                <div class="fw-bold fs-3 text-warning">@dashboard.UnreadNotifications</div>
                <small class="text-muted">Thông báo chưa đọc</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#a855f7;"></div>
                <div class="fw-bold fs-3 text-primary">@dashboard.TotalMenuItems</div>
                <small class="text-muted">Món trong menu</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#10b981;"></div>
                <div class="fw-bold fs-3 text-success">@dashboard.AvailableMenuItems</div>
                <small class="text-muted">Món đang phục vụ</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#0ea5e9;"></div>
                <div class="fw-bold fs-3 text-primary">@dashboard.TotalPoiTranslations</div>
                <small class="text-muted">@dashboard.FullyLocalizedPois/@dashboard.TotalPois POI đủ bộ</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#14b8a6;"></div>
                <div class="fw-bold fs-3 text-success">@dashboard.TotalMenuTranslations</div>
                <small class="text-muted">@dashboard.FullyLocalizedMenuItems/@dashboard.TotalMenuItems món đủ bộ</small>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="admin-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="small text-muted">Độ phủ bản dịch POI</div>
                    <strong>@dashboard.PoiTranslationCoveragePercent.ToString("0.#")%</strong>
                </div>
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: @($"{dashboard.PoiTranslationCoveragePercent}%")"></div>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="admin-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="small text-muted">Độ phủ bản dịch menu</div>
                    <strong>@dashboard.MenuTranslationCoveragePercent.ToString("0.#")%</strong>
                </div>
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @($"{dashboard.MenuTranslationCoveragePercent}%")"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#6366f1;"></div>
                <div class="fw-bold fs-3 text-primary">@dashboard.TotalPlays30Days</div>
                <small class="text-muted">Lượt nghe 30 ngày</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#8b5cf6;"></div>
                <div class="fw-bold fs-3 text-info">@dashboard.QrScans30Days</div>
                <small class="text-muted">@dashboard.TourStarts30Days bắt đầu tour</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#0ea5e9;"></div>
                <div class="fw-bold fs-3 text-primary">@dashboard.ActiveTourSessions</div>
                <small class="text-muted">@dashboard.TourResumes30Days lần tiếp tục tour</small>
            </div>
        </div>
        <div class="col-6 col-lg-3 mb-3">
            <div class="admin-card text-center py-4 h-100">
                <div class="stat-dot" style="background:#22c55e;"></div>
                <div class="fw-bold fs-3 text-success">@dashboard.TourCompletionRate30Days.ToString("0.#")%</div>
                <small class="text-muted">@dashboard.TourCompletions30Days xong • @dashboard.TourDismissals30Days bỏ dở</small>
            </div>
        </div>
    </div>
}

<div class="admin-card">
    @if (displayedLocations == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
            <p class="mt-3 text-muted">Đang lấy dữ liệu POI...</p>
        </div>
    }
    else if (displayedLocations.Count == 0)
    {
        <div class="text-center py-5">
            <div class="text-muted" style="font-size: 2rem;">POI</div>
            <h5 class="mt-3">Bạn chưa đăng ký POI nào</h5>
            <p class="text-muted">Nhấn "Đăng ký POI mới" để bắt đầu thủ tục.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle admin-table">
                <thead>
                    <tr>
                        <th style="width: 80px;">Ảnh</th>
                        <th>Thông tin POI</th>
                        <th>Trạng thái Duyệt</th>
                        <th>Tiến độ Âm thanh (TTS)</th>
                        <th style="width: 210px;" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loc in displayedLocations)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(loc.ImageUrl))
                                {
                                    <img src="@loc.ImageUrl" alt="@loc.Name" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                                }
                                else
                                {
                                    <div style="width: 60px; height: 60px; border-radius: 8px; background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; border: 1px dashed #ccc;">
                                        <span style="font-size: 0.75rem; color: #adb5bd;">No img</span>
                                    </div>
                                }
                            </td>
                            <td>
                                <strong style="font-size: 1.1rem; color: #2c3e50;">@loc.Name</strong>
                                <div class="small text-muted mb-1 mt-1">
                                    <i class="bi bi-geo-alt"></i> @(string.IsNullOrEmpty(loc.Address) ? "Chưa cung cấp địa chỉ" : loc.Address)
                                </div>
                                @if (loc.Priority == 1)
                                {
                                    <span class="badge bg-primary bg-opacity-75 rounded-pill fw-normal">POI tiêu chuẩn</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-50 text-dark rounded-pill fw-normal">POI đăng ký cơ bản</span>
                                }
                            </td>
                            <td>
                                @if (loc.IsApproved)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2 fw-medium"><i class="bi bi-check-circle"></i> Đã duyệt & Phát hành</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2 fw-medium"><i class="bi bi-hourglass-split"></i> Chờ duyệt bản nháp</span>
                                    <div class="small text-muted mt-1" style="font-size: 0.75rem;">(Bạn có thể chỉnh sửa liên tục trước khi duyệt)</div>
                                }
                            </td>
                            <td>
                                @if (loc.HasAudio)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-2 py-1">
                                        Audio Đã Render Xong
                                    </span>
                                }
                                else if (!string.IsNullOrEmpty(loc.TtsScript))
                                {
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info rounded-pill px-2 py-1">
                                        Đang đợi AI sinh âm thanh
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small fst-italic">— Cần nhập Kịch bản (TTS Script)</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 justify-content-center">
                                    <button class="btn btn-sm btn-outline-secondary shadow-sm" style="border-radius: 6px;" @onclick='() => Navigation.NavigateTo($"/owner/stats?locationId={loc.Id}")' title="Xem thống kê">
                                        Stats
                                    </button>
                                    <button class="btn btn-sm btn-outline-primary shadow-sm" style="border-radius: 6px;" @onclick="() => ShowEditModal(loc)" title="Cập nhật thông tin">Sửa</button>
                                    <button class="btn btn-sm btn-outline-danger shadow-sm" style="border-radius: 6px;" @onclick="() => DeleteLocation(loc.Id)" title="Xóa yêu cầu">Xóa</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Modal thêm/sửa POI của POI Owner *@
@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content admin-modal">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold text-primary">@modalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body bg-white">
                    <div class="alert alert-info border-0 bg-opacity-10 p-3 rounded mb-4" style="font-size: 0.9rem;">
                        <i class="bi bi-info-circle-fill me-2 text-info"></i> Mọi thay đổi sẽ <strong>tạm ẩn khởi App</strong> và chuyển về trạng thái <strong>Chờ kiểm duyệt</strong> nhằm đảm bảo chất lượng nội dung. Vui lòng điền thông tin trung thực.
                    </div>
                
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Tên POI *</label>
                            <input type="text" class="form-control" @bind="editingLocation.Name" placeholder="VD: Quán Vịt Quay Vinh Phát" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-medium">Địa chỉ thực tế</label>
                            <input type="text" class="form-control" @bind="editingLocation.Address" placeholder="VD: 123 Đường Vĩnh Khánh, Q.4" />
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-medium">Giới thiệu ngắn về POI</label>
                        <textarea class="form-control" rows="2" @bind="editingLocation.Description" placeholder="Đặc sản, món ăn nổi bật..."></textarea>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label fw-medium">Ghim vị trí trên bản đồ</label>
                        @if (UseNativePicker)
                        {
                            <div class="alert alert-info border-0 bg-opacity-10 mb-3">
                                <i class="bi bi-phone me-2"></i> Trên mobile, hệ thống sẽ mở bản đồ Android native để chọn tọa độ chính xác cho POI.
                            </div>
                            <button type="button" class="btn btn-outline-primary mb-3" @onclick="OpenNativePickerAsync">
                                Mở picker Android native
                            </button>
                        }
                        else
                        {
                            <div class="position-relative">
                                <div class="input-group mb-2">
                                    <input type="text" class="form-control" placeholder="Tìm kiếm địa chỉ để ghim nhanh..." @bind="mapSearchQuery" @bind:event="oninput" @onkeydown="@(async e => { if (e.Key == "Enter") await SearchLocationMap(); })" />
                                    <button class="btn btn-outline-secondary" type="button" @onclick="SearchLocationMap" disabled="@isSearchingMap">
                                        @if (isSearchingMap) { <span class="spinner-border spinner-border-sm"></span> } else { <span>Tìm</span> }
                                    </button>
                                </div>
                                @if (mapSearchResults != null && mapSearchResults.Any())
                                {
                                    <ul class="list-group shadow-sm" style="position: absolute; z-index: 1050; width: 100%; max-height: 250px; overflow-y: auto; top: 100%; left: 0;">
                                        @foreach (var res in mapSearchResults)
                                        {
                                            <li class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => SelectSearchResult(res)">
                                                <div class="fw-bold">@res.text</div>
                                                <small class="text-muted">@res.place_name</small>
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                            <div id="poi-map-picker" style="height: 220px; width: 100%; border-radius: 8px; border: 1px solid #e2e8f0; z-index: 1;"></div>
                        }
                        <div class="d-flex gap-3 mt-2">
                              <div class="flex-grow-1">
                                <label class="form-label small text-muted mb-0">Vĩ độ (Lat)</label>
                                <input type="number" step="0.000001" class="form-control form-control-sm" @bind="editingLocation.Latitude" @onblur="SyncMapToInputs" />
                            </div>
                            <div class="flex-grow-1">
                                <label class="form-label small text-muted mb-0">Kinh độ (Lng)</label>
                                <input type="number" step="0.000001" class="form-control form-control-sm" @bind="editingLocation.Longitude" @onblur="SyncMapToInputs" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-medium">Phân loại POI</label>
                            <select class="form-select" @bind="editingLocation.CategoryId">
                                <option value="">-- Chọn loại hình --</option>
                                @if (categories != null)
                                {
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id">@cat.EmojiIcon @cat.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-medium">Loại hình điểm đến</label>
                            <select class="form-select" @bind="editingLocation.Priority">
                                <option value="0">Đăng ký cơ bản (Tùy chọn)</option>
                                <option value="1">POI tiêu chuẩn (Khuyến nghị)</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-medium">Link Google Map (Tùy chọn)</label>
                            <input type="text" class="form-control" @bind="editingLocation.MapLink" placeholder="https://maps.app.goo.gl/..." />
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label fw-medium">Ảnh đại diện (Mặt tiền cửa hàng/Món ăn)</label>
                        <div class="card p-3 bg-light border-0 shadow-sm">
                            <div class="row align-items-center">
                                <div class="col-md-3 text-center mb-3 mb-md-0">
                                    @if (!string.IsNullOrEmpty(editingLocation.ImageUrl))
                                    {
                                        <img src="@editingLocation.ImageUrl" class="img-fluid rounded shadow-sm" style="max-height: 90px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center bg-white rounded border border-dashed" style="height: 90px; color: #ccc;">
                                            <span style="font-size: 0.75rem; color: #adb5bd;">No img</span>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-9">
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control" @bind="editingLocation.ImageUrl" placeholder="Nhập đường dẫn ảnh..." />
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <label class="btn btn-sm btn-outline-primary mb-0 me-2" style="cursor: pointer; border-radius: 6px;">
                                            Tải từ máy điện thoại/PC
                                            <InputFile OnChange="UploadImage" accept="image/*" style="display: none;" />
                                        </label>
                                        @if (isUploadingImage)
                                        {
                                            <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-2">
                        <div class="d-flex justify-content-between">
                            <label class="form-label fw-medium text-primary">Lời giới thiệu tự động bằng 4 ngôn ngữ (Kịch bản AI)</label>
                        </div>
                        <textarea class="form-control" rows="3" @bind="editingLocation.TtsScript" placeholder="Viết giới thiệu về món ăn bằng tiếng Việt. Hệ thống AI Google Gemini sẽ dịch và tự động tạo giọng nói cho Khách nước ngoài..."></textarea>
                        <small class="text-muted mt-1 d-block"><i class="bi bi-robot"></i> Nếu để trống, Audio sẽ lấy từ mục Mô tả POI.</small>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 pt-0">
                    <button type="button" class="btn btn-secondary" style="border-radius: 8px;" @onclick="CloseModal">Hủy bỏ</button>
                    <button type="button" class="btn btn-primary px-4" style="border-radius: 8px;" @onclick="SaveLocation" disabled="@saving">
                        @if (saving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @(isEditing ? "Lưu bản sửa (Chờ duyệt)" : "Nộp đơn xét duyệt POI")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LocationDto>? displayedLocations;
    private List<CategoryItem>? categories;
    private OwnerDashboardDto? dashboard;

    private bool showModal = false;
    private string modalTitle = "";
    private LocationDto editingLocation = new();
    private bool isEditing = false;
    private bool saving = false;
    private bool isUploadingImage = false;
    
    private string? errorMessage;
    private string? successMessage;

    private string mapSearchQuery = "";
    private bool isSearchingMap = false;
    private List<MapSearchResult> mapSearchResults = new();
    
    private DotNetObjectReference<MyStore>? objRef;
    private bool UseNativePicker => PlatformDetector.IsMobile;

    public class MapSearchResult {
        public double lat { get; set; }
        public double lng { get; set; }
        public string? placeId { get; set; }
        public string text { get; set; } = "";
        public string place_name { get; set; } = "";
    }

    public class CategoryItem {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string EmojiIcon { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this);
        NotificationSvc.OnRealtimeActivity += HandleRealtimeActivity;
        await LoadCategories();
        await LoadData();
    }

    private async Task LoadCategories()
    {
        try {
            categories = await Http.GetFromJsonAsync<List<CategoryItem>>("api/category");
        } catch { }
    }

    private async Task LoadData()
    {
        try
        {
            dashboard = await OwnerPortal.GetDashboardAsync();
            displayedLocations = await LocationService.GetMyLocations();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi kết nối máy chủ: {ex.Message}";
            displayedLocations = new();
            dashboard = null;
        }
    }

    private async Task ShowCreateModal()
    {
        editingLocation = new LocationDto { Radius = 30, Latitude = 10.7680, Longitude = 106.7034, Priority = 0 };
        modalTitle = "Đăng ký POI mới lên hệ thống";
        isEditing = false;
        showModal = true;
        await InitMapPicker();
    }

    private async Task ShowEditModal(LocationDto loc)
    {
        editingLocation = new LocationDto
        {
            Id = loc.Id,
            Name = loc.Name,
            Description = loc.Description,
            Address = loc.Address,
            Latitude = loc.Latitude,
            Longitude = loc.Longitude,
            Radius = loc.Radius,
            Priority = loc.Priority > 1 ? 1 : loc.Priority, // Keep POI Owner submissions within supported priority range
            ImageUrl = loc.ImageUrl,
            MapLink = loc.MapLink,
            TtsScript = loc.TtsScript,
            CategoryId = loc.CategoryId
        };
        modalTitle = "✏️ Cập nhật thông tin POI";
        isEditing = true;
        showModal = true;
        await InitMapPicker();
    }

    private void CloseModal() => showModal = false;

    private async Task SaveLocation()
    {
        saving = true;
        try
        {
            // Set required defaults for POI Owner submissions
            if(editingLocation.Radius < 10) editingLocation.Radius = 30;
            
            if (isEditing)
            {
                await LocationService.UpdateLocation(editingLocation.Id, editingLocation);
                successMessage = $"POI \"{editingLocation.Name}\" đã được chỉnh sửa và đưa vào danh sách chờ duyệt.";
            }
            else
            {
                await LocationService.CreateLocation(editingLocation);
                successMessage = $"Đã nộp đơn khởi tạo cho POI \"{editingLocation.Name}\" thành công.";
            }
            showModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Có lỗi xảy ra: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    private async Task DeleteLocation(int id)
    {
        try
        {
            await LocationService.DeleteLocation(id);
            successMessage = "Đã huỷ bản đăng ký POI thành công.";
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể xóa POI: {ex.Message}";
        }
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        isUploadingImage = true;
        errorMessage = null;

        try
        {
            if (file.Size > 5 * 1024 * 1024)
            {
                errorMessage = "File ảnh quá lớn (tối đa 5MB). Vui lòng chọn ảnh khác.";
                return;
            }

            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var url = await LocationService.UploadImageAsync(content);
            if (!string.IsNullOrEmpty(url))
            {
                editingLocation.ImageUrl = Navigation.BaseUri.TrimEnd('/') + url;
            }
            else
            {
                errorMessage = "Tải ảnh lên thất bại, vui lòng thử lại.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi khi tải ảnh: {ex.Message}";
        }
        finally
        {
            isUploadingImage = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void UpdateCoordinatesFromMap(double lat, double lng)
    {
        editingLocation.Latitude = lat;
        editingLocation.Longitude = lng;
        StateHasChanged();
    }

    private async Task SyncMapToInputs()
    {
        if (UseNativePicker)
        {
            return;
        }

        try { await JS.InvokeVoidAsync("AppMapHelper.updatePickerMarker", editingLocation.Latitude, editingLocation.Longitude); } catch { }
    }

    private async Task OpenNativePickerAsync()
    {
        var result = await NativeMapService.OpenPickerAsync(new MobileNativeMapRequest
        {
            Mode = MobileNativeMapMode.Picker,
            ScreenTitle = "Chọn vị trí POI",
            CenterLatitude = editingLocation.Latitude != 0 ? editingLocation.Latitude : 10.7680,
            CenterLongitude = editingLocation.Longitude != 0 ? editingLocation.Longitude : 106.7034,
            Zoom = 17f
        });

        if (result?.Confirmed == true && result.SelectedLatitude.HasValue && result.SelectedLongitude.HasValue)
        {
            editingLocation.Latitude = result.SelectedLatitude.Value;
            editingLocation.Longitude = result.SelectedLongitude.Value;
            await InvokeAsync(StateHasChanged);
        }
    }
    
    private async Task SearchLocationMap()
    {
        if (string.IsNullOrWhiteSpace(mapSearchQuery)) return;
        isSearchingMap = true;
        mapSearchResults.Clear();
        try
        {
            if (!await JS.InvokeAsync<bool>("AppMapHelper.hasConfiguredApiKey"))
            {
                errorMessage = "Chưa cấu hình Google Maps browser key trong runtime-config.js.";
                return;
            }

            var results = await JS.InvokeAsync<List<MapSearchResult>>("AppMapHelper.searchAddress", mapSearchQuery);
            if (results != null && results.Any())
            {
                mapSearchResults = results;
                StateHasChanged();
            }
        }
        catch
        {
            errorMessage = await GetMapHelperErrorAsync("Không thể tìm địa chỉ trên Google Maps.");
        }
        finally {
            isSearchingMap = false;
        }
    }

    private async Task SelectSearchResult(MapSearchResult res)
    {
        var selected = res;

        if (!string.IsNullOrWhiteSpace(res.placeId))
        {
            try
            {
                var resolved = await JS.InvokeAsync<MapSearchResult?>("AppMapHelper.resolveSelectedPlace", res.placeId);
                if (resolved != null && resolved.lat != 0 && resolved.lng != 0)
                {
                    selected = resolved;
                }
            }
            catch { }
        }

        editingLocation.Latitude = selected.lat;
        editingLocation.Longitude = selected.lng;
        if (string.IsNullOrWhiteSpace(editingLocation.Address)) {
            editingLocation.Address = selected.place_name;
        }
        if (string.IsNullOrWhiteSpace(editingLocation.Name)) {
            editingLocation.Name = selected.text;
        }
        mapSearchResults.Clear();
        mapSearchQuery = selected.text;
        await SyncMapToInputs();
    }

    private async Task InitMapPicker()
    {
        if (UseNativePicker)
        {
            await OpenNativePickerAsync();
            return;
        }

        await Task.Delay(300); 
        try
        {
            if (!await JS.InvokeAsync<bool>("AppMapHelper.hasConfiguredApiKey"))
            {
                errorMessage = "Chưa cấu hình Google Maps browser key trong runtime-config.js.";
                return;
            }

            double lat = editingLocation.Latitude != 0 ? editingLocation.Latitude : 10.7680;
            double lng = editingLocation.Longitude != 0 ? editingLocation.Longitude : 106.7034;
            editingLocation.Latitude = lat;
            editingLocation.Longitude = lng;
            var initialized = await JS.InvokeAsync<bool>("AppMapHelper.initPicker", "poi-map-picker", lat, lng, 16, objRef, string.Empty);
            if (!initialized)
            {
                errorMessage = await GetMapHelperErrorAsync("Không thể mở bản đồ chọn vị trí POI.");
                return;
            }

            await Task.Delay(150);
            try { await JS.InvokeVoidAsync("AppMapHelper.resize"); } catch { }
            StateHasChanged();
        } 
        catch
        {
            errorMessage = await GetMapHelperErrorAsync("Không thể mở bản đồ chọn vị trí POI.");
        }
    }

    private async Task<string> GetMapHelperErrorAsync(string fallbackMessage)
    {
        try
        {
            var helperError = await JS.InvokeAsync<string>("AppMapHelper.getLastError", fallbackMessage);
            return string.IsNullOrWhiteSpace(helperError) ? fallbackMessage : helperError;
        }
        catch
        {
            return fallbackMessage;
        }
    }
    
    public void Dispose()
    {
        NotificationSvc.OnRealtimeActivity -= HandleRealtimeActivity;
        objRef?.Dispose();
    }

    private void HandleRealtimeActivity(RealtimeActivityDto activity)
    {
        if (activity.EntityType != "poi")
        {
            return;
        }

        if (activity.EventName is RealtimeEventNames.PoiUpdated
            or RealtimeEventNames.ModerationChanged
            or RealtimeEventNames.AudioReady
            or RealtimeEventNames.MenuUpdated
            or RealtimeEventNames.TranslationUpdated)
        {
            _ = InvokeAsync(async () =>
            {
                await LoadData();
                StateHasChanged();
            });
        }
    }
}
