    private static string BuildPreviewText(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length <= 180 ? text : $"{text[..177]}...";
    }

    private static string FormatRelativeTime(DateTime createdAt)
    {
        if (createdAt == default)
        {
            return "Vừa xong";
        }

        var delta = DateTime.UtcNow - DateTime.SpecifyKind(createdAt, DateTimeKind.Utc);
        if (delta.TotalSeconds < 60)
        {
            return $"{Math.Max(1, (int)delta.TotalSeconds)} giây trước";
        }

        if (delta.TotalMinutes < 60)
        {
            return $"{(int)delta.TotalMinutes} phút trước";
        }

        if (delta.TotalHours < 24)
        {
            return $"{(int)delta.TotalHours} giờ trước";
        }

        return $"{(int)delta.TotalDays} ngày trước";
    }

    private static string GetPoiUrl(int poiId) => $"/poi/{poiId}";

    private static string GetPoiMapUrl(int poiId) => $"/map?focusId={poiId}";

    private string ToAbsoluteUrl(string relativeOrAbsolute)
    {
        if (Uri.TryCreate(relativeOrAbsolute, UriKind.Absolute, out var absolute))
        {
            return absolute.ToString();
        }

        return Nav.ToAbsoluteUri(relativeOrAbsolute).ToString();
    }

    private static string GetHealthStatusClass(bool success) => success ? "tts-health-ok" : "tts-health-bad";

    private static string FormatHealthTime(DateTime checkedAtUtc)
    {
        if (checkedAtUtc == default)
        {
            return "--";
        }

        var local = DateTime.SpecifyKind(checkedAtUtc, DateTimeKind.Utc).ToLocalTime();
        return local.ToString("HH:mm:ss dd/MM");
    }

    public void Dispose()
    {
        streamCts?.Cancel();
        streamCts?.Dispose();
    }
}

