        try
        {
            var response = await Http.PostAsJsonAsync($"api/localization/locations/{poiId}/translate", new { });
            if (!response.IsSuccessStatusCode)
            {
                var errorText = await response.Content.ReadAsStringAsync();
                enqueueMessage = $"Không thể đẩy queue: {errorText}";
                enqueueHasError = true;
                return;
            }

            enqueueMessage = $"Đã đẩy queue sinh Google TTS cho \"{SelectedPoi?.Name}\". Theo dõi tiến trình ở Task Monitor bên dưới.";
            selectedTaskFilter = "all";
            await Task.Delay(400);
            await RefreshTasks();
        }
        catch (Exception ex)
        {
            enqueueMessage = $"Lỗi: {ex.Message}";
            enqueueHasError = true;
        }
        finally
        {
            isEnqueuing = false;
        }
    }

    private async Task RefreshTasks()
    {
        try
        {
            audioTasks = await Http.GetFromJsonAsync<List<AudioTask>>("api/adminaudio/tasks") ?? [];
        }
        catch
        {
            // Keep previous task list when refresh fails.
        }
    }

    private async Task RefreshRuntimeStatus()
    {
        try
        {
            runtimeStatus = await Http.GetFromJsonAsync<AudioRuntimeStatus>("api/adminaudio/status");
        }
        catch
        {
            runtimeStatus ??= new AudioRuntimeStatus();
        }
    }

    private Task ToggleStream() => isStreaming ? StopStreaming() : StartStreaming();

    private Task StartStreaming()
    {
        if (isStreaming)
        {
            return Task.CompletedTask;
        }

        isStreaming = true;
        streamCts = new CancellationTokenSource();

        _ = Task.Run(async () =>
        {
            while (!streamCts.IsCancellationRequested)
            {
                try
                {
                    await InvokeAsync(async () =>
                    {
                        await RefreshTasks();
                        StateHasChanged();
                    });

                    await Task.Delay(TimeSpan.FromSeconds(AutoRefreshSeconds), streamCts.Token);
                }
                catch (TaskCanceledException)
                {
                    break;
                }
                catch
                {
                    try
                    {
                        await Task.Delay(TimeSpan.FromSeconds(AutoRefreshSeconds + 2), streamCts.Token);
                    }
                    catch (TaskCanceledException)
                    {
                        break;
                    }
                }
            }

            await InvokeAsync(() =>
            {
                isStreaming = false;
                StateHasChanged();
            });
        });

        return Task.CompletedTask;
    }

    private Task StopStreaming()
    {
        streamCts?.Cancel();
        return Task.CompletedTask;
    }

    private int CountTasks(string status) =>
        audioTasks.Count(task => string.Equals(task.Status, status, StringComparison.OrdinalIgnoreCase));

    private string GetLangLabel(string code) =>
        supportedLanguages.FirstOrDefault(lang => lang.Code == code)?.Label ?? code;

