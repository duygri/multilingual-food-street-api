@page "/admin/tts-console"
@layout AdminLayout
@inject HttpClient Http
@inject ILocationClientService LocationService
@inject IJSRuntime JS
@inject NavigationManager Nav
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@using System.Net.Http.Json
@implements IDisposable

<div class="tts-console">
    <div class="tts-page-header">
        <div>
            <h3 class="tts-page-title">TTS Console</h3>
            <p class="tts-page-subtitle">Test Google Cloud TTS, đẩy queue sinh audio cho POI và theo dõi tiến trình trong một chỗ.</p>
        </div>

        <div class="tts-header-badges">
            <span class="tts-header-badge">@(runtimeStatus?.Provider ?? "Google Cloud TTS")</span>
            <span class="tts-header-badge">@(runtimeStatus?.AuthMode ?? "Đang đọc auth mode")</span>
            <span class="tts-header-badge">@(string.IsNullOrWhiteSpace(runtimeStatus?.ProjectId) ? "Project ID: chưa khai báo" : $"Project: {runtimeStatus.ProjectId}")</span>
            <span class="tts-header-badge @(isStreaming ? "live" : "")">@(isStreaming ? "Tự động làm mới: Bật" : "Tự động làm mới: Tắt")</span>
        </div>
    </div>

    <div class="tts-card">
        <div class="tts-card-header">
            <div class="tts-card-icon tts-icon-teal">HEALTH</div>
            <div>
                <h4>Google Cloud Health Check</h4>
                <p>Gọi thử một lượt Translate và TTS thật để xác nhận credential, quota và đường truyền đang hoạt động.</p>
            </div>
        </div>

        <div class="tts-card-body">
            @if (!string.IsNullOrWhiteSpace(runtimeStatus?.LastAuthError))
            {
                <div class="tts-result tts-result-error">
                    <span>Auth runtime:</span>
                    <span>@runtimeStatus.LastAuthError</span>
                </div>
            }

            <div class="tts-actions">
                <button class="tts-btn tts-btn-primary"
                        @onclick="RunHealthCheckAsync"
                        disabled="@isHealthChecking">
                    @if (isHealthChecking)
                    {
                        <span class="tts-spinner"></span>
                        <span>Đang kiểm tra...</span>
                    }
                    else
                    {
                        <span>Chạy Health Check</span>
                    }
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(healthCheckError))
            {
                <div class="tts-result tts-result-error">
                    <span>Lỗi:</span>
                    <span>@healthCheckError</span>
                </div>
            }

            @if (healthCheckResult is not null)
            {
                <div class="tts-health-meta-row">
                    <span class="tts-mini-badge neutral">@(healthCheckResult.AuthMode ?? runtimeStatus?.AuthMode ?? "Unknown auth")</span>
                    <span class="tts-mini-badge neutral">@(string.IsNullOrWhiteSpace(healthCheckResult.ProjectId) ? "Project chưa khai báo" : $"Project: {healthCheckResult.ProjectId}")</span>
                    <span class="tts-mini-badge neutral">Kiểm tra lúc @FormatHealthTime(healthCheckResult.CheckedAtUtc)</span>
                </div>

                <div class="tts-health-grid">
                    @if (healthCheckResult.AuthProbe is not null)
                    {
                        <div class="tts-health-card @(GetHealthStatusClass(healthCheckResult.AuthProbe.Success))">
                            <div class="tts-health-head">
                                <strong>Auth / Access Token</strong>
                                <span class="tts-mini-badge @(healthCheckResult.AuthProbe.Success ? "ready" : "failed")">
                                    @(healthCheckResult.AuthProbe.Success ? "OK" : "Lỗi")
                                </span>
                            </div>
                            <p class="tts-health-message">@healthCheckResult.AuthProbe.Message</p>
                            @if (!string.IsNullOrWhiteSpace(healthCheckResult.AuthProbe.LastAuthError))
                            {
                                <div class="tts-health-snippet">
                                    <span class="tts-health-label">Chi tiết gần nhất</span>
                                    <code>@healthCheckResult.AuthProbe.LastAuthError</code>
                                </div>
                            }
                        </div>
                    }

                    <div class="tts-health-card @(GetHealthStatusClass(healthCheckResult.Translate.Success))">
                        <div class="tts-health-head">
                            <strong>Translate</strong>
                            <span class="tts-mini-badge @(healthCheckResult.Translate.Success ? "ready" : "failed")">
                                @(healthCheckResult.Translate.Success ? "OK" : "Lỗi")
                            </span>
                        </div>
                        <p class="tts-health-message">@healthCheckResult.Translate.Message</p>
                        @if (!string.IsNullOrWhiteSpace(healthCheckResult.Translate.OutputPreview))
                        {
                            <div class="tts-health-snippet">
                                <span class="tts-health-label">Kết quả mẫu</span>
                                <code>@healthCheckResult.Translate.OutputPreview</code>
                            </div>
                        }
                    </div>

                    <div class="tts-health-card @(GetHealthStatusClass(healthCheckResult.Tts.Success))">
                        <div class="tts-health-head">
                            <strong>TTS</strong>
                            <span class="tts-mini-badge @(healthCheckResult.Tts.Success ? "ready" : "failed")">
                                @(healthCheckResult.Tts.Success ? "OK" : "Lỗi")
                            </span>
                        </div>
                        <p class="tts-health-message">@healthCheckResult.Tts.Message</p>
                        @if (!string.IsNullOrWhiteSpace(healthCheckResult.Tts.StaticUrl))
                        {
                            <div class="tts-inline-actions">
                                <a class="tts-link-btn tts-link-btn-secondary"
                                   href="@ToAbsoluteUrl(healthCheckResult.Tts.StaticUrl)"
                                   target="_blank"
                                   rel="noopener noreferrer">
                                    Mở file test audio
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="tts-card tts-card-primary">
        <div class="tts-card-header">
            <div class="tts-card-icon tts-icon-blue">VOICE</div>
            <div>
                <h4>Quick TTS Test</h4>
                <p>Nhập nội dung thật, chọn ngôn ngữ và nghe ngay kết quả backend vừa sinh.</p>
            </div>
        </div>

        <div class="tts-card-body">
            <div class="tts-lang-selector">
                @foreach (var lang in supportedLanguages)
                {
                    <button class="tts-lang-chip @(selectedTestLang == lang.Code ? "active" : "")"
                            @onclick="() => selectedTestLang = lang.Code">
                        <span class="tts-lang-flag">@lang.Flag</span>
                        <span class="tts-lang-code">@lang.Label</span>
                    </button>
                }
            </div>

            <div class="tts-textarea-wrapper">
                <textarea class="tts-textarea"
                          placeholder="Nhập nội dung muốn test TTS tại đây..."
                          @bind="testText"
                          @bind:event="oninput"
                          rows="4"></textarea>
                <div class="tts-textarea-footer">
                    <span class="tts-char-count">@(testText?.Length ?? 0) ký tự</span>
                    @if (!string.IsNullOrWhiteSpace(testText))
                    {
                        <button class="tts-btn-clear" @onclick="ClearQuickTest">Xóa</button>
                    }
                </div>
            </div>

            <div class="tts-templates">
                <span class="tts-templates-label">Mẫu nhanh:</span>
                @foreach (var tmpl in quickTemplates)
                {
                    <button class="tts-template-btn"
                            @onclick="() => testText = tmpl.Text"
                            title="@tmpl.Text">
                        @tmpl.Label
                    </button>
                }
            </div>

            <div class="tts-actions">
                <button class="tts-btn tts-btn-primary"
                        @onclick="RunQuickTts"
                        disabled="@(isTestGenerating || string.IsNullOrWhiteSpace(testText))">
                    @if (isTestGenerating)
                    {
                        <span class="tts-spinner"></span>
                        <span>Đang sinh audio...</span>
                    }
                    else
                    {
                        <span>Sinh & Phát Audio</span>
                    }
                </button>

                @if (!string.IsNullOrEmpty(testResultUrl))
                {
                    <button class="tts-btn tts-btn-secondary" @onclick="StopTestAudio">
                        Dừng
                    </button>
                }
            </div>

            @if (!string.IsNullOrEmpty(testStatusMessage))
            {
                <div class="tts-result @(testHasError ? "tts-result-error" : "tts-result-success")">
                    <span>@(testHasError ? "Lỗi:" : "Thành công:")</span>
                    <span>@testStatusMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(testResultUrl))
            {
                <div class="tts-audio-player">
                    <div class="tts-player-header">
                        <div class="tts-player-info">
                            <span class="tts-player-icon">AUDIO</span>
                            <div>
                                <span class="tts-player-title">Audio đã sinh</span>
                                <span class="tts-player-lang">@GetLangLabel(selectedTestLang)</span>
                            </div>
                        </div>

                        <div class="tts-mini-badges">
                            <span class="tts-mini-badge info">@testAudioOriginLabel</span>
                            <span class="tts-mini-badge neutral">@(testText?.Length ?? 0) ký tự</span>
                        </div>
                    </div>

                    <div class="tts-result-metrics">
                        <div class="tts-metric-card">
                            <span class="tts-metric-label">Ngôn ngữ</span>
                            <strong>@GetLangLabel(selectedTestLang)</strong>
                        </div>
                        <div class="tts-metric-card">
                            <span class="tts-metric-label">Nguồn audio</span>
                            <strong>@testAudioOriginLabel</strong>
                        </div>
                        <div class="tts-metric-card">
                            <span class="tts-metric-label">Thời điểm sinh</span>
                            <strong>@(testGeneratedAt?.ToLocalTime().ToString("HH:mm:ss dd/MM") ?? "--")</strong>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(testStaticAudioUrl))
                    {
                        <a class="tts-link-btn tts-link-btn-secondary"
                           href="@testStaticAudioUrl"
                           target="_blank"
                           rel="noopener noreferrer">
                            Mở file MP3 tĩnh
                        </a>
                    }

                    <audio controls src="@testResultUrl" class="tts-audio-element" autoplay></audio>
                </div>
            }
        </div>
    </div>

    <div class="tts-card">
        <div class="tts-card-header">
            <div class="tts-card-icon tts-icon-green">POI</div>
            <div>
                <h4>Sinh TTS cho POI</h4>
                <p>Chọn một POI để dịch 5 ngôn ngữ và sinh audio narration đồng bộ.</p>
            </div>
        </div>

        <div class="tts-card-body">
            @if (!locations.Any())
            {
                <div class="tts-loading-mini">
                    <span class="tts-spinner"></span>
                    <span>Đang tải danh sách POI...</span>
                </div>
            }
            else
            {
                <div class="tts-poi-selector">
                    <select class="tts-select" @bind="selectedPoiId">
                        <option value="">-- Chọn POI cần sinh audio --</option>
                        @foreach (var loc in locations.OrderBy(l => l.Name))
                        {
                            <option value="@loc.Id">@loc.Name</option>
                        }
                    </select>

                    <button class="tts-btn tts-btn-green"
                            @onclick="EnqueuePoiTts"
                            disabled="@(string.IsNullOrWhiteSpace(selectedPoiId) || isEnqueuing)">
                        @if (isEnqueuing)
                        {
                            <span class="tts-spinner"></span>
                            <span>Đang đẩy queue...</span>
                        }
                        else
                        {
                            <span>Sinh Audio (5 ngôn ngữ)</span>
                        }
                    </button>
                </div>

                @if (SelectedPoi is not null)
                {
                    <div class="tts-poi-preview">
                        <div class="tts-poi-preview-head">
                            <div>
                                <h5>@SelectedPoi.Name</h5>
                                <p>@(SelectedPoi.Address ?? "Chưa có địa chỉ chi tiết")</p>
                            </div>
                            <span class="tts-mini-badge @GetAudioStatusClass(SelectedPoi.AudioStatus)">
                                @GetAudioStatusLabel(SelectedPoi.AudioStatus)
                            </span>
                        </div>

                        <div class="tts-poi-meta">
                            <span>Toạ độ: @SelectedPoi.Latitude.ToString("0.0000"), @SelectedPoi.Longitude.ToString("0.0000")</span>
                            <span>Món: @SelectedPoi.FoodCount</span>
                            <span>Audio: @(SelectedPoi.HasAudio ? "Đã có" : "Chưa có")</span>
                            <span>Duyệt: @(SelectedPoi.IsApproved ? "Đã duyệt" : "Chờ duyệt")</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(SelectedPoi.Description))
                        {
                            <p class="tts-poi-preview-text">@BuildPreviewText(SelectedPoi.Description)</p>
                        }

                        <div class="tts-inline-actions">
                            <a class="tts-link-btn" href="@GetPoiUrl(SelectedPoi.Id)">Mở POI</a>
                            <a class="tts-link-btn tts-link-btn-secondary" href="@GetPoiMapUrl(SelectedPoi.Id)">Xem trên map</a>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(enqueueMessage))
                {
                    <div class="tts-result @(enqueueHasError ? "tts-result-error" : "tts-result-success")">
                        <span>@(enqueueHasError ? "Lỗi:" : "Thành công:")</span>
                        <span>@enqueueMessage</span>
                    </div>
                }
            }
        </div>
    </div>

    <div class="tts-card">
        <div class="tts-card-header">
            <div class="tts-card-icon tts-icon-amber">MONITOR</div>
            <div>
                <h4>Task Monitor</h4>
                <p>Theo dõi queue sinh Google TTS, tự động làm mới mỗi @AutoRefreshSeconds giây khi bật.</p>
            </div>
            <div class="tts-header-actions">
                <button class="tts-btn-icon @(isStreaming ? "tts-streaming" : "")"
                        @onclick="ToggleStream"
                        title="@(isStreaming ? "Dừng tự động làm mới" : "Bật tự động làm mới")">
                    @(isStreaming ? "Dừng" : "Bật")
                </button>
                <button class="tts-btn-icon" @onclick="RefreshTasks" title="Tải lại">Tải</button>
            </div>
        </div>

        <div class="tts-card-body">
            <div class="tts-summary-grid">
                @foreach (var summary in taskSummaries)
                {
                    <button class="tts-summary-card @(selectedTaskFilter == summary.Key ? "active" : "")"
                            @onclick="() => selectedTaskFilter = summary.Key">
                        <span class="tts-summary-icon">@summary.Icon</span>
                        <div>
                            <span class="tts-summary-label">@summary.Label</span>
                            <strong>@summary.Count</strong>
                        </div>
                    </button>
                }
            </div>

            <div class="tts-filter-row">
                @foreach (var filter in taskFilters)
                {
                    <button class="tts-filter-chip @(selectedTaskFilter == filter.Key ? "active" : "")"
                            @onclick="() => selectedTaskFilter = filter.Key">
                        @filter.Label
                    </button>
                }
            </div>

            @if (!audioTasks.Any())
            {
                <div class="tts-empty-tasks">
                    <span class="tts-empty-icon text-muted">Trống</span>
                    <p>Chưa có task nào. Hãy sinh TTS cho POI ở trên để bắt đầu.</p>
                </div>
            }
            else if (!FilteredTasks.Any())
            {
                <div class="tts-empty-tasks compact">
                    <span class="tts-empty-icon text-muted">Trống</span>
                    <p>Không có task nào khớp bộ lọc hiện tại.</p>
                </div>
            }
            else
            {
                <div class="tts-task-list">
                    @foreach (var task in FilteredTasks)
                    {
                        <div class="tts-task-item @GetTaskStatusClass(task.Status)">
                            <div class="tts-task-left">
                                <span class="tts-task-status-icon">@GetTaskStatusIcon(task.Status)</span>
                                <div class="tts-task-info">
                                    <div class="tts-task-name-row">
                                        <span class="tts-task-name">@task.LocationName</span>
                                        <span class="tts-task-time">@FormatRelativeTime(task.CreatedAt)</span>
                                    </div>
                                    <span class="tts-task-message">@task.Message</span>
                                    <div class="tts-inline-actions">
                                        <a class="tts-link-btn" href="@GetPoiUrl(task.LocationId)">Mở POI</a>
                                        <a class="tts-link-btn tts-link-btn-secondary" href="@GetPoiMapUrl(task.LocationId)">Map</a>
                                    </div>
                                </div>
                            </div>

                            <div class="tts-task-right">
                                <div class="tts-progress-ring" title="@task.Progress%">
                                    <svg viewBox="0 0 36 36" class="tts-progress-svg">
                                        <path class="tts-progress-bg"
                                              d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                        <path class="tts-progress-fill @GetTaskStatusClass(task.Status)"
                                              stroke-dasharray="@task.Progress, 100"
                                              d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                    </svg>
                                    <span class="tts-progress-text">@task.Progress%</span>
                                </div>
                                <span class="tts-task-badge @GetTaskStatusClass(task.Status)">@GetTaskStatusLabel(task.Status)</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .tts-console {
        max-width: 1080px;
        margin: 0 auto;
        padding: 24px 16px 48px;
    }

    .tts-page-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 28px;
    }

    .tts-page-title {
        margin: 0 0 6px;
        font-size: 26px;
        font-weight: 900;
        color: var(--color-neutral-900);
        letter-spacing: -0.4px;
    }

    .tts-page-subtitle {
        margin: 0;
        color: var(--text-secondary);
        font-size: 14px;
        font-weight: 500;
        max-width: 720px;
    }

    .tts-header-badges,
    .tts-mini-badges,
    .tts-poi-meta,
    .tts-inline-actions,
    .tts-lang-selector,
    .tts-templates,
    .tts-actions,
    .tts-filter-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .tts-header-badge,
    .tts-mini-badge,
    .tts-filter-chip,
    .tts-link-btn {
        border-radius: var(--radius-full);
        font-weight: 700;
        font-size: 12px;
        line-height: 1;
    }

    .tts-header-badge {
        padding: 10px 14px;
        background: var(--color-info-bg);
        color: var(--color-info-dark);
        border: 1px solid rgba(59, 130, 246, 0.15);
    }

    .tts-header-badge.live {
        background: var(--color-success-bg);
        color: var(--color-success-dark);
        border-color: rgba(16, 185, 129, 0.18);
    }

    .tts-card {
        background: white;
        border-radius: var(--radius-xl);
        margin-bottom: 20px;
        border: 1px solid rgba(15, 23, 42, 0.06);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.05);
        overflow: hidden;
    }

    .tts-card-primary {
        border-color: rgba(59, 130, 246, 0.14);
        box-shadow: 0 14px 34px rgba(59, 130, 246, 0.08);
    }

    .tts-card-header {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 20px 22px;
        border-bottom: 1px solid var(--color-neutral-200);
    }

    .tts-card-header h4 {
        margin: 0 0 4px;
        font-size: 16px;
        font-weight: 800;
        color: var(--color-neutral-900);
    }

    .tts-card-header p {
        margin: 0;
        font-size: 13px;
        color: var(--text-secondary);
        font-weight: 500;
    }

    .tts-card-icon {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-lg);
        font-size: 22px;
        flex-shrink: 0;
    }

    .tts-icon-blue { background: rgba(59, 130, 246, 0.12); }
    .tts-icon-green { background: rgba(16, 185, 129, 0.12); }
    .tts-icon-amber { background: rgba(245, 158, 11, 0.12); }
    .tts-icon-teal { background: rgba(20, 184, 166, 0.12); }

    .tts-card-body {
        padding: 22px;
    }

    .tts-header-actions {
        margin-left: auto;
        display: flex;
        gap: 8px;
    }

    .tts-btn-icon {
        width: 38px;
        height: 38px;
        border: none;
        border-radius: var(--radius-lg);
        background: var(--surface-inset);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .tts-btn-icon:hover {
        background: var(--color-neutral-200);
    }

    .tts-btn-icon.tts-streaming {
        background: var(--color-danger-bg);
        animation: tts-pulse 1.8s infinite;
    }

    @@keyframes tts-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.56; }
    }

    .tts-lang-chip,
    .tts-template-btn,
    .tts-filter-chip {
        border: 1px solid var(--color-neutral-200);
        background: white;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .tts-lang-chip {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-radius: var(--radius-lg);
        font-weight: 700;
        color: var(--color-neutral-700);
    }

    .tts-lang-chip:hover,
    .tts-template-btn:hover,
    .tts-filter-chip:hover {
        background: var(--surface-inset);
        border-color: #bfd1e5;
    }

    .tts-lang-chip.active,
    .tts-filter-chip.active {
        background: var(--color-info-bg);
        border-color: var(--color-info);
        color: var(--color-info-dark);
    }

    .tts-lang-flag {
        font-size: 18px;
    }

    .tts-lang-code {
        font-size: 13px;
    }

    .tts-textarea-wrapper {
        margin: 18px 0 14px;
        border: 2px solid var(--color-neutral-200);
        border-radius: var(--radius-xl);
        overflow: hidden;
        transition: all 0.2s ease;
    }

    .tts-textarea-wrapper:focus-within {
        border-color: var(--color-info);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.08);
    }

    .tts-textarea {
        width: 100%;
        border: none;
        outline: none;
        resize: none;
        padding: 16px;
        font: inherit;
        font-size: 15px;
        line-height: 1.6;
        color: var(--color-neutral-900);
    }

    .tts-textarea-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
        background: var(--surface-inset);
        border-top: 1px solid var(--color-neutral-200);
    }

    .tts-char-count,
    .tts-templates-label,
    .tts-metric-label,
