        font-size: 13px;
    }
    
    /* Form Side */
    .auth-form-container {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px;
    }
    
    .auth-form-wrapper {
        width: 100%;
        max-width: 420px;
    }
    
