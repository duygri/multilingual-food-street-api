@page "/admin/login"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILocalizationService L
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<div class="auth-page">
    <div class="auth-container">
        <!-- Left Side - Branding -->
        <div class="auth-branding">
            <div class="branding-content">
                <div class="brand-logo">
                    <span class="logo-icon">🍜</span>
                </div>
                <h1 class="brand-title">Vĩnh Khánh</h1>
                <p class="brand-tagline">Thiên đường ẩm thực</p>
                <div class="brand-features">
                    <div class="feature-item">
                        <span class="feature-icon">📍</span>
                        <span>Quận 4, TP.HCM</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-icon">🍜</span>
                        <span>Thiên đường ẩm thực</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-icon">🎵</span>
                        <span>Thuyết minh đa ngôn ngữ</span>
                    </div>
                </div>
            </div>
            <div class="branding-footer">
                <span>Hệ thống quản trị nội dung</span>
            </div>
        </div>
        
        <!-- Right Side - Form -->
        <div class="auth-form-container">
            <div class="auth-form-wrapper">
                <div class="auth-header">
                    <h2>Đăng nhập Admin</h2>
                    <p>Dành cho Quản trị viên</p>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert-box @(isError ? "alert-error" : "alert-success")">
                        <span class="alert-icon">@(isError ? "⚠️" : "✅")</span>
                        <div class="alert-content">
                            @if (errorList != null && errorList.Any())
                            {
                                <ul>
                                    @foreach (var err in errorList)
                                    {
                                        <li>@err</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span>@message</span>
                            }
                        </div>
                    </div>
                }


                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                    <div class="form-group">
                        <label>Email</label>
                        <div class="input-wrapper @(validationErrors.ContainsKey("Email") ? "has-error" : "")">
                            <span class="input-icon">✉️</span>
                            <input type="email" @bind="model.Email" placeholder="email" />
                        </div>
                        @if (validationErrors.ContainsKey("Email"))
                        {
                            <span class="error-text">@validationErrors["Email"]</span>
                        }
                    </div>
                    
                    <div class="form-group">
                        <label>Mật khẩu</label>
                        <div class="input-wrapper @(validationErrors.ContainsKey("Password") ? "has-error" : "")">
                            <span class="input-icon">🔒</span>
                            <input type="password" @bind="model.Password" placeholder="••••••••" />
                        </div>
                        @if (validationErrors.ContainsKey("Password"))
                        {
                            <span class="error-text">@validationErrors["Password"]</span>
                        }
                    </div>

                    <button type="submit" class="btn-submit" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                        }
                        <span>Đăng nhập</span>
                    </button>
                </form>

                <div class="auth-footer d-flex flex-column gap-2 mt-4">
                    <a href="/owner/login" style="color: var(--text-secondary);"><i class="bi bi-shop"></i> Đăng nhập cổng POI Owner</a>
                    <a href="/" style="color: var(--text-secondary);"><i class="bi bi-arrow-left"></i> Về trang chủ ứng dụng</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .auth-page {
        min-height: 100vh;
        background: #f0f2f5;
    }
    
    .auth-container {
        display: flex;
        min-height: 100vh;
    }
    
    /* Branding Side */
    .auth-branding {
        width: 45%;
        background: linear-gradient(135deg, #1e2a3a 0%, #0f1724 100%);
        padding: 48px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
    
    .auth-branding::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle, rgba(255,107,53,0.15) 0%, transparent 70%);
    }
    
    .branding-content {
        position: relative;
        z-index: 1;
    }
    
    .brand-logo {
        margin-bottom: 24px;
    }
    
    .brand-logo .logo-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--color-accent) 0%, #f7931e 100%);
        border-radius: var(--radius-xl);
        font-size: 40px;
        box-shadow: 0 12px 40px rgba(255,107,53,0.4);
    }
    
    .brand-title {
        font-size: 48px;
        font-weight: 800;
        color: white;
        margin: 0 0 8px;
        letter-spacing: -1px;
    }
    
    .brand-tagline {
        font-size: 20px;
        color: rgba(255,255,255,0.6);
        margin: 0 0 48px;
    }
    
    .brand-features {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    
    .feature-item {
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.8);
        font-size: 16px;
    }
    
    .feature-icon {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.1);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }
    
    .branding-footer {
        position: absolute;
        bottom: 32px;
        left: 48px;
        color: rgba(255,255,255,0.4);
        font-size: 13px;
    }
    
    /* Form Side */
    .auth-form-container {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px;
    }
    
    .auth-form-wrapper {
        width: 100%;
        max-width: 420px;
    }
    
    .auth-header {
        margin-bottom: 32px;
    }
    
    .auth-header h2 {
        font-size: 28px;
        font-weight: 700;
        color: #1e2a3a;
        margin: 0 0 8px;
    }
    
    .auth-header p {
        color: var(--text-secondary);
        margin: 0;
    }
    
    .alert-box {
        display: flex;
        gap: 12px;
        padding: 16px;
        border-radius: var(--radius-lg);
        margin-bottom: 24px;
    }
    
    .alert-error {
        background: var(--color-danger-bg);
        border: 1px solid var(--color-danger-bg);
    }
    
    .alert-success {
        background: #f0fdf4;
        border: 1px solid var(--color-success-bg);
    }
    
    .alert-icon {
        font-size: 20px;
    }
    
    .alert-content {
        flex: 1;
        font-size: 14px;
    }
    
    .alert-content ul {
        margin: 0;
        padding-left: 16px;
    }
    
    .form-group {
        margin-bottom: 20px;
    }
    
    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #1e2a3a;
        margin-bottom: 8px;
    }
    
    .input-wrapper {
        display: flex;
        align-items: center;
        background: white;
        border: 2px solid var(--color-neutral-200);
        border-radius: var(--radius-lg);
        padding: 0 16px;
        transition: all 0.2s ease;
    }
    
    .input-wrapper:focus-within {
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px rgba(255,107,53,0.1);
    }
    
    .input-wrapper.has-error {
        border-color: var(--color-danger);
    }
    
    .input-icon {
        font-size: 16px;
        margin-right: 12px;
    }
    
    .input-wrapper input {
        flex: 1;
        border: none;
        padding: 14px 0;
        font-size: 15px;
        background: transparent;
        outline: none;
    }
    
    .error-text {
        display: block;
        color: var(--color-danger);
        font-size: 13px;
        margin-top: 6px;
    }
    
    .btn-submit {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, var(--color-accent) 0%, #f7931e 100%);
        border: none;
        border-radius: var(--radius-lg);
        color: white;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s ease;
    }
    
    .btn-submit:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255,107,53,0.35);
    }
    
    .btn-submit:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }
    
    .spinner {
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: var(--radius-full);
        animation: spin 0.8s linear infinite;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
    
    .auth-switch {
        text-align: center;
        margin-top: 24px;
        color: var(--text-secondary);
        font-size: 14px;
    }
    
    .auth-switch button {
        background: none;
        border: none;
        color: var(--color-accent);
        font-weight: 600;
        cursor: pointer;
        margin-left: 4px;
    }
    
    .auth-switch button:hover {
        text-decoration: underline;
    }
    
    .auth-footer {
        text-align: center;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid var(--color-neutral-200);
    }
    
    .auth-footer a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 14px;
    }
    
    .auth-footer a:hover {
        color: var(--color-accent);
    }
    
    @@media (max-width: 900px) {
        .auth-branding {
            display: none;
        }
        
        .auth-form-container {
            padding: 24px;
        }
    }
</style>

@code {
    private AuthModel model = new();
    private bool isLoading = false;
    private string? message;
    private List<string>? errorList;
    private bool isError = false;
    private Dictionary<string, string> validationErrors = new();

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += OnLanguageChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        message = null;
        errorList = null;
        validationErrors.Clear();
        model = new AuthModel();
        StateHasChanged();
    }

    private void OnLanguageChanged()
    {
        message = null;
        errorList = null;
        validationErrors.Clear();
        StateHasChanged();
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private bool ValidateForm()
    {
        validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(model.Email))
        {
            validationErrors["Email"] = "Vui lòng nhập email";
        }
        else if (!model.Email.Contains("@") || !model.Email.Contains("."))
        {
            validationErrors["Email"] = "Email không hợp lệ";
        }

        if (string.IsNullOrWhiteSpace(model.Password))
        {
            validationErrors["Password"] = "Vui lòng nhập mật khẩu";
        }
        else if (model.Password.Length < 8)
        {
            validationErrors["Password"] = "Mật khẩu phải có ít nhất 8 ký tự";
        }

        return validationErrors.Count == 0;
    }

    private async Task HandleSubmit()
    {
        if (!ValidateForm())
        {
            return;
        }

        isLoading = true;
        message = null;
        errorList = null;

        try
        {
            var result = await AuthService.LoginAsync(model.Email, model.Password);

            if (result.Success)
            {
                // Get claims from stored token
                var authState = await ((JwtAuthStateProvider)AuthStateProvider).GetAuthenticationStateAsync();
                var user = authState.User;

                // Admin login: only allow Admin role
                if (!user.IsInRole("Admin"))
                {
                    await AuthService.ClearTokensAsync();
                    isError = true;
                    message = "Đăng nhập không hợp lệ hoặc sai mật khẩu!";
                    return;
                }
                AuthService.NotifyStateChanged();
                Navigation.NavigateTo("/admin/locations");
            }
            else
            {
                isError = true;
                message = result.Message ?? "Đăng nhập thất bại";
                errorList = result.Errors;
            }
        }
        catch (Exception ex)
        {
            isError = true;
            message = "Lỗi kết nối: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    public class AuthModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}

