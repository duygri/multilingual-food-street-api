@page "/admin/login"
@page "/admin/register"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILocalizationService L
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<div class="auth-page">
    <div class="auth-container">
        <!-- Left Side - Branding -->
        <div class="auth-branding">
            <div class="branding-content">
                <div class="brand-logo">
                    <span class="logo-icon">🍜</span>
                </div>
                <h1 class="brand-title">Vĩnh Khánh</h1>
                <p class="brand-tagline">Thiên đường ẩm thực</p>
                <div class="brand-features">
                    <div class="feature-item">
                        <span class="feature-icon">📍</span>
                        <span>Quận 4, TP.HCM</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-icon">🍜</span>
                        <span>Thiên đường ẩm thực</span>
                    </div>
                    <div class="feature-item">
                        <span class="feature-icon">🎵</span>
                        <span>Thuyết minh đa ngôn ngữ</span>
                    </div>
                </div>
            </div>
            <div class="branding-footer">
                <span>Hệ thống quản trị nội dung</span>
            </div>
        </div>
        
        <!-- Right Side - Form -->
        <div class="auth-form-container">
            <div class="auth-form-wrapper">
                <div class="auth-header">
                    <h2>@(isLogin ? "Cổng thông tin Quản lý" : "Đăng ký làm Đối tác Bán hàng")</h2>
                    <p>@(isLogin ? "Dành cho Quản trị viên & Đối tác" : "Mở gian hàng trực tuyến của bạn ngay hôm nay")</p>
                </div>

                @if (!string.IsNullOrEmpty(message))
                {
                    <div class="alert-box @(isError ? "alert-error" : "alert-success")">
                        <span class="alert-icon">@(isError ? "⚠️" : "✅")</span>
                        <div class="alert-content">
                            @if (errorList != null && errorList.Any())
                            {
                                <ul>
                                    @foreach (var err in errorList)
                                    {
                                        <li>@err</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span>@message</span>
                            }
                        </div>
                    </div>
                }

                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                    @if (!isLogin)
                    {
                        <div class="form-group">
                            <label>Họ và tên</label>
                            <div class="input-wrapper">
                                <span class="input-icon">👤</span>
                                <input type="text" @bind="model.FullName" placeholder="Nhập họ và tên" />
                            </div>
                        </div>
                    }
                    
                    <div class="form-group">
                        <label>Email</label>
                        <div class="input-wrapper @(validationErrors.ContainsKey("Email") ? "has-error" : "")">
                            <span class="input-icon">✉️</span>
                            <input type="email" @bind="model.Email" placeholder="admin@vinhkhanh.vn" />
                        </div>
                        @if (validationErrors.ContainsKey("Email"))
                        {
                            <span class="error-text">@validationErrors["Email"]</span>
                        }
                    </div>
                    
                    <div class="form-group">
                        <label>Mật khẩu</label>
                        <div class="input-wrapper @(validationErrors.ContainsKey("Password") ? "has-error" : "")">
                            <span class="input-icon">🔒</span>
                            <input type="password" @bind="model.Password" placeholder="••••••••" />
                        </div>
                        @if (validationErrors.ContainsKey("Password"))
                        {
                            <span class="error-text">@validationErrors["Password"]</span>
                        }
                    </div>

                    @if (!isLogin)
                    {
                        <div class="form-group">
                            <label>Xác nhận mật khẩu</label>
                            <div class="input-wrapper @(validationErrors.ContainsKey("ConfirmPassword") ? "has-error" : "")">
                                <span class="input-icon">🔒</span>
                                <input type="password" @bind="model.ConfirmPassword" placeholder="••••••••" />
                            </div>
                            @if (validationErrors.ContainsKey("ConfirmPassword"))
                            {
                                <span class="error-text">@validationErrors["ConfirmPassword"]</span>
                            }
                        </div>
                    }
                    
                    @* Checkbox removed - Registration is strictly for Sellers now *@

                    <button type="submit" class="btn-submit" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                        }
                        <span>@(isLogin ? "Đăng nhập" : "Đăng ký Đối tác")</span>
                    </button>
                </form>

                <div class="auth-switch">
                    <span>@(isLogin ? "Chưa có tài khoản?" : "Đã có tài khoản?")</span>
                    <button @onclick="ToggleMode">
                        @(isLogin ? "Mở gian hàng mới" : "Đăng nhập quản lý")
                    </button>
                </div>

                <div class="auth-footer">
                    <a href="">← Về trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
