@page "/favorites"

<div class="favorites-page">
    <div class="favorites-header">
        <h1>❤️ Đã lưu</h1>
        <p>Những địa điểm bạn muốn quay lại</p>
    </div>

    <div class="empty-state">
        <div class="empty-icon">📍</div>
        <h3>Chưa có địa điểm nào</h3>
        <p>Hãy nhấn vào biểu tượng trái tim tại các quán ăn để lưu lại đây.</p>
        <a href="explore" class="btn-primary">Khám phá ngay</a>
    </div>
</div>

<style>
    .favorites-page {
        min-height: calc(100vh - 110px);
        background: #f8fafc;
    }

    .favorites-header {
        padding: 24px 20px;
        background: white;
        border-bottom: 1px solid #e2e8f0;
    }

    .favorites-header h1 {
        font-size: 20px;
        font-weight: 700;
        margin: 0 0 4px;
        color: #1e293b;
    }

    .favorites-header p {
        font-size: 13px;
        color: #64748b;
        margin: 0;
    }

    .empty-state {
        padding: 60px 40px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .empty-icon {
        font-size: 64px;
        margin-bottom: 24px;
        opacity: 0.5;
    }

    .empty-state h3 {
        font-size: 18px;
        font-weight: 600;
        color: #334155;
        margin: 0 0 8px;
    }

    .empty-state p {
        font-size: 14px;
        color: #64748b;
        margin: 0 0 32px;
        line-height: 1.5;
    }

    .btn-primary {
        display: inline-block;
        padding: 12px 24px;
        background: #ff6b35;
        color: white;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 15px;
        transition: transform 0.2s;
    }

    .btn-primary:active {
        transform: scale(0.95);
    }
</style>
