@page "/favorites"
@using FoodStreet.Client.Services
@using FoodStreet.Client.DTOs
@inject IFavoritesService FavoritesService

<div class="favorites-page">
    <div class="favorites-header">
        <h1>❤️ Đã lưu</h1>
        <p>Những địa điểm bạn muốn quay lại</p>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Đang tải...</p>
        </div>
    }
    else if (favorites.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">📍</div>
            <h3>Chưa có địa điểm nào</h3>
            <p>Hãy nhấn vào biểu tượng trái tim tại các quán ăn để lưu lại đây.</p>
            <a href="explore" class="btn-primary">Khám phá ngay</a>
        </div>
    }
    else
    {
        <div class="favorites-list">
            @foreach (var loc in favorites)
            {
                <div class="fav-card">
                    @if (!string.IsNullOrEmpty(loc.ImageUrl))
                    {
                        <img src="@loc.ImageUrl" alt="@loc.Name" class="fav-image" />
                    }
                    else
                    {
                        <div class="fav-image-placeholder">🍜</div>
                    }
                    <div class="fav-info">
                        <h4>@loc.Name</h4>
                        @if (!string.IsNullOrEmpty(loc.Address))
                        {
                            <p class="fav-address">📍 @loc.Address</p>
                        }
                        @if (!string.IsNullOrEmpty(loc.CategoryName))
                        {
                            <span class="fav-category">@loc.CategoryName</span>
                        }
                    </div>
                    <button class="remove-btn" @onclick="() => RemoveFavorite(loc.Id)" title="Bỏ lưu">
                        ❤️
                    </button>
                </div>
            }
        </div>
    }
</div>

<style>
    .favorites-page {
        min-height: calc(100vh - 110px);
        background: #f8fafc;
    }

    .favorites-header {
        padding: 24px 20px;
        background: white;
        border-bottom: 1px solid #e2e8f0;
    }

    .favorites-header h1 {
        font-size: 20px;
        font-weight: 700;
        margin: 0 0 4px;
        color: #1e293b;
    }

    .favorites-header p {
        font-size: 13px;
        color: #64748b;
        margin: 0;
    }

    .loading-state {
        padding: 60px 20px;
        text-align: center;
        color: #64748b;
    }

    .spinner {
        width: 32px;
        height: 32px;
        border: 3px solid #e2e8f0;
        border-top-color: #ff6b35;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto 16px;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    .empty-state {
        padding: 60px 40px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .empty-icon {
        font-size: 64px;
        margin-bottom: 24px;
        opacity: 0.5;
    }

    .empty-state h3 {
        font-size: 18px;
        font-weight: 600;
        color: #334155;
        margin: 0 0 8px;
    }

    .empty-state p {
        font-size: 14px;
        color: #64748b;
        margin: 0 0 32px;
        line-height: 1.5;
    }

    .btn-primary {
        display: inline-block;
        padding: 12px 24px;
        background: #ff6b35;
        color: white;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 15px;
        transition: transform 0.2s;
    }

    .btn-primary:active { transform: scale(0.95); }

    .favorites-list {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .fav-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
    }

    .fav-image {
        width: 80px;
        height: 80px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .fav-image-placeholder {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        background: #f1f5f9;
        flex-shrink: 0;
    }

    .fav-info {
        flex: 1;
        padding: 12px;
        min-width: 0;
    }

    .fav-info h4 {
        font-size: 15px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .fav-address {
        font-size: 12px;
        color: #64748b;
        margin: 0 0 6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .fav-category {
        font-size: 11px;
        background: #fff5f2;
        color: #ff6b35;
        padding: 2px 8px;
        border-radius: 6px;
        font-weight: 600;
    }

    .remove-btn {
        padding: 12px 16px;
        background: none;
        border: none;
        font-size: 20px;
        cursor: pointer;
        opacity: 0.85;
        flex-shrink: 0;
        transition: transform 0.15s;
    }

    .remove-btn:active { transform: scale(0.85); }
</style>

@code {
    private List<LocationDto> favorites = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        favorites = await FavoritesService.GetFavoritesAsync();
        isLoading = false;
    }

    private async Task RemoveFavorite(int id)
    {
        await FavoritesService.RemoveFavoriteAsync(id);
        favorites = await FavoritesService.GetFavoritesAsync();
    }
}
