@code {
    [Parameter] public int Id { get; set; }

    private LocationDto? location;
    private bool isLoading = true;
    private bool isFavorite = false;
    private bool isPlaying = false;
    private string selectedLang = "vi-VN";
    private List<MenuItemDto> menuItems = new();
    private List<LocationTranslationDto> audioTranslations = new();
    private List<LocationDto> similarPois = new();
    private string? lastLoggedEntryKey;
    private string? miniMapUrl;
    private bool hasTourJourneyContext;
    private int? sourceTourId;
    private string? sourceTourSessionId;
    private int? sourceTourStopOrder;
    private string? tourResumeUrl;

    protected override async Task OnInitializedAsync()
    {
        await LoadLocation();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reload when navigating to different POI
        await LoadLocation();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (location != null && string.IsNullOrWhiteSpace(miniMapUrl))
        {
            try
            {
                miniMapUrl = await JS.InvokeAsync<string>(
                    "AppMapHelper.buildStaticMapUrl",
                    location.Latitude,
                    location.Longitude,
                    16,
                    800,
                    320);

                if (!string.IsNullOrWhiteSpace(miniMapUrl))
                {
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch
            {
                miniMapUrl = string.Empty;
            }
        }
    }

    private async Task LoadLocation()
    {
        isLoading = true;
        StateHasChanged();
        CaptureJourneyContext();

        try
        {
            location = await LocationClient.GetLocation(Id);
            miniMapUrl = null;

            if (location != null)
            {
                selectedLang = location.LanguageCode;

                // Load in parallel
                var favTask = FavoritesService.GetFavoritesAsync();
                var transTask = LocationClient.GetLocationTranslationsAsync(Id);
                var similarTask = LocationClient.GetSimilarLocationsAsync(Id);
                var menuTask = LoadMenuItemsAsync(Id, selectedLang);

                await Task.WhenAll(favTask, transTask, similarTask, menuTask);

                var favs = await favTask;
                isFavorite = favs.Any(f => f.Id == location.Id);

                menuItems = await menuTask;
                audioTranslations = await transTask;
                similarPois = await similarTask;
                await LogEntryContextAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POI: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        if (!string.IsNullOrWhiteSpace(tourResumeUrl))
        {
            Navigation.NavigateTo(tourResumeUrl);
            return;
        }

        Navigation.NavigateTo("/explore");
    }

    private async Task OpenDirections()
    {
        if (location == null) return;
        var uri = BuildDirectionsUrl(location);
        await JS.InvokeVoidAsync("open", uri, "_blank");
    }

    private async Task ScrollToAudio()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('audio-section')?.scrollIntoView({behavior:'smooth'})");
    }

    private async Task ScrollToMenu()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('menu-section')?.scrollIntoView({behavior:'smooth'})");
    }

    private async Task SelectAndPlayLanguage(LocationTranslationDto trans)
    {
        if (isPlaying && selectedLang == trans.LanguageCode)
        {
            await StopAudio();
            return;
        }

        selectedLang = trans.LanguageCode;
        isPlaying = true;
        StateHasChanged();

        try
        {
            if (!string.IsNullOrEmpty(trans.AudioUrl))
            {
                await TtsService.PlayAudioFileAsync(trans.AudioUrl);
            }
            else if (!string.IsNullOrEmpty(trans.TtsScript))
            {
                await TtsService.PlayTextAsync(trans.TtsScript, trans.LanguageCode);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error playing audio: {ex.Message}");
        }
        finally
        {
            isPlaying = false;
            StateHasChanged();
        }
    }

    private async Task PlayDefaultAudio()
    {
        if (location == null || isPlaying) return;
        isPlaying = true;

        try
        {
            if (location.HasAudio && !string.IsNullOrEmpty(location.AudioUrl))
            {
                await TtsService.PlayAudioFileAsync(location.AudioUrl);
            }
            else if (!string.IsNullOrEmpty(location.TtsScript))
            {
                await TtsService.PlayTextAsync(location.TtsScript, location.LanguageCode);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error playing audio: {ex.Message}");
        }
        finally
        {
            isPlaying = false;
        }
    }

    private async Task StopAudio()
    {
        isPlaying = false;
        await Task.CompletedTask;
    }

    private async Task ShareLocation()
    {
        if (location == null) return;

        var shareText = $"📍 {location.Name}\n{location.Description}\n\n🗺️ https://www.google.com/maps?q={location.Latitude},{location.Longitude}";

        try
        {
            await JS.InvokeVoidAsync("eval", $"navigator.share({{ title: '{EscapeJs(location.Name)}', text: '{EscapeJs(shareText)}' }}).catch(()=>{{}})");
        }
        catch
        {
            try
            {
                await JS.InvokeVoidAsync("eval", $"navigator.clipboard.writeText('{EscapeJs(shareText)}')");
            }
            catch { }
        }
    }

    private string EscapeJs(string input)
    {
        return input.Replace("'", "\\'")
                    .Replace("\n", "\\n")
                    .Replace("\r", "");
    }

    private async Task ToggleFavorite()
    {
        if (location == null) return;

        await FavoritesService.ToggleFavoriteAsync(location);
        isFavorite = !isFavorite;
    }

    private void ViewOnMap()
    {
        if (location == null) return;
        var route = PlatformDetector.IsMobile ? "/mobile-map" : "/map";
        Navigation.NavigateTo($"{route}?focusId={location.Id}");
    }

    private void NavigateToPoi(int poiId)
    {
        Navigation.NavigateTo($"/poi/{poiId}", forceLoad: true);
    }

    private async Task<List<MenuItemDto>> LoadMenuItemsAsync(int locationId, string? languageCode)
    {
        try
        {
            var query = string.IsNullOrWhiteSpace(languageCode)
                ? string.Empty
                : $"?lang={Uri.EscapeDataString(languageCode)}";

            return await Http.GetFromJsonAsync<List<MenuItemDto>>($"api/content/menu/poi/{locationId}{query}") ?? new();
        }
        catch
        {
            return new();
        }
    }

    private static string FormatPrice(decimal price, string currency)
    {
        var normalizedCurrency = string.IsNullOrWhiteSpace(currency) ? "VND" : currency;
        return normalizedCurrency == "VND"
            ? string.Format("{0:N0} đ", price)
            : string.Format("{0:N2} {1}", price, normalizedCurrency);
    }

    private async Task LogEntryContextAsync()
    {
        if (location == null)
        {
            return;
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var entrySource = NormalizeEntrySource(GetQueryValue(uri, "entry"));
        if (entrySource == null)
        {
            return;
        }

        var logKey = $"{uri.AbsoluteUri}|{entrySource}";
        if (string.Equals(lastLoggedEntryKey, logKey, StringComparison.Ordinal))
        {
            return;
        }

        try
        {
            await Http.PostAsJsonAsync("api/admin/analytics/play", new
            {
                LocationId = location.Id,
                DurationSeconds = 0,
                SessionId = GetQueryValue(uri, "session"),
                DeviceType = "web",
                Source = entrySource
            });

            lastLoggedEntryKey = logKey;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error logging entry source: {ex.Message}");
        }
    }

    private static string? NormalizeEntrySource(string? entry)
    {
        return entry?.Trim().ToLowerInvariant() switch
        {
            "qr" or "qrcode" or "qr_scan" => "qr_scan",
            "tour" or "tour_start" => "tour_start",
            "tour_progress" => "tour_progress",
            _ => null
        };
    }

    private static string? GetQueryValue(Uri uri, string key)
    {
        if (string.IsNullOrWhiteSpace(uri.Query))
        {
            return null;
        }

        var segments = uri.Query.TrimStart('?')
            .Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        foreach (var segment in segments)
        {
            var parts = segment.Split('=', 2);
            if (!string.Equals(parts[0], key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            return parts.Length == 2
                ? Uri.UnescapeDataString(parts[1])
                : string.Empty;
        }

        return null;
    }

    private void CaptureJourneyContext()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        hasTourJourneyContext = false;
        sourceTourId = null;
        sourceTourSessionId = null;
        sourceTourStopOrder = null;
        tourResumeUrl = null;

        if (!int.TryParse(GetQueryValue(uri, "tourId"), out var tourId) || tourId <= 0)
        {
            return;
        }

        sourceTourId = tourId;
        sourceTourSessionId = GetQueryValue(uri, "session");
        sourceTourStopOrder = int.TryParse(GetQueryValue(uri, "stop"), out var stopOrder) && stopOrder > 0
            ? stopOrder
            : 1;
        hasTourJourneyContext = true;
        tourResumeUrl = BuildTourResumeUrl(tourId, sourceTourSessionId, sourceTourStopOrder.Value);
    }

    private void ReturnToTour()
    {
        if (!string.IsNullOrWhiteSpace(tourResumeUrl))
        {
            Navigation.NavigateTo(tourResumeUrl);
        }
    }

    private static string BuildTourResumeUrl(int tourId, string? sessionId, int stopOrder)
    {
        var queryParts = new List<string>();
        if (!string.IsNullOrWhiteSpace(sessionId))
        {
            queryParts.Add($"session={Uri.EscapeDataString(sessionId)}");
        }

        queryParts.Add($"stop={stopOrder}");
        var queryString = queryParts.Count == 0 ? string.Empty : $"?{string.Join("&", queryParts)}";
        return $"/tours/{tourId}{queryString}";
    }

    private static string BuildDirectionsUrl(LocationDto poi)
    {
        return $"https://www.google.com/maps/dir/?api=1&destination={poi.Latitude},{poi.Longitude}&travelmode=walking&dir_action=navigate";
    }
}
