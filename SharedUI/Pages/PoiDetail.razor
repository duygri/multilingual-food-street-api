@page "/poi/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FoodStreet.Client.Services
@using FoodStreet.Client.DTOs
@inject HttpClient Http
@inject ILocationClientService LocationClient
@inject IFavoritesService FavoritesService
@inject ITtsService TtsService
@inject IPlatformDetector PlatformDetector
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="poi-detail-page">
    @if (isLoading)
    {
        <div class="detail-loading">
            <div class="detail-spinner"></div>
            <p>Đang tải...</p>
        </div>
    }
    else if (location == null)
    {
        <div class="detail-not-found">
            <span class="nf-icon">📍</span>
            <h2>Không tìm thấy địa điểm</h2>
            <p>Địa điểm này có thể đã bị xóa hoặc chưa được duyệt.</p>
            <button class="btn-back-home" @onclick="GoBack">← Quay lại Khám phá</button>
        </div>
    }
    else
    {
        @* ===== HERO IMAGE ===== *@
        <div class="hero-section">
            @if (!string.IsNullOrEmpty(location.ImageUrl))
            {
                <img src="@location.ImageUrl" alt="@location.Name" class="hero-image" />
            }
            else
            {
                <div class="hero-placeholder">
                    <span>📍</span>
                </div>
            }
            <div class="hero-overlay"></div>

            @* Back button *@
            <button class="btn-floating-back" @onclick="GoBack">
                <span>←</span>
            </button>

            @* Favorite button *@
            <button class="btn-floating-fav @(isFavorite ? "is-fav" : "")" @onclick="ToggleFavorite">
                @(isFavorite ? "❤️" : "🤍")
            </button>

            @* Category badge *@
            @if (!string.IsNullOrEmpty(location.CategoryName))
            {
                <div class="hero-category">@location.CategoryName</div>
            }
        </div>

        @* ===== MAIN INFO ===== *@
        <div class="detail-body">
            <div class="info-section">
                <h1 class="poi-title">@location.Name</h1>

                @if (hasTourJourneyContext)
                {
                    <div class="tour-journey-card">
                        <div class="tour-journey-copy">
                            <span class="tour-journey-label">Đang theo hành trình tour</span>
                            <strong>Tour #@sourceTourId • Điểm dừng @sourceTourStopOrder</strong>
                            <p>POI này được mở từ hành trình tour. Bạn có thể quay lại đúng phiên đang đi.</p>
                        </div>
                        <button class="tour-journey-btn" @onclick="ReturnToTour">↩ Quay lại tour</button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(location.Address))
                {
                    <div class="info-row">
                        <span class="info-icon">📍</span>
                        <span class="info-text">@location.Address</span>
                    </div>
                }

                <div class="info-row">
                    <span class="info-icon">🌐</span>
                    <span class="info-text">@($"{location.Latitude:F6}, {location.Longitude:F6}")</span>
                </div>

                @if (location.HasAudio || audioTranslations.Count > 0)
                {
                    <div class="info-row">
                        <span class="info-icon">🎵</span>
                        <span class="info-text audio-available">Có audio thuyết minh (@audioTranslations.Count ngôn ngữ)</span>
                    </div>
                }
                else if (!string.IsNullOrEmpty(location.TtsScript))
                {
                    <div class="info-row">
                        <span class="info-icon">🔊</span>
                        <span class="info-text audio-available">Có thuyết minh TTS</span>
                    </div>
                }

                @if (menuItems.Count > 0)
                {
                    <div class="info-row">
                        <span class="info-icon">🍽️</span>
                        <span class="info-text">@menuItems.Count món đang hiển thị trong menu</span>
                    </div>
                }
            </div>

            @* ===== ACTION BAR (Google Maps style) ===== *@
            <div class="action-bar">
                <button class="action-item" @onclick="OpenDirections">
                    <span class="action-icon directions">🧭</span>
                    <span class="action-label">Chỉ đường</span>
                </button>

                <button class="action-item" @onclick="ScrollToAudio" disabled="@(audioTranslations.Count == 0 && string.IsNullOrEmpty(location.TtsScript))">
                    <span class="action-icon audio">🎧</span>
                    <span class="action-label">Nghe</span>
                </button>

                <button class="action-item" @onclick="ScrollToMenu" disabled="@(menuItems.Count == 0)">
                    <span class="action-icon menu">🍽️</span>
                    <span class="action-label">Menu</span>
                </button>

                <button class="action-item" @onclick="ShareLocation">
                    <span class="action-icon share">📤</span>
                    <span class="action-label">Chia sẻ</span>
                </button>

                <button class="action-item" @onclick="ToggleFavorite">
                    <span class="action-icon fav">@(isFavorite ? "❤️" : "🤍")</span>
                    <span class="action-label">@(isFavorite ? "Đã lưu" : "Lưu")</span>
                </button>
            </div>

            @* ===== DESCRIPTION ===== *@
            @if (!string.IsNullOrEmpty(location.Description))
            {
                <div class="description-section">
                    <h3>📖 Giới thiệu</h3>
                    <p>@location.Description</p>
                </div>
            }

            @if (menuItems.Count > 0)
            {
                <div class="menu-section" id="menu-section">
                    <div class="menu-section-header">
                        <div>
                            <h3>🍽️ Menu gợi ý</h3>
                            <p class="menu-section-subtitle">Các món đang được hiển thị tại POI này.</p>
                        </div>
                        <span class="menu-section-badge">@menuItems.Count món</span>
                    </div>

                    <div class="menu-list">
                        @foreach (var item in menuItems)
                        {
                            <div class="menu-card">
                                <div class="menu-card-top">
                                    <div>
                                        <div class="menu-name-row">
                                            <div class="menu-name">@item.Name</div>
                                            @if (item.FallbackUsed)
                                            {
                                                <span class="menu-lang-badge">@item.LanguageCode</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(item.Description))
                                        {
                                            <div class="menu-description">@item.Description</div>
                                        }
                                    </div>
                                    <div class="menu-price">@FormatPrice(item.Price, item.Currency)</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @* ===== MULTI-LANGUAGE AUDIO PLAYER ===== *@
            @if (audioTranslations.Count > 0 || !string.IsNullOrEmpty(location.TtsScript))
            {
                <div class="audio-player-card" id="audio-section">
                    <div class="audio-card-header">
                        <div>
                            <h4>🎧 Thuyết minh Audio</h4>
                            <p class="audio-subtitle">Chọn ngôn ngữ để nghe câu chuyện về địa điểm này</p>
                        </div>
                        <span class="audio-badge">@audioTranslations.Count ngôn ngữ</span>
                    </div>

                    <div class="audio-lang-list">
                        @foreach (var trans in audioTranslations)
                        {
                            var isActive = selectedLang == trans.LanguageCode;
                            var isThisPlaying = isPlaying && selectedLang == trans.LanguageCode;
                            <button class="audio-lang-item @(isActive ? "active" : "")" 
                                    @onclick="() => SelectAndPlayLanguage(trans)"
                                    disabled="@isPlaying">
                                <span class="lang-flag">@trans.LanguageFlag</span>
                                <div class="lang-info">
                                    <span class="lang-name">@trans.LanguageLabel</span>
                                    @if (isThisPlaying)
                                    {
                                        <span class="lang-status playing">
                                            <span class="equalizer">
                                                <span></span><span></span><span></span>
                                            </span>
                                            Đang phát...
                                        </span>
                                    }
                                    else if (!string.IsNullOrEmpty(trans.AudioUrl))
                                    {
                                        <span class="lang-status ready">Sẵn sàng</span>
                                    }
                                    else if (!string.IsNullOrEmpty(trans.TtsScript))
                                    {
                                        <span class="lang-status tts">TTS</span>
                                    }
                                </div>
                                <span class="lang-play-icon">
                                    @if (isThisPlaying)
                                    {
                                        <span>⏸️</span>
                                    }
                                    else
                                    {
                                        <span>▶️</span>
                                    }
                                </span>
                            </button>
                        }
                    </div>

                    @* Fallback: If no translations but has TTS script *@
                    @if (audioTranslations.Count == 0 && !string.IsNullOrEmpty(location.TtsScript))
                    {
                        <button class="audio-lang-item active" @onclick="PlayDefaultAudio" disabled="@isPlaying">
                            <span class="lang-flag">🇻🇳</span>
                            <div class="lang-info">
                                <span class="lang-name">Tiếng Việt</span>
                                <span class="lang-status @(isPlaying ? "playing" : "ready")">
                                    @(isPlaying ? "Đang phát..." : "TTS")
                                </span>
                            </div>
                            <span class="lang-play-icon">@(isPlaying ? "⏸️" : "▶️")</span>
                        </button>
                    }

                    @if (isPlaying)
                    {
                        <button class="btn-stop-audio" @onclick="StopAudio">
                            ⏹️ Dừng phát
                        </button>
                    }
                </div>
            }

            @* ===== MINI MAP ===== *@
            <div class="minimap-section" @onclick="ViewOnMap">
                <div class="minimap-header">
                    <h3>🗺️ Vị trí trên bản đồ</h3>
                    <span class="text-primary small fw-bold">Xem bản đồ lớn ›</span>
                </div>
                <div class="minimap-container">
                    @if (!string.IsNullOrWhiteSpace(miniMapUrl))
                    {
                        <img src="@miniMapUrl" alt="Google Map" class="minimap-img" />
                    }
                    else
                    {
                        <div class="minimap-fallback">
                            <strong>Chạm để mở Google Maps</strong>
                            <span>@($"{location.Latitude:F5}, {location.Longitude:F5}")</span>
                        </div>
                    }
                </div>
            </div>

            @* ===== DETAIL INFO CARDS ===== *@
            <div class="detail-cards">
                <div class="detail-card">
                    <span class="dc-icon">📏</span>
                    <div class="dc-info">
                        <span class="dc-label">Bán kính geofence</span>
                        <span class="dc-value">@(location.Radius)m</span>
                    </div>
                </div>

                @if (location.Distance > 0)
                {
                    <div class="detail-card">
                        <span class="dc-icon">🚶</span>
                        <div class="dc-info">
                            <span class="dc-label">Khoảng cách</span>
                            <span class="dc-value">
                                @if (location.Distance >= 1000)
                                {
                                    @($"{location.Distance / 1000:F1} km")
                                }
                                else
                                {
                                    @($"{location.Distance:F0} m")
                                }
                            </span>
                        </div>
                    </div>
                }

                <div class="detail-card">
                    <span class="dc-icon">✅</span>
                    <div class="dc-info">
                        <span class="dc-label">Trạng thái</span>
                        <span class="dc-value @(location.IsApproved ? "approved" : "pending")">
                            @(location.IsApproved ? "Đã duyệt" : "Chờ duyệt")
                        </span>
                    </div>
                </div>
            </div>

            @* ===== SIMILAR POIs ===== *@
            @if (similarPois.Count > 0)
            {
                <div class="similar-section">
                    <div class="similar-header">
                        <h3>📍 Địa điểm tương tự</h3>
                    </div>
                    <div class="similar-scroll">
                        @foreach (var poi in similarPois)
                        {
                            <div class="similar-card" @onclick="() => NavigateToPoi(poi.Id)">
                                <div class="similar-thumb">
                                    @if (!string.IsNullOrEmpty(poi.ImageUrl))
                                    {
                                        <img src="@poi.ImageUrl" alt="@poi.Name" />
                                    }
                                    else
                                    {
                                        <div class="similar-thumb-placeholder">📍</div>
                                    }
                                </div>
                                <div class="similar-info">
                                    <span class="similar-name">@poi.Name</span>
                                    @if (!string.IsNullOrEmpty(poi.CategoryName))
                                    {
                                        <span class="similar-cat">@poi.CategoryName</span>
                                    }
                                    @if (poi.HasAudio)
                                    {
                                        <span class="similar-audio">🎧 Audio</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @* Bottom padding for mobile nav *@
            <div style="height: 80px;"></div>
        </div>
    }
</div>

<style>
    .poi-detail-page {
        min-height: calc(100vh - 112px);
        background: #f8fafc;
    }

    /* Loading & Not Found */
    .detail-loading, .detail-not-found {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        color: #64748b;
        text-align: center;
        padding: 40px 20px;
    }

    .detail-spinner {
        width: 44px;
        height: 44px;
        border: 3px solid #f1f5f9;
        border-top-color: #ff6b35;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-bottom: 16px;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .nf-icon { font-size: 56px; margin-bottom: 16px; }

    .detail-not-found h2 {
        font-size: 20px;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 8px;
        letter-spacing: -0.3px;
    }

    .btn-back-home {
        margin-top: 20px;
        padding: 14px 28px;
        background: linear-gradient(135deg, #ff6b35, #f7931e);
        color: #fff;
        border: none;
        border-radius: 14px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 16px rgba(255, 107, 53, 0.25);
    }

    .btn-back-home:active {
        transform: scale(0.96);
    }

    /* === HERO === */
    .hero-section {
        position: relative;
        width: 100%;
        height: 300px;
        overflow: hidden;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        animation: fadeIn 0.4s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .hero-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 72px;
    }

    .hero-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 140px;
        background: linear-gradient(transparent, rgba(0,0,0,0.55));
        pointer-events: none;
    }

    .btn-floating-back {
        position: absolute;
        top: 16px;
        left: 16px;
        width: 42px;
        height: 42px;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: none;
        border-radius: 50%;
        font-size: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        z-index: 2;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .btn-floating-back:active { transform: scale(0.88); }

    .btn-floating-fav {
        position: absolute;
        top: 16px;
        right: 16px;
        width: 42px;
        height: 42px;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: none;
        border-radius: 50%;
        font-size: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        z-index: 2;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .btn-floating-fav:active { transform: scale(0.88); }
    .btn-floating-fav.is-fav { background: #fff0ed; }

    .hero-category {
        position: absolute;
        bottom: 16px;
        left: 16px;
        padding: 6px 14px;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
        color: #ff6b35;
        z-index: 2;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    /* === BODY === */
    .detail-body {
        padding: 20px;
        margin-top: -28px;
        position: relative;
        z-index: 1;
        background: #f8fafc;
        border-radius: 28px 28px 0 0;
    }

    .info-section {
        background: #fff;
        border-radius: 22px;
        padding: 22px;
        margin-bottom: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.04);
        animation: slideUp 0.35s ease;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .poi-title {
        font-size: 24px;
        font-weight: 900;
        color: #1e293b;
        margin: 0 0 14px;
        line-height: 1.25;
        letter-spacing: -0.5px;
    }

    .tour-journey-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 16px;
        padding: 14px 16px;
        border-radius: 18px;
        background: linear-gradient(135deg, #fff7ed, #ffffff);
        border: 1px solid #fdba74;
        box-shadow: 0 10px 24px rgba(234, 88, 12, 0.08);
    }

    .tour-journey-copy {
        min-width: 0;
    }

    .tour-journey-copy strong {
        display: block;
        margin: 4px 0;
        color: #111827;
        font-size: 15px;
        font-weight: 800;
    }

    .tour-journey-copy p {
        margin: 0;
        color: #6b7280;
        font-size: 13px;
        line-height: 1.5;
    }

    .tour-journey-label {
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        background: #ffedd5;
        color: #c2410c;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .tour-journey-btn {
        border: none;
        border-radius: 14px;
        padding: 12px 14px;
        background: linear-gradient(135deg, #ea580c, #fb923c);
        color: white;
        font-weight: 800;
        white-space: nowrap;
        cursor: pointer;
        box-shadow: 0 10px 24px rgba(234, 88, 12, 0.18);
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .tour-journey-btn:active {
        transform: scale(0.96);
    }

    .info-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .info-row:last-child { border-bottom: none; }

    .info-icon { font-size: 18px; flex-shrink: 0; }

    .info-text {
        font-size: 14px;
        color: #475569;
        line-height: 1.4;
    }

    .audio-available {
        color: #10b981;
        font-weight: 600;
    }

    /* === ACTION BAR === */
    .action-bar {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
        background: #fff;
        border-radius: 22px;
        padding: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.04);
        animation: slideUp 0.4s ease;
    }

    .action-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        padding: 12px 4px;
        background: #f8fafc;
        border: none;
        border-radius: 16px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .action-item:active:not(:disabled) {
        transform: scale(0.92);
        background: #f1f5f9;
    }

    .action-item:disabled {
        opacity: 0.35;
        cursor: not-allowed;
    }

    .action-icon {
        font-size: 24px;
        width: 46px;
        height: 46px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: transform 0.2s ease;
    }

    .action-item:active:not(:disabled) .action-icon {
        transform: scale(1.05);
    }

    .action-icon.directions { background: rgba(59, 130, 246, 0.1); }
    .action-icon.audio { background: rgba(16, 185, 129, 0.1); }
    .action-icon.menu { background: rgba(245, 158, 11, 0.12); }
    .action-icon.share { background: rgba(139, 92, 246, 0.1); }
    .action-icon.fav { background: rgba(239, 68, 68, 0.1); }

    .action-label {
        font-size: 11px;
        font-weight: 700;
        color: #475569;
        letter-spacing: -0.1px;
    }

    /* === DESCRIPTION === */
    .description-section {
        background: #fff;
        border-radius: 22px;
        padding: 22px;
        margin-bottom: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.04);
    }

    .description-section h3 {
        font-size: 16px;
        font-weight: 800;
        color: #1e293b;
        margin: 0 0 10px;
        letter-spacing: -0.2px;
    }

    .description-section p {
        font-size: 14px;
        color: #475569;
        line-height: 1.75;
        margin: 0;
        white-space: pre-line;
    }

    /* === MENU === */
    .menu-section {
        background: #fff;
        border-radius: 22px;
        padding: 22px;
        margin-bottom: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.04);
        border: 1px solid rgba(245, 158, 11, 0.1);
    }

    .menu-section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 14px;
    }

    .menu-section-header h3 {
        font-size: 16px;
        font-weight: 800;
        color: #1e293b;
        margin: 0 0 4px;
        letter-spacing: -0.2px;
    }

    .menu-section-subtitle {
        margin: 0;
        font-size: 13px;
        color: #94a3b8;
    }

    .menu-section-badge {
        background: rgba(245, 158, 11, 0.1);
        color: #d97706;
        font-size: 12px;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 20px;
        white-space: nowrap;
    }

