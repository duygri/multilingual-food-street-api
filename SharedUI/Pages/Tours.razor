@page "/tours"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@inject ITourClientService TourClient
@inject ISessionStorageService SessionStorage
@inject NavigationManager Navigation

<div class="tours-browser-page">
    <header class="tours-browser-header">
        <div>
            <h1>🗺️ Tour Vĩnh Khánh</h1>
            <p>Chọn hành trình để khám phá khu ẩm thực theo từng điểm dừng.</p>
        </div>
        <button class="back-btn" @onclick="GoBack">← Khám phá</button>
    </header>

    @if (isLoading)
    {
        <div class="tour-loading">
            <div class="tour-spinner"></div>
            <p>Đang tải tour...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="tour-empty">
            <span class="empty-icon">⚠️</span>
            <h3>Không tải được danh sách tour</h3>
            <p>@errorMessage</p>
        </div>
    }
    else if (!tours.Any())
    {
        <div class="tour-empty">
            <span class="empty-icon">🧭</span>
            <h3>Chưa có tour hoạt động</h3>
            <p>Hệ thống chưa xuất bản tour nào cho du khách.</p>
        </div>
    }
    else
    {
        @if (resumeSnapshot != null && resumeTour != null)
        {
            <section class="tour-resume-card">
                <div class="tour-resume-copy">
                    <span class="tour-resume-badge">Tiếp tục tour đang dở</span>
                    <h2>@resumeTour.Name</h2>
                    <p>
                        Đang ở điểm @resumeSnapshot.StopOrder/@resumeSnapshot.TotalStops:
                        <strong>@resumeSnapshot.CurrentStopName</strong>
                    </p>
                    <div class="tour-resume-meta">
                        <span>📈 @resumeSnapshot.ProgressPercent%</span>
                        <span>✅ @resumeSnapshot.CompletedStops/@resumeSnapshot.TotalStops điểm</span>
                        <span>🕒 @FormatTimeAgo(resumeSnapshot.UpdatedAt)</span>
                    </div>
                </div>
                <div class="tour-resume-actions">
                    <button class="resume-btn primary" @onclick="ResumeTour">▶ Tiếp tục</button>
                    <button class="resume-btn ghost" @onclick="DismissResumeAsync">Bỏ phiên này</button>
                </div>
            </section>
        }

        <div class="tour-grid">
            @foreach (var tour in tours)
            {
                <article class="tour-card" @onclick="() => OpenTour(tour.Id)">
                    <div class="tour-card-top">
                        <span class="tour-badge">Tour công khai</span>
                        <span class="tour-arrow">›</span>
                    </div>
                    <h3>@tour.Name</h3>
                    <p>@(tour.Description ?? "Khám phá các điểm ăn uống nổi bật theo lộ trình được gợi ý.")</p>
                    <div class="tour-stats">
                        <span>📍 @tour.ItemCount điểm</span>
                        <span>⏱️ @tour.EstimatedDurationMinutes phút</span>
                        <span>📏 @tour.EstimatedDistanceKm.ToString("0.#") km</span>
                    </div>
                    @if (tour.Items.Any())
                    {
                        <div class="tour-preview">
                            @foreach (var stop in tour.Items.Take(3))
                            {
                                <span class="tour-stop">@stop.Order. @stop.LocationName</span>
                            }
                            @if (tour.Items.Count > 3)
                            {
                                <span class="tour-stop more">+@(tour.Items.Count - 3) điểm khác</span>
                            }
                        </div>
                    }
                </article>
            }
        </div>
    }
</div>

<style>
    .tours-browser-page {
        min-height: calc(100vh - 112px);
        background: linear-gradient(180deg, #fff7ed 0%, #f8fafc 30%, #f8fafc 100%);
        padding: 20px 16px 28px;
    }

    .tours-browser-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 18px;
    }

    .tours-browser-header h1 {
        margin: 0 0 6px;
        font-size: 24px;
        font-weight: 800;
        color: #111827;
    }

    .tours-browser-header p {
        margin: 0;
        color: #6b7280;
        font-size: 14px;
        line-height: 1.5;
        max-width: 560px;
    }

    .back-btn {
        border: none;
        border-radius: 999px;
        padding: 10px 14px;
        background: #ffffff;
        color: #c2410c;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 24px rgba(194, 65, 12, 0.08);
        white-space: nowrap;
    }

    .tour-loading,
    .tour-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 320px;
        color: #6b7280;
        padding: 24px;
    }

    .tour-spinner {
        width: 42px;
        height: 42px;
        border: 3px solid #fed7aa;
        border-top-color: #ea580c;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-bottom: 12px;
    }

    .empty-icon {
        font-size: 52px;
        margin-bottom: 12px;
    }

    .tour-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 16px;
    }

    .tour-resume-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 18px;
        padding: 18px;
        border-radius: 26px;
        background: linear-gradient(135deg, #9a3412, #ea580c 55%, #fb923c);
        color: white;
        box-shadow: 0 20px 40px rgba(154, 52, 18, 0.18);
    }

    .tour-resume-copy {
        min-width: 0;
    }

    .tour-resume-badge {
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,0.18);
        font-size: 12px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .tour-resume-card h2 {
        margin: 0 0 8px;
        font-size: 22px;
        font-weight: 800;
    }

    .tour-resume-card p {
        margin: 0;
        color: rgba(255,255,255,0.88);
        line-height: 1.6;
    }

    .tour-resume-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 12px;
        margin-top: 12px;
        font-size: 12px;
        font-weight: 700;
        color: rgba(255,255,255,0.92);
    }

    .tour-resume-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .resume-btn {
        border: none;
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 800;
        cursor: pointer;
        white-space: nowrap;
    }

    .resume-btn.primary {
        background: white;
        color: #c2410c;
        box-shadow: 0 12px 30px rgba(255,255,255,0.2);
    }

    .resume-btn.ghost {
        background: rgba(255,255,255,0.14);
        color: white;
        border: 1px solid rgba(255,255,255,0.22);
    }

    .tour-card {
        background: #fff;
        border-radius: 24px;
        padding: 18px;
        border: 1px solid #ffedd5;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.06);
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .tour-card:active {
        transform: scale(0.985);
    }

    .tour-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 18px 36px rgba(15, 23, 42, 0.1);
    }

    .tour-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .tour-badge {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        background: #fff7ed;
        color: #c2410c;
        font-size: 12px;
        font-weight: 700;
    }

    .tour-arrow {
        font-size: 26px;
        color: #cbd5e1;
    }

    .tour-card h3 {
        margin: 0 0 8px;
        font-size: 18px;
        font-weight: 800;
        color: #111827;
    }

    .tour-card p {
        margin: 0 0 14px;
        font-size: 14px;
        line-height: 1.6;
        color: #6b7280;
    }

    .tour-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 12px;
        margin-bottom: 14px;
        font-size: 12px;
        font-weight: 700;
        color: #475569;
    }

    .tour-preview {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .tour-stop {
        font-size: 13px;
        color: #374151;
        background: #f8fafc;
        padding: 8px 10px;
        border-radius: 12px;
    }

    .tour-stop.more {
        color: #c2410c;
        background: #fff7ed;
        font-weight: 700;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    @@media (max-width: 640px) {
        .tours-browser-header {
            flex-direction: column;
        }

        .tour-resume-card {
            flex-direction: column;
            align-items: stretch;
        }

        .back-btn {
            align-self: flex-start;
        }
    }
</style>

@code {
    private List<TourDto> tours = new();
    private bool isLoading = true;
    private string? errorMessage;
    private TourResumeSnapshotDto? resumeSnapshot;
    private TourDto? resumeTour;
    private const string TourResumeStorageKey = "tour_resume_snapshot";

    protected override async Task OnInitializedAsync()
    {
        await LoadResumeSnapshotAsync();
        await LoadToursAsync();
    }

    private async Task LoadToursAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            tours = await TourClient.GetActiveToursAsync();
            await ReconcileResumeSnapshotAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            tours = new();
            resumeTour = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenTour(int id)
    {
        Navigation.NavigateTo($"/tours/{id}");
    }

    private async Task LoadResumeSnapshotAsync()
    {
        resumeSnapshot = await TourClient.GetLatestResumeAsync();
        resumeSnapshot ??= await SessionStorage.GetItemAsync<TourResumeSnapshotDto>(TourResumeStorageKey);
    }

    private async Task ReconcileResumeSnapshotAsync()
    {
        if (resumeSnapshot == null)
        {
            resumeTour = null;
            return;
        }

        resumeTour = tours.FirstOrDefault(t => t.Id == resumeSnapshot.TourId);
        if (resumeTour == null || string.IsNullOrWhiteSpace(resumeSnapshot.SessionId) || resumeSnapshot.StopOrder <= 0)
        {
            await DismissResumeAsync();
            return;
        }

        resumeSnapshot.TourName = resumeTour.Name;
        resumeSnapshot.TourDescription = resumeTour.Description;
    }

    private void ResumeTour()
    {
        if (resumeSnapshot == null)
        {
            return;
        }

        Navigation.NavigateTo($"/tours/{resumeSnapshot.TourId}?session={Uri.EscapeDataString(resumeSnapshot.SessionId)}&stop={resumeSnapshot.StopOrder}");
    }

    private async Task DismissResumeAsync()
    {
        if (!string.IsNullOrWhiteSpace(resumeSnapshot?.SessionId))
        {
            await TourClient.DismissSessionAsync(resumeSnapshot.SessionId);
        }

        resumeSnapshot = null;
        resumeTour = null;
        await SessionStorage.RemoveItemAsync(TourResumeStorageKey);
    }

    private static string FormatTimeAgo(DateTime updatedAt)
    {
        var diff = DateTime.UtcNow - updatedAt;
        if (diff.TotalMinutes < 1) return "vừa xong";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút trước";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ trước";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} ngày trước";
        return updatedAt.ToLocalTime().ToString("dd/MM HH:mm");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/explore");
    }
}
