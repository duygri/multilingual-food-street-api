@page "/tours/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FoodStreet.Client.DTOs
@using FoodStreet.Client.Services
@inject ITourClientService TourClient
@inject TourPlayerService TourPlayer
@inject ISessionStorageService SessionStorage
@inject NavigationManager Navigation

<div class="tour-detail-page">
    @if (isLoading)
    {
        <div class="tour-state">
            <div class="tour-spinner"></div>
            <p>Đang tải tour...</p>
        </div>
    }
    else if (tour == null)
    {
        <div class="tour-state">
            <span class="state-icon">🧭</span>
            <h3>Không tìm thấy tour</h3>
            <p>Tour này có thể đã bị ẩn hoặc chưa được kích hoạt.</p>
            <button class="ghost-btn" @onclick="GoBack">← Quay lại danh sách</button>
        </div>
    }
    else
    {
        <header class="tour-hero">
            <button class="hero-back" @onclick="GoBack">← Tour</button>
            <div class="hero-copy">
                <span class="hero-tag">Tour trải nghiệm</span>
                <h1>@tour.Name</h1>
                <p>@(tour.Description ?? "Khám phá từng điểm dừng theo lộ trình được gợi ý.")</p>
            </div>
            <div class="hero-stats">
                <div><strong>@tour.ItemCount</strong><span>điểm dừng</span></div>
                <div><strong>@tour.EstimatedDurationMinutes</strong><span>phút</span></div>
                <div><strong>@tour.EstimatedDistanceKm.ToString("0.#")</strong><span>km</span></div>
            </div>
        </header>

        <section class="tour-session-card">
            @if (session == null)
            {
                <div class="session-idle">
                    <h2>Bắt đầu hành trình</h2>
                    <p>Hệ thống sẽ tạo phiên tour, mở điểm dừng đầu tiên và phát thuyết minh nếu nội dung đã sẵn sàng.</p>
                    <button class="primary-btn" @onclick="StartTourAsync" disabled="@isStarting">
                        @(isStarting ? "Đang bắt đầu..." : "▶ Bắt đầu tour")
                    </button>
                </div>
            }
            else
            {
                <div class="session-header">
                    <div>
                        <h2>Tiến độ tour</h2>
                        <p>Phiên: @session.SessionId</p>
                    </div>
                    <div class="progress-pill">@(session.ProgressPercent)%</div>
                </div>

                <div class="progress-track">
                    <div class="progress-bar" style="width:@($"{session.ProgressPercent}%")"></div>
                </div>

                <div class="progress-meta">
                    <span>Đã hoàn thành @session.CompletedStops / @session.TotalStops điểm</span>
                    <span>@(session.IsCompleted ? "Đã hoàn tất hành trình" : "Đang tiếp tục hành trình")</span>
                </div>

                @if (activeStop != null)
                {
                    <article class="active-stop-card">
                        <div class="active-stop-copy">
                            <span class="stop-order">Điểm đang nghe: @activeStop.Order</span>
                            <h3>@activeStop.LocationName</h3>
                            <p>@(activeStop.LocationDescription ?? "Nội dung giới thiệu sẽ hiển thị tại đây.")</p>
                            <div class="stop-tags">
                                <span>🌐 @activeStop.LanguageCode</span>
                                <span>🎧 @activeStop.AudioStatus</span>
                                @if (activeStop.FallbackUsed)
                                {
                                    <span>↩ fallback</span>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(activeStop.LocationImageUrl))
                        {
                            <img class="active-stop-image" src="@activeStop.LocationImageUrl" alt="@activeStop.LocationName" />
                        }
                    </article>
                }

                <div class="session-actions">
                    <button class="primary-btn" @onclick="PlayActiveStopAsync" disabled="@(activeStop == null)">
                        🎧 Phát thuyết minh
                    </button>
                    <button class="ghost-btn" @onclick="OpenActivePoi" disabled="@(activeStop == null)">
                        📍 Mở chi tiết POI
                    </button>
                    <button class="ghost-btn" @onclick="AdvanceTourAsync" disabled="@(activeStop == null || session.IsCompleted || isAdvancing)">
                        @(isAdvancing ? "Đang cập nhật..." : "➡ Điểm kế tiếp")
                    </button>
                </div>

                @if (session.NextStop != null && !session.IsCompleted)
                {
                    <div class="next-stop-card">
                        <span class="next-label">Tiếp theo</span>
                        <strong>@session.NextStop.LocationName</strong>
                        <p>@(session.NextStop.Note ?? "Điểm dừng kế tiếp trong hành trình.")</p>
                    </div>
                }
            }
        </section>

        <section class="tour-stops-section">
            <div class="section-header">
                <h2>Lộ trình chi tiết</h2>
                <p>Danh sách điểm dừng theo thứ tự được đề xuất.</p>
            </div>

            <div class="stop-list">
                @foreach (var stop in tour.Items.OrderBy(i => i.Order))
                {
                    var isActive = activeStop?.LocationId == stop.LocationId;
                    var isCompleted = session != null && stop.Order <= session.CompletedStops;

                    <article class="stop-list-item @(isActive ? "active" : "") @(isCompleted ? "completed" : "")">
                        <div class="stop-number">@stop.Order</div>
                        <div class="stop-body">
                            <div class="stop-title-row">
                                <h3>@stop.LocationName</h3>
                                @if (isCompleted)
                                {
                                    <span class="stop-state complete">Đã qua</span>
                                }
                                else if (isActive)
                                {
                                    <span class="stop-state active">Hiện tại</span>
                                }
                            </div>
                            <p>@(stop.LocationDescription ?? stop.Note ?? "Điểm dừng trong tour trải nghiệm.")</p>
                            <div class="stop-meta">
                                <span>⏱️ @stop.EstimatedStopMinutes phút</span>
                                <span>🌐 @stop.LanguageCode</span>
                                @if (stop.HasAudio)
                                {
                                    <span>🎧 Có audio</span>
                                }
                            </div>
                        </div>
                        <button class="stop-link" @onclick="@(() => OpenStopPoi(stop))">Chi tiết</button>
                    </article>
                }
            </div>
        </section>
    }
</div>

<style>
    .tour-detail-page {
        min-height: calc(100vh - 112px);
        background: linear-gradient(180deg, #fff7ed 0%, #ffffff 20%, #f8fafc 100%);
        padding-bottom: 32px;
    }

    .tour-state {
        min-height: 70vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: #64748b;
        padding: 24px;
    }

    .state-icon {
        font-size: 52px;
        margin-bottom: 12px;
    }

    .tour-spinner {
        width: 42px;
        height: 42px;
        border: 3px solid #fed7aa;
        border-top-color: #ea580c;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-bottom: 12px;
    }

    .tour-hero {
        padding: 22px 18px 20px;
        background: radial-gradient(circle at top left, rgba(251, 146, 60, 0.24), transparent 40%), linear-gradient(135deg, #9a3412, #ea580c 55%, #fb923c);
        color: white;
    }

    .hero-back {
        border: none;
        background: rgba(255,255,255,0.16);
        color: white;
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: 700;
        cursor: pointer;
        margin-bottom: 16px;
    }

    .hero-tag {
        display: inline-flex;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,0.18);
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .hero-copy h1 {
        margin: 0 0 8px;
        font-size: 28px;
        font-weight: 800;
    }

    .hero-copy p {
        margin: 0;
        max-width: 720px;
        color: rgba(255,255,255,0.88);
        line-height: 1.6;
    }

    .hero-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 18px;
    }

    .hero-stats div {
        min-width: 90px;
        padding: 10px 12px;
        border-radius: 16px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(8px);
    }

    .hero-stats strong {
        display: block;
        font-size: 20px;
        line-height: 1.1;
    }

    .hero-stats span {
        font-size: 12px;
        color: rgba(255,255,255,0.8);
    }

    .tour-session-card,
    .tour-stops-section {
        margin: 16px;
        background: white;
        border-radius: 24px;
        padding: 18px;
        border: 1px solid #ffedd5;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.05);
    }

    .session-idle h2,
    .section-header h2 {
        margin: 0 0 8px;
        color: #111827;
        font-size: 20px;
        font-weight: 800;
    }

    .session-idle p,
    .section-header p {
        margin: 0 0 16px;
        color: #6b7280;
        line-height: 1.6;
    }

    .session-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .session-header h2 {
        margin: 0 0 4px;
        color: #111827;
        font-size: 20px;
    }

    .session-header p {
        margin: 0;
        color: #94a3b8;
        font-size: 12px;
    }

    .progress-pill {
        padding: 10px 14px;
        border-radius: 999px;
        background: #fff7ed;
        color: #c2410c;
        font-weight: 800;
    }

    .progress-track {
        margin-top: 16px;
        background: #e5e7eb;
        border-radius: 999px;
