        height: 40px;
        border-radius: 50%;
        background: #111827;
        color: white;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stop-title-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
    }

    .stop-title-row h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 800;
        color: #111827;
    }

    .stop-state {
        padding: 4px 8px;
        border-radius: 999px;
        font-size: 11px;
