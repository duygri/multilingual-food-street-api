        width: 112px;
        height: 112px;
        object-fit: cover;
        border-radius: 18px;
    }

    .session-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 16px;
    }

    .primary-btn,
    .ghost-btn,
    .stop-link {
        border: none;
        border-radius: 14px;
        padding: 12px 16px;
        font-weight: 700;
