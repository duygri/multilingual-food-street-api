        font-weight: 700;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    @@media (max-width: 640px) {
        .active-stop-card {
            grid-template-columns: 1fr;
        }

        .active-stop-image {
            width: 100%;
            height: 180px;
        }

        .stop-list-item {
            grid-template-columns: 36px minmax(0, 1fr);
        }

        .stop-link {
            grid-column: 2;
            justify-self: start;
        }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private TourDto? tour;
    private TourSessionDto? session;
    private TourStopDto? activeStop;
    private bool isLoading = true;
    private bool isStarting;
    private bool isAdvancing;
    private string? lastContextKey;
    private const string TourResumeStorageKey = "tour_resume_snapshot";

    protected override async Task OnParametersSetAsync()
    {
        var contextKey = $"{Id}|{Navigation.ToAbsoluteUri(Navigation.Uri).Query}";
        if (string.Equals(lastContextKey, contextKey, StringComparison.Ordinal))
        {
            return;
        }

        lastContextKey = contextKey;
        await LoadTourAsync();
    }

    private async Task LoadTourAsync()
    {
        isLoading = true;

        try
        {
            tour = await TourClient.GetTourAsync(Id);
            await RestoreSessionFromQueryAsync(Navigation.ToAbsoluteUri(Navigation.Uri));
            await PersistResumeSnapshotAsync();
        }
        catch
        {
            tour = null;
            session = null;
            activeStop = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task StartTourAsync()
    {
        if (tour == null)
        {
            return;
        }

        isStarting = true;

        try
        {
            session = await TourClient.StartTourAsync(tour.Id, new StartTourRequestDto
            {
                DeviceType = "web"
            });

            activeStop = session?.CurrentStop;
            SyncSessionToUrl();
            await PersistResumeSnapshotAsync();
            await PlayActiveStopAsync();
        }
        finally
        {
            isStarting = false;
        }
    }

    private async Task AdvanceTourAsync()
    {
        if (tour == null || session == null || activeStop == null)
        {
            return;
        }

        isAdvancing = true;

        try
        {
            var progress = await TourClient.UpdateProgressAsync(tour.Id, new TourProgressRequestDto
            {
                SessionId = session.SessionId,
                CurrentLocationId = activeStop.LocationId,
                DeviceType = "web"
            });

            if (progress != null)
            {
                session = progress;
                activeStop = progress.CurrentStop ?? progress.NextStop;
                SyncSessionToUrl();
                await PersistResumeSnapshotAsync();
                await PlayActiveStopAsync();
            }
        }
        finally
        {
            isAdvancing = false;
        }
    }

    private async Task PlayActiveStopAsync()
    {
        if (activeStop == null)
        {
            return;
        }

        await TourPlayer.Play(new PlayableItem(
            activeStop.LocationId,
            activeStop.LocationName,
            activeStop.Note ?? "Thuyết minh điểm dừng",
            activeStop.LocationImageUrl,
            activeStop.AudioUrl,
            activeStop.LocationDescription));
    }

    private void OpenActivePoi()
    {
        if (activeStop == null)
        {
            return;
        }

        Navigation.NavigateTo(BuildPoiJourneyUrl(activeStop));
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/tours");
    }

    private void OpenStopPoi(TourStopDto stop)
    {
        Navigation.NavigateTo(BuildPoiJourneyUrl(stop));
    }

    private async Task RestoreSessionFromQueryAsync(Uri uri)
    {
        if (tour == null)
        {
            session = null;
            activeStop = null;
            return;
        }

        var sessionId = GetQueryValue(uri, "session");
        if (string.IsNullOrWhiteSpace(sessionId))
        {
            session = null;
            activeStop = null;
            return;
        }

        var persistedSession = await TourClient.ResumeTourAsync(tour.Id, new ResumeTourRequestDto
        {
            SessionId = sessionId,
            DeviceType = "web"
        });

        persistedSession ??= await TourClient.GetSessionAsync(tour.Id, sessionId);
        if (persistedSession != null)
        {
            session = persistedSession;
            activeStop = persistedSession.CurrentStop ?? persistedSession.NextStop;
            return;
        }

        var orderedStops = tour.Items.OrderBy(item => item.Order).ToList();
        if (!orderedStops.Any())
        {
            session = null;
            activeStop = null;
            return;
        }

        var requestedStop = ParseStopOrder(GetQueryValue(uri, "stop"));
        var currentStop = requestedStop.HasValue
            ? orderedStops.FirstOrDefault(item => item.Order == requestedStop.Value)
            : null;

        currentStop ??= orderedStops[0];

        var nextStop = orderedStops.FirstOrDefault(item => item.Order == currentStop.Order + 1);
        var completedStops = Math.Max(0, currentStop.Order - 1);
        var progressPercent = orderedStops.Count == 0
            ? 0
            : (int)Math.Round((double)completedStops / orderedStops.Count * 100, MidpointRounding.AwayFromZero);

        session = new TourSessionDto
        {
            TourId = tour.Id,
            SessionId = sessionId,
            TotalStops = orderedStops.Count,
            CompletedStops = completedStops,
            ProgressPercent = progressPercent,
            CurrentStop = currentStop,
            NextStop = nextStop,
            IsCompleted = nextStop == null && currentStop.Order >= orderedStops.Count
        };
        activeStop = currentStop;
    }

    private void SyncSessionToUrl()
    {
        if (tour == null || session == null || activeStop == null)
        {
            return;
        }

        var targetUrl = BuildTourSessionUrl(tour.Id, session.SessionId, activeStop.Order);
        var currentRelative = $"{Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath}{Navigation.ToAbsoluteUri(Navigation.Uri).Query}";
        if (string.Equals(currentRelative, targetUrl, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        Navigation.NavigateTo(targetUrl, replace: true);
    }

    private string BuildPoiJourneyUrl(TourStopDto stop)
    {
        var queryParts = new List<string>
        {
            $"entry={Uri.EscapeDataString(GetEntrySource(stop))}",
            $"tourId={Id}",
            $"stop={stop.Order}"
        };

        if (!string.IsNullOrWhiteSpace(session?.SessionId))
        {
            queryParts.Add($"session={Uri.EscapeDataString(session.SessionId)}");
        }

        return $"/poi/{stop.LocationId}?{string.Join("&", queryParts)}";
    }

    private string GetEntrySource(TourStopDto stop)
    {
        return stop.Order <= 1 && (session?.CompletedStops ?? 0) == 0
            ? "tour_start"
            : "tour_progress";
    }

    private static string BuildTourSessionUrl(int tourId, string sessionId, int stopOrder)
    {
        return $"/tours/{tourId}?session={Uri.EscapeDataString(sessionId)}&stop={stopOrder}";
    }

    private static int? ParseStopOrder(string? value)
    {
        return int.TryParse(value, out var stopOrder) && stopOrder > 0
            ? stopOrder
            : null;
    }

    private static string? GetQueryValue(Uri uri, string key)
    {
        if (string.IsNullOrWhiteSpace(uri.Query))
        {
            return null;
        }

        var segments = uri.Query.TrimStart('?')
            .Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        foreach (var segment in segments)
        {
            var parts = segment.Split('=', 2);
            if (!string.Equals(parts[0], key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            return parts.Length == 2
                ? Uri.UnescapeDataString(parts[1])
                : string.Empty;
        }

        return null;
    }

    private async Task PersistResumeSnapshotAsync()
    {
        if (tour == null || session == null || activeStop == null || string.IsNullOrWhiteSpace(session.SessionId) || session.IsCompleted)
        {
            await SessionStorage.RemoveItemAsync(TourResumeStorageKey);
            return;
        }

        var snapshot = new TourResumeSnapshotDto
        {
            TourId = tour.Id,
            TourName = tour.Name,
            TourDescription = tour.Description,
            SessionId = session.SessionId,
            StopOrder = activeStop.Order,
            CurrentStopName = activeStop.LocationName,
            ProgressPercent = session.ProgressPercent,
            CompletedStops = session.CompletedStops,
            TotalStops = session.TotalStops,
            UpdatedAt = DateTime.UtcNow
        };

        await SessionStorage.SetItemAsync(TourResumeStorageKey, snapshot);
    }
}
