@page "/profile"
@using FoodStreet.Client.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IFavoritesService FavoritesService
@implements IDisposable

<div class="profile-page">
    @if (!isAuthenticated)
    {
        <div class="login-wrapper">
            <div class="auth-box">
                <div class="auth-header">
                    <h2>@(isLoginMode ? "Đăng nhập" : "Đăng ký tài khoản")</h2>
                    <p>@(isLoginMode ? "Khám phá ẩm thực & Lưu địa điểm yêu thích" : "Mở trải nghiệm ẩm thực của bạn ngay hôm nay")</p>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-msg">@errorMessage</div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="success-msg">@successMessage</div>
                }

                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                    @if (!isLoginMode)
                    {
                        <div class="form-group">
                            <label>Họ và tên</label>
                            <div class="input-wrapper">
                                <span class="input-icon">👤</span>
                                <input type="text" @bind="model.FullName" placeholder="Nhập họ và tên" required />
                            </div>
                        </div>
                    }

                    <div class="form-group">
                        <label>Email</label>
                        <div class="input-wrapper">
                            <span class="input-icon">✉️</span>
                            <input type="email" @bind="model.Email" placeholder="email" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Mật khẩu</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" @bind="model.Password" placeholder="••••••••" required />
                        </div>
                    </div>

                    @if (!isLoginMode)
                    {
                        <div class="form-group">
                            <label>Xác nhận mật khẩu</label>
                            <div class="input-wrapper">
                                <span class="input-icon">🔒</span>
                                <input type="password" @bind="model.ConfirmPassword" placeholder="••••••••" required />
                            </div>
                        </div>
                    }

                    <button type="submit" class="btn-primary" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                        }
                        @(isLoginMode ? "Đăng nhập" : "Đăng ký tài khoản")
                    </button>
                </form>

                <div class="auth-switch">
                    <span>@(isLoginMode ? "Chưa có tài khoản?" : "Đã có tài khoản?")</span>
                    <button @onclick="ToggleMode" type="button">
                        @(isLoginMode ? "Đăng ký ngay" : "Đăng nhập")
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="user-dashboard">
            @* === USER HEADER === *@
            <div class="user-header">
                <div class="avatar">
                    @(userName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                </div>
                <h3>@userName</h3>
                <p>@userEmail</p>
            </div>
            
            @* === Feedback messages === *@
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-msg mb-3">@errorMessage</div>
            }
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-msg mb-3">@successMessage</div>
            }

            @* === EDIT PROFILE PANEL === *@
            @if (showEditProfile)
            {
                <div class="settings-panel">
                    <div class="panel-header">
                        <h4>✏️ Sửa thông tin cá nhân</h4>
                        <button class="btn-close-panel" @onclick="() => showEditProfile = false">✕</button>
                    </div>
                    <div class="form-group">
                        <label>Tên hiển thị</label>
                        <div class="input-wrapper">
                            <span class="input-icon">👤</span>
                            <input type="text" @bind="editDisplayName" placeholder="Nhập tên hiển thị" />
                        </div>
                    </div>
                    <button class="btn-submit" @onclick="HandleUpdateProfile" disabled="@isLoading">
                        @if (isLoading) { <span class="spinner"></span> }
                        Lưu thay đổi
                    </button>
                </div>
            }

            @* === CHANGE PASSWORD PANEL === *@
            @if (showChangePassword)
            {
                <div class="settings-panel">
                    <div class="panel-header">
                        <h4>🔒 Đổi mật khẩu</h4>
                        <button class="btn-close-panel" @onclick="() => showChangePassword = false">✕</button>
                    </div>
                    <div class="form-group">
                        <label>Mật khẩu hiện tại</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔑</span>
                            <input type="password" @bind="currentPassword" placeholder="••••••••" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Mật khẩu mới</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" @bind="newPassword" placeholder="••••••••" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Xác nhận mật khẩu mới</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" @bind="confirmNewPassword" placeholder="••••••••" />
                        </div>
                    </div>
                    <button class="btn-submit" @onclick="HandleChangePassword" disabled="@isLoading">
                        @if (isLoading) { <span class="spinner"></span> }
                        Đổi mật khẩu
                    </button>
                </div>
            }

            @* === LANGUAGE SELECTOR PANEL === *@
            @if (showLanguageSelector)
            {
                <div class="settings-panel">
                    <div class="panel-header">
                        <h4>🌐 Ngôn ngữ ứng dụng</h4>
                        <button class="btn-close-panel" @onclick="() => showLanguageSelector = false">✕</button>
                    </div>
                    <div class="lang-options">
                        @foreach (var lang in supportedLanguages)
                        {
                            <button class="lang-option @(selectedLanguage == lang.Code ? "selected" : "")"
                                    @onclick="() => SetLanguage(lang.Code)">
                                <span class="lo-flag">@lang.Flag</span>
                                <span class="lo-name">@lang.Label</span>
                                @if (selectedLanguage == lang.Code)
                                {
                                    <span class="lo-check">✓</span>
                                }
                            </button>
                        }
                    </div>
                </div>
            }

            @* === SETTINGS LIST === *@
            <div class="settings-list">
                <div class="settings-group-title">Tài khoản</div>
                <div class="settings-item" @onclick="OpenEditProfile">
                    <span class="s-icon" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">✏️</span>
                    <span class="s-label">Sửa thông tin cá nhân</span>
                    <span class="arrow">›</span>
                </div>
                <div class="settings-item" @onclick="OpenChangePassword">
                    <span class="s-icon" style="background: rgba(139, 92, 246, 0.1); color: #8b5cf6;">🔒</span>
                    <span class="s-label">Đổi mật khẩu</span>
                    <span class="arrow">›</span>
                </div>

                <div class="settings-group-title mt-4">Nội dung của tôi</div>
                <div class="settings-item" @onclick='() => Navigation.NavigateTo("/favorites")'>
                    <span class="s-icon" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">❤️</span>
                    <span class="s-label">Địa điểm đã lưu</span>
                    <span class="s-value">@favoritesCount</span>
                    <span class="arrow">›</span>
                </div>
                <div class="settings-item">
                    <span class="s-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">🎧</span>
                    <span class="s-label">Đã nghe thuyết minh</span>
                    <span class="arrow">›</span>
                </div>

                <div class="settings-group-title mt-4">Cài đặt</div>
                <div class="settings-item" @onclick="OpenLanguageSelector">
                    <span class="s-icon" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">🌐</span>
                    <span class="s-label">Ngôn ngữ ứng dụng</span>
                    <span class="s-value">@GetCurrentLanguageLabel()</span>
                    <span class="arrow">›</span>
                </div>
                <div class="settings-item">
                    <span class="s-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1;">📱</span>
                    <span class="s-label">Về ứng dụng</span>
                    <span class="s-value small">v1.0</span>
                    <span class="arrow">›</span>
                </div>
                <div class="settings-item border-0" @onclick="HandleLogout">
                    <span class="s-icon text-danger" style="background: rgba(239, 68, 68, 0.1);">🚪</span>
                    <span class="s-label text-danger fw-bold">Đăng xuất</span>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .profile-page {
        min-height: calc(100vh - 110px);
        background: #f0f2f5;
        display: flex;
        flex-direction: column;
    }

    /* Auth Styles */
    .login-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: linear-gradient(180deg, #f0f2f5, #e8ecf1);
    }

    .auth-box {
        background: white;
        width: 100%;
        max-width: 420px;
        padding: 40px 28px;
        border-radius: 24px;
        box-shadow: 0 16px 48px rgba(0,0,0,0.08);
        animation: scaleIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.96) translateY(8px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .auth-header {
        margin-bottom: 32px;
    }

    .auth-header h2 {
        font-size: 28px;
        font-weight: 900;
        color: #1e2a3a;
        margin: 0 0 8px;
        letter-spacing: -0.5px;
    }

    .auth-header p {
        color: #64748b;
        font-size: 14px;
        margin: 0;
        font-weight: 500;
        line-height: 1.5;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 700;
        color: #1e2a3a;
        margin-bottom: 8px;
    }

    .input-wrapper {
        display: flex;
        align-items: center;
        background: #fff;
        border: 2px solid #e2e8f0;
        border-radius: 14px;
        padding: 0 16px;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .input-wrapper:focus-within {
        border-color: #ff6b35;
        box-shadow: 0 0 0 4px rgba(255,107,53,0.08);
    }

    .input-icon {
        font-size: 16px;
        margin-right: 12px;
        flex-shrink: 0;
    }

    .input-wrapper input {
        flex: 1;
        border: none;
        padding: 14px 0;
        font-size: 15px;
        background: transparent;
        outline: none;
        width: 100%;
        font-weight: 500;
    }

    .btn-primary, .btn-submit {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
        color: white;
        border: none;
        border-radius: 14px;
        font-size: 16px;
        font-weight: 700;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        margin-top: 8px;
        box-shadow: 0 4px 16px rgba(255,107,53,0.2);
    }

    .btn-primary:hover:not(:disabled), .btn-submit:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(255,107,53,0.3);
    }

    .btn-primary:active:not(:disabled), .btn-submit:active:not(:disabled) {
        transform: scale(0.98);
    }

    .btn-primary:disabled, .btn-submit:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .auth-switch {
        text-align: center;
        margin-top: 24px;
        font-size: 14px;
        color: #64748b;
        font-weight: 500;
    }

    .auth-switch button {
        background: none;
        border: none;
        color: #ff6b35;
        font-weight: 700;
        padding: 0;
        margin-left: 4px;
        cursor: pointer;
    }

    .auth-switch button:hover {
        text-decoration: underline;
    }

    .error-msg, .success-msg {
        display: flex;
        gap: 10px;
        padding: 14px 16px;
        border-radius: 14px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        animation: slideDown 0.25s ease;
    }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .error-msg {
        background: #fef2f2;
        color: #ef4444;
        border: 1px solid #fecaca;
    }
    
    .success-msg {
        background: #f0fdf4;
        color: #10b981;
        border: 1px solid #a7f3d0;
    }

    .mb-3 { margin-bottom: 12px; }
    .mt-4 { margin-top: 16px !important; }

    /* Dashboard Styles */
    .user-dashboard {
        padding: 24px;
        padding-bottom: 100px;
    }

    .user-header {
        text-align: center;
        margin-bottom: 24px;
        padding: 36px 20px;
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        border-radius: 28px;
        color: white;
        box-shadow: 0 12px 36px rgba(30,41,59,0.18);
        animation: scaleIn 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
    }

    .user-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -30%;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(255,107,53,0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .avatar {
        width: 84px;
        height: 84px;
        background: linear-gradient(135deg, #ff6b35, #f7931e);
        color: white;
        font-size: 34px;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: 0 auto 16px;
        border: 4px solid rgba(255,255,255,0.2);
        box-shadow: 0 8px 24px rgba(255,107,53,0.3);
        position: relative;
    }

    .user-header h3 {
        margin: 0 0 6px;
        color: #ffffff;
        font-size: 24px;
        font-weight: 800;
        letter-spacing: -0.3px;
    }

    .user-header p {
        margin: 0;
        background: rgba(255,255,255,0.1);
        display: inline-block;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 500;
        backdrop-filter: blur(8px);
    }

    /* === SETTINGS PANEL (Edit Profile / Change Password) === */
    .settings-panel {
        background: #fff;
        border-radius: 22px;
        padding: 22px;
        margin-bottom: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        border: 1px solid rgba(0,0,0,0.04);
        animation: panelSlideDown 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes panelSlideDown {
        from {
            opacity: 0;
            transform: translateY(-12px) scale(0.98);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

    .panel-header h4 {
        font-size: 16px;
        font-weight: 800;
        color: #1e293b;
        margin: 0;
        letter-spacing: -0.2px;
    }

    .btn-close-panel {
        width: 34px;
        height: 34px;
        border: none;
        background: #f1f5f9;
        border-radius: 50%;
        font-size: 16px;
        color: #64748b;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .btn-close-panel:active {
        background: #e2e8f0;
        transform: scale(0.85);
    }

    /* === Language Selector === */
    .lang-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .lang-option {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        background: #f8fafc;
        border: 2px solid transparent;
        border-radius: 16px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        width: 100%;
        text-align: left;
    }

    .lang-option:active {
        transform: scale(0.98);
    }

    .lang-option:hover {
        background: #f0fdf4;
    }

    .lang-option.selected {
        background: #f0fdf4;
        border-color: #10b981;
        box-shadow: 0 2px 12px rgba(16, 185, 129, 0.1);
    }

    .lo-flag { font-size: 24px; }

    .lo-name {
        flex: 1;
        font-size: 15px;
        font-weight: 700;
        color: #1e293b;
    }

    .lo-check {
        font-size: 18px;
        color: #10b981;
        font-weight: 700;
    }

    /* === SETTINGS LIST === */
    .settings-list {
        background: white;
        border-radius: 22px;
        padding: 8px 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.04);
    }

    .settings-group-title {
        font-size: 12px;
        text-transform: uppercase;
        font-weight: 800;
        color: #94a3b8;
        margin: 18px 0 8px 8px;
        letter-spacing: 0.6px;
    }

    .settings-item {
        display: flex;
        align-items: center;
        padding: 16px 8px;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        transition: all 0.2s ease;
        border-radius: 14px;
        margin: 2px 0;
    }

    .settings-item:active {
        background: #f8fafc;
        transform: scale(0.99);
    }

    .s-icon {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        font-size: 18px;
        margin-right: 16px;
        flex-shrink: 0;
        transition: transform 0.2s ease;
    }

    .settings-item:active .s-icon {
        transform: scale(1.05);
    }

    .s-label {
        flex: 1;
        font-size: 16px;
        font-weight: 600;
        color: #1e293b;
    }

    .s-value {
        font-size: 14px;
        color: #94a3b8;
        margin-right: 8px;
        font-weight: 500;
    }

    .settings-item .arrow {
        color: #cbd5e1;
        font-size: 24px;
        margin-left: auto;
        font-weight: 300;
    }

    .text-danger {
        color: #ef4444 !important;
    }

    .spinner {
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private bool isAuthenticated = false;
    private bool isLoginMode = true;
    private bool isLoading = false;
    private string errorMessage = "";
    private string successMessage = "";
    private string? userName;
    private string? userEmail;
    private int favoritesCount = 0;

    // Panel states
    private bool showEditProfile = false;
    private bool showChangePassword = false;
    private bool showLanguageSelector = false;

    // Edit profile
    private string editDisplayName = "";

    // Change password
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmNewPassword = "";

    // Language
    private string selectedLanguage = "vi-VN";
    private readonly List<(string Code, string Label, string Flag)> supportedLanguages = new()
    {
        ("vi-VN", "Tiếng Việt", "🇻🇳"),
        ("en-US", "English", "🇺🇸"),
        ("ja-JP", "日本語", "🇯🇵"),
        ("ko-KR", "한국어", "🇰🇷"),
        ("zh-CN", "中文", "🇨🇳")
    };

    private AuthModel model = new();

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnAuthStateChanged += StateHasChanged;
        await CheckAuthState();
    }

    private async Task CheckAuthState()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState?.User?.Identity?.IsAuthenticated == true;
        
        if (isAuthenticated)
        {
            userName = authState!.User!.Identity!.Name;
            userEmail = authState.User.Claims
                .FirstOrDefault(c => c.Type == "email" || c.Type == System.Security.Claims.ClaimTypes.Email)?.Value 
                ?? userName;
            editDisplayName = userName ?? "";

            // Load favorites count
            try
            {
                var favs = await FavoritesService.GetFavoritesAsync();
                favoritesCount = favs.Count;
            }
            catch { }
        }
    }

    private void ToggleMode()
    {
        isLoginMode = !isLoginMode;
        errorMessage = "";
        successMessage = "";
        model = new AuthModel();
    }

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = "";
        successMessage = "";

        if (!isLoginMode && model.Password != model.ConfirmPassword)
        {
            errorMessage = "Mật khẩu không khớp";
            isLoading = false;
            return;
        }

        try
        {
            AuthResult result;

            if (isLoginMode)
            {
                result = await AuthService.LoginAsync(model.Email, model.Password);
            }
            else
            {
                result = await AuthService.RegisterAsync(model.Email, model.Password, model.FullName, "User");
            }

            if (result.Success)
            {
                if (!isLoginMode)
                {
                    successMessage = "Tạo tài khoản thành công! Tự động đăng nhập...";
                    await AuthService.LoginAsync(model.Email, model.Password);
                }
                
                await CheckAuthState();
                AuthService.NotifyStateChanged();
            }
            else
            {
                errorMessage = result.Message ?? "Lỗi không xác định";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Đã có lỗi nối mạng: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    // === Panel Toggles ===
    private void OpenEditProfile()
    {
        showEditProfile = !showEditProfile;
        showChangePassword = false;
        showLanguageSelector = false;
        ClearMessages();
    }

    private void OpenChangePassword()
    {
        showChangePassword = !showChangePassword;
        showEditProfile = false;
        showLanguageSelector = false;
        currentPassword = "";
        newPassword = "";
        confirmNewPassword = "";
        ClearMessages();
    }

    private void OpenLanguageSelector()
    {
        showLanguageSelector = !showLanguageSelector;
        showEditProfile = false;
        showChangePassword = false;
        ClearMessages();
    }

    private void ClearMessages()
    {
        errorMessage = "";
        successMessage = "";
    }

    // === Actions ===
    private async Task HandleUpdateProfile()
    {
        if (string.IsNullOrWhiteSpace(editDisplayName))
        {
            errorMessage = "Vui lòng nhập tên hiển thị";
            return;
        }

        isLoading = true;
        ClearMessages();

        try
        {
            var result = await AuthService.UpdateProfileAsync(editDisplayName);
            if (result.Success)
            {
                successMessage = "Cập nhật thông tin thành công!";
                userName = editDisplayName;
                showEditProfile = false;
            }
            else
            {
                errorMessage = result.Message ?? "Cập nhật thất bại";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleChangePassword()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword))
        {
            errorMessage = "Vui lòng nhập đầy đủ mật khẩu";
            return;
        }

        if (newPassword != confirmNewPassword)
        {
            errorMessage = "Mật khẩu mới không khớp";
            return;
        }

        if (newPassword.Length < 6)
        {
            errorMessage = "Mật khẩu mới phải từ 6 ký tự trở lên";
            return;
        }

        isLoading = true;

        try
        {
            var result = await AuthService.ChangePasswordAsync(currentPassword, newPassword);
            if (result.Success)
            {
                successMessage = "Đổi mật khẩu thành công!";
                showChangePassword = false;
                currentPassword = "";
                newPassword = "";
                confirmNewPassword = "";
            }
            else
            {
                errorMessage = result.Message ?? "Đổi mật khẩu thất bại";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetLanguage(string langCode)
    {
        selectedLanguage = langCode;
        showLanguageSelector = false;
        successMessage = $"Đã chuyển ngôn ngữ sang {GetCurrentLanguageLabel()}";
        // In production: save to localStorage and reload localization
    }

    private string GetCurrentLanguageLabel()
    {
        return supportedLanguages.FirstOrDefault(l => l.Code == selectedLanguage).Label ?? "Tiếng Việt";
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        await CheckAuthState();
        StateHasChanged();
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= StateHasChanged;
    }

    public class AuthModel
    {
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
