@page "/profile"
@using FoodStreet.Client.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<div class="profile-page">
    @if (!isAuthenticated)
    {
        <div class="login-wrapper">
            <div class="auth-box">
                <div class="auth-header">
                    <h2>@(isLoginMode ? "Đăng nhập" : "Đăng ký tài khoản")</h2>
                    <p>@(isLoginMode ? "Khám phá ẩm thực & Lưu địa điểm yêu thích" : "Mở trải nghiệm ẩm thực của bạn ngay hôm nay")</p>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-msg">@errorMessage</div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="success-msg">@successMessage</div>
                }

                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                    @if (!isLoginMode)
                    {
                        <div class="form-group">
                            <label>Họ và tên</label>
                            <div class="input-wrapper">
                                <span class="input-icon">👤</span>
                                <input type="text" @bind="model.FullName" placeholder="Nhập họ và tên" required />
                            </div>
                        </div>
                    }

                    <div class="form-group">
                        <label>Email</label>
                        <div class="input-wrapper">
                            <span class="input-icon">✉️</span>
                            <input type="email" @bind="model.Email" placeholder="email" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Mật khẩu</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" @bind="model.Password" placeholder="••••••••" required />
                        </div>
                    </div>

                    @if (!isLoginMode)
                    {
                        <div class="form-group">
                            <label>Xác nhận mật khẩu</label>
                            <div class="input-wrapper">
                                <span class="input-icon">🔒</span>
                                <input type="password" @bind="model.ConfirmPassword" placeholder="••••••••" required />
                            </div>
                        </div>
                    }

                    <button type="submit" class="btn-primary" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner"></span>
                        }
                        @(isLoginMode ? "Đăng nhập" : "Đăng ký tài khoản")
                    </button>
                </form>

                <div class="auth-switch">
                    <span>@(isLoginMode ? "Chưa có tài khoản?" : "Đã có tài khoản?")</span>
                    <button @onclick="ToggleMode" type="button">
                        @(isLoginMode ? "Đăng ký ngay" : "Đăng nhập")
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="user-dashboard">
            <div class="user-header">
                <div class="avatar">
                    @(userName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                </div>
                <h3>@userName</h3>
                <p>Khách du lịch</p>
            </div>
            
            <div class="settings-list">
                <div class="settings-item">
                    <span class="icon">❤️</span>
                    <span>Địa điểm đã lưu</span>
                    <span class="arrow">›</span>
                </div>
                <div class="settings-item" @onclick="HandleLogout">
                    <span class="icon text-danger">🚪</span>
                    <span class="text-danger">Đăng xuất</span>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .profile-page {
        min-height: calc(100vh - 110px);
        background: #f0f2f5;
        display: flex;
        flex-direction: column;
    }

    /* Auth Styles */
    .login-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .auth-box {
        background: white;
        width: 100%;
        max-width: 420px;
        padding: 36px 28px;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    }

    .auth-header {
        margin-bottom: 32px;
    }

    .auth-header h2 {
        font-size: 26px;
        font-weight: 700;
        color: #1e2a3a;
        margin: 0 0 8px;
    }

    .auth-header p {
        color: #64748b;
        font-size: 14px;
        margin: 0;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #1e2a3a;
        margin-bottom: 8px;
    }

    .input-wrapper {
        display: flex;
        align-items: center;
        background: #fff;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 0 16px;
        transition: all 0.2s ease;
    }

    .input-wrapper:focus-within {
        border-color: #ff6b35;
        box-shadow: 0 0 0 3px rgba(255,107,53,0.1);
    }

    .input-icon {
        font-size: 16px;
        margin-right: 12px;
        flex-shrink: 0;
    }

    .input-wrapper input {
        flex: 1;
        border: none;
        padding: 14px 0;
        font-size: 15px;
        background: transparent;
        outline: none;
        width: 100%;
    }

    .btn-primary {
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-top: 8px;
    }

    .btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255,107,53,0.35);
    }

    .btn-primary:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .auth-switch {
        text-align: center;
        margin-top: 24px;
        font-size: 14px;
        color: #64748b;
    }

    .auth-switch button {
        background: none;
        border: none;
        color: #ff6b35;
        font-weight: 600;
        padding: 0;
        margin-left: 4px;
        cursor: pointer;
    }

    .auth-switch button:hover {
        text-decoration: underline;
    }

    .error-msg, .success-msg {
        display: flex;
        gap: 10px;
        padding: 14px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
    }

    .error-msg {
        background: #fef2f2;
        color: #ef4444;
        border: 1px solid #fecaca;
    }
    
    .success-msg {
        background: #f0fdf4;
        color: #10b981;
        border: 1px solid #a7f3d0;
    }

    /* Dashboard Styles */
    .user-dashboard {
        padding: 24px;
    }

    .user-header {
        text-align: center;
        margin-bottom: 40px;
        padding: 32px 20px;
        background: white;
        border-radius: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }

    .avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #ff6b35, #f7931e);
        color: white;
        font-size: 32px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: 0 auto 16px;
        box-shadow: 0 8px 20px rgba(255,107,53,0.3);
    }

    .user-header h3 {
        margin: 0 0 4px;
        color: #1e293b;
        font-size: 20px;
    }

    .user-header p {
        margin: 0;
        color: #64748b;
        font-size: 14px;
    }

    .settings-list {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }

    .settings-item {
        display: flex;
        align-items: center;
        padding: 20px;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
    }

    .settings-item:last-child {
        border-bottom: none;
    }

    .settings-item .icon {
        font-size: 20px;
        width: 32px;
    }

    .settings-item span:nth-child(2) {
        flex: 1;
        font-weight: 500;
        color: #334155;
    }

    .settings-item .arrow {
        color: #cbd5e1;
        font-size: 20px;
    }

    .text-danger {
        color: #ef4444 !important;
    }

    .spinner {
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private bool isAuthenticated = false;
    private bool isLoginMode = true;
    private bool isLoading = false;
    private string errorMessage = "";
    private string successMessage = "";
    private string? userName;
    private string? confirmPasswordError;
    
    private AuthModel model = new();

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnAuthStateChanged += StateHasChanged;
        await CheckAuthState();
    }

    private async Task CheckAuthState()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState?.User?.Identity?.IsAuthenticated == true;
        
        if (isAuthenticated)
        {
            userName = authState!.User!.Identity!.Name;
        }
    }

    private void ToggleMode()
    {
        isLoginMode = !isLoginMode;
        errorMessage = "";
        successMessage = "";
        model = new AuthModel();
    }

    private async Task HandleSubmit()
    {
        isLoading = true;
        errorMessage = "";
        successMessage = "";

        // Validate confirm password for registration
        if (!isLoginMode && model.Password != model.ConfirmPassword)
        {
            errorMessage = "Mật khẩu không khớp";
            isLoading = false;
            return;
        }

        try
        {
            AuthResult result;

            if (isLoginMode)
            {
                result = await AuthService.LoginAsync(model.Email, model.Password);
            }
            else
            {
                // Đăng ký tk User tự do
                result = await AuthService.RegisterAsync(model.Email, model.Password, model.FullName, "User");
            }

            if (result.Success)
            {
                if (!isLoginMode)
                {
                    successMessage = "Tạo tài khoản thành công! Tự động đăng nhập...";
                    // Auto login sau khi register
                    await AuthService.LoginAsync(model.Email, model.Password);
                }
                
                await CheckAuthState();
                AuthService.NotifyStateChanged();
            }
            else
            {
                errorMessage = result.Message ?? "Lỗi không xác định";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Đã có lỗi nối mạng: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        await CheckAuthState();
        StateHasChanged();
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= StateHasChanged;
    }

    public class AuthModel
    {
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
