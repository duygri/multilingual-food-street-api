@page "/explore"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using FoodStreet.Client.Services
@using FoodStreet.Client.DTOs
@inject IFavoritesService FavoritesService
@inject ILocationClientService LocationClient
@inject NavigationManager Navigation

<div class="explore-page">
    <header class="explore-header">
        <h1>📍 Khám phá</h1>
        <p>Các địa điểm nổi bật quanh bạn</p>
        <button class="tour-entry-btn" @onclick="OpenTours">
            <span>🗺️</span>
            <div>
                <strong>Tour trải nghiệm</strong>
                <small>Đi theo hành trình đã được gợi ý</small>
            </div>
            <span class="tour-entry-arrow">›</span>
        </button>
        @* Search bar *@
        <div class="search-bar">
            <span class="search-icon">🔍</span>
            <input type="text" placeholder="Tìm kiếm địa điểm..." @bind="searchQuery" @bind:event="oninput" />
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <button class="search-clear" @onclick="ClearSearch">✕</button>
            }
        </div>
    </header>

    <div class="explore-content">

        @if (isLoading)
        {
            <div class="explore-loading">
                <div class="explore-spinner"></div>
                <p>Đang tải địa điểm...</p>
            </div>
        }
        else if (filteredLocations.Count == 0)
        {
            <div class="explore-empty">
                <span class="empty-icon">🗺️</span>
                <h3>Không có địa điểm nào</h3>
                <p>@(string.IsNullOrEmpty(searchQuery) ? "Chưa có địa điểm nào được tạo." : "Không tìm thấy kết quả phù hợp.")</p>
            </div>
        }
        else
        {
            @* Category filter chips *@
            @if (categories.Count > 0)
            {
                <div class="category-chips">
                    <button class="chip @(selectedCategory == null ? "active" : "")"
                            @onclick="() => FilterByCategory(null)">
                        Tất cả
                    </button>
                    @foreach (var cat in categories)
                    {
                        <button class="chip @(selectedCategory == cat ? "active" : "")"
                                @onclick="() => FilterByCategory(cat)">
                            @cat
                        </button>
                    }
                </div>
            }

            @* POI count *@
            <div class="section-header">
                <h3>📍 @filteredLocations.Count địa điểm</h3>
            </div>

            @* POI list *@
            <div class="poi-list">
                @foreach (var loc in filteredLocations)
                {
                    var isFav = favoriteIds.Contains(loc.Id);
                    <div class="poi-card" @onclick="() => NavigateToPoi(loc.Id)">
                        <div class="poi-thumb">
                            @if (!string.IsNullOrEmpty(loc.ImageUrl))
                            {
                                <img src="@loc.ImageUrl" alt="@loc.Name" />
                            }
                            else
                            {
                                <div class="poi-thumb-placeholder">📍</div>
                            }
                        </div>
                        <div class="poi-info">
                            <h4>@loc.Name</h4>
                            @if (!string.IsNullOrEmpty(loc.CategoryName))
                            {
                                <span class="poi-cat">@loc.CategoryName</span>
                            }
                            <p class="poi-desc">@loc.Description</p>
                            <div class="poi-meta">
                                <span class="poi-address">📍 @(loc.Address ?? "Vĩnh Khánh, Q.4")</span>
                                @if (loc.HasAudio)
                                {
                                    <span class="poi-audio-tag">🎧</span>
                                }
                            </div>
                        </div>
                        <div class="poi-actions-col">
                            <button class="fav-btn @(isFav ? "saved" : "")"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ToggleFavorite(loc)">
                                @(isFav ? "❤️" : "🤍")
                            </button>
                            <span class="poi-arrow">›</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .explore-page {
        min-height: calc(100vh - 112px);
        background: #f5f7fa;
    }

    /* === HEADER === */
    .explore-header {
        padding: 28px 20px 22px;
        background: linear-gradient(135deg, #1e293b, #0f172a);
        color: white;
        position: relative;
    }

    .explore-header::after {
        content: '';
        position: absolute;
        bottom: -12px;
        left: 0;
        right: 0;
        height: 24px;
        background: linear-gradient(180deg, rgba(15,23,42,0.06), transparent);
        pointer-events: none;
    }

    .explore-header h1 {
        font-size: 26px;
        font-weight: 900;
        margin: 0 0 4px;
        letter-spacing: -0.5px;
    }

    .explore-header p {
        color: #94a3b8;
        font-size: 14px;
        margin: 0 0 18px;
        font-weight: 500;
    }

    .tour-entry-btn {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 14px 16px;
        color: white;
        text-align: left;
        margin-bottom: 16px;
        cursor: pointer;
        backdrop-filter: blur(12px);
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .tour-entry-btn:active {
        transform: scale(0.98);
        background: rgba(255,255,255,0.12);
    }

    .tour-entry-btn strong {
        display: block;
        font-size: 15px;
        font-weight: 800;
        letter-spacing: -0.2px;
    }

    .tour-entry-btn small {
        display: block;
        color: #cbd5e1;
        font-size: 12px;
        margin-top: 3px;
        font-weight: 500;
    }

    .tour-entry-btn div {
        flex: 1;
    }

    .tour-entry-arrow {
        font-size: 24px;
        color: #e2e8f0;
        font-weight: 300;
    }

    /* Search */
    .search-bar {
        display: flex;
        align-items: center;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(12px);
        border-radius: 14px;
        padding: 0 14px;
        gap: 10px;
        border: 1px solid rgba(255,255,255,0.08);
        transition: all 0.25s ease;
    }

    .search-bar:focus-within {
        background: rgba(255,255,255,0.14);
        border-color: rgba(255,255,255,0.15);
        box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
    }

    .search-icon { font-size: 16px; flex-shrink: 0; }

    .search-bar input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: #fff;
        font-size: 14px;
        padding: 13px 0;
        font-weight: 500;
    }

    .search-bar input::placeholder { color: #64748b; }

    .search-clear {
        background: rgba(255,255,255,0.15);
        border: none;
        color: #94a3b8;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        font-size: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
    }

    .search-clear:active {
        transform: scale(0.85);
    }

    /* === CONTENT === */
    .explore-content { padding: 20px 16px 24px; }

    /* Loading */
    .explore-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 60px 20px;
        color: #64748b;
    }

    .explore-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #f1f5f9;
        border-top-color: #ff6b35;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-bottom: 12px;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Empty */
    .explore-empty {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-icon { font-size: 56px; display: block; margin-bottom: 16px; }

    .explore-empty h3 {
        font-size: 18px;
        color: #1e293b;
        margin-bottom: 8px;
        font-weight: 700;
    }

    .explore-empty p {
        color: #94a3b8;
        font-size: 14px;
    }

    /* === CATEGORY CHIPS === */
    .category-chips {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        padding-bottom: 6px;
        margin-bottom: 18px;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
    }

    .category-chips::-webkit-scrollbar { display: none; }

    .chip {
        padding: 8px 16px;
        border-radius: 20px;
        border: 1.5px solid #e2e8f0;
        background: #fff;
        color: #475569;
        font-size: 13px;
        font-weight: 600;
        white-space: nowrap;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        flex-shrink: 0;
    }

    .chip:active {
        transform: scale(0.95);
    }

    .chip.active {
        background: linear-gradient(135deg, #ff6b35, #f7931e);
        color: #fff;
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(255,107,53,0.25);
    }

    /* Section header */
    .section-header {
        margin-bottom: 14px;
    }

    .section-header h3 {
        font-size: 16px;
        font-weight: 800;
        color: #1e293b;
        margin: 0;
        letter-spacing: -0.3px;
    }

    /* === POI LIST === */
    .poi-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .poi-card {
        display: flex;
        align-items: stretch;
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.04);
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        animation: slideUp 0.35s ease backwards;
    }

    .poi-card:nth-child(1) { animation-delay: 0s; }
    .poi-card:nth-child(2) { animation-delay: 0.04s; }
    .poi-card:nth-child(3) { animation-delay: 0.08s; }
    .poi-card:nth-child(4) { animation-delay: 0.12s; }
    .poi-card:nth-child(5) { animation-delay: 0.16s; }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .poi-card:active {
        transform: scale(0.98);
        box-shadow: 0 1px 6px rgba(0,0,0,0.06);
    }

    /* Thumbnail */
    .poi-thumb {
        width: 108px;
        min-height: 108px;
        flex-shrink: 0;
        overflow: hidden;
    }

    .poi-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .poi-card:active .poi-thumb img {
        transform: scale(1.05);
    }

    .poi-thumb-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        font-size: 32px;
    }

    /* Info */
    .poi-info {
        flex: 1;
        padding: 14px 16px;
        min-width: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .poi-info h4 {
        font-size: 15px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        letter-spacing: -0.2px;
    }

    .poi-cat {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        color: #ff6b35;
        background: #fff5f2;
        padding: 2px 8px;
        border-radius: 6px;
        margin-bottom: 5px;
    }

    .poi-desc {
        font-size: 13px;
        color: #64748b;
        margin: 0 0 6px;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }

    .poi-meta {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .poi-address {
        font-size: 11px;
        color: #94a3b8;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 500;
    }

    .poi-audio-tag {
        font-size: 14px;
        flex-shrink: 0;
    }

    /* Right column */
    .poi-actions-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 8px 14px;
        gap: 10px;
        flex-shrink: 0;
    }

    .fav-btn {
        width: 34px;
        height: 34px;
        border: none;
        background: #f8fafc;
        border-radius: 50%;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .fav-btn:active { transform: scale(0.8); }
    .fav-btn.saved { background: #fff0ed; }

    .poi-arrow {
        font-size: 22px;
        color: #cbd5e1;
        font-weight: 300;
    }
</style>

@code {
    private List<LocationDto> allLocations = new();
    private HashSet<int> favoriteIds = new();
    private string searchQuery = "";
    private string? selectedCategory = null;
    private List<string> categories = new();
    private bool isLoading = true;

    private List<LocationDto> filteredLocations =>
        allLocations
            .Where(l =>
                (string.IsNullOrEmpty(searchQuery) ||
                 l.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                 (l.Description?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                 (l.Address?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
                &&
                (selectedCategory == null || l.CategoryName == selectedCategory))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            allLocations = await LocationClient.GetApprovedLocations();
            categories = allLocations
                .Where(l => !string.IsNullOrEmpty(l.CategoryName))
                .Select(l => l.CategoryName!)
                .Distinct()
                .OrderBy(c => c)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading locations: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }

        // Load saved favorites
        var favs = await FavoritesService.GetFavoritesAsync();
        favoriteIds = favs.Select(f => f.Id).ToHashSet();
    }

    private void NavigateToPoi(int id)
    {
        Navigation.NavigateTo($"/poi/{id}");
    }

    private async Task ToggleFavorite(LocationDto loc)
    {
        await FavoritesService.ToggleFavoriteAsync(loc);

        if (favoriteIds.Contains(loc.Id))
            favoriteIds.Remove(loc.Id);
        else
            favoriteIds.Add(loc.Id);
    }

    private void FilterByCategory(string? category)
    {
        selectedCategory = category;
    }

    private void ClearSearch()
    {
        searchQuery = "";
    }

    private void OpenTours()
    {
        Navigation.NavigateTo("/tours");
    }
}
