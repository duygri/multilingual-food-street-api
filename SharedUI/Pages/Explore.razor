@page "/explore"
@using FoodStreet.Client.Services
@inject IGpsTrackingService GpsService
@inject HttpClient Http

<div class="explore-page">
    <header class="explore-header">
        <h1>🍜 Khám phá Ẩm thực</h1>
        <p>Bật GPS để tìm các địa điểm ẩm thực gần bạn</p>
    </header>

    <div class="explore-content">
        <GpsTracker />

        @if (allFoods.Count > 0)
        {
            <div class="all-pois">
                <h3>📍 Tất cả địa điểm</h3>
                <div class="poi-grid">
                    @foreach (var food in allFoods)
                    {
                        <div class="poi-card">
                            @if (!string.IsNullOrEmpty(food.ImageUrl))
                            {
                                <img src="@food.ImageUrl" alt="@food.Name" class="poi-image" />
                            }
                            else
                            {
                                <div class="poi-image-placeholder">🍜</div>
                            }
                            <div class="poi-info">
                                <h4>@food.Name</h4>
                                <p>@food.Description</p>
                                <span class="poi-price">@food.Price.ToString("N0") VNĐ</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    .explore-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);
        color: #fff;
        padding: 20px;
    }

    .explore-header {
        text-align: center;
        padding: 40px 20px;
    }

    .explore-header h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
        background: linear-gradient(135deg, #00d9ff, #0099ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .explore-header p {
        color: #888;
        font-size: 1.1rem;
    }

    .explore-content {
        max-width: 800px;
        margin: 0 auto;
    }

    .all-pois {
        margin-top: 30px;
    }

    .all-pois h3 {
        margin-bottom: 20px;
        font-size: 1.3rem;
    }

    .poi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
    }

    .poi-card {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .poi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 217, 255, 0.2);
        border-color: rgba(0, 217, 255, 0.3);
    }

    .poi-image {
        width: 100%;
        height: 150px;
        object-fit: cover;
    }

    .poi-image-placeholder {
        width: 100%;
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        background: linear-gradient(135deg, #1a1a2e, #16213e);
    }

    .poi-info {
        padding: 16px;
    }

    .poi-info h4 {
        margin: 0 0 8px;
        font-size: 1.1rem;
    }

    .poi-info p {
        color: #888;
        font-size: 0.9rem;
        margin: 0 0 12px;
        line-height: 1.4;
    }

    .poi-price {
        display: inline-block;
        background: linear-gradient(135deg, #00d9ff, #0099ff);
        color: #000;
        padding: 4px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }
</style>

@code {
    private List<FoodDto> allFoods = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<List<FoodDto>>("api/food");
            if (response != null)
            {
                allFoods = response;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading foods: {ex.Message}");
        }
    }

    public class FoodDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public decimal Price { get; set; }
        public string? ImageUrl { get; set; }
        public double Latitude { get; set; }
        public double Longitude { get; set; }
    }
}
