@inherits LayoutComponentBase
@inject NavigationManager Navigation

@* 
    MainLayout - Server Admin Only
    Redirects all public routes to Admin Login
*@

@Body

@code {
    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        
        // If not in admin or seller section, redirect to admin login
        if (!uri.AbsolutePath.StartsWith("/admin", StringComparison.OrdinalIgnoreCase) && 
            !uri.AbsolutePath.StartsWith("/seller", StringComparison.OrdinalIgnoreCase) &&
            !uri.AbsolutePath.StartsWith("/explore", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/admin/login");
        }
    }
}
