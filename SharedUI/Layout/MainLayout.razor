@inherits LayoutComponentBase
@inject NavigationManager Navigation

@* 
    MainLayout - Server Admin Only
    Redirects all public routes to Admin Login
*@

@Body

@code {
    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        
        // If not in admin section, redirect to admin login
        if (!uri.AbsolutePath.StartsWith("/admin", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/admin/login", forceLoad: true);
        }
    }
}
