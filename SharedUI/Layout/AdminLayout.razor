@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILocalizationService L
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject INotificationService NotificationSvc
@implements IDisposable
@using FoodStreet.Client.Services

<AuthorizeView>
    <Authorized>
        <div class="admin-wrapper">
            <!-- Sidebar -->
            <aside class="admin-sidebar">
                <div class="sidebar-header">
                    <div class="brand-logo">
                        <span class="logo-icon">VK</span>
                        <div class="logo-text">
                            <span class="logo-title">Vĩnh Khánh</span>
                            <span class="logo-subtitle">Admin CMS</span>
                        </div>
                    </div>
                </div>
                
                <nav class="sidebar-nav">
                    <div class="nav-section">
                        <span class="nav-section-title">CHÍNH</span>
                        <AuthorizeView Roles="Admin">
                            <Authorized Context="AuthContext">
                                <NavLink class="nav-item" href="admin/users">
                                    <span class="nav-icon">👥</span>
                                    <span class="nav-text">Quản lý Người dùng</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/locations">
                                    <span class="nav-icon">📍</span>
                                    <span class="nav-text">Quản lý POI</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/categories">
                                    <span class="nav-icon">🏷️</span>
                                    <span class="nav-text">Phân loại POI</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/tours">
                                    <span class="nav-icon">🧳</span>
                                    <span class="nav-text">Quản lý Tour</span>
                                </NavLink>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                    
                    @if (UiRoles.IsPoiOwner(context.User))
                    {
                            <div class="nav-section owner-section">
                                <span class="nav-section-title">CHỦ QUÁN</span>
                                <NavLink class="nav-item" href="owner/profile">
                                    <span class="nav-icon">👤</span>
                                    <span class="nav-text">Hồ sơ POI Owner</span>
                                </NavLink>
                                <NavLink class="nav-item" href="owner/dashboard">
                                    <span class="nav-icon">🏠</span>
                                    <span class="nav-text">POI của tôi</span>
                                </NavLink>
                                <NavLink class="nav-item" href="owner/stats">
                                    <span class="nav-icon">📊</span>
                                    <span class="nav-text">Thống kê của tôi</span>
                                </NavLink>
                            </div>
                            <div class="nav-section owner-section">
                                <span class="nav-section-title">NỘI DUNG</span>
                                <NavLink class="nav-item" href="owner/menu">
                                    <span class="nav-icon">🍽️</span>
                                    <span class="nav-text">Menu Ẩm thực</span>
                                </NavLink>
                                <NavLink class="nav-item" href="owner/audio">
                                    <span class="nav-icon">🎵</span>
                                    <span class="nav-text">Audio & TTS</span>
                                </NavLink>
                                <NavLink class="nav-item" href="owner/translations">
                                    <span class="nav-icon">🌐</span>
                                    <span class="nav-text">Ngôn ngữ & Bản dịch</span>
                                </NavLink>
                            </div>
                    }
                    
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="AuthContext">
                            <div class="nav-section">
                                <span class="nav-section-title">NỘI DUNG</span>
                                <NavLink class="nav-item" href="admin/menu">
                                    <span class="nav-icon">🍽️</span>
                                    <span class="nav-text">Menu Ẩm thực</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/audio">
                                    <span class="nav-icon">🎵</span>
                                    <span class="nav-text">Tệp âm thanh</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/tts-console">
                                    <span class="nav-icon">🎧</span>
                                    <span class="nav-text">TTS Console</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/translations">
                                    <span class="nav-icon">🌐</span>
                                    <span class="nav-text">Bản dịch</span>
                                </NavLink>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                    
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="AuthContext">
                            <div class="nav-section">
                                <span class="nav-section-title">PHÂN TÍCH</span>
                                <NavLink class="nav-item" href="admin/history">
                                    <span class="nav-icon">📜</span>
                                    <span class="nav-text">Lịch sử sử dụng</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/geofence-test">
                                    <span class="nav-icon">🎯</span>
                                    <span class="nav-text">Kiểm tra Geofence</span>
                                </NavLink>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </nav>
                
                <div class="sidebar-footer">
                    <div class="lang-switcher-sidebar">
                        <span class="lang-label">Ngôn ngữ</span>
                        <div class="lang-pills">
                            @{ var langs = new[] { ("vi-VN", "VI"), ("en-US", "EN"), ("ja-JP", "JA"), ("ko-KR", "KO") }; }
                            @foreach (var (code, label) in langs)
                            {
                                var langCode = code;
                                <button class="lang-pill @GetLangClass(langCode)" @onclick="() => SwitchLanguageAsync(langCode)">@label</button>
                            }
                        </div>
                    </div>
                    <div class="user-profile">
                        <div class="user-avatar">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <div class="user-info">
                            <span class="user-name">@context.User.Identity?.Name</span>
                            <span class="user-role">@GetRoleDisplayName(context.User)</span>
                        </div>
                    </div>
                    <button class="logout-btn" @onclick="HandleLogout">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg> Đăng xuất
                    </button>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="admin-main">
                <header class="admin-header">
                    <div class="header-left">
                        <h1 class="page-title">@GetPageTitle()</h1>
                        <nav class="breadcrumb-nav">
                            <span class="breadcrumb-item">Admin</span>
                            <span class="breadcrumb-separator">/</span>
                            <span class="breadcrumb-item active">@GetPageName()</span>
                        </nav>
                    </div>
                    <div class="header-right">
                        <div class="header-search">
                            <input type="text" placeholder="Tìm kiếm..." />
                            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        </div>
                        <div class="header-actions">
                            <div class="notification-wrapper" id="notif-wrapper">
                                <span class="connection-emoji" title="Kết nối realtime">@NotificationSvc.ConnectionStatus</span>
                                <button class="action-btn notification-btn" @onclick="ToggleNotificationPanel" title="Thông báo">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                    @if (NotificationSvc.UnreadCount > 0)
                                    {
                                        <span class="notification-badge">@(NotificationSvc.UnreadCount > 9 ? "9+" : NotificationSvc.UnreadCount.ToString())</span>
                                    }
                                </button>
                                @if (showNotificationPanel)
                                {
                                    <div class="notif-overlay" @onclick="CloseNotificationPanel"></div>
                                    <div class="notification-panel">
                                        <div class="notification-panel-header">
                                            <div class="panel-title-group">
                                                <span class="panel-title">Thông báo</span>
                                                @if (NotificationSvc.UnreadCount > 0)
                                                {
                                                    <span class="panel-count">@NotificationSvc.UnreadCount mới</span>
                                                }
                                            </div>
                                            @if (NotificationSvc.UnreadCount > 0)
                                            {
                                                <button class="mark-all-read-btn" @onclick="MarkAllRead" title="Đánh dấu tất cả đã đọc">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                                    Đọc tất cả
                                                </button>
                                            }
                                        </div>
                                        <div class="notification-list">
                                            @if (NotificationSvc.Notifications.Any())
                                            {
                                                @foreach (var n in NotificationSvc.Notifications.Take(8))
                                                {
                                                    <div class="notification-item @(n.IsRead ? "read" : "unread")" @onclick="() => MarkRead(n.Id)">
                                                        <div class="notification-icon @GetNotifIconClass(n.Type)">
                                                            @GetNotifIcon(n.Type)
                                                        </div>
                                                        <div class="notification-content">
                                                            <span class="notification-title">@n.Title</span>
                                                            <span class="notification-message">@n.Message</span>
                                                            <span class="notification-time">@FormatTimeAgo(n.CreatedAt)</span>
                                                        </div>
                                                        <div class="notification-actions">
                                                            @if (!n.IsRead)
                                                            {
                                                                <span class="unread-dot" title="Chưa đọc"></span>
                                                            }
                                                            <button class="notif-delete-btn" @onclick="() => DeleteNotif(n.Id)" @onclick:stopPropagation="true" title="Xóa">
                                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="notification-empty">
                                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                                    <span>Không có thông báo</span>
                                                </div>
                                            }
                                        </div>
                                        <div class="notification-panel-footer">
                                            <a href="admin/notifications" class="view-all-link" @onclick="CloseNotificationPanel">Xem tất cả thông báo →</a>
                                        </div>
                                    </div>
                                }
                            </div>
                            <a href="https://localhost:7214/swagger" target="_blank" class="action-btn" title="API Docs">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                            </a>
                        </div>
                    </div>
                </header>
                
                <div class="admin-content">
                    @Body
                </div>
                
                <footer class="admin-footer">
                    <span>© 2026 Nền tảng thuyết minh ẩm thực Vĩnh Khánh - Quận 4, TP.HCM</span>
                    <span class="footer-version">v1.0.0</span>
                </footer>
            </main>
        </div>
        <GlobalTourPlayer />
    </Authorized>
    
    <NotAuthorized>
        <div class="auth-required">
            <div class="auth-card">
                <div class="auth-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
                <h2>Yêu cầu đăng nhập</h2>
                <p>Bạn cần đăng nhập để truy cập Admin CMS</p>
                <a href="admin/login" class="btn-auth">Đăng nhập ngay</a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    * {
        box-sizing: border-box;
    }

    .admin-wrapper {
        display: flex;
        min-height: 100vh;
        background: var(--surface-body);
    }

    /* ===== Sidebar ===== */
    .admin-sidebar {
        width: var(--sidebar-width);
        background: linear-gradient(180deg, var(--sidebar-bg-start) 0%, var(--sidebar-bg-end) 100%);
        display: flex;
        flex-direction: column;
        position: fixed;
        height: 100vh;
        z-index: var(--z-modal);
    }

    .sidebar-header {
        padding: var(--space-6) var(--space-5);
        border-bottom: 1px solid var(--sidebar-border);
    }

    .brand-logo {
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    .logo-icon {
        width: 48px;
        height: 48px;
        background: var(--gradient-brand);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--text-md);
        font-weight: var(--weight-extrabold);
        color: var(--text-on-accent);
        letter-spacing: 1px;
        box-shadow: var(--shadow-accent);
    }

    .logo-title {
        display: block;
        color: #fff;
        font-size: var(--text-lg);
        font-weight: var(--weight-bold);
        letter-spacing: 0.5px;
    }

    .logo-subtitle {
        display: block;
        color: var(--sidebar-text-dim);
        font-size: var(--text-xs);
        font-weight: var(--weight-medium);
    }

    .sidebar-nav {
        flex: 1;
        padding: var(--space-5) 0;
        overflow-y: auto;
    }

    .nav-section {
        padding: 0 var(--space-4);
        margin-bottom: var(--space-6);
    }

    .nav-section-title {
        display: block;
        color: var(--sidebar-text-dim);
        font-size: var(--text-xs);
        font-weight: var(--weight-semibold);
        letter-spacing: 1.5px;
        margin-bottom: var(--space-3);
        padding-left: var(--space-3);
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-3) var(--space-4);
        color: var(--sidebar-text);
        text-decoration: none;
        border-radius: var(--radius-lg);
        margin-bottom: var(--space-1);
        transition: all var(--duration-fast) ease;
        font-weight: var(--weight-medium);
    }

    .nav-item:hover {
        background: var(--sidebar-hover);
        color: #fff;
    }

    .nav-item.active {
        background: var(--gradient-brand);
        color: #fff;
        box-shadow: var(--shadow-accent);
    }

    .nav-badge {
        margin-left: auto;
        min-width: 20px;
        height: 20px;
        padding: 0 var(--space-1-5);
        background: var(--color-danger);
        color: #fff;
        font-size: var(--text-xs);
        font-weight: var(--weight-semibold);
        border-radius: var(--radius-full);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .nav-icon {
        display: none;
    }

    /* Owner Section — warm amber accent to distinguish from admin */
    .owner-section .nav-section-title {
        color: rgba(251, 191, 36, 0.6);
    }

    .owner-section .nav-item.active {
        background: linear-gradient(135deg, #d97706 0%, #f59e0b 100%);
        box-shadow: 0 4px 15px rgba(217, 119, 6, 0.3);
    }

    .owner-section .nav-item:hover {
        background: rgba(217, 119, 6, 0.12);
    }

    .sidebar-footer {
        padding: var(--space-5);
        border-top: 1px solid var(--sidebar-border);
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin-bottom: var(--space-4);
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        background: var(--sidebar-hover);
        border-radius: var(--radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--text-lg);
        color: #fff;
    }

    .user-name {
        display: block;
        color: #fff;
        font-size: var(--text-base);
        font-weight: var(--weight-semibold);
        max-width: 150px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role {
        display: block;
        color: var(--sidebar-text-dim);
        font-size: var(--text-xs);
    }

    .logout-btn {
        width: 100%;
        padding: var(--space-3);
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--sidebar-border);
        border-radius: var(--radius-lg);
        color: var(--sidebar-text);
        cursor: pointer;
        transition: all var(--duration-fast) ease;
        font-weight: var(--weight-medium);
        font-size: var(--text-sm);
    }

    .logout-btn:hover {
        background: rgba(239, 68, 68, 0.15);
        border-color: rgba(239, 68, 68, 0.3);
        color: #ef4444;
    }

    /* ===== Main Content ===== */
    .admin-main {
        flex: 1;
        margin-left: var(--sidebar-width);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .admin-header {
        background: var(--surface-card);
        padding: var(--space-5) var(--space-8);
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: var(--shadow-xs);
        position: sticky;
        top: 0;
        z-index: var(--z-sticky);
    }

    .page-title {
        font-size: var(--text-2xl);
        font-weight: var(--weight-bold);
        color: var(--text-primary);
        margin: 0;
    }

    .breadcrumb-nav {
        display: flex;
        gap: var(--space-2);
        margin-top: var(--space-1);
        font-size: var(--text-sm);
    }

    .breadcrumb-item {
        color: var(--text-secondary);
    }

    .breadcrumb-item.active {
        color: var(--color-accent);
        font-weight: var(--weight-medium);
    }

    .breadcrumb-separator {
        color: var(--color-neutral-300);
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: var(--space-4);
    }

    .header-search {
        position: relative;
    }

    .header-search input {
        width: 280px;
        padding: var(--space-2-5) var(--space-4) var(--space-2-5) 40px;
        border: 1px solid var(--color-neutral-200);
        border-radius: var(--radius-lg);
        background: var(--surface-inset);
        font-size: var(--text-base);
        transition: all var(--duration-fast) ease;
    }

    .header-search input:focus {
        outline: none;
        border-color: var(--color-accent);
        background: var(--surface-card);
        box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.1);
    }

    .search-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
    }

    .header-actions {
        display: flex;
        gap: var(--space-2);
    }

    .action-btn {
        width: 40px;
        height: 40px;
        border: 1px solid var(--color-neutral-200);
        border-radius: var(--radius-lg);
        background: var(--surface-card);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--text-md);
        position: relative;
        transition: all var(--duration-fast) ease;
        text-decoration: none;
        color: var(--text-secondary);
    }

    .action-btn:hover {
        border-color: var(--color-accent);
        background: var(--color-primary-50);
        color: var(--color-accent);
    }

    /* ===== Notification Bell & Dropdown ===== */
    .connection-emoji {
        font-size: var(--text-base);
        cursor: help;
        margin-right: var(--space-1-5);
    }

    .notification-btn {
        color: var(--color-neutral-600);
    }

    .notification-badge {
        position: absolute;
        top: -5px;
        right: -5px;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #fff;
        font-size: 10px;
        font-weight: var(--weight-bold);
        border-radius: var(--radius-full);
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid var(--surface-card);
        animation: pulse-badge 2s ease-in-out infinite;
    }

    @@keyframes pulse-badge {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    .notification-wrapper {
        position: relative;
    }

    .notif-overlay {
        position: fixed;
        inset: 0;
        z-index: 999;
    }

    .notification-panel {
        position: absolute;
        top: calc(100% + 8px);
        right: -12px;
        width: 400px;
        max-height: 520px;
        background: var(--surface-card);
        border: 1px solid var(--color-neutral-200);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-2xl);
        z-index: var(--z-toast);
        overflow: hidden;
        animation: notifSlideDown var(--duration-normal) var(--ease-out);
        display: flex;
        flex-direction: column;
    }

    @@keyframes notifSlideDown {
        from { opacity: 0; transform: translateY(-8px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .notification-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--space-4) var(--space-5) var(--space-3);
        border-bottom: 1px solid var(--color-neutral-100);
    }

    .panel-title-group {
        display: flex;
        align-items: center;
        gap: var(--space-2-5);
    }

    .panel-title {
        font-weight: var(--weight-bold);
        font-size: var(--text-md);
        color: var(--text-primary);
    }

    .panel-count {
        font-size: var(--text-xs);
        font-weight: var(--weight-semibold);
        color: var(--color-accent);
        background: var(--color-primary-50);
        padding: 2px var(--space-2);
