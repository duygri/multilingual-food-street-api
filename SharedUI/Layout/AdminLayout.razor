    }
    
    .user-avatar {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }
    
    .user-name {
