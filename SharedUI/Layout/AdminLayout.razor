@code {
    protected override async Task OnInitializedAsync()
    {
        // Auto-redirect: chuẩn hóa alias cũ và role-based route cho owner/admin
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var path = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath.ToLower();

        if (user.Identity?.IsAuthenticated == true)
        {
            if (path.StartsWith("/admin/foods"))
            {
                Navigation.NavigateTo(UiRoles.IsPoiOwner(user) && !user.IsInRole(UiRoles.Admin) ? "/owner/menu" : "/admin/menu", replace: true);
                return;
            }

            if (path.StartsWith("/owner/foods"))
            {
                Navigation.NavigateTo("/owner/menu", replace: true);
                return;
            }
        }

        if (user.Identity?.IsAuthenticated == true && UiRoles.IsPoiOwner(user) && !user.IsInRole(UiRoles.Admin))
        {
            if (path.StartsWith("/admin/locations"))
            {
                Navigation.NavigateTo("/owner/dashboard", replace: true);
                return;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load saved language
            try
            {
                var savedLang = await JS.InvokeAsync<string>("localStorage.getItem", "admin_language");
                if (!string.IsNullOrEmpty(savedLang) && savedLang != L.CurrentLanguage)
                {
                }
            }
            catch { }

            // Initialize SignalR notifications
            NotificationSvc.OnNotificationsChanged += OnNotificationsChanged;
            try { await NotificationSvc.InitializeAsync(); } catch { }

            StateHasChanged();
        }
    }
    
    private async Task HandleLogout()
    {
        // Detect role before logout to redirect correctly
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var isPoiOwner = UiRoles.IsPoiOwner(authState.User);
        
        await AuthService.LogoutAsync();
        Navigation.NavigateTo(isPoiOwner ? "/owner/login" : "/admin/login", forceLoad: true);
    }
    
    private string GetPageTitle()
    {
        var uri = Navigation.Uri;
        if (uri.Contains("owner/profile")) return "Hồ sơ POI Owner";
        if (uri.Contains("owner/dashboard")) return "POI của tôi";
        if (uri.Contains("dashboard")) return "Bảng điều khiển";
        if (uri.Contains("categories")) return "Phân loại POI";
        if (uri.Contains("locations")) return "Quản lý POI";
        if (uri.Contains("menu")) return "Menu Ẩm thực";
        if (uri.Contains("foods")) return "Menu Ẩm thực";
        if (uri.Contains("tts-console")) return "TTS Console";
        if (uri.Contains("audio")) return "Tệp âm thanh";
        if (uri.Contains("translations")) return "Bản dịch";
        if (uri.Contains("qrcodes")) return "Mã QR";
        if (uri.Contains("stats")) return "Thống kê";
        if (uri.Contains("visitors")) return "Lượt truy cập";
        if (uri.Contains("tours")) return "Quản lý Tour";
        if (uri.Contains("history")) return "Lịch sử sử dụng";
        if (uri.Contains("geofence-test")) return "Kiểm tra Geofence";
        if (uri.Contains("users")) return "Quản lý Người dùng";
        return "Quản trị";
    }
    
    private string GetPageName()
    {
        var uri = Navigation.Uri;
        if (uri.Contains("owner/profile")) return "Hồ sơ";
        if (uri.Contains("owner/dashboard")) return "POI của tôi";
        if (uri.Contains("dashboard")) return "Tổng quan";
        if (uri.Contains("categories")) return "Phân loại";
        if (uri.Contains("locations")) return "POI";
        if (uri.Contains("menu")) return "Menu";
        if (uri.Contains("foods")) return "Menu";
        if (uri.Contains("tts-console")) return "TTS Console";
        if (uri.Contains("audio")) return "Âm thanh";
        if (uri.Contains("translations")) return "Bản dịch";
        if (uri.Contains("qrcodes")) return "Mã QR";
        if (uri.Contains("stats")) return "Thống kê";
        if (uri.Contains("visitors")) return "Truy cập";
        if (uri.Contains("tours")) return "Tour";
        if (uri.Contains("history")) return "Lịch sử";
        if (uri.Contains("geofence-test")) return "Geofence";
        if (uri.Contains("users")) return "Người dùng";
        return "Tổng quan";
    }
    
    private async Task SwitchLanguageAsync(string langCode)
    {
        L.SetLanguage(langCode);
        // Save to localStorage
        await JS.InvokeVoidAsync("localStorage.setItem", "admin_language", langCode);
        // Update UI instantly without page reload
        StateHasChanged();
    }
    
    private string GetLangClass(string langCode)
    {
        return L.CurrentLanguage == langCode ? "active" : "";
    }

    private static string GetRoleDisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        if (user.IsInRole(UiRoles.Admin))
        {
            return UiRoles.Admin;
        }

        if (UiRoles.IsPoiOwner(user))
        {
            return UiRoles.PoiOwner;
        }

        if (UiRoles.IsTourist(user))
        {
            return UiRoles.Tourist;
        }

        return user.Claims.FirstOrDefault(c => c.Type == "role" || c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Người dùng";
    }

    // === Notification methods ===
    private bool showNotificationPanel = false;

    private void OnNotificationsChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleNotificationPanel()
    {
        showNotificationPanel = !showNotificationPanel;
    }

    private void CloseNotificationPanel()
    {
        showNotificationPanel = false;
    }

    private async Task MarkRead(int id)
    {
        await NotificationSvc.MarkAsReadAsync(id);
    }

    private async Task MarkAllRead()
    {
        await NotificationSvc.MarkAllAsReadAsync();
    }

    private async Task DeleteNotif(int id)
    {
        await NotificationSvc.DeleteAsync(id);
    }

    private string GetNotifIconClass(string type) => type switch
    {
        "POI_Created" or "POI_Updated" => "icon-created",
        "POI_Approved" or "POI_AudioReady" => "icon-approved",
        "POI_Rejected" => "icon-rejected",
        _ when UiNotificationTypes.IsMenuNotification(type) && type.Contains("Created", StringComparison.OrdinalIgnoreCase) => "icon-created",
        _ when UiNotificationTypes.IsMenuNotification(type) && type.Contains("Approved", StringComparison.OrdinalIgnoreCase) => "icon-approved",
        _ when UiNotificationTypes.IsMenuNotification(type) && type.Contains("Rejected", StringComparison.OrdinalIgnoreCase) => "icon-rejected",
        _ => "icon-default"
    };

    private static string GetNotifIcon(string type) => type switch
    {
        "POI_Created" => "●",
        "POI_Updated" => "✎",
        "POI_Approved" => "✓",
        "POI_Rejected" => "✗",
        "POI_AudioReady" => "♪",
        _ when UiNotificationTypes.IsMenuNotification(type) && type.Contains("Created", StringComparison.OrdinalIgnoreCase) => "●",
        _ when UiNotificationTypes.IsMenuNotification(type) && type.Contains("Approved", StringComparison.OrdinalIgnoreCase) => "✓",
        _ when UiNotificationTypes.IsMenuNotification(type) && type.Contains("Rejected", StringComparison.OrdinalIgnoreCase) => "✗",
        _ => "•"
    };

    private string FormatTimeAgo(DateTime createdAt)
    {
        var diff = DateTime.UtcNow - createdAt;
        if (diff.TotalMinutes < 1) return "Vừa xong";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút trước";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ trước";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} ngày trước";
        return createdAt.ToString("dd/MM/yyyy");
    }



    public void Dispose()
    {
        NotificationSvc.OnNotificationsChanged -= OnNotificationsChanged;
    }
}
