        background: #fff;
        padding: 48px;
        border-radius: 24px;
        text-align: center;
        max-width: 400px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.25);
    }
    
    .auth-icon {
        font-size: 48px;
        margin-bottom: 20px;
    }
    
    .auth-card h2 {
        color: #1e2a3a;
        margin-bottom: 12px;
        font-weight: 700;
    }
    
    .auth-card p {
        color: #64748b;
        margin-bottom: 24px;
    }
    
    .btn-auth {
        display: inline-block;
        padding: 14px 32px;
        background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
        color: #fff;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.2s ease;
    }
    
    .btn-auth:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255, 107, 53, 0.35);
        color: #fff;
    }
    
    /* Language Switcher */
    .language-switcher {
        display: flex;
        gap: 4px;
        padding: 4px;
        background: #f1f5f9;
        border-radius: 10px;
    }
    
    .lang-btn {
        padding: 6px 12px;
        border: none;
        background: transparent;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        color: #64748b;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .lang-btn:hover {
        color: #1e2a3a;
    }
    
    .lang-btn.active {
        background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
        color: #fff;
        box-shadow: 0 2px 8px rgba(255, 107, 53, 0.25);
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Auto-redirect: Seller truy cập /admin/* → chuyển sang /seller/*
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true && user.IsInRole("Seller") && !user.IsInRole("Admin"))
        {
            var path = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath.ToLower();
            if (path.StartsWith("/admin/locations"))
            {
                Navigation.NavigateTo("/seller/locations", replace: true);
                return;
            }
            if (path.StartsWith("/admin/foods"))
            {
                Navigation.NavigateTo("/seller/foods", replace: true);
                return;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedLang = await JS.InvokeAsync<string>("localStorage.getItem", "admin_language");
                if (!string.IsNullOrEmpty(savedLang) && savedLang != L.CurrentLanguage)
                {
                    L.SetLanguage(savedLang);
                    FoodClient.SetLanguage(savedLang);
                    StateHasChanged();
                }
            }
            catch { }
        }
    }
    
    private async Task HandleLogout()
    {
        // Detect role before logout to redirect correctly
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var isSeller = authState.User.IsInRole("Seller");
        
        await AuthService.LogoutAsync();
        Navigation.NavigateTo(isSeller ? "/seller/login" : "/admin/login", forceLoad: true);
    }
    
    private string GetPageTitle()
    {
        var uri = Navigation.Uri;
        if (uri.Contains("dashboard")) return "Thống kê";
        if (uri.Contains("locations")) return "Quản lý POI";
        if (uri.Contains("foods")) return "Món ăn";
        if (uri.Contains("audio")) return "Tệp âm thanh";
        if (uri.Contains("translations")) return "Bản dịch";
        if (uri.Contains("qrcodes")) return "Mã QR";
        if (uri.Contains("stats")) return "Thống kê";
        if (uri.Contains("visitors")) return "Lượt truy cập";
        if (uri.Contains("tours")) return "Quản lý Tour";
        if (uri.Contains("history")) return "Lịch sử sử dụng";
        if (uri.Contains("gps-test")) return "Kiểm tra GPS";
        return "Quản trị";
    }
    
    private string GetPageName()
    {
        var uri = Navigation.Uri;
        if (uri.Contains("dashboard")) return "Thống kê";
        if (uri.Contains("locations")) return "POI";
        if (uri.Contains("foods")) return "Món ăn";
        if (uri.Contains("audio")) return "Âm thanh";
        if (uri.Contains("translations")) return "Bản dịch";
        if (uri.Contains("qrcodes")) return "Mã QR";
        if (uri.Contains("stats")) return "Thống kê";
        if (uri.Contains("visitors")) return "Truy cập";
        if (uri.Contains("tours")) return "Tour";
        if (uri.Contains("history")) return "Lịch sử";
        if (uri.Contains("gps-test")) return "GPS";
        return "Tổng quan";
    }
    
    private async Task SwitchLanguageAsync(string langCode)
    {
        L.SetLanguage(langCode);
        FoodClient.SetLanguage(langCode);
        // Save to localStorage
        await JS.InvokeVoidAsync("localStorage.setItem", "admin_language", langCode);
        // Update UI instantly without page reload
        StateHasChanged();
    }
    
    private string GetLangClass(string langCode)
    {
        return L.CurrentLanguage == langCode ? "active" : "";
    }
}
