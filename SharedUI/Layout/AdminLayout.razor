@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILocalizationService L
@inject IFoodClientService FoodClient
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<AuthorizeView>
    <Authorized>
        <div class="admin-wrapper">
            <!-- Sidebar -->
            <aside class="admin-sidebar">
                <div class="sidebar-header">
                    <div class="brand-logo">
                        <span class="logo-icon">🍜</span>
                        <div class="logo-text">
                            <span class="logo-title">Vĩnh Khánh</span>
                            <span class="logo-subtitle">
                                <AuthorizeView Roles="Admin"><Authorized Context="ctx1">Admin CMS</Authorized></AuthorizeView>
                                <AuthorizeView Roles="Seller"><Authorized Context="ctx2">Seller</Authorized></AuthorizeView>
                            </span>
                        </div>
                    </div>
                </div>
                
                <nav class="sidebar-nav">
                    <div class="nav-section">
                        <span class="nav-section-title">CHÍNH</span>
                        <AuthorizeView Roles="Admin">
                            <Authorized Context="AuthContext">
                                <NavLink class="nav-item" href="admin/users">
                                    <span class="nav-icon">👥</span>
                                    <span class="nav-text">Quản lý Người dùng</span>
                                </NavLink>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Roles="Admin">
                            <Authorized Context="AuthContext">
                                <NavLink class="nav-item" href="admin/dashboard" Match="NavLinkMatch.All">
                                    <span class="nav-icon">📊</span>
                                    <span class="nav-text">Thống kê</span>
                                </NavLink>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Roles="Admin">
                            <Authorized Context="AuthContext">
                                <NavLink class="nav-item" href="admin/locations">
                                    <span class="nav-icon">📍</span>
                                    <span class="nav-text">Quản lý POI</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/foods">
                                    <span class="nav-icon">🍲</span>
                                    <span class="nav-text">Món ăn</span>
                                </NavLink>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Roles="Seller">
                            <Authorized Context="AuthContext">
                                <NavLink class="nav-item" href="seller/locations">
                                    <span class="nav-icon">📍</span>
                                    <span class="nav-text">POI của tôi</span>
                                </NavLink>
                                <NavLink class="nav-item" href="seller/foods">
                                    <span class="nav-icon">🍲</span>
                                    <span class="nav-text">Món ăn</span>
                                </NavLink>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Roles="Admin">
                            <Authorized Context="AuthContext">
                                <NavLink class="nav-item" href="admin/tours">
                                    <span class="nav-icon">🗺️</span>
                                    <span class="nav-text">Quản lý Tour</span>
                                </NavLink>
                            </Authorized>
                        </AuthorizeView>
                    </div>
                    
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="AuthContext">
                            <div class="nav-section">
                                <span class="nav-section-title">NỘI DUNG</span>
                                <NavLink class="nav-item" href="admin/audio">
                                    <span class="nav-icon">🎵</span>
                                    <span class="nav-text">Tệp âm thanh</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/translations">
                                    <span class="nav-icon">🌐</span>
                                    <span class="nav-text">Bản dịch</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/qrcodes">
                                    <span class="nav-icon">📱</span>
                                    <span class="nav-text">Mã QR</span>
                                </NavLink>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                    
                    <AuthorizeView Roles="Admin">
                        <Authorized Context="AuthContext">
                            <div class="nav-section">
                                <span class="nav-section-title">PHÂN TÍCH</span>
                                <NavLink class="nav-item" href="admin/stats">
                                    <span class="nav-icon">📈</span>
                                    <span class="nav-text">Thống kê</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/visitors">
                                    <span class="nav-icon">👥</span>
                                    <span class="nav-text">Lượt truy cập</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/history">
                                    <span class="nav-icon">📜</span>
                                    <span class="nav-text">Lịch sử sử dụng</span>
                                </NavLink>
                                <NavLink class="nav-item" href="admin/gps-test">
                                    <span class="nav-icon">📍</span>
                                    <span class="nav-text">Test GPS</span>
                                </NavLink>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </nav>
                
                <div class="sidebar-footer">
                    <div class="user-profile">
                        <div class="user-avatar">
                            <span>👤</span>
                        </div>
                        <div class="user-info">
                            <span class="user-name">@context.User.Identity?.Name</span>
                            <span class="user-role">@context.User.Claims.FirstOrDefault(c => c.Type == "role" || c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</span>
                        </div>
                    </div>
                    <button class="logout-btn" @onclick="HandleLogout">
                        <span>🚪</span> Đăng xuất
                    </button>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="admin-main">
                <header class="admin-header">
                    <div class="header-left">
                        <h1 class="page-title">@GetPageTitle()</h1>
                        <nav class="breadcrumb-nav">
                            <span class="breadcrumb-item">
                                <AuthorizeView Roles="Admin"><Authorized Context="ctx3">Admin</Authorized></AuthorizeView>
                                <AuthorizeView Roles="Seller"><Authorized Context="ctx4">Seller</Authorized></AuthorizeView>
                            </span>
                            <span class="breadcrumb-separator">/</span>
                            <span class="breadcrumb-item active">@GetPageName()</span>
                        </nav>
                    </div>
                    <div class="header-right">
                        <div class="header-search">
                            <input type="text" placeholder="Tìm kiếm..." />
                            <span class="search-icon">🔍</span>
                        </div>
                        <div class="header-actions">
                            <button class="action-btn notification-btn">
                                <span>🔔</span>
                                <span class="notification-badge">3</span>
                            </button>
                            <a href="https://localhost:7214/swagger" target="_blank" class="action-btn">
                                <span>📄</span>
                            </a>
                        </div>
                    </div>
                </header>
                
                <div class="admin-content">
                    @Body
                </div>
                
                <footer class="admin-footer">
                    <span>© 2026 Vĩnh Khánh Food Street Guide - Quận 4, TP.HCM</span>
                    <span class="footer-version">v1.0.0</span>
                </footer>
            </main>
        </div>
    </Authorized>
    
    <NotAuthorized>
        <div class="auth-required">
            <div class="auth-card">
                <div class="auth-icon">🔐</div>
                <h2>Yêu cầu đăng nhập</h2>
                <p>Bạn cần đăng nhập để truy cập Admin CMS</p>
                <a href="admin/login" class="btn-auth">Đăng nhập ngay</a>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
