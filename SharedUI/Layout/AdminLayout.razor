    }
    
    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: #1e2a3a;
        margin: 0;
    }
    
    .breadcrumb-nav {
        display: flex;
        gap: 8px;
        margin-top: 4px;
        font-size: 13px;
    }
    
    .breadcrumb-item {
        color: #64748b;
    }
    
    .breadcrumb-item.active {
        color: #ff6b35;
        font-weight: 500;
    }
    
    .breadcrumb-separator {
        color: #cbd5e1;
    }
    
    .header-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    
    .header-search {
        position: relative;
    }
    
    .header-search input {
        width: 280px;
        padding: 10px 16px 10px 40px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
