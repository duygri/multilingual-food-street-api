@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject INotificationService NotificationSvc
@using FoodStreet.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

<CascadingAuthenticationState>
    <AuthorizeView>
        <Authorized>
            <div class="mobile-app">
                @* ===== MOBILE HEADER ===== *@
                <header class="mobile-header">
                    <div class="mobile-header-left">
                        <span class="mobile-logo">🍜</span>
                        <span class="mobile-title">FoodStreet</span>
                    </div>
                    <div class="mobile-header-right">
                        <button class="icon-btn">
                            <span class="icon">🔍</span>
                        </button>
                        <button class="icon-btn" @onclick="ToggleNotificationPanel">
                            <span class="icon">
                                🔔
                                @if (NotificationSvc.UnreadCount > 0)
                                {
                                    <span class="badge">@(NotificationSvc.UnreadCount > 9 ? "9+" : NotificationSvc.UnreadCount.ToString())</span>
                                }
                            </span>
                        </button>
                    </div>
                </header>

                @* ===== CONTENT AREA ===== *@
                <main class="mobile-content">
                    @Body
                </main>

                @* ===== BOTTOM TAB BAR ===== *@
                <nav class="mobile-tab-bar">
                    <a href="explore" class="tab-item @IsActive("/explore")">
                        <span class="tab-icon">🏠</span>
                        <span class="tab-label">Khám phá</span>
                    </a>
                    <a href="mobile-map" class="tab-item @IsActive("/mobile-map")">
                        <span class="tab-icon">🗺️</span>
                        <span class="tab-label">Bản đồ</span>
                    </a>
                    <a href="geofence-guide" class="tab-item @IsActive("/geofence-guide")">
                        <span class="tab-icon">🎧</span>
                        <span class="tab-label">Thuyết minh</span>
                    </a>
                    <a href="favorites" class="tab-item @IsActive("/favorites")">
                        <span class="tab-icon">❤️</span>
                        <span class="tab-label">Đã lưu</span>
                    </a>
                    <a href="profile" class="tab-item @IsActive("/profile")">
                        <span class="tab-icon">👤</span>
                        <span class="tab-label">Cá nhân</span>
                    </a>
                </nav>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="mobile-auth-shell">
                @Body
            </div>
        </NotAuthorized>
    </AuthorizeView>
</CascadingAuthenticationState>

<style>
    /* ===== MOBILE APP SHELL ===== */
    .mobile-app {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        max-height: 100vh;
        background: #f5f7fa;
        overflow: hidden;
    }

    /* ===== HEADER ===== */
    .mobile-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
        color: #fff;
        height: 52px;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(255, 107, 53, 0.3);
        z-index: 100;
    }

    .mobile-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .mobile-logo {
        font-size: 24px;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 8px;
    }

    .mobile-title {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    .mobile-header-right {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .icon-btn {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        padding: 4px;
        margin-left: 8px;
        position: relative;
        cursor: pointer;
    }

    .icon-btn .badge {
        position: absolute;
        top: -2px;
        right: -6px;
        background: #ef4444;
        color: white;
        border-radius: 50%;
        font-size: 10px;
        height: 16px;
        min-width: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        border: 2px solid #ff6b35;
    }

    /* ===== CONTENT ===== */
    .mobile-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        -webkit-overflow-scrolling: touch;
        padding-bottom: env(safe-area-inset-bottom, 0px);
    }

    /* Override admin styles for mobile */
    .mobile-content .admin-wrapper {
        display: block;
        min-height: auto;
    }

    .mobile-content .admin-sidebar {
        display: none !important;
    }

    .mobile-content .admin-main {
        margin-left: 0;
        min-height: auto;
    }

    .mobile-content .admin-header {
        display: none !important;
    }

    .mobile-content .admin-footer {
        display: none !important;
    }

    .mobile-content .admin-content {
        padding: 12px;
    }

    /* ===== BOTTOM TAB BAR ===== */
    .mobile-tab-bar {
        display: flex;
        align-items: center;
        justify-content: space-around;
        height: 60px;
        background: #fff;
        border-top: 1px solid #e8ecf1;
        flex-shrink: 0;
        padding-bottom: env(safe-area-inset-bottom, 0px);
        box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.06);
        z-index: 100;
    }

    .tab-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2px;
        flex: 1;
        height: 100%;
        text-decoration: none;
        color: #94a3b8;
        font-size: 10px;
        font-weight: 500;
        transition: color 0.2s ease;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        position: relative;
    }

    .tab-item:hover,
    .tab-item:active {
        color: #ff6b35;
    }

    .tab-item.active {
        color: #ff6b35;
    }

    .tab-item.active::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 24px;
        height: 3px;
        background: #ff6b35;
        border-radius: 0 0 3px 3px;
    }

    .tab-icon {
        font-size: 22px;
        line-height: 1;
        position: relative;
    }

    .tab-label {
        font-size: 10px;
        line-height: 1;
        margin-top: 1px;
    }

    .tab-badge {
        position: absolute;
        top: -6px;
        right: -10px;
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        background: #ef4444;
        color: #fff;
        font-size: 9px;
        font-weight: 700;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    /* ===== AUTH SHELL ===== */
    .mobile-auth-shell {
        min-height: 100vh;
        background: #f8fafc;
    }
</style>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private string IsActive(string path)
    {
        var currentUri = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath;
        // Default to explore if at root
        if (currentUri == "/" && path == "/explore") return "active";
        return currentUri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private bool showNotificationPanel = false;

    private void ToggleNotificationPanel() => showNotificationPanel = !showNotificationPanel;

    private async Task MarkAllRead()
    {
        await NotificationSvc.MarkAllAsReadAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
