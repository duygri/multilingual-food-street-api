@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject INotificationService NotificationSvc
@using FoodStreet.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

<CascadingAuthenticationState>
    <AuthorizeView>
        <Authorized>
            <div class="mobile-app">
                @* ===== MOBILE HEADER ===== *@
                <header class="mobile-header">
                    <div class="mobile-header-left">
                        <span class="mobile-logo">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
                        </span>
                        <span class="mobile-title">FoodStreet</span>
                    </div>
                    <div class="mobile-header-right">
                        <button class="icon-btn">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        </button>
                        <button class="icon-btn" @onclick="ToggleNotificationPanel">
                            <span class="icon">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                @if (NotificationSvc.UnreadCount > 0)
                                {
                                    <span class="badge">@(NotificationSvc.UnreadCount > 9 ? "9+" : NotificationSvc.UnreadCount.ToString())</span>
                                }
                            </span>
                        </button>
                    </div>
                </header>

                @* ===== CONTENT AREA ===== *@
                <main class="mobile-content">
                    @Body
                </main>

                @* ===== BOTTOM TAB BAR ===== *@
                <nav class="mobile-tab-bar">
                    <a href="explore" class="tab-item @IsActive("/explore")">
                        <span class="tab-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
                        <span class="tab-label">Khám phá</span>
                    </a>
                    <a href="mobile-map" class="tab-item @IsActive("/mobile-map")">
                        <span class="tab-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg></span>
                        <span class="tab-label">Bản đồ</span>
                    </a>

                    <a href="favorites" class="tab-item @IsActive("/favorites")">
                        <span class="tab-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></span>
                        <span class="tab-label">Đã lưu</span>
                    </a>
                    <a href="profile" class="tab-item @IsActive("/profile")">
                        <span class="tab-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                        <span class="tab-label">Cá nhân</span>
                    </a>
                </nav>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="mobile-auth-shell">
                @Body
            </div>
        </NotAuthorized>
    </AuthorizeView>
</CascadingAuthenticationState>

<style>
    /* ===== MOBILE APP SHELL ===== */
    .mobile-app {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        max-height: 100vh;
        background: #f5f7fa;
        overflow: hidden;
    }

    /* ===== HEADER ===== */
    .mobile-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 16px;
        background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
        color: #fff;
        height: 56px;
        flex-shrink: 0;
        box-shadow: 0 4px 20px rgba(255, 107, 53, 0.25);
        z-index: 100;
        position: relative;
    }

    .mobile-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    }

    .mobile-header-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .mobile-logo {
        font-size: 22px;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.18);
        backdrop-filter: blur(8px);
        border-radius: 10px;
        transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .mobile-logo:active {
        transform: scale(0.9);
    }

    .mobile-title {
        font-size: 19px;
        font-weight: 800;
        letter-spacing: -0.3px;
    }

    .mobile-header-right {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .icon-btn {
        background: transparent;
        border: none;
        color: white;
        font-size: 20px;
        padding: 8px;
        position: relative;
        cursor: pointer;
        border-radius: 10px;
        transition: background 0.2s ease;
    }

    .icon-btn:active {
        background: rgba(255,255,255,0.15);
    }

    .icon-btn .badge {
        position: absolute;
        top: 2px;
        right: 2px;
        background: #ef4444;
        color: white;
        border-radius: 50%;
        font-size: 9px;
        height: 18px;
        min-width: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        border: 2px solid #ff6b35;
        animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleIn {
        from { transform: scale(0); }
        to { transform: scale(1); }
    }

    /* ===== CONTENT ===== */
    .mobile-content {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        -webkit-overflow-scrolling: touch;
        padding-bottom: env(safe-area-inset-bottom, 0px);
        scroll-behavior: smooth;
    }

    /* Override admin styles for mobile */
    .mobile-content .admin-wrapper {
        display: block;
        min-height: auto;
    }

    .mobile-content .admin-sidebar {
        display: none !important;
    }

    .mobile-content .admin-main {
        margin-left: 0;
        min-height: auto;
    }

    .mobile-content .admin-header {
        display: none !important;
    }

    .mobile-content .admin-footer {
        display: none !important;
    }

    .mobile-content .admin-content {
        padding: 12px;
    }

    /* ===== BOTTOM TAB BAR ===== */
    .mobile-tab-bar {
        display: flex;
        align-items: center;
        justify-content: space-around;
        height: 64px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-top: 1px solid rgba(0, 0, 0, 0.04);
        flex-shrink: 0;
        padding-bottom: env(safe-area-inset-bottom, 0px);
        box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.06);
        z-index: 100;
    }

    .tab-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        flex: 1;
        height: 100%;
        text-decoration: none;
        color: #94a3b8;
        font-size: 10px;
        font-weight: 600;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        position: relative;
    }

    .tab-item:hover,
    .tab-item:active {
        color: #ff6b35;
    }

    .tab-item.active {
        color: #ff6b35;
    }

    .tab-item.active .tab-icon {
        transform: translateY(-2px);
    }

    .tab-item.active::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 28px;
        height: 3px;
        background: linear-gradient(90deg, #ff6b35, #f7931e);
        border-radius: 0 0 4px 4px;
        box-shadow: 0 2px 8px rgba(255, 107, 53, 0.3);
    }

    .tab-icon {
        font-size: 22px;
        line-height: 1;
        position: relative;
        transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .tab-label {
        font-size: 10px;
        line-height: 1;
        margin-top: 1px;
        letter-spacing: 0.02em;
    }

    .tab-badge {
        position: absolute;
        top: -6px;
        right: -10px;
        min-width: 16px;
        height: 16px;
        padding: 0 4px;
        background: #ef4444;
        color: #fff;
        font-size: 9px;
        font-weight: 700;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    /* ===== AUTH SHELL ===== */
    .mobile-auth-shell {
        min-height: 100vh;
        background: linear-gradient(180deg, #f8fafc 0%, #f0f2f5 100%);
    }
</style>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private string IsActive(string path)
    {
        var currentUri = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath;
        // Default to explore if at root
        if (currentUri == "/" && path == "/explore") return "active";
        return currentUri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private bool showNotificationPanel = false;

    private void ToggleNotificationPanel() => showNotificationPanel = !showNotificationPanel;

    private async Task MarkAllRead()
    {
        await NotificationSvc.MarkAllAsReadAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
